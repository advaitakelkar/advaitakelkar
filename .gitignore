# Use pnpm only — block npm lockfile
package-lock.json

# Project source documents (PDF/PPTX) and raw media masters — synced by Drive,
# never committed and never deployed. This includes source-files/virtual-gods/
# (~1.3 GB of .mov films, 900px GIFs and 3000px posters). Anything the Virtual
# Gods exhibition actually serves is generated into public/images/virtual-gods/vg/
# by scripts/build-vg-assets.sh.
#
# Keep masters OUT of public/: Astro copies public/ into dist/ verbatim, so a
# file parked there is uploaded to Firebase even if no page references it.
source-files/
