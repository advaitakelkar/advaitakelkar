---
export interface Props {
  title?: string;
}

const { title = 'Protected page' } = Astro.props;
---

<section class="password-gate" data-password-gate data-unlocked="false">
  <form class="password-gate__panel" data-password-form>
    <p class="password-gate__eyebrow">Private Archive</p>
    <h1 class="password-gate__title">{title}</h1>
    <div class="password-gate__row">
      <input
        class="password-gate__input"
        data-password-input
        type="password"
        placeholder="Password"
        autocomplete="current-password"
        aria-label="Password"
      />
      <button class="password-gate__button" type="submit">Enter</button>
    </div>
    <p class="password-gate__error" data-password-error aria-live="polite"></p>
  </form>

  <div class="password-gate__content" data-password-content>
    <slot />
  </div>
</section>

<script>
  const PASSWORD = 'advt';
  const STORAGE_KEY = 'ak-project-access';

  function setupPasswordGates() {
    const gates = Array.from(document.querySelectorAll('[data-password-gate]'));
    const hasAccess = sessionStorage.getItem(STORAGE_KEY) === PASSWORD;

    gates.forEach((gate) => {
      const form = gate.querySelector('[data-password-form]');
      const input = gate.querySelector('[data-password-input]');
      const error = gate.querySelector('[data-password-error]');

      function unlock() {
        gate.setAttribute('data-unlocked', 'true');
        sessionStorage.setItem(STORAGE_KEY, PASSWORD);
      }

      if (hasAccess) {
        unlock();
      }

      form?.addEventListener('submit', (event) => {
        event.preventDefault();
        if ((input as HTMLInputElement | null)?.value === PASSWORD) {
          unlock();
          return;
        }
        if (error) error.textContent = 'Incorrect password.';
        (input as HTMLInputElement | null)?.focus();
        (input as HTMLInputElement | null)?.select();
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupPasswordGates);
  } else {
    setupPasswordGates();
  }
  document.addEventListener('astro:after-swap', setupPasswordGates);
</script>

<style>
  .password-gate {
    min-height: 100dvh;
  }

  .password-gate__panel {
    min-height: 100dvh;
    padding: calc(clamp(2rem, 4vh, 3rem) + 48px) var(--_tokens---space--small) var(--_tokens---space--small);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
    box-sizing: border-box;
  }

  @media (min-width: 1200px) {
    .password-gate__panel {
      padding-inline: clamp(6rem, 12vw, 16rem);
    }
  }

  @media (max-width: 767px) and (orientation: portrait) {
    .password-gate__panel {
      padding-bottom: 80px;
    }
  }

  .password-gate__eyebrow {
    font-size: var(--_tokens---type--micro);
    color: var(--_tokens---color--muted);
  }

  .password-gate__title {
    max-width: 14ch;
    font-size: var(--_tokens---type--big);
    line-height: 1;
    font-weight: 500;
  }

  .password-gate__row {
    display: flex;
    gap: 10px;
    width: min(100%, 420px);
  }

  .password-gate__input,
  .password-gate__button {
    height: 42px;
    border: 1px solid var(--_tokens---color--line);
    border-radius: var(--_tokens---radius--medium);
    font: inherit;
    font-size: var(--_tokens---type--micro);
  }

  .password-gate__input {
    min-width: 0;
    flex: 1;
    padding-inline: 14px;
    background: var(--_tokens---color--bg);
    color: var(--_tokens---color--fg);
  }

  .password-gate__button {
    padding-inline: 18px;
    background: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    cursor: pointer;
  }

  .password-gate__error {
    min-height: 1.4em;
    font-size: var(--_tokens---type--micro);
    color: var(--_tokens---color--muted);
  }

  .password-gate__content {
    display: none;
  }

  .password-gate[data-unlocked="true"] .password-gate__panel {
    display: none;
  }

  .password-gate[data-unlocked="true"] .password-gate__content {
    display: block;
  }
</style>
