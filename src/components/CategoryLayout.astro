---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

export interface Props {
  projects: any[];
  title: string;
  crumbs?: { label: string; href?: string }[];
}

const { projects, title, crumbs } = Astro.props;

// Get all tags and categories for formatting
const allTags = await getCollection('tags');
const allCats = await getCollection('categories');
const tagMap = Object.fromEntries(allTags.map(t => [t.id, t.data.name]));
const catMap = Object.fromEntries(allCats.map(c => [c.id, c.data.displayName]));

// Gather cover images for the slider
const sliderImages = projects.map(p => p.data.coverImage).filter(Boolean);
if (sliderImages.length === 0) {
  sliderImages.push('/images/admin/placeholder.png');
}

// Abbreviate name function (for footer bubbles)
function abbrevName(name: string): string {
  return name.trim().split(/\s+/).filter(w => w.length > 0).map(w => w.length <= 3 ? w : w.slice(0, 3)).join(' ');
}
---

<PageLayout
  title={title}
  label={title}
  crumbs={crumbs || [{ label: 'Home', href: '/' }, { label: title }]}
  showFooter={false}
>
  <article class="category-detail">
    <!-- Top Full Width Header -->
    <header class="project-top-header category-hero-header" id="project-top-header">
      <h1 class="project-card__title" style="font-size: clamp(3rem, 8vw, 6rem); line-height: 1; letter-spacing: -0.02em;">{title}</h1>
    </header>

    <!-- 2-Column Hero Grid -->
    <div class="project-content-grid">
      <!-- Left Column: Text Content -->
      <div class="project-col-left category-col-left">
        <div class="project-card-info" style="margin-top: 0; border-top: none; padding-top: 0;">
          <div class="project-card__intro category-intro-text">
            <p style="font-size: var(--_tokens---type--medium); line-height: 1.3; margin-bottom: var(--_tokens---space--medium);">Welcome to the {title} category. Here you will find a curated collection of projects highlighting our work in this space. Below is a detailed showcase of our selected projects.</p>
          </div>
        </div>
      </div>

      <!-- Right Column: Image Slider -->
      <div class="project-col-right" id="project-slider-col">
        <div class="project-slider" id="project-slider">
          {sliderImages.map((img, i) => (
            <img src={img} alt={`Slide ${i + 1}`} class:list={["slider-image", i === 0 && "active"]} loading={i === 0 ? "eager" : "lazy"} />
          ))}
          {sliderImages.length > 1 && (
            <div class="slider-controls">
              <button class="slider-btn prev" aria-label="Previous image">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
              </button>
              <button class="slider-btn next" aria-label="Next image">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </button>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Stacked Projects List -->
    <div class="category-projects-list" style="margin-top: clamp(4rem, 8vh, 6rem);">
      {projects.map(p => {
        const tagsArr = (p.data.tags ?? []).map(t => tagMap[t.id] || t.id);
        const tagLine = tagsArr.join(', ');
        return (
          <a href={`/projects/${p.id}`} class="category-list-item switch-row">
            <div class="switch-row__content">
              <span class="switch-row__name">{p.data.shortName || p.data.name}</span>
              <span class="switch-row__arrow">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><line x1="2" y1="12" x2="22" y2="12"></line><polyline points="15 5 22 12 15 19"></polyline></svg>
              </span>
            </div>
            {p.data.coverImage && (
              <div class="hover-reveal-img" aria-hidden="true">
                <img src={p.data.coverImage} alt={p.data.name} loading="lazy" />
              </div>
            )}
          </a>
        );
      })}
    </div>

    <!-- Custom Category Footer -->
    <footer class="home-search-footer" style="border-top: none; padding-top: clamp(4rem, 8vh, 6rem);">
      <div class="home-search__header">
        <h2 class="home-search__title">All Projects in {title}</h2>
      </div>
      <div class="proj-bubbles" style="margin-top: 16px; border-top: none; padding-top: 0;">
        {projects.map(p => {
          const tagsArr = (p.data.tags ?? []).map(t => tagMap[t.id] || t.id);
          return (
            <a href={`/projects/${p.id}`} class="proj-bubble">
              <span class="proj-bubble__name" data-short={p.data.shortName || abbrevName(p.data.name)} data-full={p.data.name}>{p.data.shortName || abbrevName(p.data.name)}</span>
              <span class="proj-bubble__tag">{tagsArr[0] || (p.data.category ? catMap[p.data.category.id] : 'Design')}</span>
              <svg class="link-arrow proj-bubble__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                <line x1="6" y1="18" x2="18" y2="6"></line>
                <polyline points="10 6 18 6 18 14"></polyline>
              </svg>
            </a>
          );
        })}
      </div>
    </footer>
  </article>

  <style>
    .category-projects-list {
      border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
      display: flex;
      flex-direction: column;
    }
    


    /* Switch-style Row (Premium Typography & Hover) */
    .switch-row {
      position: relative;
      display: block;
      text-decoration: none;
      color: var(--_tokens---color--fg);
      padding: clamp(2rem, 4vw, 4rem) 0;
      border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
      z-index: 1;
    }
    .switch-row:first-child {
      border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    }
    .switch-row__content {
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: relative;
      z-index: 5;
      mix-blend-mode: difference; /* Optional: makes text pop over images, or just ensure z-index */
      pointer-events: none; /* Let hover hit the row exactly */
    }
    .switch-row__name {
      font-size: clamp(3rem, 7vw, 7rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1;
      text-transform: uppercase;
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
      transform-origin: left center;
    }
    .switch-row__arrow {
      opacity: 0;
      transform: translateX(-20px);
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .switch-row__arrow svg {
      width: clamp(30px, 5vw, 60px);
      height: clamp(30px, 5vw, 60px);
    }
    
    /* Hover state for row content */
    .switch-row:hover .switch-row__name {
      transform: translateX(20px);
    }
    .switch-row:hover .switch-row__arrow {
      opacity: 1;
      transform: translateX(0);
    }

    /* Hover Reveal Image (Cursor Tracking) */
    .hover-reveal-img {
      position: fixed;
      top: 0;
      left: 0;
      width: 400px; /* Adjust size as needed */
      aspect-ratio: 16/10;
      pointer-events: none;
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.8); /* Center on cursor, scale down initially */
      z-index: 4; /* Below the text (z-index 5) but above background */
      transition: opacity 0.4s ease, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      overflow: hidden;
      border-radius: 8px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }
    .hover-reveal-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .switch-row:hover .hover-reveal-img {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }

    @media (max-width: 767px) {
      /* Mobile fallback: disable hover reveal and just show a neat list */
      .hover-reveal-img { display: none !important; }
      .switch-row__name { font-size: 2.5rem; }
      .switch-row:hover .switch-row__name { transform: translateX(10px); }
      .switch-row__arrow { opacity: 1; transform: translateX(0); }
      .switch-row__arrow svg { width: 30px; height: 30px; }
      .switch-row { padding: 1.5rem 0; }
    }

    /* Slider Styles */
    .project-slider {
      position: relative;
      width: 100%;
      height: 100%;
      min-height: 50vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: color-mix(in srgb, var(--_tokens---color--fg) 3%, transparent);
      border-radius: 4px;
    }
    .slider-image {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0;
      transition: opacity 0.5s ease-in-out;
    }
    .slider-image.active {
      opacity: 1;
      z-index: 1;
    }
    .slider-controls {
      position: absolute;
      bottom: 16px;
      right: 16px;
      display: flex;
      gap: 8px;
      z-index: 10;
    }
    .slider-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--_tokens---color--bg);
      color: var(--_tokens---color--fg);
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 15%, transparent);
      cursor: pointer;
      transition: all 0.2s;
    }
    .slider-btn:hover {
      background: var(--_tokens---color--fg);
      color: var(--_tokens---color--bg);
    }
    .slider-btn svg {
      width: 20px;
      height: 20px;
    }
  </style>

  <script>
    function initCategorySliders() {
      const slider = document.getElementById('project-slider');
      if (!slider) return;

      const images = slider.querySelectorAll('.slider-image');
      const prevBtn = slider.querySelector('.prev');
      const nextBtn = slider.querySelector('.next');
      if (images.length <= 1) return;

      let currentIdx = 0;
      let interval: number;

      function showSlide(idx: number) {
        images[currentIdx].classList.remove('active');
        currentIdx = (idx + images.length) % images.length;
        images[currentIdx].classList.add('active');
      }

      function nextSlide() { showSlide(currentIdx + 1); }
      function prevSlide() { showSlide(currentIdx - 1); }

      function startAutoSlide() {
        clearInterval(interval);
        interval = setInterval(nextSlide, 3000);
      }

      function stopAutoSlide() {
        clearInterval(interval);
      }

      nextBtn?.addEventListener('click', () => { nextSlide(); startAutoSlide(); });
      prevBtn?.addEventListener('click', () => { prevSlide(); startAutoSlide(); });

      slider.addEventListener('mouseenter', stopAutoSlide);
      slider.addEventListener('mouseleave', startAutoSlide);

      startAutoSlide();
    }

    function initHoverReveal() {
      const rows = document.querySelectorAll('.switch-row');
      rows.forEach(row => {
        const revealImg = row.querySelector('.hover-reveal-img') as HTMLElement;
        if (!revealImg) return;

        row.addEventListener('mousemove', (e: Event) => {
          const mouseEvent = e as MouseEvent;
          // Set coordinates exactly at the cursor
          revealImg.style.left = `${mouseEvent.clientX}px`;
          revealImg.style.top = `${mouseEvent.clientY}px`;
        });
      });
    }

    document.addEventListener('astro:page-load', () => {
      initCategorySliders();
      initHoverReveal();
    });
  </script>
</PageLayout>
