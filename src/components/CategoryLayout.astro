---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import ProjectCard from './ProjectCard.astro';

export interface Props {
  projects: any[];
  title: string;
  crumbs?: { label: string; href?: string }[];
}

const { projects, title, crumbs } = Astro.props;

// Get all tags and categories for formatting
const allTags = await getCollection('tags');
const allCats = await getCollection('categories');
const tagMap = Object.fromEntries(allTags.map(t => [t.id, t.data.name]));

// Gather cover images for the slider
const sliderImages = projects.map(p => p.data.coverImage).filter(Boolean);
if (sliderImages.length === 0) {
  sliderImages.push('/images/admin/placeholder.webp');
}

// Split this category's projects into studio tabs by tag (Studio 823 / FKD Workshop)
const tagHas = (p: any, id: string) => (p.data.tags ?? []).some((t: any) => t.id === id);
const tabGroups = [
  { id: 'studio-823',   label: 'Studio 823',   projects: projects.filter((p: any) => tagHas(p, 'studio-823')) },
  { id: 'faizan-khatri', label: 'FKD Workshop', projects: projects.filter((p: any) => tagHas(p, 'faizan-khatri')) },
];
const showTabs = tabGroups.some(g => g.projects.length > 0);
const showSlider = title !== 'Work';

// 3-column intro copy — Work tells the studio story; other categories fall back to a generic intro
const introsByTitle: Record<string, string[]> = {
  Work: [
    "Welcome. This is the archive of my professional work — a collection of every project I've had the privilege of being part of across my career, from 2018 to 2024. Each one is something I genuinely loved building, and together they trace how I've grown as a designer and architect.",
    "My working life began in college in 2018. Through my batchmate Varun Mehta I met Samir Raut, Faizan Khatri, and Siddhesh Kadam, and was introduced to Studio 823 — a small independent practice run out of a garage in Shivaji Park, Mumbai. I joined as an intern and grew into an architect there; much of my work ethic and the way I approach making still traces back to that team.",
    "From Studio 823 I went on to work with Faizan Khatri at FKD Workshop, an offshoot of 823, where I helped build a new studio from the ground up. In a short but intense stretch we grew from three people to eight, and I stepped into far bigger roles — leading projects, mentoring, and learning first-hand what it takes to build, and be part of, a team.",
  ],
};
const introCols = introsByTitle[title] ?? [
  `Welcome to the ${title} category — a curated collection of projects highlighting work in this space.`,
  "Each project is part of a unified practice — different mediums tracing the threads of form, material, and concept that recur and evolve from one project to the next.",
  "Browse the selected work below to explore the projects gathered in this collection.",
];
---

<PageLayout
  title={title}
  label={title}
  crumbs={crumbs || [{ label: 'Home', href: '/' }, { label: title }]}
  showFooter={true}
>
  <article class="category-detail">
    <!-- Top Full Width Header -->
    <header class="project-top-header category-hero-header" id="project-top-header">
      <h1 class="project-card__title" style="font-size: clamp(3rem, 8vw, 6rem); font-weight: 500; line-height: 1; letter-spacing: -0.02em;">{title}</h1>
    </header>

    <!-- 3-Column Intro (mirrors the home page) -->
    <section class="category-intro">
      <div class="category-intro__body">
        {introCols.map(text => (
          <div class="category-intro__column">
            <p class="category-intro__desc">{text}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Full-width Image Slider (hidden on the Work page) -->
    {showSlider && (
      <div class="category-slider" id="project-slider-col">
        <div class="project-slider" id="project-slider">
          {sliderImages.map((img, i) => (
            <img src={img} alt={`Slide ${i + 1}`} class:list={["slider-image", i === 0 && "active"]} loading={i === 0 ? "eager" : "lazy"} />
          ))}
          {sliderImages.length > 1 && (
            <div class="slider-controls">
              <button class="slider-btn prev" aria-label="Previous image">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
              </button>
              <button class="slider-btn next" aria-label="Next image">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </button>
            </div>
          )}
        </div>
      </div>
    )}

    <!-- Project groups — tabbed (Studio 823 / FKD Workshop), styled like the About tabs -->
    {showTabs ? (
      <section class="cat-tabs" style="margin-top: clamp(4rem, 8vh, 6rem);">
        <div class="cat-tabs__bar" role="tablist" aria-label="Project groups">
          {tabGroups.map((g, i) => (
            <button class:list={["cat-tab-btn", i === 0 && "is-active"]} role="tab" aria-selected={i === 0 ? 'true' : 'false'} data-tab={g.id} type="button">
              <span>{g.label}</span>
              <svg class="pill-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
            </button>
          ))}
        </div>
        {tabGroups.map((g, i) => (
          <div class:list={["cat-tab-panel", i === 0 && "is-active"]} id={`cat-panel-${g.id}`} role="tabpanel" style={i === 0 ? undefined : 'display:none;'}>
            <div class="cat-card-list">
              {g.projects.map(p => (
                <ProjectCard project={p} tagMap={tagMap} showDescription={false} />
              ))}
              {g.projects.length === 0 && <p class="cat-tab-empty text-muted">No projects in this group yet.</p>}
            </div>
          </div>
        ))}
      </section>
    ) : (
      <div class="category-projects-list" style="margin-top: clamp(4rem, 8vh, 6rem);">
        {projects.map(p => (
          <a href={`/projects/${p.id}`} class="category-list-item switch-row">
            <div class="switch-row__content">
              <h2 class="switch-row__name">{p.data.name}</h2>
              <span class="project-card__pill">
                <span>View</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
              </span>
            </div>
            {p.data.coverImage && (
              <div class="hover-reveal-img" aria-hidden="true">
                <img src={p.data.coverImage} alt={p.data.name} loading="lazy" />
              </div>
            )}
          </a>
        ))}
      </div>
    )}

  </article>

  <style>
    /* Layout styling matched with Project pages */
    .category-detail {
      padding-bottom: clamp(4rem, 8vh, 8rem);
      min-height: 100dvh;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      gap: var(--_tokens---space--medium);
    }

    /* ── 3-Column Intro (mirrors the home page) ── */
    .category-intro__body {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 32px;
      width: 100%;
    }

    @media (max-width: 767px) {
      .category-intro__body {
        grid-template-columns: 1fr;
        gap: 20px;
      }
    }

    .category-intro__desc {
      font-size: var(--_tokens---type--small);
      font-weight: 500; /* medium — matches the big title's weight */
      line-height: 1.4;
      color: var(--_tokens---color--fg);
      margin: 0;
    }

    .category-intro__link {
      color: var(--_tokens---color--fg);
      text-decoration: none;
      white-space: nowrap;
      border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 30%, transparent);
      transition: border-color 0.2s ease;
    }
    .category-intro__link:hover { border-color: var(--_tokens---color--fg); }
    .category-intro__link .link-arrow {
      width: 0.75em;
      height: 0.75em;
      display: inline-block;
      vertical-align: baseline;
      margin-left: 1px;
    }

    /* ── Full-width slider (below the intro, like the home page) ── */
    .category-slider {
      width: 100%;
    }
    .category-slider .project-slider {
      min-height: 0;
      aspect-ratio: 16 / 9;
      max-height: 70vh;
    }

    /* ── Sticky Headers ── */
    .project-top-header {
      position: sticky;
      top: 0;
      z-index: 50;
      background-color: var(--_tokens---color--bg); /* Solid bg for scrolling over */
      padding-top: calc(clamp(2rem, 4vh, 3rem) + 48px);
      padding-bottom: 24px;
      margin-top: calc(-1 * (clamp(2rem, 4vh, 3rem) + 48px)); /* Offset parent padding if any, but parent has none now */
      cursor: pointer;
      transition: background-color 0.3s;
    }
    
    @media (min-width: 1200px) {
      .project-top-header {
        padding-top: calc(clamp(4rem, 6vh, 5rem) + 48px);
      }
    }

    /* ── Right Column (Sticky Slider) ── */
    .project-col-right {
      position: sticky;
      top: calc(clamp(4rem, 6vh, 5rem) + 48px + 100px); /* Stick below the project title */
    }

    .category-projects-list {
      border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
      display: flex;
      flex-direction: column;
    }

    /* ── Project group tabs (same look as the About page tabs) ── */
    .cat-tabs__bar {
      display: flex;
      flex-direction: row;
      gap: 6px;
      flex-wrap: nowrap;
      width: 100%;
      margin-bottom: 16px;
      border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
      padding-bottom: 12px;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .cat-tabs__bar::-webkit-scrollbar { display: none; }

    .cat-tab-btn {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: var(--_tokens---type--medium);
      font-family: inherit;
      font-weight: 500;
      letter-spacing: -0.03em;
      line-height: 1;
      background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
      border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
      color: var(--_tokens---color--muted);
      padding: 14px 22px;
      cursor: pointer;
      border-radius: 999px;
      white-space: nowrap;
      transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }
    .cat-tab-btn .pill-arrow {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      opacity: 0.55;
      transition: opacity 0.2s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .cat-tab-btn:hover {
      background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
      color: var(--_tokens---color--fg);
      border-color: color-mix(in srgb, var(--_tokens---color--fg) 22%, transparent);
    }
    .cat-tab-btn:hover .pill-arrow { opacity: 1; transform: translate(2px, -2px); }
    .cat-tab-btn.is-active {
      background-color: var(--_tokens---color--fg);
      color: var(--_tokens---color--bg);
      border-color: var(--_tokens---color--fg);
    }
    .cat-tab-btn.is-active .pill-arrow { opacity: 0.7; }

    .cat-tab-empty { padding: 2rem 24px; }

    .cat-card-list {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    /* Switch-style Row (Premium Typography & Hover) */
    .switch-row {
      position: relative;
      display: block;
      text-decoration: none;
      color: var(--_tokens---color--fg);
      padding: 1.5rem 0;
      border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
      z-index: 1;
      transition: background-color 0.2s;
    }
    .switch-row:first-child {
      border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    }
    .switch-row:hover {
      background-color: color-mix(in srgb, var(--_tokens---color--fg) 3%, transparent);
    }
    .switch-row__content {
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: relative;
      z-index: 5;
      pointer-events: none; /* Let hover hit the row exactly */
      padding: 0 24px;
    }
    .switch-row__name {
      font-size: var(--_tokens---type--medium);
      font-weight: 500;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin: 0;
      transition: opacity 0.2s ease;
    }
    .switch-row:hover .switch-row__name {
      opacity: 0.7;
    }
    
    .project-card__pill {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      font-size: var(--_tokens---type--micro);
      font-weight: 500;
      color: var(--_tokens---color--fg);
      text-decoration: none;
      border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 22%, transparent);
      border-radius: 999px;
      padding: 7px 14px;
      white-space: nowrap;
      flex-shrink: 0;
      transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    }
    .project-card__pill svg { width: 0.85em; height: 0.85em; transition: transform 0.25s ease; }
    .switch-row:hover .project-card__pill {
      background-color: var(--_tokens---color--fg);
      color: var(--_tokens---color--bg);
      border-color: var(--_tokens---color--fg);
    }
    .switch-row:hover .project-card__pill svg { transform: translate(2px, -2px); }

    /* Hover Reveal Image (Cursor Tracking) */
    .hover-reveal-img {
      position: fixed;
      top: 0;
      left: 0;
      width: 400px; /* Adjust size as needed */
      aspect-ratio: 16/10;
      pointer-events: none;
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.8); /* Center on cursor, scale down initially */
      z-index: 4; /* Below the text (z-index 5) but above background */
      transition: opacity 0.4s ease, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      overflow: hidden;
      border-radius: 8px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }
    .hover-reveal-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .switch-row:hover .hover-reveal-img {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }

    @media (max-width: 767px) {
      /* Mobile fallback: disable hover reveal */
      .hover-reveal-img { display: none !important; }
      .switch-row__content { padding: 0 16px; }
    }

    /* Slider Styles */
    .project-slider {
      position: relative;
      width: 100%;
      height: 100%;
      min-height: 50vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: color-mix(in srgb, var(--_tokens---color--fg) 3%, transparent);
      border-radius: 4px;
    }
    .slider-image {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0;
      transition: opacity 0.5s ease-in-out;
    }
    .slider-image.active {
      opacity: 1;
      z-index: 1;
    }
    .slider-controls {
      position: absolute;
      bottom: 16px;
      right: 16px;
      display: flex;
      gap: 8px;
      z-index: 10;
    }
    .slider-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--_tokens---color--bg);
      color: var(--_tokens---color--fg);
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 15%, transparent);
      cursor: pointer;
      transition: all 0.2s;
    }
    .slider-btn:hover {
      background: var(--_tokens---color--fg);
      color: var(--_tokens---color--bg);
    }
    .slider-btn svg {
      width: 20px;
      height: 20px;
    }
  </style>

  <script>
    function initCategorySliders() {
      const slider = document.getElementById('project-slider');
      if (!slider) return;

      const images = slider.querySelectorAll('.slider-image');
      const prevBtn = slider.querySelector('.prev');
      const nextBtn = slider.querySelector('.next');
      if (images.length <= 1) return;

      let currentIdx = 0;
      let interval: number;

      function showSlide(idx: number) {
        images[currentIdx].classList.remove('active');
        currentIdx = (idx + images.length) % images.length;
        images[currentIdx].classList.add('active');
      }

      function nextSlide() { showSlide(currentIdx + 1); }
      function prevSlide() { showSlide(currentIdx - 1); }

      function startAutoSlide() {
        clearInterval(interval);
        interval = setInterval(nextSlide, 3000);
      }

      function stopAutoSlide() {
        clearInterval(interval);
      }

      nextBtn?.addEventListener('click', () => { nextSlide(); startAutoSlide(); });
      prevBtn?.addEventListener('click', () => { prevSlide(); startAutoSlide(); });

      slider.addEventListener('mouseenter', stopAutoSlide);
      slider.addEventListener('mouseleave', startAutoSlide);

      startAutoSlide();
    }

    function initHoverReveal() {
      const rows = document.querySelectorAll('.switch-row');
      rows.forEach(row => {
        const revealImg = row.querySelector('.hover-reveal-img') as HTMLElement;
        if (!revealImg) return;

        row.addEventListener('mousemove', (e: Event) => {
          const mouseEvent = e as MouseEvent;
          // Set coordinates exactly at the cursor
          revealImg.style.left = `${mouseEvent.clientX}px`;
          revealImg.style.top = `${mouseEvent.clientY}px`;
        });
      });
    }

    function initCategoryTabs() {
      const tabs = document.querySelectorAll<HTMLElement>('.cat-tab-btn');
      const panels = document.querySelectorAll<HTMLElement>('.cat-tab-panel');
      if (!tabs.length) return;
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.dataset.tab;
          tabs.forEach((t) => {
            const m = t === tab;
            t.classList.toggle('is-active', m);
            t.setAttribute('aria-selected', String(m));
          });
          panels.forEach((p) => {
            const m = p.id === `cat-panel-${target}`;
            p.style.display = m ? '' : 'none';
            p.classList.toggle('is-active', m);
          });
        });
      });
    }

    // Run on initial load (no View Transitions router here, so astro:page-load
    // doesn't fire) and again after any swap.
    initCategorySliders();
    initHoverReveal();
    initCategoryTabs();
    document.addEventListener('astro:after-swap', () => {
      initCategorySliders();
      initHoverReveal();
      initCategoryTabs();
    });
  </script>
</PageLayout>
