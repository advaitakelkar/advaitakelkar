---
// The exhibition room: process on the left, the active work in the middle,
// its index down the right edge.
//
// Deliberately mirrors the project detail pages' two-column card layout, but
// with the scrub moved OFF the left column and onto the right, beside the work
// it indexes. The left column is for reading and for leaving; the right side is
// always the exhibition.
export interface Props {
  title: string;
  subtitle?: string;
  backHref: string;
  backLabel: string;
  /** Ordered stages, each with its own media. Flattened into one index. */
  groups: Array<{
    label: string;
    note?: string;
    items: Array<{ type: 'video' | 'image'; src: string; label: string; film?: boolean }>;
  }>;
}
const { title, subtitle, backHref, backLabel, groups } = Astro.props;

// One flat, globally-indexed list — the right rail and the keyboard both walk it.
const flat = groups.flatMap((g, gi) =>
  g.items.map((it, ii) => ({
    ...it,
    group: g.label,
    groupIndex: gi,
    first: ii === 0,
    thumb: it.type === 'video' ? `${it.src}.jpg` : it.src,
    media: it.type === 'video' ? `${it.src}.mp4` : it.src,
  }))
);
const first = flat[0];
---

<div class="vgs" data-vgs>
  <!-- LEFT — the process, and the way out -->
  <aside class="vgs__process">
    <header class="vgs__head">
      <h1 class="vgs__title">{title}</h1>
      {subtitle && <p class="vgs__subtitle">{subtitle}</p>}
    </header>

    <ol class="vgs__steps">
      {groups.map((g, gi) => (
        <li>
          <button
            class:list={["vgs__step", gi === 0 && "is-active"]}
            type="button"
            data-step={gi}
            aria-current={gi === 0 ? 'true' : 'false'}
          >
            <span class="vgs__step-num">{String(gi + 1).padStart(2, '0')}</span>
            <span class="vgs__step-body">
              <span class="vgs__step-label">{g.label}</span>
              {g.note && <span class="vgs__step-note">{g.note}</span>}
            </span>
            <span class="vgs__step-count">{g.items.length}</span>
          </button>
        </li>
      ))}
    </ol>

    <a class="vgs__escape" href={backHref}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="11 18 5 12 11 6"></polyline></svg>
      <span>{backLabel}</span>
    </a>
  </aside>

  <!-- CENTER — the active work -->
  <div class="vgs__active">
    <div class="vgs__frame">
      <video
        class="vgs__video"
        data-vgs-video
        src={first.type === 'video' ? first.media : undefined}
        poster={first.type === 'video' ? first.thumb : undefined}
        hidden={first.type !== 'video'}
        preload="metadata"
        loop muted playsinline
      ></video>
      <img
        class="vgs__img"
        data-vgs-img
        src={first.type === 'image' ? first.media : undefined}
        alt={first.type === 'image' ? first.label : ''}
        hidden={first.type !== 'image'}
      />
    </div>
    <div class="vgs__caption">
      <span class="vgs__caption-label" data-vgs-label>{first.label}</span>
      <span class="vgs__caption-count"><span data-vgs-pos>1</span> / {flat.length}</span>
    </div>
  </div>

  <!-- RIGHT — the index of the active work -->
  <nav class="vgs__index" aria-label="Index">
    {flat.map((it, i) => (
      <button
        class:list={["vgs__thumb", i === 0 && "is-active"]}
        type="button"
        data-i={i}
        data-type={it.type}
        data-media={it.media}
        data-label={it.label}
        data-group={it.groupIndex}
        aria-label={it.label}
        title={it.label}
      >
        <img src={it.thumb} alt="" loading="lazy" decoding="async" />
      </button>
    ))}
  </nav>
</div>

<style>
  .vgs {
    display: grid;
    grid-template-columns: minmax(200px, 260px) minmax(0, 1fr) auto;
    gap: clamp(16px, 2.5vw, 40px);
    align-items: start;
    width: 100%;
    box-sizing: border-box;
    padding: clamp(16px, 3vh, 32px) clamp(16px, 2.5vw, 32px) clamp(24px, 5vh, 48px);
  }

  /* ── left: process ── */
  .vgs__process {
    position: sticky;
    top: clamp(16px, 3vh, 32px);
    display: flex;
    flex-direction: column;
    gap: 28px;
    min-width: 0;
  }

  .vgs__head { display: flex; flex-direction: column; gap: 6px; }

  .vgs__title {
    margin: 0;
    font-size: var(--_tokens---type--small);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--_tokens---color--fg);
  }

  .vgs__subtitle { margin: 0; font-size: var(--_tokens---type--ultrathin); color: var(--q, var(--_tokens---color--muted)); }

  .vgs__steps { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 2px; }

  .vgs__step {
    display: flex;
    align-items: baseline;
    gap: 10px;
    width: 100%;
    padding: 9px 10px;
    text-align: left;
    font-family: inherit;
    background: transparent;
    border: none;
    border-radius: var(--_tokens---radius--small);
    cursor: pointer;
    color: var(--_tokens---color--muted);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .vgs__step:hover { background-color: color-mix(in srgb, var(--_tokens---color--fg) 5%, transparent); }

  .vgs__step.is-active { color: var(--_tokens---color--fg); }
  .vgs__step.is-active .vgs__step-num { color: var(--q, var(--_tokens---color--fg)); }

  .vgs__step-num { font-size: var(--_tokens---type--ultrathin); letter-spacing: 0.1em; flex-shrink: 0; }
  .vgs__step-body { display: flex; flex-direction: column; gap: 1px; flex: 1; min-width: 0; }
  .vgs__step-label { font-size: var(--_tokens---type--micro); }
  .vgs__step-note { font-size: var(--_tokens---type--ultrathin); opacity: 0.7; }
  .vgs__step-count { font-size: var(--_tokens---type--ultrathin); opacity: 0.6; flex-shrink: 0; }

  .vgs__escape {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
    font-size: var(--_tokens---type--ultrathin);
    color: var(--_tokens---color--muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .vgs__escape svg { width: 1em; height: 1em; }
  .vgs__escape:hover { color: var(--_tokens---color--fg); }

  /* ── center: the active work ── */
  .vgs__active { display: flex; flex-direction: column; gap: 10px; min-width: 0; }

  .vgs__frame {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: min(72vh, 780px);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 3%, transparent);
    border: 1px solid var(--_tokens---color--line-soft);
    border-radius: var(--_tokens---radius--small);
    box-sizing: border-box;
    padding: clamp(12px, 2vw, 28px);
    overflow: hidden;
  }

  .vgs__video,
  .vgs__img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .vgs__video[hidden], .vgs__img[hidden] { display: none; }

  .vgs__caption {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    font-size: var(--_tokens---type--ultrathin);
    color: var(--_tokens---color--muted);
  }
  .vgs__caption-label { color: var(--_tokens---color--fg); }

  /* ── right: the index rail ── */
  .vgs__index {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: min(72vh, 780px);
    overflow-y: auto;
    padding-right: 2px;
    scrollbar-width: thin;
  }
  .vgs__index::-webkit-scrollbar { width: 3px; }
  .vgs__index::-webkit-scrollbar-thumb { background: var(--_tokens---color--line-soft); }

  .vgs__thumb {
    all: unset;
    width: 54px;
    height: 54px;
    flex: 0 0 auto;
    cursor: pointer;
    overflow: hidden;
    border-radius: var(--_tokens---radius--small);
    border: 1px solid transparent;
    box-sizing: border-box;
    transition: border-color 0.2s ease, opacity 0.2s ease;
    opacity: 0.5;
  }

  .vgs__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; filter: grayscale(1); transition: filter 0.2s ease; }

  .vgs__thumb:hover { opacity: 1; }
  .vgs__thumb:hover img { filter: grayscale(0); }

  .vgs__thumb.is-active {
    opacity: 1;
    border-color: var(--q, var(--_tokens---color--fg));
  }
  .vgs__thumb.is-active img { filter: grayscale(0); }

  .vgs__thumb:focus-visible { outline: 2px solid var(--_tokens---color--fg); outline-offset: 2px; }

  /* ── mobile: process on top, media, then a horizontal index ── */
  @media (max-width: 900px) {
    .vgs {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .vgs__process { position: static; gap: 18px; }
    .vgs__frame { height: 52vh; }
    .vgs__index {
      flex-direction: row;
      max-height: none;
      overflow-x: auto;
      overflow-y: hidden;
      padding-bottom: 4px;
    }
    .vgs__thumb { width: 48px; height: 48px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .vgs__thumb, .vgs__thumb img, .vgs__step { transition: none; }
  }
</style>

<script>
  // One active work at a time. The right rail, the left step list and the
  // arrow keys all drive the same setActive() so they can never disagree.
  function initVGStage() {
    const root = document.querySelector('[data-vgs]') as HTMLElement | null;
    if (!root || (root as any)._wired) return;
    (root as any)._wired = true;

    const video = root.querySelector('[data-vgs-video]') as HTMLVideoElement;
    const img = root.querySelector('[data-vgs-img]') as HTMLImageElement;
    const label = root.querySelector('[data-vgs-label]') as HTMLElement;
    const pos = root.querySelector('[data-vgs-pos]') as HTMLElement;
    const thumbs = Array.from(root.querySelectorAll('.vgs__thumb')) as HTMLButtonElement[];
    const steps = Array.from(root.querySelectorAll('.vgs__step')) as HTMLButtonElement[];
    if (!thumbs.length) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const setActive = (i: number, scroll = true) => {
      const t = thumbs[i];
      if (!t) return;

      thumbs.forEach(x => x.classList.remove('is-active'));
      t.classList.add('is-active');

      const isVideo = t.dataset.type === 'video';
      if (isVideo) {
        img.hidden = true;
        video.hidden = false;
        // Only swap the source when it actually changes — resetting src on an
        // already-playing video restarts the decoder and flashes the poster.
        const next = t.dataset.media!;
        if (!video.src.endsWith(next)) {
          video.src = next;
          video.poster = t.querySelector('img')!.src;
        }
        if (!reduced) video.play().catch(() => {});
      } else {
        video.pause();
        video.hidden = true;
        img.hidden = false;
        img.src = t.dataset.media!;
        img.alt = t.dataset.label!;
      }

      label.textContent = t.dataset.label!;
      pos.textContent = String(i + 1);

      const g = Number(t.dataset.group);
      steps.forEach((s, si) => {
        s.classList.toggle('is-active', si === g);
        s.setAttribute('aria-current', si === g ? 'true' : 'false');
      });

      if (scroll) t.scrollIntoView({ block: 'nearest', inline: 'nearest', behavior: 'smooth' });
    };

    thumbs.forEach((t, i) => t.addEventListener('click', () => setActive(i, false)));

    // A step jumps to the first work in that stage.
    steps.forEach((s, si) => {
      s.addEventListener('click', () => {
        const target = thumbs.findIndex(t => Number(t.dataset.group) === si);
        if (target >= 0) setActive(target);
      });
    });

    // Arrow keys walk the index — but never steal typing from a form field.
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp' && e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
      const tag = (document.activeElement as HTMLElement | null)?.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA') return;
      const cur = thumbs.findIndex(t => t.classList.contains('is-active'));
      const fwd = e.key === 'ArrowDown' || e.key === 'ArrowRight';
      e.preventDefault();
      setActive((cur + (fwd ? 1 : -1) + thumbs.length) % thumbs.length);
    });

    if (!reduced && !video.hidden) video.play().catch(() => {});
  }

  initVGStage();
  document.addEventListener('astro:after-swap', initVGStage);
</script>
