---
import { getCollection } from 'astro:content';

export interface Props {
  currentPath?: string;
}
const { currentPath = '/' } = Astro.props;

// Derive human-readable page name for the label
function pageName(path: string): string {
  if (path === '/') return 'HOME';
  const parts = path.split('/').filter(Boolean);
  if (parts[0] === 'about') return 'ABOUT';
  if (parts[0] === 'projects' && parts.length === 1) return 'PROJECTS';
  if (parts[0] === 'projects' && parts.length > 1) {
    return parts[1].replace(/-/g, ' ').toUpperCase();
  }
  return parts[parts.length - 1].replace(/-/g, ' ').toUpperCase();
}

const barLabel = `INDEX / ${pageName(currentPath)}`;

// Fetch all projects for the infinite scroll wheel
const allProjects = await getCollection('projects');
const wheelProjects = [...allProjects].sort(
  (a, b) => parseInt(b.data.year ?? '0') - parseInt(a.data.year ?? '0')
);

// Color schemes for dropdown
const schemes = [
  { id: 'default', label: 'Void',     bg: '#111111', fg: '#ffffff' },
  { id: 'sch1',    label: 'Ocean',    bg: '#0D5072', fg: '#7FEEFF' },
  { id: 'sch2',    label: 'Moss',     bg: '#ECE7E2', fg: '#4A7766' },
  { id: 'sch3',    label: 'Crimson',  bg: '#F5F5DA', fg: '#7B021D' },
  { id: 'sch4',    label: 'Dusk',     bg: '#6C5383', fg: '#D7E7C3' },
  { id: 'sch5',    label: 'Midnight', bg: '#0B1A35', fg: '#D2B96A' },
  { id: 'sch6',    label: 'Cobalt',   bg: '#191265', fg: '#EBEBDF' },
  { id: 'sch7',    label: 'Sapphire', bg: '#275CCC', fg: '#F5E4CF' },
  { id: 'sch8',    label: 'Garden',   bg: '#BAD797', fg: '#670626' },
  { id: 'sch9',    label: 'Forest',   bg: '#033631', fg: '#FFEDA8' },
];
---

<div class="sn-wrap" id="sn-wrap">

  <!-- ── Narrow INDEX bar ── -->
  <div class="sn-bar" id="sn-bar" role="button" tabindex="0"
       aria-expanded="false" aria-controls="sn-panel" aria-label="Toggle navigation">

    <!-- Logo (top) -->
    <a href="/" class="sn-bar__logo" id="sn-logo" aria-label="Home" title="Home">
      <div class="sn-bar__mark" id="sn-logo-mark"></div>
    </a>

    <!-- Color scheme switcher -->
    <div class="sn-scheme" id="sn-scheme">
      <button class="sn-scheme__btn" id="sn-scheme-btn"
              aria-label="Change color scheme" title="Color scheme"
              aria-haspopup="listbox" aria-expanded="false">
        <div class="sn-scheme__indicator" id="sn-scheme-indicator"></div>
      </button>
      <!-- Dropdown -->
      <div class="sn-scheme__dropdown" id="sn-scheme-dropdown" role="listbox" aria-label="Color schemes">
        {schemes.map(s => (
          <button
            class="sn-scheme__option"
            role="option"
            data-scheme={s.id}
            title={s.label}
            aria-label={s.label}
          >
            <span class="sn-scheme__swatch" style={`background:${s.bg}`}>
              <span class="sn-scheme__swatch-fg" style={`background:${s.fg}`}></span>
            </span>
            <span class="sn-scheme__name">{s.label}</span>
          </button>
        ))}
      </div>
    </div>

    <!-- Hamburger (open / close trigger — visual only, bar click is the trigger) -->
    <div class="sn-bar__hamburger" id="sn-hamburger" aria-hidden="true">
      <span></span>
      <span></span>
    </div>

    <!-- Vertical label (bottom): index / current page -->
    <span class="sn-bar__label" id="sn-bar-label"><span class="sn-bar__label-index">index</span><span class="sn-bar__label-page"> / {pageName(currentPath)}</span></span>
  </div>

  <!-- ── Slide-in panel ── -->
  <div class="sn-panel" id="sn-panel" aria-hidden="true">

    <!-- Top: identity + main nav -->
    <div class="sn-panel__top">
      <div class="sn-panel__header">
        <p class="sn-panel__name" data-scramble>Advaita Kelkar</p>
        <p class="sn-panel__bio">Hey! 👋 Advaita here — architectural designer from Mumbai 🇮🇳, currently at SCAD in Savannah 🌿. I work across architecture, interiors, urban design 🏙️ and everything in between ✨. Always curious, always making. Glad you're here! 🙌</p>
      </div>

      <nav class="sn-panel__nav" aria-label="Site navigation">
        <a href="/" class:list={['sn-panel__link', currentPath === '/' && 'is-active']}>
          <span data-scramble>Home</span>
          <span class="sn-panel__arrow">
            <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <line x1="6" y1="18" x2="18" y2="6"></line>
              <polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </span>
        </a>
        <a href="/about" class:list={['sn-panel__link', currentPath === '/about' && 'is-active']}>
          <span data-scramble>About Me</span>
          <span class="sn-panel__arrow">
            <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <line x1="6" y1="18" x2="18" y2="6"></line>
              <polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </span>
        </a>
        <a href="/projects" class:list={['sn-panel__link', currentPath.startsWith('/projects') && 'is-active']}>
          <span data-scramble>Projects</span>
          <span class="sn-panel__arrow">
            <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <line x1="6" y1="18" x2="18" y2="6"></line>
              <polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </span>
        </a>
      </nav>
    </div>

    <!-- Center: infinite, scrollable project wheel -->
    <div class="sn-panel__wheel" id="sn-wheel">
      <div class="sn-wheel__track" id="sn-wheel-track">
        {[0, 1, 2].map(() => (
          wheelProjects.map(p => (
            <a href={`/projects/${p.id}`} class="sn-wheel__item">
              <span data-scramble>{p.data.name}</span>
              <span class="sn-panel__arrow">
                <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                  <line x1="6" y1="18" x2="18" y2="6"></line>
                  <polyline points="10 6 18 6 18 14"></polyline>
                </svg>
              </span>
            </a>
          ))
        ))}
      </div>
    </div>

    <!-- Bottom: contact -->
    <div class="sn-panel__contact">
      <div class="sn-panel__email" id="sn-email-box" role="button" tabindex="0" aria-label="Copy email address">
        <span class="sn-panel__email-text">advaitakelkar@gmail.com</span>
        <span class="sn-panel__copy" aria-hidden="true">
          <svg class="sn-copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg class="sn-check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </span>
      </div>

      <nav class="sn-panel__social" aria-label="Social links">
        <a href="https://behance.net/advaitakelkar" class="sn-panel__link sn-panel__link--social" target="_blank" rel="noopener">
          <span>Behance</span>
          <span class="sn-panel__arrow">
            <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <line x1="6" y1="18" x2="18" y2="6"></line>
              <polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </span>
        </a>
        <a href="https://instagram.com/advaitakelkar" class="sn-panel__link sn-panel__link--social" target="_blank" rel="noopener">
          <span>Instagram</span>
          <span class="sn-panel__arrow">
            <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <line x1="6" y1="18" x2="18" y2="6"></line>
              <polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </span>
        </a>
        <a href="https://linkedin.com/in/advaitakelkar" class="sn-panel__link sn-panel__link--social" target="_blank" rel="noopener">
          <span>LinkedIn</span>
          <span class="sn-panel__arrow">
            <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <line x1="6" y1="18" x2="18" y2="6"></line>
              <polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </span>
        </a>
      </nav>
    </div>

  </div>

  <!-- Backdrop -->
  <div class="sn-backdrop" id="sn-backdrop" aria-hidden="true"></div>
</div>

<style>
  /* ── Wrapper ── */
  .sn-wrap {
    position: fixed;
    top: 0;
    left: 0;
    height: 100dvh;
    z-index: 200;
    display: flex;
  }

  /* ── Narrow bar ── */
  .sn-bar {
    position: relative;
    z-index: 201;
    width: 64px; /* Increased to 64px */
    height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding: 24px 0;
    background-color: var(--_tokens---color--bg);
    border-right: 1px solid var(--_tokens---color--line); /* Restored border line */
    cursor: pointer;
    flex-shrink: 0;
    transition: background-color 0.3s ease;
    user-select: none;
  }

  /* Logo */
  .sn-bar__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    text-decoration: none;
    width: 44px; /* Much bigger */
    height: 44px;
    margin-bottom: 24px;
    transition: transform 0.1s linear; /* Smooth scroll rotation transition */
  }

  .sn-bar__mark {
    width: 44px; /* Much bigger */
    height: 44px;
    background-color: var(--_tokens---color--fg);
    -webkit-mask: url('/ak-logo.svg') center / contain no-repeat;
    mask: url('/ak-logo.svg') center / contain no-repeat;
    flex-shrink: 0;
    transition: background-color 0.3s ease;
    /* Living logo: Continuous slow rotation and breathing glow */
    animation: rotate-logo var(--logo-speed, 20s) linear infinite, glow-logo 4s ease-in-out infinite;
  }

  @keyframes rotate-logo {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes glow-logo {
    0%, 100% {
      opacity: 0.7;
      filter: drop-shadow(0 0 1px var(--_tokens---color--fg));
    }
    50% {
      opacity: 1;
      filter: drop-shadow(0 0 6px var(--_tokens---color--fg));
    }
  }

  /* ── Color scheme switcher ── */
  .sn-scheme {
    position: relative;
    flex-shrink: 0;
  }

  .sn-scheme__btn {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none; /* minimal — no border */
    background: transparent;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.15s;
  }

  .sn-scheme__btn:hover { transform: scale(1.1); }

  /* Half-fill indicator showing current scheme — borderless */
  .sn-scheme__indicator {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: linear-gradient(to right,
      var(--_tokens---color--fg) 50%,
      color-mix(in srgb, var(--_tokens---color--fg) 22%, transparent) 50%
    );
  }

  /* Dropdown — drops linearly DOWN inside the index bar, icons stacked one below the other */
  .sn-scheme__dropdown {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    width: auto;
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 9px;
    opacity: 0;
    pointer-events: none;
    transform: translateX(-50%) translateY(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 300;
  }

  .sn-scheme__dropdown.is-open {
    opacity: 1;
    pointer-events: all;
    transform: translateX(-50%) translateY(0);
  }

  .sn-scheme__option {
    display: flex;
    border: none;
    background: transparent;
    cursor: pointer;
    padding: 0;
    border-radius: 50%;
    transition: transform 0.15s;
  }

  .sn-scheme__option:hover { transform: scale(1.18); }

  .sn-scheme__option.is-active .sn-scheme__swatch {
    outline: 1.5px solid var(--_tokens---color--fg);
    outline-offset: 2px;
  }

  /* Color swatch — small circular dot, no border (minimal) */
  .sn-scheme__swatch {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
  }

  .sn-scheme__swatch-fg {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Hide name — colors only */
  .sn-scheme__name {
    display: none;
  }

  /* ── Hamburger — pinned to exact center of bar ── */
  .sn-bar__hamburger {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    gap: 5px;
    align-items: center;
    pointer-events: none;
  }

  .sn-bar__hamburger span {
    display: block;
    width: 18px;
    height: 1.5px;
    background-color: var(--_tokens---color--fg);
    transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
    transform-origin: center;
  }

  /* Animate to X when panel open */
  .sn-wrap.is-open .sn-bar__hamburger span:nth-child(1) {
    transform: translateY(3.25px) rotate(45deg);
  }

  .sn-wrap.is-open .sn-bar__hamburger span:nth-child(2) {
    transform: translateY(-3.25px) rotate(-45deg);
  }

  /* ── Vertical label (bottom): index / current page ── */
  .sn-bar__label {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
    margin-top: auto;
    pointer-events: none;
    white-space: nowrap;
    text-transform: none;
    letter-spacing: 0.04em;
    transition: color 0.3s ease;
  }

  /* "index" — larger (medium-leaning), medium weight */
  .sn-bar__label-index {
    font-size: clamp(1.25rem, 1.8vw, 1.7rem);
    font-weight: 500;
    color: var(--_tokens---color--fg);
    vertical-align: middle;
  }

  /* "/ page" — small, regular */
  .sn-bar__label-page {
    font-size: var(--_tokens---type--small);
    font-weight: 400;
    color: var(--_tokens---color--muted);
    vertical-align: middle;
  }

  /* ── Slide-in panel ── */
  .sn-panel {
    position: fixed;
    top: 0;
    left: 64px; /* Positioned relative to 64px sidebar */
    width: 400px;
    height: 100dvh;
    background-color: var(--_tokens---color--bg);
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0;
    overflow: hidden; /* the wheel scrolls internally */
    transform: translateX(-100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 200;
    pointer-events: none;
  }

  .sn-panel.is-open {
    transform: translateX(0);
    pointer-events: all;
  }

  /* ── Top block: identity + nav ── */
  .sn-panel__top { flex-shrink: 0; }

  .sn-panel__header {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: var(--_tokens---space--small) var(--_tokens---space--small) 0;
  }

  /* Name — micro, bold */
  .sn-panel__name {
    font-size: var(--_tokens---type--micro);
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--_tokens---color--fg);
    margin: 0;
  }

  /* Bio — micro */
  .sn-panel__bio {
    font-size: var(--_tokens---type--micro);
    line-height: 1.55;
    color: var(--_tokens---color--muted);
    margin: 0;
  }

  /* Main nav — tight, after a small spacer */
  .sn-panel__nav {
    display: flex;
    flex-direction: column;
    padding: 0 var(--_tokens---space--small);
    margin-top: 20px; /* small spacer */
    gap: 0;
  }

  .sn-panel__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: var(--_tokens---type--small);
    font-weight: 500;
    line-height: 1.1;
    color: var(--_tokens---color--fg);
    text-decoration: none;
    padding: 3px 0; /* tightly spaced */
    transition: opacity 0.15s ease, transform 0.2s ease;
    opacity: 0.65;
    white-space: nowrap;
    gap: 12px;
  }

  .sn-panel__link:hover,
  .sn-panel__link.is-active {
    opacity: 1;
    transform: translateX(4px);
  }

  /* ── Center: infinite project wheel ── */
  .sn-panel__wheel {
    height: 280px; /* fixed height for 5-project focus */
    max-height: 280px;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: none;
    margin: auto 0;
    padding-inline: var(--_tokens---space--small);
    /* fade (grey out) items away from the center 5 focus area */
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, 0.15) 12%, #000 32%, #000 68%, rgba(0, 0, 0, 0.15) 88%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, 0.15) 12%, #000 32%, #000 68%, rgba(0, 0, 0, 0.15) 88%, transparent 100%);
  }

  .sn-panel__wheel::-webkit-scrollbar { display: none; }

  .sn-wheel__track {
    display: flex;
    flex-direction: column;
  }

  .sn-wheel__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: var(--_tokens---type--small);
    font-weight: 400;
    line-height: 1.2;
    color: var(--_tokens---color--fg);
    text-decoration: none;
    padding: 10px 0; /* increased padding for spacious white space */
    gap: 12px;
    opacity: 0.85;
    white-space: nowrap;
    transition: opacity 0.15s ease, transform 0.2s ease;
  }

  .sn-wheel__item:hover {
    opacity: 1;
    transform: translateX(4px);
  }

  /* ── Bottom: contact ── */
  .sn-panel__contact {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 12px var(--_tokens---space--small) var(--_tokens---space--small);
  }

  /* Email — greyed box with copy icon */
  .sn-panel__email {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 7%, transparent);
    border-radius: 8px;
    padding: 9px 12px;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .sn-panel__email:hover {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 11%, transparent);
  }

  .sn-panel__email-text {
    font-size: var(--_tokens---type--micro);
    font-weight: 400;
    color: var(--_tokens---color--fg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sn-panel__copy {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    color: var(--_tokens---color--muted);
    position: relative;
  }

  .sn-panel__copy svg {
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .sn-copy-icon { opacity: 1; }
  .sn-check-icon { opacity: 0; transform: scale(0.6); color: var(--_tokens---color--fg); }
  .sn-panel__email.is-copied .sn-copy-icon { opacity: 0; }
  .sn-panel__email.is-copied .sn-check-icon { opacity: 1; transform: scale(1); }

  /* Social links — same size as main nav */
  .sn-panel__social {
    display: flex;
    flex-direction: column;
    padding: 0;
    gap: 0;
  }

  .sn-panel__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.1em;
    height: 1.15em;
    flex-shrink: 0;
    opacity: 0.6;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }

  .sn-panel__arrow .link-arrow {
    width: 100%;
    height: 100%;
  }

  .sn-panel__link:hover .sn-panel__arrow,
  .sn-wheel__item:hover .sn-panel__arrow {
    transform: translate(2px, -2px);
    opacity: 1;
  }

  /* ── Backdrop ── */
  .sn-backdrop {
    position: fixed;
    inset: 0;
    left: 64px; /* Positioned relative to 64px sidebar */
    background-color: rgba(0, 0, 0, 0.35);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
    z-index: 199;
  }

  .sn-backdrop.is-open {
    opacity: 1;
    pointer-events: all;
  }
</style>

<script>
  // ── State ──────────────────────────────────────────────────
  let navOpen = false;
  let schemeOpen = false;

  const wrap      = document.getElementById('sn-wrap')!;
  const bar       = document.getElementById('sn-bar')!;
  const panel     = document.getElementById('sn-panel')!;
  const backdrop  = document.getElementById('sn-backdrop')!;
  const logo      = document.getElementById('sn-logo')!;
  const logoMark  = document.getElementById('sn-logo-mark')!;

  // ── Living Logo Activity & Scroll Controls ─────────────────
  let lastScrollTop = 0;
  let scrollRotation = 0;
  let currentSpeed = 20; // 20s rotation speed (slow)
  let targetSpeed = 20;

  // Rotate logo container on page scroll
  window.addEventListener('scroll', () => {
    const st = window.pageYOffset || document.documentElement.scrollTop;
    const diff = st - lastScrollTop;
    scrollRotation += diff * 0.15; // sensitivity coefficient
    lastScrollTop = st <= 0 ? 0 : st;
    if (logo) {
      logo.style.transform = `rotate(${scrollRotation}deg)`;
    }
  }, { passive: true });

  // Boost logo velocity on interaction
  function boostLogo(speed = 2) {
    targetSpeed = speed; // Spin faster (smaller animation period)
  }

  // Activity listeners
  window.addEventListener('mousemove', () => boostLogo(2.5), { passive: true });
  window.addEventListener('keydown', () => boostLogo(1.5), { passive: true });
  window.addEventListener('scroll', () => boostLogo(3), { passive: true });

  // Hyper-boost logo speed when clicking the index bar
  bar.addEventListener('click', () => boostLogo(0.4));

  // Velocity controller loop with smooth decay
  function updateVelocity() {
    currentSpeed = currentSpeed + (targetSpeed - currentSpeed) * 0.04;
    if (logoMark) {
      logoMark.style.setProperty('--logo-speed', `${currentSpeed}s`);
    }
    
    // Watermark logo animation speed (different speed factor, e.g. 1.8x slower)
    const watermarkLogo = document.getElementById('watermark-logo');
    if (watermarkLogo) {
      watermarkLogo.style.setProperty('--watermark-speed', `${currentSpeed * 1.8}s`);
    }

    if (targetSpeed < 20) {
      targetSpeed += 0.15; // Slow down gradually
      if (targetSpeed > 20) targetSpeed = 20;
    }
    requestAnimationFrame(updateVelocity);
  }
  requestAnimationFrame(updateVelocity);
  const schemeEl  = document.getElementById('sn-scheme')!;
  const schemeBtn = document.getElementById('sn-scheme-btn')!;
  const dropdown  = document.getElementById('sn-scheme-dropdown')!;

  // ── Nav toggle ─────────────────────────────────────────────
  function openNav() {
    navOpen = true;
    wrap.classList.add('is-open');
    bar.setAttribute('aria-expanded', 'true');
    panel.classList.add('is-open');
    panel.setAttribute('aria-hidden', 'false');
    backdrop.classList.add('is-open');
  }

  function closeNav() {
    navOpen = false;
    wrap.classList.remove('is-open');
    bar.setAttribute('aria-expanded', 'false');
    panel.classList.remove('is-open');
    panel.setAttribute('aria-hidden', 'true');
    backdrop.classList.remove('is-open');
  }

  bar.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('#sn-logo')) return;
    if ((e.target as HTMLElement).closest('#sn-scheme')) return;
    navOpen ? closeNav() : openNav();
  });

  bar.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); navOpen ? closeNav() : openNav(); }
    if (e.key === 'Escape') closeNav();
  });

  logo.addEventListener('click', (e) => e.stopPropagation());
  backdrop.addEventListener('click', closeNav);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { closeNav(); closeScheme(); }
  });

  // ── Scheme dropdown ────────────────────────────────────────
  const SCHEMES = [
    'default','sch1','sch2','sch3','sch4','sch5','sch6','sch7','sch8','sch9'
  ];

  function getCurrentScheme(): string {
    const match = document.documentElement.className.match(/sch\d+/);
    return match ? match[0] : 'default';
  }

  function applyScheme(id: string) {
    // Remove all sch classes
    document.documentElement.classList.remove(...SCHEMES.filter(s => s !== 'default'));
    if (id !== 'default') document.documentElement.classList.add(id);
    sessionStorage.setItem('aks', id === 'default' ? '' : id);
    updateActiveOption();
    closeScheme();
  }

  function updateActiveOption() {
    const current = getCurrentScheme();
    dropdown.querySelectorAll<HTMLElement>('.sn-scheme__option').forEach(btn => {
      btn.classList.toggle('is-active', btn.dataset.scheme === current);
    });
  }

  function openScheme() {
    schemeOpen = true;
    schemeBtn.setAttribute('aria-expanded', 'true');
    dropdown.classList.add('is-open');
    updateActiveOption();
  }

  function closeScheme() {
    schemeOpen = false;
    schemeBtn.setAttribute('aria-expanded', 'false');
    dropdown.classList.remove('is-open');
  }

  schemeBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    schemeOpen ? closeScheme() : openScheme();
  });

  schemeEl.addEventListener('click', (e) => e.stopPropagation());

  dropdown.querySelectorAll<HTMLElement>('.sn-scheme__option').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const id = btn.dataset.scheme ?? 'default';
      applyScheme(id);
    });
  });

  // Close scheme if clicking outside
  document.addEventListener('click', (e) => {
    if (schemeOpen && !schemeEl.contains(e.target as Node)) closeScheme();
  });

  // Restore persisted scheme on load
  const saved = sessionStorage.getItem('aks');
  if (saved && SCHEMES.includes(saved)) {
    document.documentElement.classList.remove(...SCHEMES.filter(s => s !== 'default'));
    document.documentElement.classList.add(saved);
  }
  updateActiveOption();

  // ── Infinite project wheel ─────────────────────────────────
  const wheel = document.getElementById('sn-wheel');
  const wheelTrack = document.getElementById('sn-wheel-track');
  if (wheel && wheelTrack) {
    const oneCopyHeight = () => wheelTrack.scrollHeight / 3;
    // start in the middle copy so it can loop both directions
    requestAnimationFrame(() => { wheel.scrollTop = oneCopyHeight(); });
    let ticking = false;
    wheel.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const h = oneCopyHeight();
        if (h > 0) {
          if (wheel.scrollTop < h * 0.5) wheel.scrollTop += h;
          else if (wheel.scrollTop > h * 1.5) wheel.scrollTop -= h;
        }
        ticking = false;
      });
    }, { passive: true });
  }

  // ── Copy email to clipboard ────────────────────────────────
  const emailBox = document.getElementById('sn-email-box');
  emailBox?.addEventListener('click', async () => {
    try { await navigator.clipboard.writeText('advaitakelkar@gmail.com'); } catch (_) {}
    emailBox.classList.add('is-copied');
    setTimeout(() => emailBox.classList.remove('is-copied'), 1500);
  });
  emailBox?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); (emailBox as HTMLElement).click(); }
  });
</script>
