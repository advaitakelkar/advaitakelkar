    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, 0.1) 8%, #000 25%, #000 75%, rgba(0, 0, 0, 0.1) 92%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, 0.1) 8%, #000 25%, #000 75%, rgba(0, 0, 0, 0.1) 92%, transparent 100%);
