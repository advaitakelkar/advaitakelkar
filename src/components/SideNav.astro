---
import { getCollection } from 'astro:content';
import { publicFileExists } from '../lib/content';

export interface Props {
  currentPath?: string;
}
const { currentPath = '/' } = Astro.props;

// PDF pills only render once the files actually exist in public/
const hasPortfolio = publicFileExists('/advaita-kelkar-portfolio.pdf');
const hasCv = publicFileExists('/advaita-kelkar-resume.pdf');

// Fetch all projects for route mapping
const allProjects = await getCollection('projects');
const allCategories = await getCollection('categories');

// Normalize path (ignore trailing slash)
const normPath = currentPath.replace(/\/$/, '') || '/';

const pathParts = normPath.split('/').filter(Boolean);
const isProjectPage = pathParts[0] === 'projects' && pathParts.length > 1;

let categoryLink = '';
let categoryName = '';

if (isProjectPage) {
  const projectSlug = pathParts[1];
  const project = allProjects.find(p => p.id === projectSlug);
  if (project && project.data.category) {
    const catId = project.data.category.id;
    const cat = allCategories.find(c => c.id === catId);
    categoryName = cat?.data.displayName || catId;
    categoryLink = `/${catId}`;
  }
}

// Derive human-readable page name for the label (normal case)
function pageName(path: string): string {
  const norm = path.replace(/\/$/, '') || '/';
  if (norm === '/') return 'Home';
  const parts = norm.split('/').filter(Boolean);
  if (parts[0] === 'about') return 'About';
  if (parts[0] === 'projects') {
    if (parts.length === 1) return 'Projects';
    const slug = parts[1];
    const proj = allProjects.find(p => p.id === slug);
    if (proj) return proj.data.name; // return actual name (normal case)
    return parts[1].split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
  }
  // Categories/Tags
  if (parts[0] === 'work' && parts.length > 1) {
    const sub = parts[1];
    if (sub === 'studio-823') return 'Studio 823';
    if (sub === 'faizan-khatri') return 'FKD Workshop';
  }
  return parts[parts.length - 1].split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
}

const barLabel = `INDEX / ${pageName(currentPath)}`;
const wheelProjects = [...allProjects].sort(
  (a, b) => parseInt(b.data.year ?? '0') - parseInt(a.data.year ?? '0')
);

// Combined wheel items: top-level pages first, then projects
type WheelItem = { href: string; name: string; id: string; isPage: boolean };
const wheelItems: WheelItem[] = [
  { href: '/',         name: 'Home',     id: '__home__',     isPage: true },
  { href: '/about',    name: 'About',    id: '__about__',    isPage: true },
  { href: '/projects', name: 'Projects', id: '__projects__', isPage: true },
  { href: '/work', name: 'Work', id: '__work__', isPage: true },
  { href: '/academic', name: 'Academic', id: '__academic__', isPage: true },
  { href: '/freelancer', name: 'Freelancer', id: '__freelancer__', isPage: true },
  { href: '/archv', name: 'Archv', id: '__archv__', isPage: true },
  ...wheelProjects.map(p => ({ href: `/projects/${p.id}`, name: p.data.name, id: p.id, isPage: false })),
];

// Color schemes — all light variants; dark mode flips bg↔fg via CSS
// fg doubles as the dark-mode bg for swatch rendering
const schemes = [
  { id: 'default', label: 'Void',     bg: '#ffffff', fg: '#111111' },
  { id: 'sch1',    label: 'Moss',     bg: '#ECE7E2', fg: '#4A7766' },
  { id: 'sch2',    label: 'Clay',     bg: '#fee7d5', fg: '#4b3935' },
  { id: 'sch3',    label: 'Dusk',     bg: '#D7E7C3', fg: '#6C5383' },
  { id: 'sch4',    label: 'Midnight', bg: '#D2B96A', fg: '#0B1A35' },
  { id: 'sch6',    label: 'Ember',    bg: '#ffe4a1', fg: '#97322D' },
  { id: 'sch7',    label: 'Nomad',    bg: '#edcdc2', fg: '#0093AF' },
];
---

<div class="sn-wrap" id="sn-wrap">

  <!-- ── Narrow INDEX bar ── -->
  <div class="sn-bar" id="sn-bar" role="button" tabindex="0"
       aria-expanded="false" aria-controls="sn-panel" aria-label="Toggle navigation">

    <!-- Logo (top) -->
    <a href="/" class="sn-bar__logo" id="sn-logo" aria-label="Home" title="Home">
      <div class="sn-bar__mark" id="sn-logo-mark"></div>
    </a>

    <!-- Color scheme switcher -->
    <div class="sn-scheme" id="sn-scheme">
      <button class="sn-scheme__btn" id="sn-scheme-btn"
              aria-label="Change color scheme" title="Color scheme"
              aria-haspopup="listbox" aria-expanded="false">
        <div class="sn-scheme__indicator" id="sn-scheme-indicator"></div>
      </button>
      <!-- Dropdown -->
      <div class="sn-scheme__dropdown" id="sn-scheme-dropdown" role="listbox" aria-label="Color schemes">
        {schemes.map(s => (
          <button
            class="sn-scheme__option"
            role="option"
            data-scheme={s.id}
            title={s.label}
            aria-label={s.label}
          >
            <span class="sn-scheme__swatch" style={`--sw-l:${s.fg};--sw-d:${s.bg};`}></span>
            <span class="sn-scheme__name">{s.label}</span>
          </button>
        ))}
        <!-- Mode toggle: half-dark / half-light circle -->
        <hr class="sn-scheme__divider" aria-hidden="true" />
        <button
          class="sn-scheme__option"
          id="sn-mode-btn"
          title="Toggle dark / light"
          aria-label="Toggle dark / light mode"
        >
          <span class="sn-scheme__swatch sn-mode-swatch"></span>
          <span class="sn-scheme__name">Mode</span>
        </button>
      </div>
    </div>

    <!-- Hamburger (open / close trigger — visual only, bar click is the trigger) -->
    <div class="sn-bar__hamburger" id="sn-hamburger" aria-hidden="true">
      <span></span>
      <span></span>
    </div>

    <!-- "tap to open" — glitch-typed on a loop, invites the click.
         The invisible ghost keeps the bar layout steady while it types. -->
    <span class="sn-bar__open-tag" id="sn-open-tag" aria-hidden="true">
      <span class="sn-open-tag__ghost">tap to open</span>
      <span class="sn-open-tag__type" id="sn-open-type"></span>
    </span>

    <!-- Vertical label (bottom): index / current page -->
    <span class="sn-bar__label" id="sn-bar-label">
      <span class="sn-bar__label-index">index</span>
      <span class="sn-bar__label-page">
        / {isProjectPage && categoryName ? (
          <a href={categoryLink} class="sn-bar__category-link">{categoryName}</a>
        ) : (
          pageName(currentPath)
        )}
      </span>
    </span>

    <!-- Lock / unlock toggle (bottom corner) — unlocks all project pages at once -->
    <button class="sn-lock" id="sn-lock-toggle" data-lock-toggle data-unlocked="false" type="button" aria-label="Lock or unlock the project archive" title="Lock / unlock projects">
      <svg class="sn-lock__icon sn-lock__icon--locked" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="5" y="11" width="14" height="9" rx="2"></rect>
        <path d="M8 11V8a4 4 0 0 1 8 0v3"></path>
      </svg>
      <svg class="sn-lock__icon sn-lock__icon--unlocked" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="5" y="11" width="14" height="9" rx="2"></rect>
        <path d="M8 11V8a4 4 0 0 1 7.5-1.9"></path>
      </svg>
    </button>
  </div>

  <!-- ── Slide-in panel ── -->
  <div class="sn-panel" id="sn-panel" aria-hidden="true">

    <!-- Top Identity Block -->
    <div class="sn-panel__top">
      <div class="sn-panel__header">
        <p class="sn-panel__name" data-scramble>Advaita Kelkar</p>
        
        <!-- Click-to-copy email box -->
        <div class="sn-panel__email" id="sn-email-box" role="button" tabindex="0" aria-label="Copy email address">
          <span class="sn-panel__email-text">advaitakelkar@gmail.com</span>
          <span class="sn-panel__copy" aria-hidden="true">
            <svg class="sn-copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            <svg class="sn-check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </span>
        </div>

        <div class="sn-panel__spacer"></div>

        <p class="sn-panel__bio">Hey! I'm Adi — Advaita Kelkar — architectural designer from India, currently completing my MArch at SCAD (Savannah College of Art and Design), class of 2027, in Savannah. I work across architecture, interiors, urban design and everything in between. Always curious, always making. Glad you're here!</p>

        <div class="sn-panel__divider" aria-hidden="true"></div>

        <!-- Archive blurb + socials + downloads — one continuous paragraph -->
        <div class="sn-panel__footer">
          <p class="sn-panel__archive-text">
            This is the living archive of my design work — an ecosystem bringing together everything I design, draw, research, make and create.
            Connect with me at
            <a href="https://linkedin.com/in/advaitakelkar" target="_blank" rel="noopener" class="sn-panel__inline-link">LinkedIn</a>,
            <a href="https://instagram.com/advaitakelkar" target="_blank" rel="noopener" class="sn-panel__inline-link">Instagram</a>,
            <a href="https://github.com/advaitakelkar" target="_blank" rel="noopener" class="sn-panel__inline-link">GitHub</a>,
            <a href="https://instagram.com/3xpmnts" target="_blank" rel="noopener" class="sn-panel__inline-link">3xpmnts</a>,
            <a href="https://instagram.com/archv.in" target="_blank" rel="noopener" class="sn-panel__inline-link">ARCHV</a>.
            Download my
            <a href="/resume.pdf" download class="sn-panel__inline-link">Resume</a>
            or
            <a href="/portfolio.pdf" download class="sn-panel__inline-link">Portfolio</a>.
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom Area: infinite looping scroll wheel of page items and projects -->
    <div class="sn-panel__bottom-track">
      <div class="sn-panel__wheel" id="sn-wheel">
        <!-- ONE copy in the HTML; the infinite loop needs three, so the
             script clones two more on first open. Shipping all three copies
             on every page cost ~150 links + SVGs of dead-weight DOM. -->
        <div class="sn-wheel__track" id="sn-wheel-track" data-copies="1">
          {wheelItems.map(item => (
            <a
              href={item.href}
              class:list={[
                'sn-wheel__item',
                item.isPage && 'sn-wheel__item--page',
                (normPath === (item.href.replace(/\/$/, '') || '/')) && 'is-active'
              ]}
              data-item-id={item.id}
            >
              <span data-scramble>{item.name}</span>
              <span class="sn-panel__arrow">
                <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                  <line x1="6" y1="18" x2="18" y2="6"></line>
                  <polyline points="10 6 18 6 18 14"></polyline>
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </div>

  </div>

  <!-- Backdrop -->
  <div class="sn-backdrop" id="sn-backdrop" aria-hidden="true"></div>
</div>

<style>
  /* ── Wrapper ── */
  .sn-wrap {
    position: fixed;
    top: 0;
    left: 0;
    height: 100dvh;
    z-index: 200;
    display: flex;
  }

  /* ── Narrow bar ── */
  .sn-bar {
    position: relative;
    z-index: 201;
    width: 44px; /* Slimmed to 44px */
    height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding: 24px 0;
    background-color: var(--_tokens---color--bg-glass);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-right: 1px solid var(--_tokens---color--line);
    cursor: pointer;
    flex-shrink: 0;
    transition: background-color 0.3s ease, border-right-color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    user-select: none;
  }

  .sn-wrap.is-open .sn-bar {
    border-right-color: transparent;
  }

  /* Logo */
  .sn-bar__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    text-decoration: none;
    width: 36px; /* enlarged logo */
    height: 36px;
    margin-bottom: 20px;
  }

  .sn-bar__mark {
    width: 36px; /* enlarged logo */
    height: 36px;
    background-color: var(--_tokens---color--fg);
    -webkit-mask: url('/ak-logo.svg') center / contain no-repeat;
    mask: url('/ak-logo.svg') center / contain no-repeat;
    flex-shrink: 0;
    transition: background-color 0.3s ease;
    /* Rotation is driven by scroll velocity in JS; keep only the breathing glow here */
    animation: glow-logo 4s ease-in-out infinite;
    will-change: transform;
  }

  @keyframes glow-logo {
    0%, 100% {
      opacity: 0.7;
      filter: drop-shadow(0 0 1px var(--_tokens---color--fg));
    }
    50% {
      opacity: 1;
      filter: drop-shadow(0 0 6px var(--_tokens---color--fg));
    }
  }

  /* ── Color scheme switcher ── */
  .sn-scheme {
    position: relative;
    flex-shrink: 0;
  }

  .sn-scheme__btn {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none; /* minimal — no border */
    background: transparent;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.15s;
  }

  .sn-scheme__btn:hover { transform: scale(1.1); }

  /* Solid circle — current scheme fg (darker) with bg border */
  .sn-scheme__indicator {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--_tokens---color--fg);
    border: 1.5px solid var(--_tokens---color--bg);
  }

  /* Dropdown — drops linearly DOWN inside the index bar, icons stacked one below the other */
  .sn-scheme__dropdown {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    width: auto;
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 9px;
    opacity: 0;
    pointer-events: none;
    transform: translateX(-50%) translateY(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 300;
  }

  .sn-scheme__dropdown.is-open {
    opacity: 1;
    pointer-events: all;
    transform: translateX(-50%) translateY(0);
  }

  .sn-scheme__option {
    display: flex;
    border: none;
    background: transparent;
    cursor: pointer;
    padding: 0;
    border-radius: 50%;
    transition: transform 0.15s;
  }

  .sn-scheme__option:hover { transform: scale(1.18); }

  .sn-scheme__option.is-active .sn-scheme__swatch {
    outline: 1.5px solid var(--_tokens---color--fg);
    outline-offset: 2px;
  }

  /* Single-color swatch — shows light bg; dark mode shows dark bg */
  .sn-scheme__swatch {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--sw-l);
    border: none;
  }

  @media (prefers-color-scheme: dark) {
    .sn-scheme__swatch {
      background: var(--sw-d);
    }
  }

  /* Mode toggle divider */
  .sn-scheme__divider {
    width: 16px;
    height: 1px;
    background: color-mix(in srgb, var(--_tokens---color--fg) 18%, transparent);
    border: none;
    margin: 4px 0;
    flex-shrink: 0;
  }

  /* Mode toggle swatch — diagonal split showing both halves of current scheme */
  .sn-mode-swatch {
    background: linear-gradient(
      135deg,
      var(--_tokens---color--fg) 50%,
      var(--_tokens---color--bg) 50%
    ) !important;
    border: none !important;
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--_tokens---color--fg) 25%, transparent) !important;
    overflow: hidden;
  }

  /* Hide name — colors only */
  .sn-scheme__name {
    display: none;
  }

  /* ── Hamburger — pinned to exact center of bar ── */
  .sn-bar__hamburger {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    gap: 5px;
    align-items: center;
    pointer-events: none;
  }

  .sn-bar__hamburger span {
    display: block;
    width: 18px;
    height: 1.5px;
    background-color: var(--_tokens---color--fg);
    transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
    transform-origin: center;
  }

  /* Animate to X when panel open */
  .sn-wrap.is-open .sn-bar__hamburger span:nth-child(1) {
    transform: translateY(3.25px) rotate(45deg);
  }

  .sn-wrap.is-open .sn-bar__hamburger span:nth-child(2) {
    transform: translateY(-3.25px) rotate(-45deg);
  }

  /* ── Vertical label (bottom): index / current page ── */
  .sn-bar__label {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
    margin-top: auto;
    pointer-events: none;
    white-space: nowrap;
    text-transform: none;
    letter-spacing: 0.04em;
    transition: color 0.3s ease;
  }

  /* "index" — small token, weight 500 distinguishes from "/ page" */
  .sn-bar__label-index {
    font-size: var(--_tokens---type--small);
    font-weight: 500;
    color: var(--_tokens---color--fg);
    vertical-align: middle;
  }

  /* "/ page" — small, regular */
  .sn-bar__label-page {
    font-size: var(--_tokens---type--small);
    font-weight: 400;
    color: var(--_tokens---color--muted);
    vertical-align: middle;
  }

  .sn-bar__category-link {
    color: inherit;
    text-decoration: none;
    pointer-events: auto;
    transition: color 0.2s ease;
  }
  .sn-bar__category-link:hover {
    color: var(--_tokens---color--fg);
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 3px;
  }

  /* Blinking "open" tag in the middle of the closed bar */
  .sn-bar__open-tag {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
    font-size: var(--_tokens---type--ultrathin);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--_tokens---color--fg);
    user-select: none;
    pointer-events: none;
    margin-top: 24px;
    margin-bottom: 24px;
    opacity: 0.85;
    position: relative;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .sn-open-tag__ghost {
    visibility: hidden; /* reserves the full text's space */
  }
  .sn-open-tag__type {
    position: absolute;
    inset: 0;
  }

  .sn-wrap.is-open .sn-bar__open-tag {
    opacity: 0.8;
    visibility: visible;
    pointer-events: none;
  }

  @keyframes sn-blink {
    0%, 100% { opacity: 0.25; }
    50% { opacity: 1; }
  }

  /* ── Lock / unlock toggle (bottom of the bar, just under the label) ── */
  .sn-lock {
    all: unset;
    margin-top: 16px;   /* gap below the index / page label */
    margin-bottom: 10px; /* nudge it up from the very bottom */
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--_tokens---color--fg);
    cursor: pointer;
    flex-shrink: 0;
    opacity: 0.65;
    transition: opacity 0.2s ease;
  }
  .sn-lock:hover,
  .sn-lock:focus-visible { opacity: 1; outline: none; }
  .sn-lock__icon { width: 100%; height: 100%; }
  .sn-lock__icon--unlocked { display: none; }
  .sn-lock[data-unlocked="true"] { opacity: 1; }
  .sn-lock[data-unlocked="true"] .sn-lock__icon--locked { display: none; }
  .sn-lock[data-unlocked="true"] .sn-lock__icon--unlocked { display: block; }

  /* ── Slide-in panel ── */
  .sn-panel {
    position: fixed;
    top: 0;
    left: 44px; /* Positioned relative to 44px sidebar */
    width: min(400px, calc(85vw - 44px));
    height: 100dvh;
    background-color: var(--_tokens---color--bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 24px;
    padding: 24px 0;
    overflow: hidden; /* the wheel scrolls internally */
    transform: translateX(-100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 200;
    pointer-events: none;
    border-right: 1px solid var(--_tokens---color--line);
  }

  .sn-panel.is-open {
    transform: translateX(0);
    pointer-events: all;
  }

  /* ── Top block: identity + nav ── */
  .sn-panel__top { flex-shrink: 0; }

  .sn-panel__header {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 0 16px;
  }

  /* Name — micro, bold */
  .sn-panel__name {
    font-size: var(--_tokens---type--micro);
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--_tokens---color--fg);
    margin: 0;
  }

  .sn-panel__spacer {
    height: 12px;
    flex-shrink: 0;
  }

  /* Bio — micro */
  .sn-panel__bio {
    font-size: var(--_tokens---type--micro);
    line-height: 1.55;
    color: var(--_tokens---color--muted);
    margin: 0;
  }

  .sn-panel__divider {
    height: 1px;
    background: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
    margin: 14px 0;
  }

  .sn-panel__footer {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .sn-panel__archive-text {
    font-size: var(--_tokens---type--micro);
    line-height: 1.55;
    color: var(--_tokens---color--muted);
    margin: 0;
  }

  .sn-panel__inline-link {
    color: var(--_tokens---color--fg);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    text-decoration-color: color-mix(in srgb, var(--_tokens---color--fg) 35%, transparent);
    transition: text-decoration-color 0.2s ease, opacity 0.2s ease;
  }

  .sn-panel__inline-link:hover {
    text-decoration-color: var(--_tokens---color--fg);
  }

  .sn-panel__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: var(--_tokens---type--medium);
    font-weight: 500;
    line-height: 1.1;
