</style>

<script>
  // ── State ──────────────────────────────────────────────────
  let navOpen = false;
  let schemeOpen = false;
  let isOpeningNav = false;

  const wrap      = document.getElementById('sn-wrap')!;
  const bar       = document.getElementById('sn-bar')!;
  const panel     = document.getElementById('sn-panel')!;
  const backdrop  = document.getElementById('sn-backdrop')!;
  const logo      = document.getElementById('sn-logo')!;
  const logoMark  = document.getElementById('sn-logo-mark')!;

  // ── Scroll Wheel Physics & Audio State ─────────────────────
  let targetScrollTop = 0;
  let isAnimating = false;
  let lastNearestIndex = -1;
  let isWrapping = false;
  let audioCtx: AudioContext | null = null;

  function initAudio() {
    if (!audioCtx) {
      audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
    }
    if (audioCtx.state === 'suspended') {
      audioCtx.resume();
    }
  }

  function playTick() {
    initAudio();
    if (!audioCtx || audioCtx.state === 'suspended') return;
    
    // Mechanical iPod click wheel tick (crisp high-pass white noise burst)
    const duration = 0.005; // 5ms burst
    const bufferSize = audioCtx.sampleRate * duration;
    const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
    const data = buffer.getChannelData(0);
    for (let i = 0; i < bufferSize; i++) {
      data[i] = Math.random() * 2 - 1;
    }
    
    const noise = audioCtx.createBufferSource();
    noise.buffer = buffer;
    
    const filter = audioCtx.createBiquadFilter();
    filter.type = 'bandpass';
    filter.frequency.value = 1800; // crisp high pitch
    filter.Q.value = 4.0;
    
    const gain = audioCtx.createGain();
    gain.gain.setValueAtTime(0.06, audioCtx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + duration - 0.001);
    
    noise.connect(filter);
    filter.connect(gain);
    gain.connect(audioCtx.destination);
    
    noise.start();
    noise.stop(audioCtx.currentTime + duration);
  }

  // ── Logo spin driven by scroll velocity ────────────────────
  // Spins rapidly while the page is scrolling, then decelerates rapidly once it stops.
  let logoAngle = 0;
  let logoAngVel = 0;
  let lastScrollY = window.pageYOffset || document.documentElement.scrollTop || 0;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion) {
    window.addEventListener('scroll', () => {
      const y = window.pageYOffset || document.documentElement.scrollTop || 0;
      const delta = y - lastScrollY;
      lastScrollY = y;
      // Each pixel of scroll feeds angular velocity; clamp so it stays tasteful
      logoAngVel += delta * 0.5;
      logoAngVel = Math.max(-45, Math.min(45, logoAngVel));
    }, { passive: true });

    const spinLogo = () => {
      logoAngle += logoAngVel;
      logoAngVel *= 0.80; // rapid deceleration when scrolling stops
      if (Math.abs(logoAngVel) < 0.01) logoAngVel = 0;
      if (logoMark) {
        logoMark.style.transform = `rotate(${logoAngle}deg)`;
      }
      requestAnimationFrame(spinLogo);
    };
    requestAnimationFrame(spinLogo);
  }
  const schemeEl  = document.getElementById('sn-scheme')!;
  const schemeBtn = document.getElementById('sn-scheme-btn')!;
  const dropdown  = document.getElementById('sn-scheme-dropdown')!;

  function scrollWheelToActive() {
    requestAnimationFrame(() => {
      const wheel      = document.getElementById('sn-wheel') as HTMLElement | null;
      const wheelTrack = document.getElementById('sn-wheel-track') as HTMLElement | null;
      if (!wheel || !wheelTrack) return;

      // Find the active item in the MIDDLE copy so infinite wrap has room above and below
      const allItems = Array.from(wheelTrack.querySelectorAll<HTMLElement>('.sn-wheel__item'));
      const perCopy  = Math.round(allItems.length / 3);
      const middle   = allItems.slice(perCopy, perCopy * 2);
      const target   = middle.find(el => el.classList.contains('is-active')) ?? middle[0];

      // getBoundingClientRect avoids the position:fixed offsetParent problem.
      // itemTopInWheel = item's current y position within the wheel's visible area.
      // Adding scrollTop converts it to an absolute position in the scroll container.
      const itemRect       = target.getBoundingClientRect();
      const wheelRect      = wheel.getBoundingClientRect();
      const itemAbsTop     = itemRect.top - wheelRect.top + wheel.scrollTop;
      const scroll         = Math.max(0, itemAbsTop - (wheel.clientHeight - itemRect.height) / 2);

      wheel.scrollTop  = scroll;
      targetScrollTop  = scroll;
      lastNearestIndex = -1;
    });
  }

  // ── Scramble Text effect for the Open/Close label ───────────
  function scrambleText(element: HTMLElement, targetText: string) {
    const GLYPHS = '01XYZ%$#@?*+=#-_[]{}<>/';
    const originalText = targetText;
    let frame = 0;
    const queue: Array<{ from: string; to: string; start: number; end: number; char?: string }> = [];
    const currentText = element.textContent || '';
    const length = Math.max(originalText.length, currentText.length);
    
    for (let i = 0; i < length; i++) {
      const from = currentText[i] || '';
      const to = originalText[i] || '';
      const start = Math.floor(Math.random() * 6);
      const end = start + Math.floor(Math.random() * 8) + 3;
      queue.push({ from, to, start, end });
    }

    cancelAnimationFrame((element as any)._scrambleFrameId);

    function tick() {
      let output = '';
      let complete = 0;

      for (let i = 0; i < queue.length; i++) {
        let { from, to, start, end, char } = queue[i];
        if (frame >= end) {
          complete++;
          output += to;
        } else if (frame >= start) {
          if (!char || Math.random() < 0.28) {
            char = GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
            queue[i].char = char;
          }
          output += char;
        } else {
          output += from;
        }
      }

      element.textContent = output;

      if (complete === queue.length) {
        element.textContent = originalText;
      } else {
        frame++;
        (element as any)._scrambleFrameId = requestAnimationFrame(tick);
      }
    }

    tick();
  }

  // ── Nav toggle ─────────────────────────────────────────────
  function openNav() {
    initAudio(); // Initialize audio context on user interaction
    isOpeningNav = true;
    navOpen = true;
    wrap.classList.add('is-open');
    bar.setAttribute('aria-expanded', 'true');
    panel.classList.add('is-open');
    panel.setAttribute('aria-hidden', 'false');
    backdrop.classList.add('is-open');
    
    const openTag = document.getElementById('sn-open-tag');
    if (openTag) scrambleText(openTag, 'tap to close');

    scrollWheelToActive();
    
    // Tell watermark physics where the panel's right edge will land (paddle target)
    (window as any).__navPanelTarget = 44 + panel.offsetWidth;

    setTimeout(() => {
      isOpeningNav = false;
    }, 450);
  }

  function closeNav() {
    navOpen = false;
    wrap.classList.remove('is-open');
    bar.setAttribute('aria-expanded', 'false');
    panel.classList.remove('is-open');
    panel.setAttribute('aria-hidden', 'true');
    backdrop.classList.remove('is-open');

    const openTag = document.getElementById('sn-open-tag');
    if (openTag) scrambleText(openTag, 'tap to open');

    // Retract paddle back to the bare nav bar
    (window as any).__navPanelTarget = 44;
  }

  bar.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('#sn-logo')) return;
    if ((e.target as HTMLElement).closest('#sn-scheme')) return;
    if ((e.target as HTMLElement).closest('.sn-bar__category-link')) return;
    navOpen ? closeNav() : openNav();
  });

  bar.addEventListener('keydown', (e) => {
    // Enter toggles here; Space is handled once by the global listener below
    // (handling it in both places double-toggles and cancels out).
    if (e.key === 'Enter') { e.preventDefault(); navOpen ? closeNav() : openNav(); }
    if (e.key === 'Escape') closeNav();
  });

  logo.addEventListener('click', (e) => e.stopPropagation());
  backdrop.addEventListener('click', closeNav);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { closeNav(); closeScheme(); }
  });

  // Global spacebar listener to toggle side navigation index bar
  if (!(window as any).hasSideNavSpacebarInit) {
    (window as any).hasSideNavSpacebarInit = true;
    window.addEventListener('keydown', (e) => {
      const active = document.activeElement as HTMLElement | null;
      if (active && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA' || active.isContentEditable)) {
        return;
      }

      // Do not toggle SideNav if any lightbox is open
      const detailLightbox1 = document.getElementById('project-active-lightbox');
      const detailLightbox2 = document.getElementById('card-lightbox');
      const scarpinLightbox = document.getElementById('scarpin-lightbox');
      const listLightbox = document.getElementById('project-lightbox');
      const isAnyLightboxOpen = 
        (detailLightbox1 && detailLightbox1.style.display !== 'none') ||
        (detailLightbox2 && detailLightbox2.style.display !== 'none') ||
        (scarpinLightbox && scarpinLightbox.style.display !== 'none') ||
        (listLightbox && listLightbox.classList.contains('is-open'));
      if (isAnyLightboxOpen) return;

      if (e.key === ' ' || e.code === 'Space') {
        e.preventDefault();
        navOpen ? closeNav() : openNav();
      }
    });
  }

  // ── Scheme dropdown ────────────────────────────────────────
  const SCHEMES = ['default','sch1','sch2','sch3','sch4','sch6','sch7'];

  function getCurrentScheme(): string {
    const match = document.documentElement.className.match(/sch\d+/);
    return match ? match[0] : 'default';
  }

  function applyScheme(id: string) {
    // Remove all sch classes, add new one
    document.documentElement.classList.remove(...SCHEMES.filter(s => s !== 'default'));
    if (id !== 'default') document.documentElement.classList.add(id);
    // Store id directly — 'default' is stored as the string 'default' (not empty string)
    sessionStorage.setItem('aks', id);
    updateActiveOption();
    closeScheme();
  }

  function updateActiveOption() {
    const current = getCurrentScheme();
    dropdown.querySelectorAll<HTMLElement>('.sn-scheme__option').forEach(btn => {
      btn.classList.toggle('is-active', btn.dataset.scheme === current);
    });
  }

  function openScheme() {
    schemeOpen = true;
    schemeBtn.setAttribute('aria-expanded', 'true');
    dropdown.classList.add('is-open');
    updateActiveOption();
  }

  function closeScheme() {
    schemeOpen = false;
    schemeBtn.setAttribute('aria-expanded', 'false');
    dropdown.classList.remove('is-open');
  }

  schemeBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    schemeOpen ? closeScheme() : openScheme();
  });

  schemeEl.addEventListener('click', (e) => e.stopPropagation());

  dropdown.querySelectorAll<HTMLElement>('.sn-scheme__option').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const id = btn.dataset.scheme ?? 'default';
      applyScheme(id);
    });
  });

  // Close scheme if clicking outside
  document.addEventListener('click', (e) => {
    if (schemeOpen && !schemeEl.contains(e.target as Node)) closeScheme();
  });

  // Scheme already applied by the <head> inline script — just sync the active highlight
  updateActiveOption();


  // ── Dark / light mode toggle ──────────────────────────────
  const modeBtn = document.getElementById('sn-mode-btn');

  function getEffectiveDark(): boolean {
    if (document.documentElement.classList.contains('mode-dark')) return true;
    if (document.documentElement.classList.contains('mode-light')) return false;
    return window.matchMedia('(prefers-color-scheme: dark)').matches;
  }

  modeBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isDark = getEffectiveDark();
    document.documentElement.classList.remove('mode-dark', 'mode-light');
    if (isDark) {
      // Force light
      document.documentElement.classList.add('mode-light');
      sessionStorage.setItem('aks-mode', 'light');
    } else {
      // Force dark
      document.documentElement.classList.add('mode-dark');
      sessionStorage.setItem('aks-mode', 'dark');
    }
    closeScheme();
  });

  // ── "tap to open" glitch typewriter — loops to draw the eye ─────────
  (function initOpenTagTyper() {
    const el = document.getElementById('sn-open-type');
    if (!el || (el as any)._wired) return;
    (el as any)._wired = true;
    const TEXT = 'tap to open';
    const G = '!<>-_/[]{}=+*#';
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.textContent = TEXT;
      return;
    }
    let pos = 0;
    function typeStep() {
      if (pos <= TEXT.length) {
        const head = pos < TEXT.length ? G[(Math.random() * G.length) | 0] : '';
        el.textContent = TEXT.slice(0, pos) + head;
        pos++;
        setTimeout(typeStep, 80 + Math.random() * 60);
      } else {
        // settled — after a beat, a short glitch burst, then wipe and loop
        setTimeout(() => {
          let burst = 0;
          const bi = setInterval(() => {
            const idx = (Math.random() * TEXT.length) | 0;
            el.textContent = TEXT.slice(0, idx) + G[(Math.random() * G.length) | 0] + TEXT.slice(idx + 1);
            if (++burst > 5) {
              clearInterval(bi);
              el.textContent = TEXT;
              setTimeout(() => { pos = 0; el.textContent = ''; setTimeout(typeStep, 500); }, 1400);
            }
          }, 90);
        }, 1800);
      }
    }
    typeStep();
  })();

  // ── Infinite project wheel (Custom Physics, Snapping, Sound) ─────────
  const wheel = document.getElementById('sn-wheel') as HTMLElement | null;
  const wheelTrack = document.getElementById('sn-wheel-track') as HTMLElement | null;

  if (wheel && wheelTrack) {
    // The HTML ships ONE copy of the list (lighter pages); the seamless
    // loop needs three, so clone the other two here before any measuring.
    if (wheelTrack.dataset.copies === '1') {
      const originals = Array.from(wheelTrack.children);
      for (let c = 0; c < 2; c++) {
        originals.forEach(item => wheelTrack.appendChild(item.cloneNode(true)));
      }
      wheelTrack.dataset.copies = '3';
    }

    const oneCopyHeight = () => wheelTrack.scrollHeight / 3;
    scrollWheelToActive();

    function handleInfiniteWrap() {
      const h = oneCopyHeight();
      if (h <= 0) return;
      if (wheel.scrollTop < h * 0.5) {
        isWrapping = true;
        wheel.scrollTop += h;
        targetScrollTop += h;
        requestAnimationFrame(() => { isWrapping = false; });
      } else if (wheel.scrollTop > h * 1.5) {
        isWrapping = true;
        wheel.scrollTop -= h;
        targetScrollTop -= h;
        requestAnimationFrame(() => { isWrapping = false; });
      }
    }

    function updateTicks() {
      if (!wheel || !wheelTrack) return;
      const containerCenter = wheel.scrollTop + wheel.clientHeight / 2;
      const items = Array.from(wheelTrack.querySelectorAll('.sn-wheel__item')) as HTMLElement[];
      if (items.length === 0) return;
      
      let nearestIndex = -1;
      let minDiff = Infinity;
      
      items.forEach((item, idx) => {
        const itemCenter = item.offsetTop + item.offsetHeight / 2;
        const diff = Math.abs(itemCenter - containerCenter);
        if (diff < minDiff) {
          minDiff = diff;
          nearestIndex = idx;
        }
      });
      
      if (nearestIndex !== -1 && nearestIndex !== lastNearestIndex) {
        const indexDiff = Math.abs(nearestIndex - lastNearestIndex);
        if (lastNearestIndex !== -1 && !isWrapping && !isOpeningNav && indexDiff < 3) {
          playTick();
        }
        lastNearestIndex = nearestIndex;
      }
    }

    // Intercept mouse wheel events for custom inertia and resistance
    wheel.addEventListener('wheel', (e) => {
      e.preventDefault(); // Hijack default scroll
      initAudio();
      
      // Scale scroll delta to create resistance (friction)
      const resistanceFactor = 0.4;
      targetScrollTop += e.deltaY * resistanceFactor;
      
      // Clamp target scroll
      const maxScroll = wheel.scrollHeight - wheel.clientHeight;
      targetScrollTop = Math.max(0, Math.min(maxScroll, targetScrollTop));
      
      if (!isAnimating) {
        isAnimating = true;
        wheel.style.scrollSnapType = 'none'; // disable native snap during custom animation
        animateScroll();
      }
    }, { passive: false });

    function animateScroll() {
      if (!wheel) return;
      const diff = targetScrollTop - wheel.scrollTop;
      
      if (Math.abs(diff) > 0.4) {
        wheel.scrollTop += diff * 0.14; // smooth inertia easing
        updateTicks();
        requestAnimationFrame(animateScroll);
      } else {
        wheel.scrollTop = targetScrollTop;
        isAnimating = false;
        handleInfiniteWrap();
        snapToNearest();
      }
    }

    function snapToNearest() {
      if (!wheel || !wheelTrack) return;
      const containerCenter = wheel.scrollTop + wheel.clientHeight / 2;
      const items = Array.from(wheelTrack.querySelectorAll('.sn-wheel__item')) as HTMLElement[];
      if (items.length === 0) return;
      
      let closestItem: HTMLElement | null = null;
      let minDiff = Infinity;
      
      items.forEach(item => {
        const itemCenter = item.offsetTop + item.offsetHeight / 2;
        const diff = Math.abs(itemCenter - containerCenter);
        if (diff < minDiff) {
          minDiff = diff;
          closestItem = item;
        }
      });
      
      if (closestItem) {
        const targetY = closestItem.offsetTop - (wheel.clientHeight / 2) + (closestItem.offsetHeight / 2);
        targetScrollTop = targetY;
        
        if (!isAnimating) {
          isAnimating = true;
          wheel.style.scrollSnapType = 'none';
          animateScrollSnap();
        }
      }
    }

    function animateScrollSnap() {
      if (!wheel) return;
      const diff = targetScrollTop - wheel.scrollTop;
      if (Math.abs(diff) > 0.4) {
        wheel.scrollTop += diff * 0.16;
        updateTicks();
        requestAnimationFrame(animateScrollSnap);
      } else {
        wheel.scrollTop = targetScrollTop;
        isAnimating = false;
        wheel.style.scrollSnapType = 'y mandatory';
        handleInfiniteWrap();
      }
    }

    // Scroll listener for touch scroll and scrollbar interaction
    wheel.addEventListener('scroll', () => {
      if (!isAnimating) {
        targetScrollTop = wheel.scrollTop;
        handleInfiniteWrap();
        updateTicks();
      }
    }, { passive: true });
  }

  // ── Copy email to clipboard ────────────────────────────────
  const emailBox = document.getElementById('sn-email-box');
  emailBox?.addEventListener('click', async () => {
    try { await navigator.clipboard.writeText('advaitakelkar@gmail.com'); } catch (_) {}
    emailBox.classList.add('is-copied');
    setTimeout(() => emailBox.classList.remove('is-copied'), 1500);
  });
  emailBox?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); (emailBox as HTMLElement).click(); }
  });

  // ── Randomize Social link pills ────────────────────────────
  function initSocialPills() {
    const nav = document.querySelector('.sn-panel__social');
    if (!nav) return;
    const pills = Array.from(nav.querySelectorAll('.sn-panel__social-pill'));
    if (!pills.length) return;
    
    // Fisher-Yates shuffle
    for (let i = pills.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [pills[i], pills[j]] = [pills[j], pills[i]];
    }
    
    // Re-append in random order
    pills.forEach(pill => nav.appendChild(pill));
  }

  initSocialPills();
  document.addEventListener('astro:after-swap', initSocialPills);
</script>
