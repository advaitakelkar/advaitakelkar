---
import { getCollection } from 'astro:content';

export interface Props {
  isEmbedded?: boolean;
}

const { isEmbedded = false } = Astro.props;

// Fetch projects, categories, and tags
const allProjects = await getCollection('projects');
const allTags     = await getCollection('tags');
const allCats     = await getCollection('categories');

// Lookup maps
const tagMap = Object.fromEntries(allTags.map(t => [t.id, t.data.name]));
const catMap = Object.fromEntries(allCats.map(c => [c.id, c.data.displayName]));

// Sort projects
const sorted = [...allProjects].sort((a, b) => {
  if (a.data.numbr && b.data.numbr) return a.data.numbr - b.data.numbr;
  if (a.data.numbr) return -1;
  if (b.data.numbr) return 1;
  return parseInt(b.data.year ?? '0') - parseInt(a.data.year ?? '0');
});
---

<footer class:list={["home-search-footer", isEmbedded && "home-search-footer--embedded"]} id="home-search-footer">
  <div class="home-search__header">
    <h2 class="home-search__title">Projects Quick Search</h2>
  </div>
  <div class="home-search__bar">
    <input
      type="search"
      id="qs-input"
      class="home-search__input"
      placeholder="Search projects by name or tag..."
      autocomplete="off"
      aria-label="Search projects"
    />
    <button class="home-search__clear" id="qs-clear" type="button">@Clear All</button>
  </div>
  <p class="home-search__count" id="qs-count" aria-live="polite"></p>
  
  <!-- Pill/bubble search — multi-row paragraph; each row slides left on hover -->
  <div class="proj-bubbles" id="qs-grid" role="list" style="margin-top: 28px; border-top: none; padding-top: 0;">
    {sorted.map(p => {
      const tagsArr = (p.data.tags ?? []).map(t => tagMap[t.id] || t.id);
      return (
        <a
          href={`/projects/${p.id}`}
          class="proj-bubble"
          data-name={p.data.name}
          data-tags={tagsArr.join(',')}
          data-cat={p.data.category ? (catMap[p.data.category.id] || p.data.category.id) : ''}
          data-year={p.data.year ?? ''}
          data-loc={p.data.location ?? ''}
          data-client={p.data.client ?? ''}
          data-status={p.data.status ?? ''}
          data-program={p.data.program ?? ''}
        >
          <span class="proj-bubble__name">{p.data.name}</span>
          <span class="proj-bubble__tag">{tagsArr[0] || (p.data.category ? catMap[p.data.category.id] : 'Design')}</span>
          <svg class="link-arrow proj-bubble__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <line x1="6" y1="18" x2="18" y2="6"></line>
            <polyline points="10 6 18 6 18 14"></polyline>
          </svg>
        </a>
      );
    })}
    
    <!-- Admin CMS Quick Links (also filterable via Quick Search) -->
    <a
      href="/keystatic/singleton/home"
      class="proj-bubble admin-bubble"
      data-name="Home Admin"
      data-tags="admin,cms,homepage,keystatic"
      data-cat="Admin"
      data-year=""
      data-loc=""
      data-client=""
      data-status=""
      data-program=""
    >
      <span class="proj-bubble__name">Home Admin</span>
      <span class="proj-bubble__tag">Admin</span>
      <svg class="link-arrow proj-bubble__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
        <line x1="6" y1="18" x2="18" y2="6"></line>
        <polyline points="10 6 18 6 18 14"></polyline>
      </svg>
    </a>
    <a
      href="/keystatic/singleton/about"
      class="proj-bubble admin-bubble"
      data-name="About Admin"
      data-tags="admin,cms,about,me,keystatic"
      data-cat="Admin"
      data-year=""
      data-loc=""
      data-client=""
      data-status=""
      data-program=""
    >
      <span class="proj-bubble__name">About Admin</span>
      <span class="proj-bubble__tag">Admin</span>
      <svg class="link-arrow proj-bubble__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
        <line x1="6" y1="18" x2="18" y2="6"></line>
        <polyline points="10 6 18 6 18 14"></polyline>
      </svg>
    </a>
    <a
      href="/keystatic/collection/projects"
      class="proj-bubble admin-bubble"
      data-name="Projects Admin"
      data-tags="admin,cms,projects,keystatic"
      data-cat="Admin"
      data-year=""
      data-loc=""
      data-client=""
      data-status=""
      data-program=""
    >
      <span class="proj-bubble__name">Projects Admin</span>
      <span class="proj-bubble__tag">Admin</span>
      <svg class="link-arrow proj-bubble__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
        <line x1="6" y1="18" x2="18" y2="6"></line>
        <polyline points="10 6 18 6 18 14"></polyline>
      </svg>
    </a>
  </div>
</footer>

<style>
  .home-search-footer {
    width: 100%;
    border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    padding-top: 32px;
    padding-bottom: 24px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
  }

  /* standalone (non-embedded) padding to match standard page margins */
  .home-search-footer:not(.home-search-footer--embedded) {
    padding-inline: var(--_tokens---space--small);
    margin-top: clamp(3rem, 6vh, 5rem);
  }

  @media (min-width: 1200px) {
    .home-search-footer:not(.home-search-footer--embedded) {
      padding-inline: clamp(6rem, 12vw, 16rem);
    }
  }

  @media (max-width: 767px) and (orientation: portrait) {
    .home-search-footer:not(.home-search-footer--embedded) {
      padding-bottom: 80px; /* space for mobile bottom docked breadcrumbs */
    }
  }

  .home-search-footer--embedded {
    margin-top: auto; /* push to the bottom when placed in a flex layout */
  }

  .home-search__header {
    margin-bottom: 16px;
  }

  .home-search__title {
    font-size: var(--_tokens---type--small);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--_tokens---color--fg);
    margin: 0;
  }

  .home-search__bar {
    display: flex;
    gap: 10px;
    margin-bottom: 14px;
  }

  .home-search__input {
    flex: 1;
    height: 42px;
    padding: 0 20px;
    font-size: var(--_tokens---type--micro);
    font-family: inherit;
    background: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    color: var(--_tokens---color--fg);
    border-radius: 999px;
    outline: none;
    opacity: 0.35; /* grayed out by default */
    transition: background-color 0.2s, opacity 0.3s ease;
  }

  .home-search__input::placeholder { color: var(--_tokens---color--muted); }
  .home-search__input:focus,
  .home-search__input:not(:placeholder-shown),
  .home-search__input.is-active {
    opacity: 1; /* activated on focus / input */
  }

  .home-search__clear {
    height: 42px;
    padding: 0 18px;
    font-size: var(--_tokens---type--micro);
    font-family: inherit;
    font-weight: 400;
    letter-spacing: 0.04em;
    background: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    color: var(--_tokens---color--fg);
    border-radius: 999px;
    cursor: pointer;
    white-space: nowrap;
    opacity: 0.35; /* grayed out by default */
    transition: background-color 0.2s, color 0.2s, opacity 0.3s ease;
  }

  .home-search__input:focus ~ .home-search__clear,
  .home-search__input:not(:placeholder-shown) ~ .home-search__clear,
  .home-search__clear:hover {
    opacity: 1; /* activated on search/hover */
  }

  .home-search__clear:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  .home-search__count {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    color: var(--_tokens---color--muted);
    letter-spacing: 0.04em;
    margin-bottom: 24px;
  }

  /* ── Pill/bubble search — multi-row paragraph; rows shift (looping) on hover/search ── */
  .proj-bubbles {
    display: flex;
    flex-direction: column;
    flex-wrap: nowrap;
    gap: 7px;
    --qs-shift: 0px;            /* shared shift; all rows move together */
    /* soft fade at both horizontal ends */
    -webkit-mask-image: linear-gradient(to right, transparent 0%, #000 2.5%, #000 97.5%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, #000 2.5%, #000 97.5%, transparent 100%);
  }

  /* Each visual row clips its overflow; never wraps */
  .qs-row {
    overflow: hidden;
    width: 100%;
  }

  /* The moving track inside a row (holds the row's pills duplicated for a seamless loop) */
  .qs-row__track {
    display: flex;
    flex-wrap: nowrap;
    width: max-content;
    gap: 7px;
    transform: translateX(var(--qs-shift));
    transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .qs-row__track { transition: none; }
  }

  .proj-bubble {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    text-decoration: none;
    white-space: nowrap;
    color: var(--_tokens---color--muted);
    transition: background-color 0.2s, color 0.2s, border-color 0.2s, transform 0.15s, opacity 0.2s;
  }

  .proj-bubble__name {
    font-size: var(--_tokens---type--micro);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: inherit;
  }

  /* Tag is collapsed at rest (pill shows only name + arrow);
     it grows open on hover or when a search matches the tag. */
  .proj-bubble__tag {
    font-family: var(--_tokens---font--mono);
    line-height: 1;
    font-size: 0.6rem;
    color: inherit;
    opacity: 0;
    letter-spacing: 0.04em;
    max-width: 0;
    margin-left: -7px; /* cancel the inter-item gap while collapsed */
    overflow: hidden;
    white-space: nowrap;
    transition: max-width 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.28s ease,
                margin-left 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Reveal (grow) the tag on hover or on a tag-search match */
  .proj-bubble:hover .proj-bubble__tag,
  .proj-bubble.is-tag-reveal .proj-bubble__tag {
    max-width: 160px;
    opacity: 0.6;
    margin-left: 0;
  }

  .proj-bubble__arrow {
    width: 0.8em;
    height: 0.8em;
    flex-shrink: 0;
    opacity: 0.55;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  /* Hover state: switches to full contrast (bg is fg, text/arrow is bg) and vertical translate -1px */
  .proj-bubble:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    border-color: var(--_tokens---color--fg);
    transform: translateY(-1px);
  }

  .proj-bubble:hover .proj-bubble__arrow {
    opacity: 1;
  }

  /* Matching state: switches to full contrast during active search */
  .proj-bubble.is-match {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    border-color: var(--_tokens---color--fg);
  }

  .proj-bubble.is-match:hover {
    transform: translateY(-1px);
  }

  /* Active search state: dim non-matching bubbles */
  .proj-bubbles.has-search .proj-bubble:not(.is-match) {
    opacity: 0.2;
  }

  .proj-bubbles.has-search .proj-bubble:not(.is-match):hover {
    opacity: 1;
  }

  /* ── Admin Bubbles ── */
  .admin-bubble {
    border-color: color-mix(in srgb, var(--_tokens---color--fg) 14%, transparent);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
  }
</style>

<script>
  function initQuickSearch() {
    const footer = document.querySelector('.home-search-footer');
    if (!footer) return;
    const grid     = footer.querySelector('#qs-grid') as HTMLElement | null;
    const input    = footer.querySelector('#qs-input') as HTMLInputElement | null;
    const clearBtn = footer.querySelector('#qs-clear');
    const count    = footer.querySelector('#qs-count');
    if (!grid || grid.dataset.qsInit) return;  // guard against double-init on the same DOM
    grid.dataset.qsInit = '1';
    const g = grid;

    // Shuffle the original pills once
    const originals = Array.from(g.querySelectorAll('.proj-bubble')) as HTMLElement[];
    for (let i = originals.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      const t = originals[i]; originals[i] = originals[j]; originals[j] = t;
    }
    const total = originals.length;

    const setShift = (px: number) => g.style.setProperty('--qs-shift', px + 'px');
    const curShift = () => parseFloat(getComputedStyle(g).getPropertyValue('--qs-shift')) || 0;

    // Group the pills into visual rows (by wrap position), then make each row a
    // clipped, horizontally-shiftable track with a duplicate copy for seamless looping.
    function buildRows() {
      setShift(0);
      g.querySelectorAll('.qs-row').forEach(r => r.remove());
      originals.forEach(p => g.appendChild(p));        // flatten
      g.style.flexDirection = 'row';                   // measure natural wrapping
      g.style.flexWrap = 'wrap';
      const groups: HTMLElement[][] = [];
      let cur: HTMLElement[] = []; let last: number | null = null;
      originals.forEach(p => {
        const t = p.offsetTop;
        if (last === null || Math.abs(t - last) <= 6) cur.push(p);
        else { groups.push(cur); cur = [p]; }
        last = t;
      });
      if (cur.length) groups.push(cur);
      g.style.flexDirection = ''; g.style.flexWrap = ''; // back to column of rows
      groups.forEach(grp => {
        const row = document.createElement('div'); row.className = 'qs-row';
        const track = document.createElement('div'); track.className = 'qs-row__track';
        grp.forEach(p => track.appendChild(p));
        row.appendChild(track); g.appendChild(row);
      });
    }

    // Shift every row together just enough to keep a pill (once grown) fully visible
    function shiftToShow(pill: HTMLElement) {
      const gr = g.getBoundingClientRect();
      const margin = 14;
      const tag = pill.querySelector('.proj-bubble__tag') as HTMLElement | null;
      const grow = tag ? tag.scrollWidth + 8 : 0; // width the tag will add when revealed
      const pr = pill.getBoundingClientRect();
      const overflowR = (pr.right + grow) - (gr.right - margin);
      if (overflowR > 0) { setShift(curShift() - overflowR); return; }
      if (pr.left < gr.left + margin) setShift(Math.min(0, curShift() + ((gr.left + margin) - pr.left)));
    }

    function render(query: string) {
      const q = query.trim().toLowerCase();
      const keywords = q.split(/\s+/).filter(Boolean);
      g.classList.toggle('has-search', keywords.length > 0);
      const matched = new Set<string>();
      let firstMatch: HTMLElement | null = null;
      Array.from(g.querySelectorAll('.proj-bubble')).forEach(el0 => {
        const el = el0 as HTMLElement;
        if (!keywords.length) { el.classList.remove('is-match'); el.classList.remove('is-tag-reveal'); return; }
        const hay = [
          el.dataset.name, el.dataset.tags, el.dataset.cat, el.dataset.year,
          el.dataset.loc, el.dataset.client, el.dataset.status, el.dataset.program
        ].join(' ').toLowerCase();
        const isMatch = keywords.every(kw => hay.includes(kw));
        el.classList.toggle('is-match', isMatch);
        if (isMatch) { if (el.dataset.name) matched.add(el.dataset.name); if (!firstMatch) firstMatch = el; }
        const tagText = (el.querySelector('.proj-bubble__tag')?.textContent || '').toLowerCase();
        el.classList.toggle('is-tag-reveal', isMatch && keywords.some(kw => kw.length >= 3 && tagText.includes(kw)));
      });
      if (count) {
        count.textContent = q
          ? `Results ${total}   Showing Items 1 to ${matched.size} of ${total}`
          : `Results ${total}   Showing all items`;
      }
      if (keywords.length && firstMatch) shiftToShow(firstMatch); else setShift(0);
    }

    buildRows();
    render('');

    // Hover → shift the paragraph so the hovered pill grows in view (delegated, so it
    // survives row rebuilds and never double-binds)
    let lastPill: HTMLElement | null = null;
    g.addEventListener('mouseover', (e) => {
      const pill = (e.target as HTMLElement).closest('.proj-bubble') as HTMLElement | null;
      if (pill && pill !== lastPill) { lastPill = pill; shiftToShow(pill); }
    });
    g.addEventListener('mouseleave', () => {
      lastPill = null;
      if (!input || !input.value.trim()) setShift(0);
    });

    input?.addEventListener('input', () => {
      render(input.value);
      input.classList.toggle('is-active', !!input.value.trim());
    });

    clearBtn?.addEventListener('click', () => {
      if (input) { input.value = ''; input.classList.remove('is-active'); render(''); input.focus(); }
    });

    let rt: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(() => { buildRows(); render(input?.value || ''); }, 200);
    });
  }

  // Setup on page load
  initQuickSearch();

  // Support Astro View Transitions
  document.addEventListener('astro:after-swap', initQuickSearch);
</script>
