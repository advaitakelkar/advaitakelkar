---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

export interface Props {
  projects: any[];
  title: string;
  crumbs?: { label: string; href?: string }[];
}

const { projects, title, crumbs } = Astro.props;

const allTags = await getCollection('tags');
const allCats = await getCollection('categories');

// Sort by number then year
const sorted = [...projects].sort((a, b) => {
  if (a.data.numbr && b.data.numbr) return a.data.numbr - b.data.numbr;
  if (a.data.numbr) return -1;
  if (b.data.numbr) return 1;
  return parseInt(b.data.year ?? '0') - parseInt(a.data.year ?? '0');
});

const tagMap = Object.fromEntries(allTags.map(t => [t.id, t.data.name]));
const catMap = Object.fromEntries(allCats.map(c => [c.id, c.data.displayName]));

// Abbreviate project names for footer bubbles (same logic as Footer.astro)
function abbrevName(name: string): string {
  return name.trim().split(/\s+/).filter(w => w.length > 0).map(w => w.length <= 3 ? w : w.slice(0, 3)).join(' ');
}

// Count projects per tag to find top 4
const tagCounts: Record<string, number> = {};
projects.forEach(p => {
  (p.data.tags ?? []).forEach(t => {
    tagCounts[t.id] = (tagCounts[t.id] || 0) + 1;
  });
});
const sortedTags = [...allTags].sort((a, b) => (tagCounts[b.id] || 0) - (tagCounts[a.id] || 0));
---

<PageLayout
  title={title}
  label={title}
  crumbs={crumbs || [
    { label: 'Home', href: '/' },
    { label: title }
  ]}
  showFooter={false}
>
  <section class="projects-page">
    <!-- Top Section: Header, search, filters, and cards -->
    <div class="projects-top-section">
      <div class="projects-sticky-header">
      <header class="projects-header">
        <h1 class="projects-title">{title}</h1>
        <p class="projects-count text-muted">{projects.length} of {projects.length} works</p>
      </header>

      <!-- Search bar matching home UI -->
      <div class="projects-search-bar">
        <input
          type="search"
          id="projects-search-input"
          class="projects-search-input"
          placeholder="Search projects by name, tag, location, client, status, year..."
          autocomplete="off"
          aria-label="Search projects"
        />
        <button class="projects-search-clear" id="projects-search-clear" type="button">Clear All</button>
      </div>

      <!-- Filter bar with dropdown and scrollable tag picker -->
      <div class="filter-bar">
        <div class="filter-group">
          <span class="filter-label text-muted">Category</span>
          <div class="filter-select-wrap">
            <select id="cat-select" class="filter-select">
              <option value="">All Categories</option>
              {allCats.map(cat => (
                <option value={cat.id}>{cat.data.displayName}</option>
              ))}
            </select>
            <svg class="filter-select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </div>
        </div>
        
        <div class="filter-group filter-group--tags">
          <div class="tag-picker-wrapper">
            <button class="tag-picker-item is-active" data-filter="" id="all-tag-btn" type="button">All</button>
            <span class="tag-picker-divider">|</span>
            <div class="tag-scroll-nav">
              <button class="tag-scroll-arrow tag-scroll-arrow--left" id="tag-scroll-left" aria-label="Scroll tags left" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                  <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
              </button>
              <div class="tag-picker-container" id="tag-picker-container">
                <div class="tag-picker" id="tag-picker">
                  {sortedTags.map(tag => (
                    <button class="tag-picker-item" data-filter={tag.id} type="button">
                      {tag.data.name}
                    </button>
                  ))}
                </div>
              </div>
              <button class="tag-scroll-arrow tag-scroll-arrow--right" id="tag-scroll-right" aria-label="Scroll tags right" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>


    <!-- Project list — accordion cards -->
    <div class="project-cards-container" id="project-cards-container">
      {sorted.map((p, i) => {
        const tagsArr = (p.data.tags ?? []).map(t => tagMap[t.id] || t.id);
        const tagLine = tagsArr.join(', ');
        const firstTag = tagsArr[0] || (p.data.category ? catMap[p.data.category.id] : '');
        const metaParts = [
          { label: 'Location', val: p.data.location },
          { label: 'Client',   val: p.data.client },
          { label: 'Status',   val: p.data.status },
          { label: 'Program',  val: p.data.program },
        ].filter(m => m.val);
        // Take first 5 images only, no padding
        const rawImgs: string[] = [];
        if (p.data.coverImage) rawImgs.push(p.data.coverImage);
        if (p.data.multiImage) rawImgs.push(...(p.data.multiImage as string[]));
        const allImgs: string[] = rawImgs.slice(0, 5);
        return (
        <div
          class="project-card"
          data-name={p.data.name}
          data-loc={p.data.location ?? ''}
          data-year={p.data.year ?? ''}
          data-client={p.data.client ?? ''}
          data-status={p.data.status ?? ''}
          data-size={p.data.size ?? ''}
          data-program={p.data.program ?? ''}
          data-cat={p.data.category ? (catMap[p.data.category.id] || p.data.category.id) : ''}
          data-cat-id={p.data.category ? p.data.category.id : ''}
          data-tags={(p.data.tags ?? []).map(t => tagMap[t.id] || t.id).join(',')}
          data-tag-ids={(p.data.tags ?? []).map(t => t.id).join(',')}
        >
          <!-- Header -->
          <div class="project-card__header">
            <h2 class="project-card__stack-name">{p.data.name}</h2>
            <span class="project-card__stack-right">
              <a href={`/projects/${p.id}`} class="project-card__pill">
                <span>Go to project</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
              </a>
            </span>
          </div>

          <div class="project-card__body">
            <div class="project-card__body-inner">
              <div class="project-card__columns">
                <!-- Left: description -->
                <div class="project-card__description-col">
                  <p class="project-card__intro">{p.data.smallIntro}</p>
                  {p.data.description && (
                    <p class="project-card__desc">
                      {p.data.description.replace(/<[^>]*>/g, '').substring(0, 120) + (p.data.description.replace(/<[^>]*>/g, '').length > 120 ? '...' : '')}
                    </p>
                  )}
                </div>

                <!-- Right: scrollable thumbnail strip -->
                <div class="project-card__image-col">
                  <div class="project-card__thumbs-scroll">
                    {allImgs.map((src, idx) => (
                      <button
                        type="button"
                        class="project-card__thumb-item"
                        data-src={src}
                        data-alt={p.data.name}
                        aria-label={`View image ${idx + 1} of ${p.data.name}`}
                      >
                        <img src={src} alt={`${p.data.name} ${idx + 1}`} loading="lazy" />
                      </button>
                    ))}
                    {allImgs.length === 0 && <div class="project-card__placeholder" />}
                  </div>
                </div>

                <!-- In-card hover preview (overlays description col on desktop, full card on mobile) -->
                <div class="project-card__hover-preview">
                  <img class="project-card__hover-preview-img" src="" alt="" />
                </div>
              </div>

              <!-- Bottom Bar -->
              <div class="project-card__bottom-bar">
                <div class="project-card__bottom-left">
                  <div class="project-card__metaline">
                    {metaParts.map((m, idx) => (
                      <span class="project-card__meta-item">
                        {idx > 0 && <span class="project-card__meta-sep">·</span>}
                        <span class="project-card__meta-val">{m.val}</span>
                      </span>
                    ))}
                  </div>
                </div>
                <div class="project-card__bottom-right">
                  {tagLine && <span class="project-card__bottom-tags">{tagLine}</span>}
                  {p.data.year && <span class="project-card__bottom-year">{p.data.year}</span>}
                </div>
              </div>
            </div>
          </div>
        </div>
        );
      })}
    </div>
    </div> <!-- End projects-top-section -->

    <!-- Bottom Section: Bubbles interface — styled to match Footer -->
    <div class="projects-bottom-section">
      <h2 class="projects-bottom-section__title">Projects Quick Search</h2>
      <!-- Bottom quick-search bubbles — all projects, grey by default, highlight on match -->
      <div class="proj-bubbles" id="proj-bubbles" aria-label="Quick project search">
        {sorted.map(p => {
          const tagsArr = (p.data.tags ?? []).map(t => tagMap[t.id] || t.id);
          return (
            <a
              href={`/projects/${p.id}`}
              class="proj-bubble"
              data-name={p.data.name}
              data-loc={p.data.location ?? ''}
              data-year={p.data.year ?? ''}
              data-client={p.data.client ?? ''}
              data-status={p.data.status ?? ''}
              data-program={p.data.program ?? ''}
              data-cat={p.data.category ? (catMap[p.data.category.id] || p.data.category.id) : ''}
              data-tags={tagsArr.join(',')}
            >
              <span class="proj-bubble__name" data-short={p.data.shortName || abbrevName(p.data.name)} data-full={p.data.name}>{p.data.shortName || abbrevName(p.data.name)}</span>
              <span class="proj-bubble__tag">{tagsArr[0] || (p.data.category ? catMap[p.data.category.id] : 'Design')}</span>
              <svg class="link-arrow proj-bubble__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                <line x1="6" y1="18" x2="18" y2="6"></line>
                <polyline points="10 6 18 6 18 14"></polyline>
              </svg>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</PageLayout>

<style>
  :global(html) {
    scroll-snap-type: none !important;
    scroll-behavior: smooth;
    scroll-padding-top: 64px; /* any anchored/jumped heading lands clear of the fixed top breadcrumb */
  }

  @media (max-width: 767px) and (orientation: portrait) {
    :global(html) {
      scroll-padding-top: 12px; /* breadcrumb docks to the bottom on mobile */
    }
  }

  .projects-page {
    padding-top: calc(clamp(3.5rem, 7vh, 6rem) + 48px); /* more top padding + fixed breadcrumb space */
    padding-bottom: var(--_tokens---space--small);
    min-height: 100dvh;
    box-sizing: border-box;
    position: relative;
  }

  @media (min-width: 1200px) {
    .projects-page {
      padding-top: calc(clamp(4rem, 6vh, 5rem) + 48px);
    }
  }

  @media (max-width: 767px) and (orientation: portrait) {
    .projects-page {
      padding-bottom: 80px; /* space for mobile bottom docked breadcrumbs */
    }
  }

  /* Fixed search and filter header */
  .projects-sticky-header {
    position: fixed;
    top: 0; /* opaque bg covers the full top strip so cards never peek above it */
    left: 44px; /* Offset for SideNav */
    right: 0;
    z-index: 90; /* Lower than Breadcrumb (100) and SideNav (200) */
    background-color: var(--_tokens---color--bg);
    padding-inline: var(--_tokens---space--small);
    padding-top: 80px; /* 64px breadcrumb strip + 16px breathing room — keeps content below the breadcrumb */
    padding-bottom: 24px;
    border: none;
    transition: background-color 0.3s ease;
  }

  @media (max-width: 767px) and (orientation: portrait) {
    .projects-sticky-header {
      top: 0; /* Breadcrumb docks to bottom on mobile, so header goes to very top */
      padding-top: 16px; /* no breadcrumb strip to clear up here on mobile */
    }
  }

  @media (min-width: 1200px) {
    .projects-sticky-header {
      padding-inline: clamp(6rem, 12vw, 16rem);
    }
  }

  .projects-header {
    display: flex;
    flex-direction: row;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
  }

  .projects-title {
    font-size: var(--_tokens---type--big);
    font-weight: 500;
    color: var(--_tokens---color--fg);
    letter-spacing: -0.03em;
    line-height: 0.95;
    margin: 0;
  }

  .projects-count {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    letter-spacing: 0.04em;
    margin: 0;
  }

  /* Search Bar — left-aligned, taller for breathing room */
  .projects-search-bar {
    display: flex;
    gap: 12px;
    margin: 0 0 18px;
    width: 100%;
    max-width: 100%;
  }

  .projects-search-input {
    flex: 1;
    height: 66px;
    padding: 0 32px;
    font-size: var(--_tokens---type--small);
    font-family: inherit;
    background: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    color: var(--_tokens---color--fg);
    border-radius: 999px;
    outline: none;
    opacity: 0.35; /* grayed out by default */
    transition: background-color 0.2s, opacity 0.3s ease;
  }

  .projects-search-input::placeholder { color: var(--_tokens---color--muted); }
  .projects-search-input:focus,
  .projects-search-input:not(:placeholder-shown),
  .projects-search-input.is-active {
    opacity: 1; /* activated */
  }

  .projects-search-clear {
    height: 66px;
    padding: 0 32px;
    font-size: var(--_tokens---type--small);
    font-family: inherit;
    font-weight: 400;
    letter-spacing: 0.04em;
    background: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    color: var(--_tokens---color--fg);
    border-radius: 999px;
    cursor: pointer;
    white-space: nowrap;
    opacity: 0.35; /* grayed out by default */
    transition: background-color 0.2s, color 0.2s, opacity 0.3s ease;
  }

  .projects-search-input:focus ~ .projects-search-clear,
  .projects-search-input:not(:placeholder-shown) ~ .projects-search-clear,
  .projects-search-clear:hover {
    opacity: 1; /* activated */
  }

  .projects-search-clear:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  /* Filters (Dropdown Category + Scrollable Tag Picker) */
  .filter-bar {
    display: flex;
    flex-direction: row;
    gap: 32px;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 100%;
    margin: 0;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .filter-group--tags {
    flex: 1;
    min-width: 0;
    opacity: 0.35; /* grayed out by default */
    transition: opacity 0.3s ease;
  }

  .filter-group--tags:hover,
  .filter-group--tags:focus-within,
  .filter-group--tags.is-active {
    opacity: 1; /* activated */
  }

  .filter-label {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    text-transform: none;
    letter-spacing: 0.08em;
    color: var(--_tokens---color--muted);
    flex-shrink: 0;
  }

  .filter-select-wrap {
    position: relative;
    display: inline-block;
    flex-shrink: 0;
    opacity: 0.35; /* grayed out by default */
    transition: opacity 0.3s ease;
  }

  .filter-select-wrap:hover,
  .filter-select-wrap:focus-within,
  .filter-select-wrap.is-active {
    opacity: 1; /* activated */
  }

  .filter-select {
    appearance: none;
    -webkit-appearance: none;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--fg);
    font-family: inherit;
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    text-transform: none;
    letter-spacing: 0.04em;
    border: none;
    border-radius: 999px;
    padding: 10px 40px 10px 20px;
    cursor: pointer;
    outline: none;
    min-width: 180px;
    transition: background-color 0.2s;
  }

  .filter-select:hover {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
  }

  .filter-select option {
    background-color: var(--_tokens---color--bg);
    color: var(--_tokens---color--fg);
  }

  .filter-select-arrow {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    width: 1em;
    height: 1em;
    font-size: var(--_tokens---type--micro);
    pointer-events: none;
    color: var(--_tokens---color--fg);
    opacity: 0.7;
  }

  /* Tag horizontal scrollable picker */
  .tag-picker-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
    min-width: 0;
  }

  .tag-picker-divider {
    color: color-mix(in srgb, var(--_tokens---color--fg) 15%, transparent);
    font-weight: 300;
    font-size: var(--_tokens---type--micro);
    user-select: none;
    flex-shrink: 0;
  }

  .tag-scroll-nav {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
    min-width: 0;
  }

  .tag-scroll-arrow {
    display: none;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--fg);
    cursor: pointer;
    flex-shrink: 0;
    transition: background-color 0.2s, opacity 0.2s;
    opacity: 0.8;
  }

  .tag-scroll-arrow:hover {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    opacity: 1;
  }

  .tag-scroll-arrow:disabled {
    opacity: 0.15;
    cursor: not-allowed;
  }

  .tag-scroll-arrow svg {
    width: 16px;
    height: 16px;
  }

  .tag-picker-container {
    flex: 1;
    min-width: 0;
    max-width: 420px;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 2px;
    scroll-behavior: smooth;
  }

  .tag-picker-container::-webkit-scrollbar {
    display: none;
  }

  .tag-picker {
    display: flex;
    gap: 8px;
    white-space: nowrap;
    width: max-content;
  }

  .tag-picker-item {
    background-color: transparent;
    color: var(--_tokens---color--fg);
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 22%, transparent);
    border-radius: 999px;
    padding: 6px 14px;
    font-size: var(--_tokens---type--micro);
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .tag-picker-item:hover,
  .tag-picker-item.is-active {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    border-color: var(--_tokens---color--fg);
  }

  /* ── Accordion Card List ── */
  .project-cards-container {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 290px; /* Space to clear the fixed search header */
  }

  .project-card {
    width: 100%;
    box-sizing: border-box;
    cursor: default;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 2.5%, var(--_tokens---color--bg));
    border: none;
    border-radius: 0;
    overflow: visible;
    box-shadow: 0 8px 24px -10px color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    /* background stays clipped to border-radius visually via this trick */
    isolation: isolate;
  }

  .project-card[hidden] { display: none !important; }

  /* ── Always-visible header strip ── */
  .project-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 10px 20px;
    user-select: none;
    cursor: pointer;
  }

  .project-card__stack-name {
    font-size: clamp(2rem, 1.375rem + 3.5vw, 4rem); /* between --type--medium and --type--big */
    font-weight: 500;
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--_tokens---color--fg);
    transition: opacity 0.2s ease;
    margin: 0;
  }

  .project-card:hover .project-card__stack-name {
    opacity: 1;
  }

  .project-card__stack-right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    transition: opacity 0.2s ease;
  }

  .project-card.is-open:hover .project-card__stack-right {
    opacity: 0;
    pointer-events: none;
  }

  .project-card__stack-tags,
  .project-card__stack-year {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    color: var(--_tokens---color--muted);
    white-space: nowrap;
  }

  /* ── Pill / CTA button ── */
  .project-card__pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: var(--_tokens---type--micro);
    font-weight: 500;
    color: var(--_tokens---color--fg);
    text-decoration: none;
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 22%, transparent);
    border-radius: 999px;
    padding: 7px 14px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .project-card__pill svg { width: 0.85em; height: 0.85em; transition: transform 0.25s ease; }

  .project-card__pill:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    border-color: var(--_tokens---color--fg);
  }

  .project-card__pill:hover svg { transform: translate(2px, -2px); }

  .project-card__body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-card.is-open .project-card__body {
    max-height: 500px;
    overflow: visible;
  }

  .project-card__body-inner {
    position: relative;
    overflow: hidden;
    min-height: 0;
  }

  .project-card.is-open .project-card__body-inner {
    overflow: visible;
  }

  .project-card__columns {
    display: flex;
    flex-direction: row;
    width: 100%;
    min-height: 120px;
    border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    overflow: visible;
    position: relative;
  }

  .project-card__description-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 10px 20px;
    box-sizing: border-box;
  }

  .project-card__intro {
    font-size: var(--_tokens---type--small);
    font-weight: 600; /* semibold */
    line-height: 1.4; /* slightly tighter */
    color: var(--_tokens---color--muted);
    margin: 0;
    max-width: 62ch;
  }

  .project-card__desc {
    font-size: var(--_tokens---type--micro); /* micro size */
    line-height: 1.55;
    color: var(--_tokens---color--muted);
    margin: 0;
    max-width: 62ch;
    opacity: 0.85;
  }

  .project-card__image-col {
    width: 40%;
    flex-shrink: 0;
    overflow: hidden;
    border-left: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
    position: relative;
    display: flex;
    align-items: stretch;
    background: none;
  }

  /* ── Thumbnail strip: flush images, no scroll, right-aligned ── */
  .project-card__thumbs-scroll {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-end;
    overflow: hidden;
    width: 100%;
    height: 100%;
    gap: 2px;
    padding: 0;
    background: none;
  }

  /* Flush square thumbnails — no border, no bg, no padding */
  .project-card__thumb-item {
    all: unset;
    display: block;
    flex: 1;
    min-width: 0;
    max-width: 80px;
    aspect-ratio: 1;
    overflow: hidden;
    cursor: crosshair;
    position: relative;
  }

  .project-card__thumb-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: opacity 0.12s ease;
  }

  .project-card__thumb-item:hover img,
  .project-card__thumb-item.is-active img {
    opacity: 0.6;
  }

  /* ── In-card hover preview: covers description col (left), image bleeds 1.5× ── */
  .project-card__hover-preview {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    right: 40%; /* Stop at the thumbnail strip — keeps thumbs hoverable */
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: color-mix(in srgb, var(--_tokens---color--bg) 88%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    overflow: visible;
  }

  .project-card__hover-preview.is-visible {
    opacity: 1;
    /* pointer-events stays none so scrubbing works through to thumbs */
    pointer-events: none;
  }

  /* Image grows 1.5× the description col height — bleeds above + below card, anchored left */
  .project-card__hover-preview-img {
    position: absolute;
    top: 50%;
    left: 16px;
    transform: translateY(-50%);
    height: auto;
    width: auto;
    max-height: 360px;
    max-width: calc(100% - 16px);
    object-fit: contain;
    border-radius: 8px;
    display: block;
    box-shadow: 0 24px 60px -12px color-mix(in srgb, var(--_tokens---color--fg) 35%, transparent);
  }

  .project-card__placeholder {
    width: 100%;
    height: 100%;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
  }

  .project-card__bottom-bar {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding: 8px 20px;
    box-sizing: border-box;
    font-size: var(--_tokens---type--micro);
    color: var(--_tokens---color--muted);
    transition: opacity 0.2s ease;
  }

  .project-card.is-open:hover .project-card__bottom-bar {
    opacity: 0;
    pointer-events: none;
  }

  .project-card__bottom-left {
    display: flex;
    align-items: center;
    min-width: 0;
  }

  .project-card__bottom-right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    font-weight: 300;
  }

  .project-card__bottom-tags {
    color: var(--_tokens---color--muted);
  }

  .project-card__bottom-year {
    color: var(--_tokens---color--muted);
  }

  .project-card__metaline {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 4px 4px;
    font-size: var(--_tokens---type--micro);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .project-card__meta-item { display: inline-flex; align-items: center; gap: 5px; flex-shrink: 0; }
  .project-card__meta-sep { color: color-mix(in srgb, var(--_tokens---color--fg) 25%, transparent); margin-right: 4px; }
  .project-card__meta-val { color: var(--_tokens---color--fg); font-weight: 400; }

  @media (max-width: 768px) {
    .project-card__meta-item:not(:first-child),
    .project-card__meta-sep {
      display: none;
    }
  }

  .project-card__pill--cta {
    padding: 9px 16px;
    font-size: var(--_tokens---type--small);
  }

  .projects-top-section {
    position: relative;
    width: 100%;
  }



  /* ── Bottom quick-search section — matches Footer visual style ── */
  .projects-bottom-section {
    position: relative;
    width: 100%;
    margin-top: clamp(2rem, 5vh, 4rem);
    border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    padding-top: 32px;
    padding-bottom: 24px;
  }

  .projects-bottom-section__title {
    font-size: var(--_tokens---type--small);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--_tokens---color--fg);
    margin: 0 0 16px 0;
  }

  /* Bubbles container — wrap freely, same gap as footer */
  .proj-bubbles {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 5px;
    transition: opacity 0.25s ease;
  }

  /* Individual pill — matches Footer .proj-bubble exactly */
  .proj-bubble {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: var(--_tokens---type--ultrathin);
    font-weight: 300;
    color: var(--_tokens---color--muted);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    border-radius: 999px;
    padding: 6px 12px;
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    box-sizing: border-box;
    transition: background-color 0.2s, color 0.2s, transform 0.15s, opacity 0.2s;
  }

  .proj-bubble__name {
    font-size: var(--_tokens---type--ultrathin);
    font-weight: 300;
    letter-spacing: -0.01em;
    color: inherit;
  }

  .proj-bubble__tag {
    font-family: var(--_tokens---font--mono);
    line-height: 1;
    font-size: var(--_tokens---type--ultrathin);
    color: inherit;
    letter-spacing: 0.04em;
    opacity: 0;
    max-width: 0;
    margin-left: -7px;
    overflow: hidden;
    white-space: nowrap;
    transition: max-width 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.28s ease,
                margin-left 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .proj-bubble:hover .proj-bubble__tag {
    max-width: 160px;
    opacity: 0.6;
    margin-left: 0;
  }

  .proj-bubble__arrow {
    width: 0.8em;
    height: 0.8em;
    flex-shrink: 0;
    opacity: 0.55;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .proj-bubble:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    border-color: var(--_tokens---color--fg);
    transform: translateY(-1px);
  }

  .proj-bubble:hover .proj-bubble__arrow {
    opacity: 1;
  }

  /* Search match state */
  .proj-bubble.is-match {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    border-color: var(--_tokens---color--fg);
  }

  .proj-bubble.is-match:hover {
    transform: translateY(-1px);
  }

  /* Active search: dim non-matching bubbles */
  .proj-bubbles.has-search .proj-bubble:not(.is-match) {
    opacity: 0.2;
  }

  .proj-bubbles.has-search .proj-bubble:not(.is-match):hover {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .filter-bar {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
    .project-cards-container {
      margin-top: 240px;
    }
    /* Mobile card: name + pill + images only */
    .project-card__description-col {
      display: none;
    }
    .project-card__bottom-bar {
      display: none;
    }
    .project-card__columns {
      flex-direction: column;
      min-height: auto;
    }
    .project-card__image-col {
      width: 100%;
      height: 80px;
      border-left: none;
      border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    }
    /* Thumbs take equal share on mobile too, slightly smaller */
    .project-card__thumb-item {
      max-width: 50px;
    }
    /* Preview covers full columns on mobile (already inset:0) */
    .project-card__hover-preview {
      background-color: color-mix(in srgb, var(--_tokens---color--bg) 95%, transparent);
    }
  }
</style>

<script>
  // ── In-card scrub preview (desktop) / tap reveal (mobile) ──
  function initImagePreview() {
    const isHoverDevice = window.matchMedia('(hover: hover)').matches;

    document.querySelectorAll<HTMLElement>('.project-card').forEach(card => {
      const preview = card.querySelector<HTMLElement>('.project-card__hover-preview');
      const previewImg = card.querySelector<HTMLImageElement>('.project-card__hover-preview-img');
      const strip = card.querySelector<HTMLElement>('.project-card__thumbs-scroll');
      if (!preview || !previewImg || !strip) return;

      const thumbs = Array.from(card.querySelectorAll<HTMLElement>('.project-card__thumb-item'));
      let hideTimer: ReturnType<typeof setTimeout> | null = null;

      function show(src: string, alt: string, thumb?: HTMLElement) {
        if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
        previewImg.src = src;
        previewImg.alt = alt;
        preview.classList.add('is-visible');
        thumbs.forEach(t => t.classList.remove('is-active'));
        if (thumb) thumb.classList.add('is-active');
      }

      function hide() {
        hideTimer = setTimeout(() => {
          preview.classList.remove('is-visible');
          thumbs.forEach(t => t.classList.remove('is-active'));
        }, 80);
      }

      if (isHoverDevice) {
        // Show first image when mouse enters the strip
        strip.addEventListener('mouseenter', () => {
          if (thumbs.length > 0) {
            const first = thumbs[0];
            show(first.dataset.src ?? '', first.dataset.alt ?? '', first);
          }
        });

        // Scrub: update image as cursor moves over each thumb
        thumbs.forEach(thumb => {
          thumb.addEventListener('mouseenter', () => {
            show(thumb.dataset.src ?? '', thumb.dataset.alt ?? '', thumb);
          });
        });

        // Hide when mouse leaves the strip
        strip.addEventListener('mouseleave', () => hide());

      } else {
        // Mobile: tap a thumb to show/hide
        thumbs.forEach(thumb => {
          thumb.addEventListener('click', () => {
            const src = thumb.dataset.src ?? '';
            if (preview.classList.contains('is-visible') && thumb.classList.contains('is-active')) {
              hide();
            } else {
              show(src, thumb.dataset.alt ?? '', thumb);
            }
          });
        });

        // Tap preview background to dismiss
        preview.addEventListener('click', () => hide());
      }
    });

    // Escape to dismiss all
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll<HTMLElement>('.project-card__hover-preview').forEach(p => p.classList.remove('is-visible'));
        document.querySelectorAll<HTMLElement>('.project-card__thumb-item').forEach(t => t.classList.remove('is-active'));
      }
    });
  }

  initImagePreview();
  document.addEventListener('astro:after-swap', initImagePreview);

  // ── Accordion toggle open/close ──
  function initAccordion() {
    document.querySelectorAll<HTMLElement>('.project-card').forEach(card => {
      const header = card.querySelector<HTMLElement>('.project-card__header');
      
      // Click to toggle
      header?.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('.project-card__pill')) return;
        card.classList.toggle('is-open');
      });

      // Hover header to open
      header?.addEventListener('mouseenter', () => {
        card.classList.add('is-open');
      });

      // Mouse leave the entire card to collapse it back
      card.addEventListener('mouseleave', () => {
        card.classList.remove('is-open');
        // Clear active states of inside previews
        card.querySelectorAll<HTMLElement>('.project-card__hover-preview').forEach(p => p.classList.remove('is-visible'));
        card.querySelectorAll<HTMLElement>('.project-card__thumb-item').forEach(t => t.classList.remove('is-active'));
      });
    });
  }

  initAccordion();
  document.addEventListener('astro:after-swap', initAccordion);
</script>

<script>
  const container = document.getElementById('project-cards-container');
  const cards = Array.from(container?.querySelectorAll<HTMLElement>('.project-card') ?? []);
  const searchInput = document.getElementById('projects-search-input') as HTMLInputElement;
  const clearBtn = document.getElementById('projects-search-clear');
  const countLabel = document.querySelector('.projects-count');

  const catSelect = document.getElementById('cat-select') as HTMLSelectElement;
  const tagPicker = document.getElementById('tag-picker');

  let searchQuery = '';
  let activeCat = '';
  let activeTag = '';

  // ── State ──────────────────────────────────────────────────

  function getVisibleCards() {
    return cards.filter(c => !c.hidden);
  }

  // Click to toggle open/close has been removed - cards are statically open.



  function applyVisibility(matchingCards: HTMLElement[]) {
    cards.forEach(card => {
      card.hidden = true;
    });
    matchingCards.forEach(card => { card.hidden = false; });
    if (countLabel) {
      countLabel.textContent = `${matchingCards.length} of ${cards.length} works`;
    }
  }

  // Bottom bubbles: always present, grey by default, highlight on search match
  const grid = document.getElementById('proj-bubbles');
  if (grid) {
    const bubblesArr = Array.from(grid.querySelectorAll('.proj-bubble')) as HTMLElement[];
    for (let i = bubblesArr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      const temp = bubblesArr[i];
      bubblesArr[i] = bubblesArr[j];
      bubblesArr[j] = temp;
    }
    bubblesArr.forEach(b => grid.appendChild(b));
  }

  // Hover name swap: abbreviated → full on mouseenter, back on mouseleave
  document.querySelectorAll<HTMLElement>('.proj-bubble__name').forEach(nameEl => {
    const bubble = nameEl.closest('.proj-bubble') as HTMLElement;
    if (!bubble) return;
    bubble.addEventListener('mouseenter', () => {
      nameEl.textContent = nameEl.dataset.full ?? nameEl.textContent;
    });
    bubble.addEventListener('mouseleave', () => {
      nameEl.textContent = nameEl.dataset.short ?? nameEl.textContent;
    });
  });

  const bubbles = document.querySelectorAll<HTMLElement>('.proj-bubble');
  function updateBubbles(keywords: string[]) {
    if (grid) {
      grid.classList.toggle('has-search', keywords.length > 0);
    }
    bubbles.forEach(b => {
      if (!keywords.length) { b.classList.remove('is-match'); return; }
      const hay = [
        b.dataset.name, b.dataset.loc, b.dataset.year, b.dataset.client,
        b.dataset.status, b.dataset.program, b.dataset.cat, b.dataset.tags
      ].join(' ').toLowerCase();
      b.classList.toggle('is-match', keywords.every(kw => hay.includes(kw)));
    });
  }

  function updateFieldActivation() {
    // 1. Search input
    if (searchInput) {
      if (searchInput.value.trim()) searchInput.classList.add('is-active');
      else searchInput.classList.remove('is-active');
    }
    // 2. Category select dropdown
    const selectWrap = document.querySelector('.filter-select-wrap');
    if (catSelect && selectWrap) {
      if (catSelect.value) selectWrap.classList.add('is-active');
      else selectWrap.classList.remove('is-active');
    }
    // 3. Tag group wrapper
    const tagGroup = document.querySelector('.filter-group--tags');
    if (tagGroup) {
      if (activeTag) tagGroup.classList.add('is-active');
      else tagGroup.classList.remove('is-active');
    }
  }

  function applyFilter() {
    updateFieldActivation();
    const query = searchQuery.trim().toLowerCase();
    const keywords = query.split(/\s+/).filter(Boolean);

    const matchingCards: HTMLElement[] = [];

    cards.forEach(card => {
      const name = (card.dataset.name ?? '').toLowerCase();
      const loc = (card.dataset.loc ?? '').toLowerCase();
      const year = (card.dataset.year ?? '').toLowerCase();
      const client = (card.dataset.client ?? '').toLowerCase();
      const status = (card.dataset.status ?? '').toLowerCase();
      const size = (card.dataset.size ?? '').toLowerCase();
      const program = (card.dataset.program ?? '').toLowerCase();
      const cat = (card.dataset.cat ?? '').toLowerCase();
      const tags = (card.dataset.tags ?? '').toLowerCase();
      const catId = card.dataset.catId ?? '';
      const tagIds = (card.dataset.tagIds ?? '').split(',').filter(Boolean);

      // smart multi-keyword match (AND logic)
      const searchMatch = !keywords.length || keywords.every(kw =>
        name.includes(kw) ||
        loc.includes(kw) ||
        year.includes(kw) ||
        client.includes(kw) ||
        status.includes(kw) ||
        size.includes(kw) ||
        program.includes(kw) ||
        cat.includes(kw) ||
        tags.includes(kw)
      );

      const catMatch = !activeCat || catId === activeCat;
      const tagMatch = !activeTag || tagIds.includes(activeTag);

      if (searchMatch && catMatch && tagMatch) {
        matchingCards.push(card);
      }
    });

    applyVisibility(matchingCards);
    updateBubbles(keywords);
  }

  // Input typing listener
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value;
    applyFilter();
  });

  // Select dropdown filter listeners
  catSelect?.addEventListener('change', (e) => {
    activeCat = (e.target as HTMLSelectElement).value;
    applyFilter();
  });

  // --- Tag Picker Scroll Navigation ---
  const tagPickerContainer = document.getElementById('tag-picker-container');
  const scrollLeftBtn = document.getElementById('tag-scroll-left') as HTMLButtonElement;
  const scrollRightBtn = document.getElementById('tag-scroll-right') as HTMLButtonElement;

  function updateScrollArrows() {
    if (!tagPickerContainer || !scrollLeftBtn || !scrollRightBtn) return;
    const { scrollLeft, scrollWidth, clientWidth } = tagPickerContainer;
    
    // Disable arrows based on scroll position limits
    scrollLeftBtn.disabled = scrollLeft <= 1;
    scrollRightBtn.disabled = scrollLeft + clientWidth >= scrollWidth - 2;
    
    // Only display arrows if container actually has overflow
    const hasOverflow = scrollWidth > clientWidth;
    scrollLeftBtn.style.display = hasOverflow ? 'flex' : 'none';
    scrollRightBtn.style.display = hasOverflow ? 'flex' : 'none';
  }

  // Smooth scroll offset on arrow click
  scrollLeftBtn?.addEventListener('click', () => {
    tagPickerContainer?.scrollBy({ left: -140, behavior: 'smooth' });
  });

  scrollRightBtn?.addEventListener('click', () => {
    tagPickerContainer?.scrollBy({ left: 140, behavior: 'smooth' });
  });

  tagPickerContainer?.addEventListener('scroll', updateScrollArrows, { passive: true });
  window.addEventListener('resize', updateScrollArrows, { passive: true });

  const allTagBtn = document.getElementById('all-tag-btn');

  // Static All Tag button click listener
  allTagBtn?.addEventListener('click', () => {
    // Remove active state from all scrolling tag buttons
    tagPicker?.querySelectorAll('.tag-picker-item').forEach(b => b.classList.remove('is-active'));
    allTagBtn.classList.add('is-active');
    activeTag = '';
    applyFilter();
    setTimeout(updateScrollArrows, 50);
  });

  // Tag scrollable picker click listener using event delegation
  tagPicker?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.tag-picker-item');
    if (!btn) return;

    const filter = (btn as HTMLElement).dataset.filter ?? '';
    activeTag = filter;

    // Set active state on clicked button and remove from all others (including All tag button)
    allTagBtn?.classList.remove('is-active');
    tagPicker.querySelectorAll('.tag-picker-item').forEach(b => {
      b.classList.toggle('is-active', b === btn);
    });

    applyFilter();
    // Re-check arrows in case item selection changes container layout (unlikely but safe)
    setTimeout(updateScrollArrows, 50);
  });

  // Clear search and filters trigger
  clearBtn?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    if (catSelect) catSelect.value = '';
    searchQuery = '';
    activeCat = '';
    activeTag = '';
    // Reset tag picker active states
    allTagBtn?.classList.add('is-active');
    tagPicker?.querySelectorAll('.tag-picker-item').forEach(btn => {
      btn.classList.remove('is-active');
    });
    applyFilter();
    updateScrollArrows();
  });

  // Pre-load search query from URL params if present (links from skillset click on About page)
  const urlParams = new URLSearchParams(window.location.search);
  const qParam = urlParams.get('search') || urlParams.get('q');
  if (qParam) {
    searchQuery = qParam;
    if (searchInput) searchInput.value = qParam;
  }

  // Initialize visibility and tag scroll arrows
  applyFilter();
  setTimeout(updateScrollArrows, 100);
</script>
