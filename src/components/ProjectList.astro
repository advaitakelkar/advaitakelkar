  /* ── Mobile image preview ────────────────────────────────────────────
     A transparent full-screen container holding two frosted-glass panes that
     sandwich the card's scrub strip. The strip stays sharp in the gap; the
     image and the link/✕ bar sit sharp on the glass; everything behind the
     glass (other cards) is blurred — same glass as the side nav / breadcrumb.
     Sits BELOW the breadcrumb (100) + side nav (200). */
  /* Single full-screen glass — same as the side nav (bg 35% + blur 20) */
  .project-lightbox {
    display: none;
    position: fixed;
    left: 44px; /* clear the side-nav index bar */
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 95; /* under breadcrumb (100) + side nav (200) */
    pointer-events: auto; /* tap the glass to close */
    background-color: color-mix(in srgb, var(--_tokens---color--bg) 35%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
