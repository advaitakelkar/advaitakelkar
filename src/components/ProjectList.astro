<script>
  // ── Mobile image preview controller (shared, top-level — floats over cards) ──
  const lightbox = document.getElementById('project-lightbox');
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const lbImageArea = document.getElementById('lightbox-image-area');
  const lbBar = document.getElementById('lightbox-bar');
  const lbLink = document.getElementById('lightbox-link') as HTMLAnchorElement | null;
  const lbPrev = document.getElementById('lightbox-prev');
  const lbNext = document.getElementById('lightbox-next');
  let lbThumbs: HTMLElement[] = [];     // the CARD's own thumbnails (strip stays put)
  let lbStripEl: HTMLElement | null = null; // the card strip currently being previewed
  let activeCard: HTMLElement | null = null; // card whose preview is showing (for grayscale)
  let lbIndex = 0;                      // current image index (for prev/next loop)

  // Which thumbnail is under a given screen-x — drives the drag/scrub
  function thumbIndexAtX(thumbs: HTMLElement[], clientX: number): number {
    if (!thumbs.length) return -1;
    for (let i = 0; i < thumbs.length; i++) {
      const r = thumbs[i].getBoundingClientRect();
      if (clientX >= r.left && clientX <= r.right) return i;
    }
    return clientX < thumbs[0].getBoundingClientRect().left ? 0 : thumbs.length - 1;
  }

  function setLbActive(i: number) {
    if (!lbImg) return;
    const t = lbThumbs[i];
    if (!t) return;
    lbIndex = i;
    lbThumbs.forEach((el, j) => el.classList.toggle('is-active', j === i));
    lbImg.src = t.dataset.src ?? '';
    lbImg.alt = t.dataset.alt ?? '';
  }

  // Prev / next with wraparound (infinity loop)
  function stepLb(dir: number) {
    const n = lbThumbs.length;
    if (!n) return;
    setLbActive((lbIndex + dir + n) % n);
  }

  // Sandwich the strip: image pane fills the larger side, filler pane the other,
  // and the link/✕ bar sits in the gap right next to the strip.
  const BAR_H = 44;
  function positionPanel(strip: HTMLElement) {
    if (!lightbox || !lbImageArea || !lbBar) return;
    const rect = strip.getBoundingClientRect();
    const vh = window.innerHeight;
    const imageOnBottom = (vh - rect.bottom) >= rect.top;
    if (imageOnBottom) {
      // image fills below the strip; bar just below the strip
      lbImageArea.style.top = rect.bottom + 'px';
      lbImageArea.style.bottom = '0px';
      lbImageArea.style.paddingTop = BAR_H + 'px'; // clear the bar
      lbImageArea.style.paddingBottom = '84px';    // clear the breadcrumb dock
      lbBar.style.top = rect.bottom + 'px';
    } else {
      // image fills above the strip; bar just above the strip
      lbImageArea.style.top = '0px';
      lbImageArea.style.bottom = (vh - rect.top) + 'px';
      lbImageArea.style.paddingTop = '20px';
      lbImageArea.style.paddingBottom = BAR_H + 'px'; // clear the bar
      lbBar.style.top = (rect.top - BAR_H) + 'px';
    }
  }

  function openLightbox(card: HTMLElement, strip: HTMLElement, startIdx: number) {
    if (!lightbox) return;
    lbThumbs = Array.from(card.querySelectorAll<HTMLElement>('.project-card__thumb-item'));
    lbStripEl = strip;
    activeCard = card;
    card.classList.add('is-previewing'); // grayscales the non-active thumbnails
    const href = card.querySelector('.project-card__pill')?.getAttribute('href');
    if (lbLink && href) lbLink.href = href;
    positionPanel(strip);
    setLbActive(startIdx);
    lightbox.classList.add('is-open');
    lightbox.setAttribute('aria-hidden', 'false');
    // Fully lock the page so nothing scrolls behind the open lightbox
    document.documentElement.style.overflow = 'hidden';
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.classList.remove('is-open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.documentElement.style.overflow = '';
    document.body.style.overflow = '';
    lbThumbs.forEach(t => t.classList.remove('is-active'));
    activeCard?.classList.remove('is-previewing');
    activeCard = null;
    lbStripEl = null;
  }

  if (lightbox) {
    // Tap the glass (or image) to dismiss — the strip is lifted above it and
    // stays tappable; the ✕ closes; the link navigates
    lightbox.addEventListener('click', closeLightbox);
    document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
    lbLink?.addEventListener('click', (e) => e.stopPropagation());
    // Prev/next image arrows (don't close)
    lbPrev?.addEventListener('click', (e) => { e.stopPropagation(); stepLb(-1); });
    lbNext?.addEventListener('click', (e) => { e.stopPropagation(); stepLb(1); });
    // Block touch-scroll/rubber-band on the glass while open
    lightbox.addEventListener('touchmove', (e) => e.preventDefault(), { passive: false });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
    window.addEventListener('resize', () => {
      if (lbStripEl && lightbox.classList.contains('is-open')) positionPanel(lbStripEl);
    });
  }

  // ── Scrub preview: same model on desktop and mobile ──
  // Desktop: hovering / dragging across the strip scrubs the left-side preview.
  // Mobile: tap opens the frosted lightbox; sliding across the strip scrubs it.
  // In both, the active thumbnail stays in colour while the rest go grayscale.
  function initImagePreview() {
    const isHoverDevice = window.matchMedia('(hover: hover)').matches;

    document.querySelectorAll<HTMLElement>('.project-card').forEach(card => {
      const strip = card.querySelector<HTMLElement>('.project-card__thumbs-scroll');
      if (!strip) return;
      const thumbs = Array.from(card.querySelectorAll<HTMLElement>('.project-card__thumb-item'));
      let lastIdx = -1;

      if (isHoverDevice) {
        const preview = card.querySelector<HTMLElement>('.project-card__hover-preview');
        const previewImg = card.querySelector<HTMLImageElement>('.project-card__hover-preview-img');
        if (!preview || !previewImg) return;
        let hideTimer: ReturnType<typeof setTimeout> | null = null;

        const showIdx = (i: number) => {
          const t = thumbs[i];
          if (!t) return;
          if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
          previewImg.src = t.dataset.src ?? '';
          previewImg.alt = t.dataset.alt ?? '';
          preview.classList.add('is-visible');
          card.classList.add('is-previewing'); // grayscale the rest
          thumbs.forEach((el, j) => el.classList.toggle('is-active', j === i));
          lastIdx = i;
        };
        const hide = () => {
          hideTimer = setTimeout(() => {
            preview.classList.remove('is-visible');
            card.classList.remove('is-previewing');
            thumbs.forEach(t => t.classList.remove('is-active'));
            lastIdx = -1;
          }, 80);
        };

        strip.addEventListener('pointerenter', () => { if (thumbs.length) showIdx(0); });
        // Scrub: image follows the pointer across the strip (hover or click-drag)
        strip.addEventListener('pointermove', (e) => {
          const i = thumbIndexAtX(thumbs, e.clientX);
          if (i >= 0 && i !== lastIdx) showIdx(i);
        });
        strip.addEventListener('pointerleave', () => hide());
      } else {
        // Mobile: tap a thumb → open the frosted lightbox at that image
        thumbs.forEach((thumb, idx) => {
          thumb.addEventListener('click', () => openLightbox(card, strip, idx));
        });
        // Slide across the strip while the lightbox is open → scrub the image
        strip.addEventListener('pointermove', (e) => {
          if (!lightbox || !lightbox.classList.contains('is-open') || activeCard !== card) return;
          const i = thumbIndexAtX(thumbs, e.clientX);
          if (i >= 0 && i !== lastIdx) { lastIdx = i; setLbActive(i); }
        });
      }
    });
  }

  initImagePreview();
  document.addEventListener('astro:after-swap', initImagePreview);

  // ── Accordion toggle: click the name to open/close the whole card ──
  function initAccordion() {
    document.querySelectorAll<HTMLElement>('.project-card').forEach(card => {
      const header = card.querySelector<HTMLElement>('.project-card__header');

      // Click toggles open/close (ignore clicks on the "Go to project" pill)
      header?.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('.project-card__pill')) return;
        card.classList.toggle('is-open');
      });

      // Leaving the card just clears the scrub preview — the card stays open
      card.addEventListener('mouseleave', () => {
        card.querySelectorAll<HTMLElement>('.project-card__hover-preview').forEach(p => p.classList.remove('is-visible'));
        card.querySelectorAll<HTMLElement>('.project-card__thumb-item').forEach(t => t.classList.remove('is-active'));
      });
    });
  }

  initAccordion();
  document.addEventListener('astro:after-swap', initAccordion);
</script>

<script>
  const container = document.getElementById('project-cards-container');
  const cards = Array.from(container?.querySelectorAll<HTMLElement>('.project-card') ?? []);
  const searchInput = document.getElementById('projects-search-input') as HTMLInputElement;
  const clearBtn = document.getElementById('projects-search-clear');
  const countLabel = document.querySelector('.projects-count');

  const catSelect = document.getElementById('cat-select') as HTMLSelectElement;
  const tagPicker = document.getElementById('tag-picker');

  let searchQuery = '';
  let activeCat = '';
  let activeTag = '';

  // ── State ──────────────────────────────────────────────────

  function getVisibleCards() {
    return cards.filter(c => !c.hidden);
  }

  // Click to toggle open/close has been removed - cards are statically open.



  function applyVisibility(matchingCards: HTMLElement[]) {
    cards.forEach(card => {
      card.hidden = true;
    });
    matchingCards.forEach(card => { card.hidden = false; });
    if (countLabel) {
      countLabel.textContent = `${matchingCards.length} of ${cards.length} works`;
    }
  }

  // Bottom bubbles: always present, grey by default, highlight on search match
  const grid = document.getElementById('proj-bubbles');
  if (grid) {
    const bubblesArr = Array.from(grid.querySelectorAll('.proj-bubble')) as HTMLElement[];
    for (let i = bubblesArr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      const temp = bubblesArr[i];
      bubblesArr[i] = bubblesArr[j];
      bubblesArr[j] = temp;
    }
    bubblesArr.forEach(b => grid.appendChild(b));
  }

  // Hover name swap: abbreviated → full on mouseenter, back on mouseleave
  document.querySelectorAll<HTMLElement>('.proj-bubble__name').forEach(nameEl => {
    const bubble = nameEl.closest('.proj-bubble') as HTMLElement;
    if (!bubble) return;
    bubble.addEventListener('mouseenter', () => {
      nameEl.textContent = nameEl.dataset.full ?? nameEl.textContent;
    });
    bubble.addEventListener('mouseleave', () => {
      nameEl.textContent = nameEl.dataset.short ?? nameEl.textContent;
    });
  });

  const bubbles = document.querySelectorAll<HTMLElement>('.proj-bubble');
  function updateBubbles(keywords: string[]) {
    if (grid) {
      grid.classList.toggle('has-search', keywords.length > 0);
    }
    bubbles.forEach(b => {
      if (!keywords.length) { b.classList.remove('is-match'); return; }
      const hay = [
        b.dataset.name, b.dataset.loc, b.dataset.year, b.dataset.client,
        b.dataset.status, b.dataset.program, b.dataset.cat, b.dataset.tags
      ].join(' ').toLowerCase();
      b.classList.toggle('is-match', keywords.every(kw => hay.includes(kw)));
    });
  }

  function updateFieldActivation() {
    // 1. Search input
    if (searchInput) {
      if (searchInput.value.trim()) searchInput.classList.add('is-active');
      else searchInput.classList.remove('is-active');
    }
    // 2. Category select dropdown
    const selectWrap = document.querySelector('.filter-select-wrap');
    if (catSelect && selectWrap) {
      if (catSelect.value) selectWrap.classList.add('is-active');
      else selectWrap.classList.remove('is-active');
    }
    // 3. Tag group wrapper
    const tagGroup = document.querySelector('.filter-group--tags');
    if (tagGroup) {
      if (activeTag) tagGroup.classList.add('is-active');
      else tagGroup.classList.remove('is-active');
    }
  }

  function applyFilter() {
    updateFieldActivation();
    const query = searchQuery.trim().toLowerCase();
    const keywords = query.split(/\s+/).filter(Boolean);

    const matchingCards: HTMLElement[] = [];

    cards.forEach(card => {
      const name = (card.dataset.name ?? '').toLowerCase();
      const loc = (card.dataset.loc ?? '').toLowerCase();
      const year = (card.dataset.year ?? '').toLowerCase();
      const client = (card.dataset.client ?? '').toLowerCase();
      const status = (card.dataset.status ?? '').toLowerCase();
      const size = (card.dataset.size ?? '').toLowerCase();
      const program = (card.dataset.program ?? '').toLowerCase();
      const cat = (card.dataset.cat ?? '').toLowerCase();
      const tags = (card.dataset.tags ?? '').toLowerCase();
      const catId = card.dataset.catId ?? '';
      const tagIds = (card.dataset.tagIds ?? '').split(',').filter(Boolean);

      // smart multi-keyword match (AND logic)
      const searchMatch = !keywords.length || keywords.every(kw =>
        name.includes(kw) ||
        loc.includes(kw) ||
        year.includes(kw) ||
        client.includes(kw) ||
        status.includes(kw) ||
        size.includes(kw) ||
        program.includes(kw) ||
        cat.includes(kw) ||
        tags.includes(kw)
      );

      const catMatch = !activeCat || catId === activeCat;
      const tagMatch = !activeTag || tagIds.includes(activeTag);

      if (searchMatch && catMatch && tagMatch) {
        matchingCards.push(card);
      }
    });

    applyVisibility(matchingCards);
    updateBubbles(keywords);
  }

  // Input typing listener
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value;
    applyFilter();
  });

  // Select dropdown filter listeners
  catSelect?.addEventListener('change', (e) => {
    activeCat = (e.target as HTMLSelectElement).value;
    applyFilter();
  });

  // --- Tag Picker Scroll Navigation ---
  const tagPickerContainer = document.getElementById('tag-picker-container');
  const scrollLeftBtn = document.getElementById('tag-scroll-left') as HTMLButtonElement;
  const scrollRightBtn = document.getElementById('tag-scroll-right') as HTMLButtonElement;

  function updateScrollArrows() {
    if (!tagPickerContainer || !scrollLeftBtn || !scrollRightBtn) return;
    const { scrollLeft, scrollWidth, clientWidth } = tagPickerContainer;
    
    // Disable arrows based on scroll position limits
    scrollLeftBtn.disabled = scrollLeft <= 1;
    scrollRightBtn.disabled = scrollLeft + clientWidth >= scrollWidth - 2;
    
    // Only display arrows if container actually has overflow
    const hasOverflow = scrollWidth > clientWidth;
    scrollLeftBtn.style.display = hasOverflow ? 'flex' : 'none';
    scrollRightBtn.style.display = hasOverflow ? 'flex' : 'none';
  }

  // Smooth scroll offset on arrow click
  scrollLeftBtn?.addEventListener('click', () => {
    tagPickerContainer?.scrollBy({ left: -140, behavior: 'smooth' });
  });

  scrollRightBtn?.addEventListener('click', () => {
    tagPickerContainer?.scrollBy({ left: 140, behavior: 'smooth' });
  });

  tagPickerContainer?.addEventListener('scroll', updateScrollArrows, { passive: true });
  window.addEventListener('resize', updateScrollArrows, { passive: true });

  const allTagBtn = document.getElementById('all-tag-btn');

  // Static All Tag button click listener
  allTagBtn?.addEventListener('click', () => {
    // Remove active state from all scrolling tag buttons
    tagPicker?.querySelectorAll('.tag-picker-item').forEach(b => b.classList.remove('is-active'));
    allTagBtn.classList.add('is-active');
    activeTag = '';
    applyFilter();
    setTimeout(updateScrollArrows, 50);
  });

  // Tag scrollable picker click listener using event delegation
  tagPicker?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.tag-picker-item');
    if (!btn) return;

    const filter = (btn as HTMLElement).dataset.filter ?? '';
    activeTag = filter;

    // Set active state on clicked button and remove from all others (including All tag button)
    allTagBtn?.classList.remove('is-active');
    tagPicker.querySelectorAll('.tag-picker-item').forEach(b => {
      b.classList.toggle('is-active', b === btn);
    });

    applyFilter();
    // Re-check arrows in case item selection changes container layout (unlikely but safe)
    setTimeout(updateScrollArrows, 50);
  });

  // Clear search and filters trigger
  clearBtn?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    if (catSelect) catSelect.value = '';
    searchQuery = '';
    activeCat = '';
    activeTag = '';
    // Reset tag picker active states
    allTagBtn?.classList.add('is-active');
    tagPicker?.querySelectorAll('.tag-picker-item').forEach(btn => {
      btn.classList.remove('is-active');
    });
    applyFilter();
    updateScrollArrows();
  });

  // Mobile space-savers: shorter placeholder + abbreviated "All Categories"
  if (window.matchMedia('(max-width: 768px)').matches) {
    if (searchInput) searchInput.placeholder = 'Search projects';
    const allCatOpt = catSelect?.querySelector('option[value=""]');
    if (allCatOpt) allCatOpt.textContent = 'CTGRY';
  }

  // Pre-load search query from URL params if present (links from skillset click on About page)
  const urlParams = new URLSearchParams(window.location.search);
  const qParam = urlParams.get('search') || urlParams.get('q');
  if (qParam) {
    searchQuery = qParam;
    if (searchInput) searchInput.value = qParam;
  }

  // Initialize visibility and tag scroll arrows
  applyFilter();
  setTimeout(updateScrollArrows, 100);
</script>
