    pointer-events: none; /* taps fall through to the glass → close */
  }

  .project-lightbox__img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  /* Link (left) + ✕ (right) bar — sits in the gap right by the strip */
  .project-lightbox__bar {
    position: absolute;
    left: 0;
    right: 0;
    height: 44px;
    /* top set in JS — just above the strip (image on top) or just below it */
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px;
    box-sizing: border-box;
    pointer-events: none;
