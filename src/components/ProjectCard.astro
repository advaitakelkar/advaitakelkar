---
import fs from 'node:fs';
import path from 'node:path';
// Reusable project card — matches the projects-page card. Set showDescription
// to false (e.g. on the category tabs) to drop the intro + description column.
export interface Props {
  project: any;
  tagMap: Record<string, string>;
  catMap?: Record<string, string>;
  showDescription?: boolean;
}
const { project: p, tagMap, catMap = {}, showDescription = true } = Astro.props;
import { realText } from '../lib/content';

// Placeholder copy from the initial import never renders on cards
const intro = realText(p.data.smallIntro);
const desc = realText(p.data.description);

const tagsArr = (p.data.tags ?? []).map((t: any) => tagMap[t.id] || t.id);

// Find first collaborator tag (Studio 823 / FKD Workshop) or default to the first tag
const studioTag = tagsArr.find((t: string) => t === 'Studio 823' || t === 'FKD Workshop');
const displayStudio = p.data.collaborator || studioTag || tagsArr[0];

const leftFacts = [p.data.year, p.data.location, displayStudio].filter(Boolean).join(', ');
const rightTags = tagsArr.filter((t: string) => t !== 'Studio 823' && t !== 'FKD Workshop' && t !== p.data.collaborator).join(', ');

const allImgs: string[] = [];
if (p.id === 'ai-works') {
  try {
    const aiWorksDir = path.resolve('public/images/ai-works');
    if (fs.existsSync(aiWorksDir)) {
      const folders = fs.readdirSync(aiWorksDir).filter(f => {
        const fullPath = path.join(aiWorksDir, f);
        return fs.statSync(fullPath).isDirectory();
      }).sort();

      for (const folder of folders) {
        const folderPath = path.join(aiWorksDir, folder);
        const files = fs.readdirSync(folderPath).filter(file => {
          const ext = path.extname(file).toLowerCase();
          return ['.png', '.jpg', '.jpeg', '.webp'].includes(ext);
        }).sort();

        if (files.length > 0) {
          allImgs.push(`/images/ai-works/${folder}/${files[0]}`);
        }
      }
    }
  } catch (e) {
    console.error("Error reading AI works folders in ProjectCard:", e);
  }
} else {
  if (p.data.coverImage) allImgs.push(p.data.coverImage);
  if (p.data.multiImage) allImgs.push(...(p.data.multiImage as string[]));
}
---

<a href={`/projects/${p.id}`} class="pcard" data-name={p.data.name}>
  <div class="pcard__row-first">
    <h2 class="pcard__name">{p.data.name}</h2>
    <div class="pcard__right-wrap">
      <div class="pcard__image-col">
        <div class:list={["pcard__thumbs", allImgs.length < 5 && "is-few"]}>
          {allImgs.map((src, idx) => (
            <span class="pcard__thumb"><img src={src} alt={`${p.data.name} ${idx + 1}`} loading="lazy" /></span>
          ))}
        </div>
      </div>
      <svg class="link-arrow pcard__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
    </div>
  </div>

  <div class="pcard__row-second">
    <span class="pcard__meta-left">{leftFacts}</span>
    <span class="pcard__meta-right">{rightTags}</span>
  </div>
</a>

<style>
  .pcard {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--_tokens---color--fg);
    background: transparent;
    box-shadow: none;
    width: 100%;
    box-sizing: border-box;
    border-bottom: 1px solid var(--_tokens---color--line-soft);
    padding: 1.5rem 0;
  }

  .pcard:first-child {
    border-top: none;
  }

  .pcard__row-first {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 24px;
  }

  .pcard__name {
    font-size: clamp(1.9rem, 1.3rem + 2.8vw, 3.2rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex-shrink: 1;
    min-width: 0;
  }

  .pcard__right-wrap {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 24px;
    flex-shrink: 0;
  }

  .pcard__image-col {
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .pcard__thumbs {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 4px;
  }

  .pcard__thumb {
    width: 64px;
    height: 64px;
    overflow: hidden;
    display: block;
    aspect-ratio: 1;
    flex-shrink: 0;
    cursor: pointer;
  }

  .pcard__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: filter 0.15s ease, opacity 0.15s ease;
  }

  .pcard__arrow {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    color: var(--_tokens---color--fg);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pcard:hover .pcard__arrow {
    transform: translate(3px, -3px);
  }

  .pcard__row-second {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    margin-top: 12px;
    font-size: var(--_tokens---type--micro);
    color: var(--_tokens---color--muted);
  }

  .pcard__meta-left {
    font-weight: 400;
  }

  .pcard__meta-right {
    font-weight: 400;
    text-align: right;
  }

  /* While scrubbing: active thumb in colour, the rest grayscale */
  .pcard.is-previewing .pcard__thumb img { filter: grayscale(1); opacity: 0.5; }
  .pcard.is-previewing .pcard__thumb.is-active img { filter: none; opacity: 1; }

  @media (max-width: 768px) {
    .pcard {
      padding: 1rem 0;
    }

    .pcard__row-first {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      gap: 12px 8px;
    }

    .pcard__name {
      grid-column: 1;
      grid-row: 1;
      white-space: normal;
      overflow: visible;
      text-overflow: clip;
      font-size: var(--_tokens---type--medium);
    }

    .pcard__right-wrap {
      display: contents;
    }

    .pcard__image-col {
      grid-column: 1 / -1;
      grid-row: 2;
      width: 100%;
    }

    .pcard__thumbs {
      width: 100%;
      gap: 2px;
    }

    .pcard__thumb {
      flex: 1 1 0%;
      width: auto;
      height: auto;
      aspect-ratio: 1;
    }

    .pcard__arrow {
      grid-column: 2;
      grid-row: 1;
      width: 20px;
      height: 20px;
    }

    .pcard__row-second {
      margin-top: 8px;
      font-size: var(--_tokens---type--micro);
    }

    /* Lift the strip above the mobile glass and scrub (no native scroll) */
    .pcard.is-previewing .pcard__thumbs {
      position: relative;
      z-index: 121;
      touch-action: pan-x;
    }
  }
</style>

<script>
  // Scrub preview for category project cards — mirrors the projects page.
  // Desktop: a frosted preview fills the LEFT of the screen; hover/drag the
  // thumbnails to scrub. Mobile: a frosted lightbox where the image sits ABOVE
  // or BELOW the strip (whichever has room); the strip stays sharp and scrubs.
  function initPcardScrub() {
    const strips = Array.from(document.querySelectorAll<HTMLElement>('.pcard__thumbs'));
    if (!strips.length) return;
    const isHover = window.matchMedia('(hover: hover)').matches;

    // Each load: keep 5 random thumbs per strip (random pick, random order),
    // drop the rest — five squares always fill the row, nothing scrolls.
    strips.forEach((strip) => {
      if ((strip as any)._pruned) return; (strip as any)._pruned = true;
      const items = Array.from(strip.children) as HTMLElement[];
      for (let i = items.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [items[i], items[j]] = [items[j], items[i]];
      }
      items.slice(5).forEach(el => el.remove());
      items.slice(0, 5).forEach(el => strip.appendChild(el));
    });

    // Overlays must live inside .page-wrap (a z-index:1 stacking context) so the
    // nav/breadcrumb stay above them and the lifted mobile strip can sit on top.
    const host = (document.querySelector('.page-wrap') as HTMLElement) || document.body;
    const imgsOf = (strip: HTMLElement) => Array.from(strip.querySelectorAll('img')) as HTMLImageElement[];
    const imgAtX = (imgs: HTMLImageElement[], x: number) => {
      for (const im of imgs) { const r = im.getBoundingClientRect(); if (x >= r.left && x <= r.right) return im; }
      return imgs[imgs.length - 1];
    };
    const mark = (imgs: HTMLImageElement[], active: HTMLImageElement | null) =>
      imgs.forEach(im => im.closest('.pcard__thumb')?.classList.toggle('is-active', im === active));

    if (isHover) {
      // ── Desktop: left-side frosted preview ──
      let pv = document.getElementById('pcard-preview');
      if (!pv) {
        pv = document.createElement('div');
        pv.id = 'pcard-preview';
        Object.assign(pv.style, {
          position: 'fixed', left: '44px', top: '0', bottom: '0', width: '56vw', zIndex: '95',
          display: 'flex', alignItems: 'center', justifyContent: 'center', padding: '48px', boxSizing: 'border-box',
          backgroundColor: 'var(--_tokens---color--bg-glass)',
          backdropFilter: 'blur(20px)', webkitBackdropFilter: 'blur(20px)',
          opacity: '0', pointerEvents: 'none', transition: 'opacity 0.18s ease',
        } as Partial<CSSStyleDeclaration>);
        const im = document.createElement('img');
        Object.assign(im.style, { maxWidth: '100%', maxHeight: '90vh', objectFit: 'contain', display: 'block' } as Partial<CSSStyleDeclaration>);
        pv.appendChild(im);
        host.appendChild(pv);
      }
      const pvImg = pv.querySelector('img') as HTMLImageElement;

      strips.forEach((strip) => {
        if ((strip as any)._pc) return; (strip as any)._pc = true;
        const imgs = imgsOf(strip); if (!imgs.length) return;
        const card = strip.closest('.pcard');
        strip.addEventListener('pointerenter', () => { pvImg.src = imgs[0].src; pv!.style.opacity = '1'; card?.classList.add('is-previewing'); mark(imgs, imgs[0]); });
        strip.addEventListener('pointermove', (e) => { const t = imgAtX(imgs, (e as PointerEvent).clientX); pvImg.src = t.src; mark(imgs, t); });
        strip.addEventListener('pointerleave', () => { pv!.style.opacity = '0'; card?.classList.remove('is-previewing'); mark(imgs, null); });
      });
    } else {
      // ── Mobile: lightbox anchored above/below the strip ──
      let lb = document.getElementById('pcard-lb');
      if (!lb) {
        lb = document.createElement('div');
        lb.id = 'pcard-lb';
        Object.assign(lb.style, {
          position: 'fixed', left: '44px', top: '0', right: '0', bottom: '0', zIndex: '120', display: 'none',
          backgroundColor: 'var(--_tokens---color--bg-glass)',
          backdropFilter: 'blur(20px)', webkitBackdropFilter: 'blur(20px)',
        } as Partial<CSSStyleDeclaration>);
        const area = document.createElement('div');
        area.className = 'pcard-lb-area';
        Object.assign(area.style, { position: 'absolute', left: '0', right: '0', display: 'flex', alignItems: 'center', justifyContent: 'center', padding: '16px', boxSizing: 'border-box', pointerEvents: 'none' } as Partial<CSSStyleDeclaration>);
        const im = document.createElement('img');
        Object.assign(im.style, { maxWidth: '100%', maxHeight: '100%', objectFit: 'contain', display: 'block' } as Partial<CSSStyleDeclaration>);
        area.appendChild(im);

        // Bar container (contains Go to project link and Close button)
        const bar = document.createElement('div');
        bar.id = 'pcard-lb-bar';
        bar.className = 'pcard-lb-bar';
        Object.assign(bar.style, {
          position: 'absolute', left: '0', right: '0', height: '44px', display: 'flex', alignItems: 'center', justifyContent: 'space-between', padding: '0 16px', boxSizing: 'border-box', pointerEvents: 'none'
        } as Partial<CSSStyleDeclaration>);

        const link = document.createElement('a');
        link.id = 'pcard-lb-link';
        link.className = 'pcard-lb-link';
        link.innerHTML = '<span>Go to project</span><svg viewBox="0 0 24 24" style="width: 0.9em; height: 0.9em; flex-shrink: 0; margin-left: 6px;" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"/><polyline points="10 6 18 6 18 14"/></svg>';
        Object.assign(link.style, {
          display: 'inline-flex', alignItems: 'center', color: 'var(--_tokens---color--fg)', textDecoration: 'none', fontFamily: 'var(--_tokens---font--mono)', fontSize: 'var(--_tokens---type--micro)', fontWeight: '500', letterSpacing: '0.05em', pointerEvents: 'auto', outline: 'none'
        } as Partial<CSSStyleDeclaration>);

        const close = document.createElement('button');
        close.className = 'pcard-lb-close';
        close.setAttribute('aria-label', 'Close');
        close.innerHTML = '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
        Object.assign(close.style, { display: 'flex', alignItems: 'center', justifyContent: 'center', background: 'transparent', border: 'none', color: 'var(--_tokens---color--fg)', cursor: 'pointer', pointerEvents: 'auto', width: '40px', height: '40px', padding: '0', margin: '0' } as Partial<CSSStyleDeclaration>);

        bar.appendChild(link);
        bar.appendChild(close);
        
        // Title container
        const title = document.createElement('h2');
        title.id = 'pcard-lb-title';
        title.className = 'pcard-lb-title';
        Object.assign(title.style, {
          position: 'absolute', left: '0', right: '0', display: 'flex', justifyContent: 'flex-start', textAlign: 'left', padding: '16px 16px', margin: '0', boxSizing: 'border-box', fontWeight: '600', color: 'var(--_tokens---color--fg)', pointerEvents: 'none', fontFamily: 'var(--_tokens---font--sans)', lineHeight: '1.25'
        } as Partial<CSSStyleDeclaration>);

        lb.appendChild(area); lb.appendChild(bar); lb.appendChild(title);
        host.appendChild(lb);
      }
      const lbEl = lb as HTMLElement;
      const area = lbEl.querySelector('.pcard-lb-area') as HTMLElement;
      const lbImg = area.querySelector('img') as HTMLImageElement;
      const lbBar = lbEl.querySelector('#pcard-lb-bar') as HTMLElement;
      const lbLink = lbEl.querySelector('#pcard-lb-link') as HTMLAnchorElement;
      const lbTitle = lbEl.querySelector('#pcard-lb-title') as HTMLElement | null;
      let activeStrip: HTMLElement | null = null;

      const position = (strip: HTMLElement) => {
        const r = strip.getBoundingClientRect();
        const vh = window.innerHeight;
        if (vh - r.bottom >= r.top) { // image below the strip
          area.style.top = (r.bottom + 44) + 'px'; area.style.bottom = '84px';
          lbBar.style.top = r.bottom + 'px'; lbBar.style.bottom = 'auto';

          // Title is on TOP (above the strip)
          if (lbTitle) {
            lbTitle.style.top = '0px';
            lbTitle.style.bottom = (vh - r.top) + 'px';
            lbTitle.style.paddingTop = '20px';
            lbTitle.style.paddingBottom = '12px';
            lbTitle.style.alignItems = 'flex-end';
            const availableHeight = r.top - 20 - 12;
            const fontSizePx = Math.max(18, Math.min(36, availableHeight * 0.12));
            lbTitle.style.fontSize = `${fontSizePx}px`;
          }
        } else { // image above the strip
          area.style.top = '0px'; area.style.bottom = (vh - r.top + 44) + 'px';
          lbBar.style.top = (r.top - 44) + 'px'; lbBar.style.bottom = 'auto';

          // Title is on BOTTOM (below the strip)
          if (lbTitle) {
            lbTitle.style.top = r.bottom + 'px';
            lbTitle.style.bottom = '0px';
            lbTitle.style.paddingTop = '12px';
            lbTitle.style.paddingBottom = '84px';
            lbTitle.style.alignItems = 'flex-start';
            const availableHeight = (vh - r.bottom) - 84 - 12;
            const fontSizePx = Math.max(18, Math.min(36, availableHeight * 0.12));
            lbTitle.style.fontSize = `${fontSizePx}px`;
          }
        }
      };
      const open = (strip: HTMLElement, im: HTMLImageElement) => {
        activeStrip = strip;
        const card = strip.closest('.pcard') as HTMLElement;
        if (lbTitle) lbTitle.textContent = card?.dataset.name || '';
        const href = card?.getAttribute('href');
        if (lbLink && href) lbLink.href = href;
        position(strip);
        lbImg.src = im.src;
        card?.classList.add('is-previewing');
        lbEl.style.display = 'block';
        document.documentElement.style.overflow = 'hidden'; document.body.style.overflow = 'hidden';
      };
      const close = () => {
        lbEl.style.display = 'none';
        document.documentElement.style.overflow = ''; document.body.style.overflow = '';
        activeStrip?.closest('.pcard')?.classList.remove('is-previewing');
        activeStrip = null;
      };

      if (!(lbEl as any)._bound) {
        (lbEl as any)._bound = true;
        lbEl.addEventListener('click', close);
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
        window.addEventListener('resize', () => {
          if (activeStrip && lbEl.style.display === 'block') position(activeStrip);
        });
      }

      strips.forEach((strip) => {
        if ((strip as any)._pc) return; (strip as any)._pc = true;
        const imgs = imgsOf(strip); if (!imgs.length) return;
        imgs.forEach((im) => {
          im.closest('.pcard__thumb')?.addEventListener('click', (e) => {
            e.preventDefault(); e.stopPropagation();
            mark(imgs, im); open(strip, im);
          });
        });
        strip.addEventListener('pointermove', (e) => {
          if (lbEl.style.display !== 'block' || activeStrip !== strip) return;
          const t = imgAtX(imgs, (e as PointerEvent).clientX); lbImg.src = t.src; mark(imgs, t);
        });
      });
    }
  }

  initPcardScrub();
  document.addEventListener('astro:after-swap', initPcardScrub);
</script>
