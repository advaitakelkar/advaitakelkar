---
// Site-wide soft lock for project detail pages. Password: advt.
// Public pages (home, about, projects index, categories) stay open.
// State lives in sessionStorage; the SideNav lock toggle ([data-lock-toggle])
// can lock/unlock the whole site at once.
---

<div class="site-lock" id="site-lock" hidden aria-hidden="true">
  <button class="site-lock__close" id="site-lock-close" type="button" aria-label="Close">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
  <div class="site-lock__panel">
    <svg class="site-lock__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="4" y="10.5" width="16" height="10.5" rx="2.2"></rect>
      <path d="M8 10.5V7a4 4 0 0 1 8 0v3.5"></path>
      <circle cx="12" cy="15.4" r="1.3"></circle>
      <line x1="12" y1="16.7" x2="12" y2="18.4"></line>
    </svg>
    <p class="site-lock__title">Private project</p>
    <p class="site-lock__sub">Enter the password to open the project archive.</p>
    <form class="site-lock__form" id="site-lock-form">
      <input class="site-lock__input" id="site-lock-input" type="password" placeholder="Password" autocomplete="current-password" aria-label="Password" />
      <button class="site-lock__btn" type="submit" aria-label="Enter password">
        <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
          <line x1="6" y1="18" x2="18" y2="6"></line>
          <polyline points="10 6 18 6 18 14"></polyline>
        </svg>
      </button>
    </form>
    <p class="site-lock__error" id="site-lock-error" aria-live="polite"></p>
  </div>
</div>

<script>
  const PASSWORD = 'advt';       // Tier 1 — unlocks viewing the gated project pages
  const EDIT_PASSWORD = 'edit';  // Tier 2 — enters inline Edit Mode (localhost only)
  const KEY = 'ak-project-access';

  const isLocal = ['localhost', '127.0.0.1', '[::1]'].includes(location.hostname);

  const lock  = document.getElementById('site-lock');
  const form  = document.getElementById('site-lock-form');
  const input = document.getElementById('site-lock-input') as HTMLInputElement | null;
  const error = document.getElementById('site-lock-error');

  // On localhost, hint that this gate doubles as the editing entrance.
  if (isLocal) {
    const sub = document.querySelector('.site-lock__sub');
    if (sub) sub.textContent = 'Enter the password to view — or the edit password to edit text in place.';
  }

  const isUnlocked = () => sessionStorage.getItem(KEY) === PASSWORD;

  const BYPASS_SLUGS = [
    'alt-verse',
    'architect-x-architects',
    'future-of-dance',
    'indian-royals',
    'sups-cards',
    'sups-in-the-hinterland',
    'human-pods'
  ];

  const onProjectPage = () => {
    const p = window.location.pathname.replace(/\/$/, '') || '/';
    if (!p.startsWith('/projects/') || p === '/projects') return false;
    const slug = p.split('/').pop() || '';
    if (BYPASS_SLUGS.includes(slug)) return false;
    return true;
  };

  function reflectToggles() {
    document.querySelectorAll('[data-lock-toggle]').forEach(t =>
      t.setAttribute('data-unlocked', String(isUnlocked()))
    );
  }

  function openLock() {
    if (!lock) return;
    lock.hidden = false;
    lock.setAttribute('aria-hidden', 'false');
    document.documentElement.style.overflow = 'hidden';
    document.body.style.overflow = 'hidden';
    setTimeout(() => input?.focus(), 60);
  }
  function closeLock() {
    if (!lock) return;
    lock.hidden = true;
    lock.setAttribute('aria-hidden', 'true');
    document.documentElement.style.overflow = '';
    document.body.style.overflow = '';
    if (error) error.textContent = '';
  }

  // Gate the current page: project pages require unlock; everything else is open.
  function applyGate() {
    if (!isUnlocked() && onProjectPage()) openLock();
    else closeLock();
    reflectToggles();
  }

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (input && isLocal && input.value === EDIT_PASSWORD) {
      // Edit Mode: also unlock previews so project pages are viewable while editing.
      sessionStorage.setItem(KEY, PASSWORD);
      input.value = '';
      closeLock();
      reflectToggles();
      document.dispatchEvent(new Event('ak:editmode:on'));
    } else if (input && input.value === PASSWORD) {
      sessionStorage.setItem(KEY, PASSWORD);
      input.value = '';
      applyGate();
    } else {
      if (error) error.textContent = 'Incorrect password.';
      input?.focus();
      input?.select();
    }
  });

  // SideNav lock toggle.
  // • On localhost it's the Edit-Mode entrance: open the password screen (or, if
  //   already editing, leave it to the toolbar's Exit button).
  // • On the live site it keeps its original meaning: unlocked → re-lock,
  //   locked → open the preview password screen.
  // Capture phase so it intercepts before the surrounding side-nav bar's click
  // (which would otherwise open the nav panel).
  document.addEventListener('click', (e) => {
    const toggle = (e.target as HTMLElement).closest('[data-lock-toggle]');
    if (!toggle) return;
    e.stopPropagation();
    e.preventDefault();
    if (isLocal) {
      openLock();
      reflectToggles();
      return;
    }
    if (isUnlocked()) {
      sessionStorage.removeItem(KEY);
      applyGate();
    } else {
      openLock();
      reflectToggles();
    }
  }, true);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lock && !lock.hidden && !onProjectPage()) closeLock();
  });

  // ✕ close: on a locked project page there's nothing to reveal behind the
  // gate, so step back out instead of just hiding it.
  document.getElementById('site-lock-close')?.addEventListener('click', () => {
    if (onProjectPage()) {
      if (history.length > 1) history.back();
      else window.location.href = '/projects';
    } else {
      closeLock();
    }
  });

  applyGate();
  document.addEventListener('astro:after-swap', applyGate);
</script>

<style>
  .site-lock {
    position: fixed;
    left: 44px; /* clear the side-nav bar */
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 90; /* over the page content, under breadcrumb (100) + side nav (200) */
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    box-sizing: border-box;
    background-color: var(--_tokens---color--bg);
  }
  .site-lock[hidden] { display: none; }

  .site-lock__panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
    width: min(100%, 420px);
  }

  /* ✕ close — top-right corner of the overlay */
  .site-lock__close {
    position: absolute;
    top: 18px;
    right: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid var(--_tokens---color--line-soft);
    border-radius: 50%;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s;
  }
  .site-lock__close svg { width: 16px; height: 16px; }
  .site-lock__close:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  .site-lock__icon {
    width: clamp(72px, 14vh, 110px);
    height: clamp(72px, 14vh, 110px);
    color: var(--_tokens---color--fg);
    margin-bottom: 4px;
  }

  .site-lock__title {
    font-size: var(--_tokens---type--medium);
    font-weight: 500;
    color: var(--_tokens---color--fg);
    margin: 0;
  }
  .site-lock__sub {
    font-size: var(--_tokens---type--micro);
    color: var(--_tokens---color--muted);
    margin: 0;
  }

  /* One pill field; the submit arrow floats inside its right edge —
     same single-bar language as the site's search fields */
  .site-lock__form {
    position: relative;
    display: flex;
    width: min(100%, 360px);
    margin-top: 8px;
  }
  .site-lock__input {
    flex: 1;
    min-width: 0;
    height: 48px;
    padding: 0 56px 0 18px; /* right side clears the inline arrow */
    border: 1px solid var(--_tokens---color--line);
    border-radius: var(--_tokens---radius--pill);
    font: inherit;
    font-size: var(--_tokens---type--small);
    background: var(--_tokens---color--bg);
    color: var(--_tokens---color--fg);
    outline: none;
  }
  .site-lock__btn {
    position: absolute;
    right: 5px;
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: none;
    border-radius: 50%;
    background: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .site-lock__btn svg { width: 16px; height: 16px; }
  .site-lock__btn:hover { opacity: 0.85; }
  .site-lock__error {
    min-height: 1.2em;
    font-size: var(--_tokens---type--micro);
    color: var(--_tokens---color--muted);
    margin: 0;
  }

  @media (max-width: 767px) {
    .site-lock { padding: 20px; }
  }
</style>
