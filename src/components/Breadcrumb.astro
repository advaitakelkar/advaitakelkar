---
import { getCollection } from 'astro:content';

export interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

// Fetch projects and categories
const allProjects = await getCollection('projects');
const allCats = await getCollection('categories');

const categoryDisplayNames: Record<string, string> = {
  'studio-823': '823',
  'faizan-khatri': 'FKD',
  'archv': 'ARCHV',
  'scad': 'SCAD',
  'collaboration': 'COLLAB',
  'freelancer': 'FREE'
};

const getCatDisplayName = (id: string, def: string) => categoryDisplayNames[id] || def;

const projects = [...allProjects].sort((a, b) => a.data.name.localeCompare(b.data.name));
const categories = [...allCats].sort((a, b) => 
  getCatDisplayName(a.id, a.data.displayName).localeCompare(getCatDisplayName(b.id, b.data.displayName))
);

// Normalize path for matching (ignoring trailing slash)
const normalizedPath = currentPath.replace(/\/$/, '') || '/';

// Determine active state for parent links
const isHome = normalizedPath === '/';
const isAbout = normalizedPath === '/about';
const isProjectsIndex = normalizedPath === '/projects';
const isProjectPage = normalizedPath.startsWith('/projects/') && !isProjectsIndex;

// Extract current project ID, name, and category ID
let currentProjectId = '';
let currentProjectCatId = '';
let currentProjectName = '';
let prevProjectUrl = '';
let nextProjectUrl = '';

let activeProject = null;

if (isProjectPage) {
  const parts = normalizedPath.split('/').filter(Boolean);
  const projectId = parts[1] || '';
  activeProject = projects.find(p => p.id === projectId);
}

// Fallback to the latest project (first in the list) if not on a project page
if (!activeProject && projects.length > 0) {
  activeProject = projects[0];
}

if (activeProject) {
  currentProjectId = activeProject.id;
  currentProjectName = activeProject.data.name;
  if (activeProject.data.category) {
    currentProjectCatId = activeProject.data.category.id;
  }
  
  const idx = projects.findIndex(p => p.id === currentProjectId);
  if (idx !== -1) {
    const prevIdx = (idx - 1 + projects.length) % projects.length;
    const nextIdx = (idx + 1) % projects.length;
    prevProjectUrl = `/projects/${projects[prevIdx].id}`;
    nextProjectUrl = `/projects/${projects[nextIdx].id}`;
  }
}
---

<nav class="breadcrumb" aria-label="Secondary navigation">
  <div class:list={["breadcrumb__list", isProjectPage && "breadcrumb__list--project-page"]}>
    <!-- Home -->
    <a href="/" class:list={["breadcrumb__link", "breadcrumb__link--home", isHome && "is-active"]}>
      <span>Home</span>
      <svg class="link-arrow breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
        <line x1="6" y1="18" x2="18" y2="6"></line>
        <polyline points="10 6 18 6 18 14"></polyline>
      </svg>
    </a>
    <span class="breadcrumb__sep breadcrumb__sep--home" aria-hidden="true">/</span>

    <!-- About -->
    <a href="/about" class:list={["breadcrumb__link", "breadcrumb__link--about", isAbout && "is-active"]}>
      <span>About</span>
      <svg class="link-arrow breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
        <line x1="6" y1="18" x2="18" y2="6"></line>
        <polyline points="10 6 18 6 18 14"></polyline>
      </svg>
    </a>
    <span class="breadcrumb__sep breadcrumb__sep--about" aria-hidden="true">/</span>

    <!-- Projects -->
    <a href="/projects" class:list={["breadcrumb__link", "breadcrumb__link--projects", isProjectsIndex && "is-active"]}>
      <span>Projects</span>
      <svg class="link-arrow breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
        <line x1="6" y1="18" x2="18" y2="6"></line>
        <polyline points="10 6 18 6 18 14"></polyline>
      </svg>
    </a>
    <span class="breadcrumb__sep breadcrumb__sep--projects" aria-hidden="true">/</span>
  </div>

  <!-- Select Category & Project Dropdown Menu (outside links wrapper to prevent clipping) -->
  <div class:list={["breadcrumb__project-nav", isProjectPage && "is-active"]}>
    {prevProjectUrl && (
      <a href={prevProjectUrl} class="breadcrumb__arrow breadcrumb__arrow--prev" title="Previous Project" aria-label="Previous Project">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </a>
    )}

    <!-- Custom Dropdown Menu System -->
    <div class="breadcrumb__custom-dropdown" id="breadcrumb-custom-dropdown">
      <div class="breadcrumb__dropdown-trigger" id="breadcrumb-dropdown-trigger" aria-haspopup="true" aria-expanded="false">
        <input
          type="text"
          id="breadcrumb-search-input"
          placeholder={isProjectPage && currentProjectName ? currentProjectName : 'Search projects'}
          autocomplete="off"
          aria-label="Search projects"
        />
        <svg class="link-arrow breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
          <line x1="6" y1="18" x2="18" y2="6"></line>
          <polyline points="10 6 18 6 18 14"></polyline>
        </svg>
      </div>

      <div class="breadcrumb__dropdown-panel" id="breadcrumb-dropdown-panel">
        <!-- Column 1: Categories -->
        <div class="breadcrumb__menu-column breadcrumb__menu-column--categories">
          <button class="breadcrumb__cat-item is-active" data-cat-id="all" type="button">
            <span>All</span>
            <svg class="link-arrow breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <line x1="6" y1="18" x2="18" y2="6"></line>
              <polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </button>
          {categories.map(c => (
            <button class="breadcrumb__cat-item" data-cat-id={c.id} type="button">
              <span>{categoryDisplayNames[c.id] || c.data.displayName}</span>
              <svg class="link-arrow breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                <line x1="6" y1="18" x2="18" y2="6"></line>
                <polyline points="10 6 18 6 18 14"></polyline>
              </svg>
            </button>
          ))}
        </div>

        <!-- Column 2: Projects -->
        <div class="breadcrumb__menu-column breadcrumb__menu-column--projects">
          <!-- Back button for mobile viewports -->
          <button class="breadcrumb__back-btn" type="button" aria-label="Back to categories">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
            <span>Back</span>
          </button>
          
          <!-- All projects list -->
          <div class="breadcrumb__proj-list is-active" data-cat-id="all">
            {projects.map(p => (
              <a href={`/projects/${p.id}`} class:list={["breadcrumb__proj-item", currentProjectId === p.id && "is-active"]} data-cat-id={p.data.category?.id || ''}>
                <span class="breadcrumb__proj-name">{p.data.name}</span>
                <svg class="link-arrow breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                  <line x1="6" y1="18" x2="18" y2="6"></line>
                  <polyline points="10 6 18 6 18 14"></polyline>
                </svg>
              </a>
            ))}
          </div>

          <!-- Categorized projects lists -->
          {categories.map(c => {
            const catProjects = projects.filter(p => p.data.category?.id === c.id);
            return (
              <div class="breadcrumb__proj-list" data-cat-id={c.id}>
                {catProjects.length === 0 ? (
                  <div class="breadcrumb__proj-empty">No projects</div>
                ) : (
                  catProjects.map(p => (
                    <a href={`/projects/${p.id}`} class:list={["breadcrumb__proj-item", currentProjectId === p.id && "is-active"]} data-cat-id={p.data.category?.id || ''}>
                      <span class="breadcrumb__proj-name">{p.data.name}</span>
                      <svg class="link-arrow breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                        <line x1="6" y1="18" x2="18" y2="6"></line>
                        <polyline points="10 6 18 6 18 14"></polyline>
                      </svg>
                    </a>
                  ))
                )}
              </div>
            );
          })}
        </div>
      </div>
    </div>

    {nextProjectUrl && (
      <a href={nextProjectUrl} class="breadcrumb__arrow breadcrumb__arrow--next" title="Next Project" aria-label="Next Project">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </a>
    )}
  </div>
</nav>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    width: 100%;
    gap: 7px;
  }

  .breadcrumb__list {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 7px;
  }

  .breadcrumb__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    text-decoration: none;
    transition: background-color 0.2s, color 0.2s, border-color 0.2s, transform 0.15s, opacity 0.2s;
    opacity: 0.8;
    white-space: nowrap;
    font-family: var(--_tokens---font--mono);
    font-size: 9px;
    letter-spacing: 0.05em;
  }

  .breadcrumb__link:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    border-color: var(--_tokens---color--fg);
    opacity: 1;
  }

  .breadcrumb__link.is-active {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    border-color: var(--_tokens---color--fg);
    opacity: 1;
    font-weight: 500;
  }

  .breadcrumb__sep {
    display: none;
  }

  .breadcrumb__proj-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    text-align: left;
    flex: 1;
  }

  .breadcrumb__arrow-icon {
    width: 8px;
    height: 8px;
    flex-shrink: 0;
    opacity: 0.55;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .breadcrumb__link:hover .breadcrumb__arrow-icon,
  .breadcrumb__link:focus-visible .breadcrumb__arrow-icon,
  .breadcrumb__dropdown-trigger:hover .breadcrumb__arrow-icon,
  .breadcrumb__dropdown-trigger:focus-visible .breadcrumb__arrow-icon,
  .breadcrumb__cat-item:hover .breadcrumb__arrow-icon,
  .breadcrumb__cat-item:focus-visible .breadcrumb__arrow-icon,
  .breadcrumb__proj-item:hover .breadcrumb__arrow-icon,
  .breadcrumb__proj-item:focus-visible .breadcrumb__arrow-icon {
    opacity: 1;
  }

  /* Dropdown & Nav container styling */
  .breadcrumb__project-nav {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  /* Custom Dropdown Menu System styling */
  .breadcrumb__custom-dropdown {
    position: relative;
    display: inline-block;
  }

  .breadcrumb__dropdown-trigger {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    font-family: inherit;
    font-size: 9px;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0.05em;
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    border-radius: 999px;
    padding: 5px 12px;
    cursor: pointer;
    outline: none;
    white-space: nowrap;
    transition: background-color 0.2s, color 0.2s, border-color 0.2s;
  }

  .breadcrumb__project-nav.is-active .breadcrumb__dropdown-trigger {
    color: var(--_tokens---color--fg);
    border-color: var(--_tokens---color--fg);
  }

  .breadcrumb__project-nav.is-active .breadcrumb__dropdown-trigger:hover,
  .breadcrumb__project-nav.is-active .breadcrumb__dropdown-trigger:focus-within {
    color: var(--_tokens---color--bg);
  }

  .breadcrumb__dropdown-trigger:hover,
  .breadcrumb__dropdown-trigger:focus-within,
  .breadcrumb__dropdown-trigger[aria-expanded="true"] {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    border-color: var(--_tokens---color--fg);
  }

  #breadcrumb-search-input {
    background: none;
    border: none;
    outline: none;
    font-family: inherit;
    font-size: 9px;
    font-weight: 500;
    color: currentColor;
    width: 80px;
    padding: 0;
    margin: 0;
    letter-spacing: inherit;
    transition: color 0.2s;
  }

  #breadcrumb-search-input::placeholder {
    color: color-mix(in srgb, var(--_tokens---color--fg) 60%, transparent);
    transition: color 0.2s;
  }

  .breadcrumb__dropdown-trigger:hover #breadcrumb-search-input::placeholder,
  .breadcrumb__dropdown-trigger:focus-within #breadcrumb-search-input::placeholder {
    color: color-mix(in srgb, var(--_tokens---color--bg) 60%, transparent);
  }

  @media (min-width: 768px) {
    #breadcrumb-search-input {
      width: 120px;
    }
  }

  .breadcrumb__dropdown-panel {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    z-index: 500;
    background-color: transparent;
    border: none;
    border-radius: 8px;
    box-shadow: none;
    display: none; /* toggled via js */
    overflow: hidden;
    
    /* Default categories-only width */
    grid-template-columns: 110px;
    width: 110px;
    transition: width 0.15s ease, grid-template-columns 0.15s ease;
  }

  /* When docked on mobile bottom, let the dropdown open upwards! */
  @media (max-width: 767px) and (orientation: portrait) {
    .breadcrumb__dropdown-panel {
      top: auto;
      bottom: calc(100% + 6px);
      box-shadow: none;
    }
  }

  .breadcrumb__dropdown-panel.is-open {
    display: grid;
  }

  /* Show projects column on desktop when active category is hovered */
  @media (min-width: 768px) {
    .breadcrumb__dropdown-panel.has-active-cat {
      grid-template-columns: 110px 190px;
      width: 300px;
    }
  }

  /* Align to the right of trigger on mobile viewports so it opens leftward */
  @media (max-width: 767px) {
    .breadcrumb__dropdown-panel {
      left: auto;
      right: 0;
      grid-template-columns: 160px;
      width: 160px;
    }
    
    .breadcrumb__dropdown-panel.show-projects {
      grid-template-columns: 200px;
      width: 200px;
    }
  }

  .breadcrumb__menu-column {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 8px;
    box-sizing: border-box;
  }

  .breadcrumb__menu-column--categories {
    border-right: none;
    background-color: transparent;
  }

  .breadcrumb__menu-column--projects {
    display: none; /* hidden by default */
    background-color: transparent;
    width: 100%;
  }

  /* Show projects column on desktop when category active */
  @media (min-width: 768px) {
    .breadcrumb__dropdown-panel.has-active-cat .breadcrumb__menu-column--projects {
      display: flex;
      flex-direction: column;
    }
  }

  /* Stacked/replaced behavior on mobile */
  @media (max-width: 767px) {
    .breadcrumb__dropdown-panel.show-projects .breadcrumb__menu-column--categories {
      display: none;
    }

    .breadcrumb__dropdown-panel.show-projects .breadcrumb__menu-column--projects {
      display: flex;
      flex-direction: column;
    }
  }

  /* Back button for mobile categories navigation */
  .breadcrumb__back-btn {
    display: none;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    font-family: inherit;
    font-size: 9px;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0.05em;
    cursor: pointer;
    box-sizing: border-box;
    align-self: flex-start;
    margin-bottom: 6px;
    transition: background-color 0.2s, color 0.2s, border-color 0.2s;
    width: auto;
    flex-shrink: 0;
  }

  .breadcrumb__back-btn svg {
    width: 8px;
    height: 8px;
  }

  .breadcrumb__back-btn:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    border-color: var(--_tokens---color--fg);
  }

  @media (max-width: 767px) {
    .breadcrumb__back-btn {
      display: flex;
    }
  }

  .breadcrumb__cat-item,
  .breadcrumb__proj-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 5px 10px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    font-family: inherit;
    font-size: 9px;
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    box-sizing: border-box;
    transition: background-color 0.2s, color 0.2s, border-color 0.2s, transform 0.15s, opacity 0.2s;
  }

  .breadcrumb__cat-item:hover,
  .breadcrumb__cat-item.is-active,
  .breadcrumb__proj-item:hover,
  .breadcrumb__proj-item.is-active {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    border-color: var(--_tokens---color--fg);
  }

  .breadcrumb__proj-list {
    display: none;
  }

  .breadcrumb__proj-list.is-active {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .breadcrumb__proj-empty {
    font-size: 8px;
    color: var(--_tokens---color--muted);
    padding: 12px;
    text-align: center;
  }

  /* Arrows */
  .breadcrumb__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.8em;
    height: 1.8em;
    border-radius: 50%;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    transition: background-color 0.2s, color 0.2s, transform 0.2s;
    cursor: pointer;
    flex-shrink: 0;
  }

  .breadcrumb__arrow:hover {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    color: var(--_tokens---color--fg);
  }

  .breadcrumb__arrow svg {
    width: 1em;
    height: 1em;
  }

  /* Mobile Portrait responsive optimization: on project pages hide Home & About Me to fit dropdowns */
  @media (max-width: 767px) {
    .breadcrumb__list--project-page .breadcrumb__link--home,
    .breadcrumb__list--project-page .breadcrumb__sep--home,
    .breadcrumb__list--project-page .breadcrumb__link--about,
    .breadcrumb__list--project-page .breadcrumb__sep--about {
      display: none;
    }
  }

  /* Premium outlines/focus styles for keyboard navigability */
  .breadcrumb__link:focus-visible,
  .breadcrumb__dropdown-trigger:focus-visible,
  .breadcrumb__cat-item:focus-visible,
  .breadcrumb__proj-item:focus-visible,
  .breadcrumb__back-btn:focus-visible,
  .breadcrumb__arrow:focus-visible {
    outline: 2px solid var(--_tokens---color--fg);
    outline-offset: 4px;
    opacity: 1 !important;
  }
  /* Predictive Search Highlighting & Sorting rules */
  .breadcrumb__dropdown-panel.has-search .breadcrumb__cat-item:not(.is-match),
  .breadcrumb__dropdown-panel.has-search .breadcrumb__proj-item:not(.is-match) {
    opacity: 0.15;
    pointer-events: none;
  }

  .breadcrumb__dropdown-panel.has-search .breadcrumb__cat-item.is-match,
  .breadcrumb__dropdown-panel.has-search .breadcrumb__proj-item.is-match {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    border-color: var(--_tokens---color--fg);
    opacity: 1;
  }

  .breadcrumb__dropdown-panel.has-search .breadcrumb__cat-item.is-match .breadcrumb__arrow-icon,
  .breadcrumb__dropdown-panel.has-search .breadcrumb__proj-item.is-match .breadcrumb__arrow-icon {
    opacity: 1;
  }
</style>

<script>
  function setupCustomDropdown() {
    const trigger = document.getElementById('breadcrumb-dropdown-trigger');
    const panel = document.getElementById('breadcrumb-dropdown-panel');
    const dropdown = document.getElementById('breadcrumb-custom-dropdown');
    if (!trigger || !panel || !dropdown) return;

    const searchInput = document.getElementById('breadcrumb-search-input') as HTMLInputElement | null;

    // Toggle dropdown panel open/close on click/focus
    if (searchInput) {
      searchInput.addEventListener('focus', () => {
        panel.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
        
        // Auto-activate correct category on focus
        const activeCatProjItem = dropdown.querySelector('.breadcrumb__proj-list:not([data-cat-id="all"]) .breadcrumb__proj-item.is-active');
        if (activeCatProjItem) {
          const parentList = activeCatProjItem.closest('.breadcrumb__proj-list');
          const catId = parentList ? parentList.getAttribute('data-cat-id') : null;
          if (catId && catId !== 'all') {
            activateCategory(catId);
          }
        } else {
          activateCategory('all');
        }
      });

      trigger.addEventListener('click', (e) => {
        if (e.target !== searchInput) {
          searchInput.focus();
        }
      });

      // Predictive search input handler
      searchInput.addEventListener('input', () => {
        const query = searchInput.value.toLowerCase().trim();
        const projItems = Array.from(dropdown.querySelectorAll('.breadcrumb__proj-list[data-cat-id="all"] .breadcrumb__proj-item')) as HTMLElement[];
        const catItems = Array.from(dropdown.querySelectorAll('.breadcrumb__cat-item')) as HTMLElement[];
        
        if (!query) {
          panel.classList.remove('has-search');
          projItems.forEach(el => el.classList.remove('is-match'));
          catItems.forEach(el => el.classList.remove('is-match'));
          
          // Restore active category selection
          const activeCatBtn = panel.querySelector('.breadcrumb__cat-item.is-active');
          if (activeCatBtn) {
            activateCategory(activeCatBtn.getAttribute('data-cat-id') || 'all');
          } else {
            activateCategory('all');
          }
          return;
        }
        
        // Active search: always activate "all" categories list to search across all projects
        activateCategory('all');
        panel.classList.add('has-search');
        
        let hasMatches = false;
        projItems.forEach(el => {
          const nameText = el.querySelector('.breadcrumb__proj-name')?.textContent || el.textContent || '';
          const matches = nameText.toLowerCase().includes(query);
          if (matches) {
            el.classList.add('is-match');
            hasMatches = true;
            
            const catId = el.getAttribute('data-cat-id');
            if (catId) {
              const catBtn = dropdown.querySelector(`.breadcrumb__cat-item[data-cat-id="${catId}"]`);
              if (catBtn) {
                catBtn.classList.add('is-match');
              }
            }
          } else {
            el.classList.remove('is-match');
          }
        });
        
        if (hasMatches) {
          const allCatBtn = dropdown.querySelector('.breadcrumb__cat-item[data-cat-id="all"]');
          if (allCatBtn) {
            allCatBtn.classList.add('is-match');
          }
        } else {
          dropdown.querySelectorAll('.breadcrumb__cat-item').forEach(el => el.classList.remove('is-match'));
        }
      });
    }

    // Commented out for strict selection mode: has to select a project or you cannot exit
    /*
    document.addEventListener('click', (e) => {
      if (!dropdown.contains(e.target as Node)) {
        panel.classList.remove('is-open');
        panel.classList.remove('has-active-cat');
        panel.classList.remove('show-projects');
        trigger.setAttribute('aria-expanded', 'false');
      }
    });
    */

    // Handle category hover / click selections to filter projects list
    const catItems = Array.from(dropdown.querySelectorAll('.breadcrumb__cat-item')) as HTMLButtonElement[];
    const projLists = Array.from(dropdown.querySelectorAll('.breadcrumb__proj-list')) as HTMLDivElement[];

    function activateCategory(catId: string) {
      catItems.forEach(item => {
        item.classList.toggle('is-active', item.getAttribute('data-cat-id') === catId);
      });
      projLists.forEach(list => {
        list.classList.toggle('is-active', list.getAttribute('data-cat-id') === catId);
      });

      if (catId) {
        panel.classList.add('has-active-cat');
        if (window.innerWidth < 768) {
          panel.classList.add('show-projects');
        }
      }
    }

    catItems.forEach(item => {
      const catId = item.getAttribute('data-cat-id') || '';

      // Desktop Hover
      item.addEventListener('mouseenter', () => {
        if (window.innerWidth >= 768) {
          activateCategory(catId);
        }
      });

      // Mobile Click
      item.addEventListener('click', (e) => {
        e.stopPropagation();
        activateCategory(catId);
      });
    });

    // Mobile Back Button
    const backBtn = dropdown.querySelector('.breadcrumb__back-btn');
    backBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      panel.classList.remove('show-projects');
      panel.classList.remove('has-active-cat');
      catItems.forEach(item => item.classList.remove('is-active'));
      projLists.forEach(list => list.classList.remove('is-active'));
    });

    // Helper to update active project in the DOM on non-project page load
    function updateActiveProject(projectId: string) {
      const projItems = Array.from(dropdown.querySelectorAll('.breadcrumb__proj-list[data-cat-id="all"] .breadcrumb__proj-item')) as HTMLAnchorElement[];
      const idx = projItems.findIndex(el => el.getAttribute('href') === `/projects/${projectId}`);
      if (idx === -1) return;
      
      const activeEl = projItems[idx];
      const activeName = activeEl.querySelector('.breadcrumb__proj-name')?.textContent?.trim() || activeEl.textContent?.trim() || '';
      
      // Update trigger placeholder only if on a project page
      if (searchInput) {
        const path = window.location.pathname.replace(/\/$/, '') || '/';
        const isProjPage = path.startsWith('/projects/') && path !== '/projects';
        if (isProjPage) {
          searchInput.placeholder = activeName;
        } else {
          searchInput.placeholder = 'Search projects';
        }
      }
      
      // Update active class in all proj lists
      dropdown.querySelectorAll('.breadcrumb__proj-item').forEach(el => {
        const href = el.getAttribute('href');
        el.classList.toggle('is-active', href === `/projects/${projectId}`);
      });
      
      // Update arrows
      const prevIdx = (idx - 1 + projItems.length) % projItems.length;
      const nextIdx = (idx + 1) % projItems.length;
      
      const prevEl = projItems[prevIdx];
      const nextEl = projItems[nextIdx];
      
      const prevArrow = document.querySelector('.breadcrumb__arrow--prev') as HTMLAnchorElement | null;
      const nextArrow = document.querySelector('.breadcrumb__arrow--next') as HTMLAnchorElement | null;
      
      if (prevArrow) prevArrow.setAttribute('href', prevEl.getAttribute('href') || '#');
      if (nextArrow) nextArrow.setAttribute('href', nextEl.getAttribute('href') || '#');
    }

    // Sync localStorage latestProject
    const path = window.location.pathname.replace(/\/$/, '') || '/';
    const isProjPage = path.startsWith('/projects/') && path !== '/projects';
    
    if (isProjPage) {
      const parts = path.split('/').filter(Boolean);
      const currentProjId = parts[1] || '';
      if (currentProjId) {
        localStorage.setItem('latestProject', currentProjId);
      }
    } else {
      const latestProjId = localStorage.getItem('latestProject');
      if (latestProjId) {
        updateActiveProject(latestProjId);
      }
    }

    // On page load: auto-activate correct category if on a project detail view
    const activeCatProjItem = dropdown.querySelector('.breadcrumb__proj-list:not([data-cat-id="all"]) .breadcrumb__proj-item.is-active');
    if (activeCatProjItem) {
      const parentList = activeCatProjItem.closest('.breadcrumb__proj-list');
      const catId = parentList ? parentList.getAttribute('data-cat-id') : null;
      if (catId && catId !== 'all') {
        activateCategory(catId);
      }
    } else {
      activateCategory('all');
    }
  }

  function setupKeyboardNavigation() {
    if ((window as any).hasKbNavInit) return;
    (window as any).hasKbNavInit = true;

    window.addEventListener('keydown', (e) => {
      const active = document.activeElement as HTMLElement | null;
      
      // Ignore if typing in an input (except our search input when pressing ArrowDown or ArrowRight)
      if (active && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA' || active.isContentEditable)) {
        if (active.id === 'breadcrumb-search-input') {
          if (e.key !== 'ArrowDown' && e.key !== 'ArrowRight') {
            return;
          }
        } else {
          return;
        }
      }

      const panel = document.getElementById('breadcrumb-dropdown-panel') as HTMLElement | null;
      const trigger = document.getElementById('breadcrumb-dropdown-trigger') as HTMLElement | null;
      if (!panel || !trigger) return;
      const isOpen = panel.classList.contains('is-open');

      // 1. Arrow navigation when dropdown is closed (direct page turners)
      if (!isOpen) {
        if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
          const path = window.location.pathname.replace(/\/$/, '') || '/';
          if (e.key === 'ArrowRight') {
            if (path === '/') {
              e.preventDefault();
              window.location.href = '/about';
            } else if (path === '/about') {
              e.preventDefault();
              window.location.href = '/projects';
            }
          } else if (e.key === 'ArrowLeft') {
            if (path === '/projects') {
              e.preventDefault();
              window.location.href = '/about';
            } else if (path === '/about') {
              e.preventDefault();
              window.location.href = '/';
            }
          }
        }
        return;
      }

      // 2. Arrow navigation when dropdown is open
      if (isOpen && (e.key === 'ArrowRight' || e.key === 'ArrowLeft' || e.key === 'ArrowDown' || e.key === 'ArrowUp')) {
        e.preventDefault();
        const catItems = Array.from(panel.querySelectorAll('.breadcrumb__cat-item')) as HTMLElement[];
        const activeProjList = panel.querySelector('.breadcrumb__proj-list.is-active');
        const projItems = activeProjList 
          ? (Array.from(activeProjList.querySelectorAll('.breadcrumb__proj-item')) as HTMLElement[])
          : [];
        const backBtn = panel.querySelector('.breadcrumb__back-btn') as HTMLElement | null;
        
        // Combine projects and back button (if visible) into right column items
        const rightItems = [backBtn, ...projItems].filter((el): el is HTMLElement => !!el && el.offsetHeight > 0);

        const isCatFocused = catItems.includes(active!);
        const isRightFocused = rightItems.includes(active!);

        if (isCatFocused) {
          const idx = catItems.indexOf(active!);
          if (e.key === 'ArrowDown') {
            catItems[(idx + 1) % catItems.length].focus();
          } else if (e.key === 'ArrowUp') {
            catItems[(idx - 1 + catItems.length) % catItems.length].focus();
          } else if (e.key === 'ArrowRight') {
            // Activate category and focus first right item
            active!.click();
            setTimeout(() => {
              const updatedActiveProjList = panel.querySelector('.breadcrumb__proj-list.is-active');
              const updatedProjItems = updatedActiveProjList 
                ? (Array.from(updatedActiveProjList.querySelectorAll('.breadcrumb__proj-item')) as HTMLElement[])
                : [];
              const updatedRightItems = [backBtn, ...updatedProjItems].filter((el): el is HTMLElement => !!el && el.offsetHeight > 0);
              if (updatedRightItems.length > 0) {
                updatedRightItems[0].focus();
              }
            }, 60);
          }
        } else if (isRightFocused) {
          const idx = rightItems.indexOf(active!);
          if (e.key === 'ArrowDown') {
            rightItems[(idx + 1) % rightItems.length].focus();
          } else if (e.key === 'ArrowUp') {
            rightItems[(idx - 1 + rightItems.length) % rightItems.length].focus();
          } else if (e.key === 'ArrowLeft') {
            // Back to active category item
            const activeCat = panel.querySelector('.breadcrumb__cat-item.is-active') as HTMLElement | null;
            if (activeCat) {
              activeCat.focus();
            } else {
              catItems[0].focus();
            }
          }
        } else {
          // Dropdown is open but focus is elsewhere, focus first category
          if (catItems.length > 0) catItems[0].focus();
        }
      }
    });
  }

  // Initial load
  setupCustomDropdown();
  setupKeyboardNavigation();

  // Support Astro View Transitions
  document.addEventListener('astro:after-swap', () => {
    setupCustomDropdown();
    setupKeyboardNavigation();
  });
</script>
