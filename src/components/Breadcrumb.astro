---
import { getCollection } from 'astro:content';

export interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

// Fetch projects and categories
const allProjects = await getCollection('projects');
const allCats = await getCollection('categories');

const categoryDisplayNames: Record<string, string> = {
  'studio-823': '823',
  'faizan-khatri': 'FKD',
  'archv': 'ARCHV',
  'scad': 'SCAD',
  'collaboration': 'COLLAB',
  'freelancer': 'FREE'
};

const getCatDisplayName = (id: string, def: string) => categoryDisplayNames[id] || def;

const projects = [...allProjects].sort((a, b) => a.data.name.localeCompare(b.data.name));
const categories = [...allCats].sort((a, b) => 
  getCatDisplayName(a.id, a.data.displayName).localeCompare(getCatDisplayName(b.id, b.data.displayName))
);

// Normalize path for matching (ignoring trailing slash)
const normalizedPath = currentPath.replace(/\/$/, '') || '/';

// Determine active state for parent links
const isHome = normalizedPath === '/';
const isAbout = normalizedPath === '/about';
const isProjectsIndex = normalizedPath === '/projects';
const isProjectPage = normalizedPath.startsWith('/projects/') && !isProjectsIndex;

// Extract current project ID and category ID if on a project page
let currentProjectId = '';
let currentProjectCatId = '';
let prevProjectUrl = '';
let nextProjectUrl = '';

if (isProjectPage) {
  // Extract id from path (e.g. /projects/carlo -> carlo)
  const parts = normalizedPath.split('/').filter(Boolean);
  currentProjectId = parts[1] || '';
  
  const currentProject = projects.find(p => p.id === currentProjectId);
  if (currentProject && currentProject.data.category) {
    currentProjectCatId = currentProject.data.category.id;
  }
  
  const idx = projects.findIndex(p => p.id === currentProjectId);
  if (idx !== -1) {
    const prevIdx = (idx - 1 + projects.length) % projects.length;
    const nextIdx = (idx + 1) % projects.length;
    prevProjectUrl = `/projects/${projects[prevIdx].id}`;
    nextProjectUrl = `/projects/${projects[nextIdx].id}`;
  }
}
---

<nav class="breadcrumb" aria-label="Secondary navigation">
  <div class:list={["breadcrumb__list", isProjectPage && "breadcrumb__list--project-page"]}>
    <!-- Home -->
    <a href="/" class:list={["breadcrumb__link", "breadcrumb__link--home", isHome && "is-active"]}>Home</a>
    <span class="breadcrumb__sep breadcrumb__sep--home" aria-hidden="true">/</span>

    <!-- About Me -->
    <a href="/about" class:list={["breadcrumb__link", "breadcrumb__link--about", isAbout && "is-active"]}>About Me</a>
    <span class="breadcrumb__sep breadcrumb__sep--about" aria-hidden="true">/</span>

    <!-- Projects -->
    <a href="/projects" class:list={["breadcrumb__link", "breadcrumb__link--projects", isProjectsIndex && "is-active"]}>Projects</a>
    <span class="breadcrumb__sep breadcrumb__sep--projects" aria-hidden="true">/</span>

    <!-- Select Category & Project Dropdowns -->
    <div class:list={["breadcrumb__project-nav", isProjectPage && "is-active"]}>
      {isProjectPage && prevProjectUrl && (
        <a href={prevProjectUrl} class="breadcrumb__arrow breadcrumb__arrow--prev" title="Previous Project" aria-label="Previous Project">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </a>
      )}

      <!-- Category dropdown -->
      <div class="breadcrumb__select-wrap">
        <select id="breadcrumb-category-select" class="breadcrumb__select breadcrumb__select--category" aria-label="Filter projects by category">
          <option value="">All Categories</option>
          {categories.map(c => (
            <option value={c.id} selected={currentProjectCatId === c.id}>
              {categoryDisplayNames[c.id] || c.data.displayName}
            </option>
          ))}
        </select>
        <span class="breadcrumb__select-arrow" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </span>
      </div>

      <!-- Projects dropdown -->
      <div class="breadcrumb__select-wrap">
        <select id="breadcrumb-project-select" class="breadcrumb__select breadcrumb__select--project" aria-label="Quick nav projects">
          <option value="" disabled selected={!isProjectPage}>&lt; Select Project &gt;</option>
          {projects.map(p => (
            <option value={`/projects/${p.id}`} data-category={p.data.category ? p.data.category.id : ''} selected={currentProjectId === p.id}>
              {p.data.name}
            </option>
          ))}
        </select>
        <span class="breadcrumb__select-arrow" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </span>
      </div>

      {isProjectPage && nextProjectUrl && (
        <a href={nextProjectUrl} class="breadcrumb__arrow breadcrumb__arrow--next" title="Next Project" aria-label="Next Project">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </a>
      )}
    </div>
  </div>
</nav>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    width: 100%;
  }

  .breadcrumb__list {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 0;
    font-family: var(--_tokens---font--mono);
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.08em;
    text-transform: none;
    color: var(--_tokens---color--muted);
    width: 100%;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .breadcrumb__list::-webkit-scrollbar {
    display: none;
  }

  .breadcrumb__link {
    color: var(--_tokens---color--muted);
    text-decoration: none;
    transition: color 0.2s ease, opacity 0.2s ease;
    opacity: 0.6;
    white-space: nowrap;
  }

  .breadcrumb__link:hover {
    color: var(--_tokens---color--fg);
    opacity: 1;
  }

  .breadcrumb__link.is-active {
    color: var(--_tokens---color--fg);
    opacity: 1;
    font-weight: 300;
  }

  .breadcrumb__sep {
    margin-inline: 0.6em;
    opacity: 0.35;
    user-select: none;
    flex-shrink: 0;
  }

  /* Dropdown & Nav container styling */
  .breadcrumb__project-nav {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  .breadcrumb__project-nav.is-active .breadcrumb__select-wrap {
    border-color: var(--_tokens---color--fg);
  }

  /* Custom Select container styling */
  .breadcrumb__select-wrap {
    position: relative;
    display: inline-block;
  }

  .breadcrumb__select {
    appearance: none;
    -webkit-appearance: none;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    font-family: inherit;
    font-size: 9px;
    font-weight: 300;
    text-transform: none;
    letter-spacing: 0.06em;
    border: 1.5px solid transparent;
    border-radius: 6px;
    padding: 6px 30px 6px 12px;
    cursor: pointer;
    outline: none;
    text-overflow: ellipsis;
    white-space: nowrap;
    overflow: hidden;
    transition: background-color 0.2s, color 0.2s, border-color 0.2s;
  }

  .breadcrumb__select--category {
    min-width: 110px;
    max-width: 130px;
  }

  .breadcrumb__select--project {
    min-width: 140px;
    max-width: 180px;
  }

  .breadcrumb__project-nav.is-active .breadcrumb__select {
    color: var(--_tokens---color--fg);
    font-weight: 300;
  }

  .breadcrumb__select:hover {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
    color: var(--_tokens---color--fg);
  }

  .breadcrumb__select option {
    background-color: var(--_tokens---color--bg);
    color: var(--_tokens---color--fg);
    text-transform: none; /* Let option text preserve original capitalization */
    letter-spacing: normal;
    font-size: 14px; /* Highly readable in drop down menu */
  }

  .breadcrumb__select-arrow {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    width: 10px;
    height: 10px;
    pointer-events: none;
    color: currentColor;
    opacity: 0.7;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .breadcrumb__select-arrow svg {
    width: 100%;
    height: 100%;
  }

  /* Arrows */
  .breadcrumb__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.8em;
    height: 1.8em;
    border-radius: 50%;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    transition: background-color 0.2s, color 0.2s, transform 0.2s;
    cursor: pointer;
    flex-shrink: 0;
  }

  .breadcrumb__arrow:hover {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    color: var(--_tokens---color--fg);
  }

  .breadcrumb__arrow svg {
    width: 1em;
    height: 1em;
  }

  /* Mobile Portrait responsive optimization: on project pages hide Home & About Me to fit dropdowns */
  @media (max-width: 767px) {
    .breadcrumb__list--project-page .breadcrumb__link--home,
    .breadcrumb__list--project-page .breadcrumb__sep--home,
    .breadcrumb__list--project-page .breadcrumb__link--about,
    .breadcrumb__list--project-page .breadcrumb__sep--about {
      display: none;
    }
  }
</style>

<script>
  // Setup event listener to filter projects by category and navigate on project selection
  function setupDoubleDropdown() {
    const catSelect = document.getElementById('breadcrumb-category-select') as HTMLSelectElement | null;
    const projSelect = document.getElementById('breadcrumb-project-select') as HTMLSelectElement | null;
    if (!catSelect || !projSelect) return;

    // Save all original options except the placeholder
    const originalOptions = Array.from(projSelect.querySelectorAll('option')).filter(opt => opt.value !== "");
    const placeholder = projSelect.querySelector('option[value=""]') as HTMLOptionElement | null;

    function updateProjectsList(catId: string, currentUrl?: string) {
      // Clear current options
      projSelect!.innerHTML = '';
      
      // Re-add placeholder
      if (placeholder) {
        projSelect!.appendChild(placeholder);
      }

      // Filter and append options
      const matches = catId 
        ? originalOptions.filter(opt => opt.getAttribute('data-category') === catId)
        : originalOptions;

      matches.forEach(opt => {
        // Clone option so we don't lose the original reference
        const clone = opt.cloneNode(true) as HTMLOptionElement;
        projSelect!.appendChild(clone);
      });

      // If a currentUrl is provided and matches one of the options, select it
      if (currentUrl && matches.some(opt => opt.value === currentUrl)) {
        projSelect!.value = currentUrl;
      } else {
        projSelect!.value = "";
      }
    }

    // Listen to Category dropdown changes
    catSelect.addEventListener('change', () => {
      const currentUrl = window.location.pathname.replace(/\/$/, '');
      updateProjectsList(catSelect.value, currentUrl);
    });

    // Listen to Project dropdown changes (navigation)
    projSelect.addEventListener('change', () => {
      const val = projSelect.value;
      if (val) {
        window.location.href = val;
      }
    });

    // Initial setup: filter by current selected category on page load
    const initialCat = catSelect.value;
    const currentUrl = window.location.pathname.replace(/\/$/, '');
    updateProjectsList(initialCat, currentUrl);
  }

  // Run on page load
  setupDoubleDropdown();

  // Support Astro View Transitions if enabled
  document.addEventListener('astro:after-swap', setupDoubleDropdown);
</script>
