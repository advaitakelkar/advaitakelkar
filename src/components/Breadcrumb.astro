---
import { getCollection } from 'astro:content';

export interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const allProjects = await getCollection('projects');
const allCats     = await getCollection('categories');

const categoryDisplayNames: Record<string, string> = {
  'studio-823':    '823',
  'faizan-khatri': 'FKD',
  'archv':         'ARCHV',
  'scad':          'SCAD',
  'collaboration': 'COLLAB',
  'freelancer':    'FREE',
};

const projects   = [...allProjects].sort((a, b) => a.data.name.localeCompare(b.data.name));
const categories = [...allCats].sort((a, b) =>
  (categoryDisplayNames[a.id] || a.data.displayName)
    .localeCompare(categoryDisplayNames[b.id] || b.data.displayName)
);

const normalizedPath   = currentPath.replace(/\/$/, '') || '/';
const isHome           = normalizedPath === '/';
const isAbout          = normalizedPath === '/about';
const isProjectsIndex  = normalizedPath === '/projects';
const isProjectPage    = normalizedPath.startsWith('/projects/') && !isProjectsIndex;

let currentProjectId   = '';
let currentProjectName = '';
let prevProjectUrl     = '';
let nextProjectUrl     = '';

let activeProject = isProjectPage
  ? projects.find(p => p.id === normalizedPath.split('/').filter(Boolean)[1])
  : null;
if (!activeProject && projects.length > 0) activeProject = projects[0];

if (activeProject) {
  currentProjectId   = activeProject.id;
  currentProjectName = activeProject.data.name;
  const idx = projects.findIndex(p => p.id === currentProjectId);
  if (idx !== -1) {
    prevProjectUrl = `/projects/${projects[(idx - 1 + projects.length) % projects.length].id}`;
    nextProjectUrl = `/projects/${projects[(idx + 1) % projects.length].id}`;
  }
}
---

<nav class="breadcrumb" aria-label="Secondary navigation">

  <!-- Left: Home / About / Projects pills -->
  <div class:list={["breadcrumb__list", isProjectPage && "breadcrumb__list--project-page"]}>
    <a href="/" class:list={["breadcrumb__link", "breadcrumb__link--home", isHome && "is-active"]}>
      <span class="crumb-full">Home</span>
      <svg class="crumb-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
        <polyline points="9 22 9 12 15 12 15 22"></polyline>
      </svg>
    </a>
    <span class="breadcrumb__sep" aria-hidden="true">/</span>

    <a href="/about" class:list={["breadcrumb__link", "breadcrumb__link--about", isAbout && "is-active"]}>
      <span class="crumb-full">About</span>
      <svg class="crumb-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
        <rect x="4" y="4" width="16" height="16" rx="2"></rect>
      </svg>
    </a>
    <span class="breadcrumb__sep" aria-hidden="true">/</span>

    <a href="/projects" class:list={["breadcrumb__link", "breadcrumb__link--projects", isProjectsIndex && "is-active"]}>
      <span class="crumb-full">Projects</span>
      <svg class="crumb-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
        <circle cx="12" cy="12" r="9"></circle>
      </svg>
    </a>
    <span class="breadcrumb__sep" aria-hidden="true">/</span>
  </div>

  <!-- Right: prev arrow + dropdown trigger + next arrow -->
  <div class:list={["breadcrumb__project-nav", isProjectPage && "is-active"]}>
    {prevProjectUrl && (
      <a href={prevProjectUrl} class="breadcrumb__arrow breadcrumb__arrow--prev" aria-label="Previous project">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </a>
    )}

    <div class="breadcrumb__custom-dropdown" id="breadcrumb-custom-dropdown">
      <!-- Trigger button — no input, fully keyboard-operable -->
      <button
        class="breadcrumb__dropdown-trigger"
        id="breadcrumb-dropdown-trigger"
        type="button"
        aria-haspopup="true"
        aria-expanded="false"
      >
        <span class="breadcrumb__trigger-label" id="breadcrumb-trigger-label">
          {isProjectPage && currentProjectName ? currentProjectName : 'Projects'}
        </span>
        <svg class="breadcrumb__trigger-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>

      <div class="breadcrumb__dropdown-panel" id="breadcrumb-dropdown-panel">

        <!-- Mobile-only: Home / About / All Projects links at the top -->
        <div class="breadcrumb__mobile-nav">
          <a href="/" class:list={["breadcrumb__nav-item", isHome && "is-active"]}>
            <span>Home</span>
            <svg class="link-arrow breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
              <line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </a>
          <a href="/about" class:list={["breadcrumb__nav-item", isAbout && "is-active"]}>
            <span>About</span>
            <svg class="link-arrow breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
              <line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </a>
          <a href="/projects" class:list={["breadcrumb__nav-item", isProjectsIndex && "is-active"]}>
            <span>All Projects</span>
            <svg class="link-arrow breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
              <line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </a>
          <div class="breadcrumb__mobile-divider" aria-hidden="true"></div>
        </div>

        <!-- Column 1: Categories -->
        <div class="breadcrumb__menu-column breadcrumb__menu-column--categories">
          <a href="/projects" class="breadcrumb__cat-item" data-cat-id="all">
            <span>All</span>
            <svg class="link-arrow breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
              <line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </a>
          {categories.map(c => (
            <a href={`/${c.id}`} class="breadcrumb__cat-item" data-cat-id={c.id}>
              <span>{categoryDisplayNames[c.id] || c.data.displayName}</span>
              <svg class="link-arrow breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
                <line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline>
              </svg>
            </a>
          ))}
        </div>

        <!-- Column 2: Projects (desktop only — shown when a category is hovered) -->
        <div class="breadcrumb__menu-column breadcrumb__menu-column--projects">
          <div class="breadcrumb__proj-list is-active" data-cat-id="all">
            {projects.map(p => (
              <a
                href={`/projects/${p.id}`}
                class:list={["breadcrumb__proj-item", currentProjectId === p.id && "is-active"]}
                data-cat-id={p.data.category?.id || ''}
              >
                <span class="breadcrumb__proj-name">{p.data.name}</span>
                <svg class="link-arrow breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
                  <line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline>
                </svg>
              </a>
            ))}
          </div>
          {categories.map(c => {
            const catProjs = projects.filter(p => p.data.category?.id === c.id);
            return (
              <div class="breadcrumb__proj-list" data-cat-id={c.id}>
                {catProjs.length === 0
                  ? <div class="breadcrumb__proj-empty">No projects</div>
                  : catProjs.map(p => (
                    <a
                      href={`/projects/${p.id}`}
                      class:list={["breadcrumb__proj-item", currentProjectId === p.id && "is-active"]}
                      data-cat-id={p.data.category?.id || ''}
                    >
                      <span class="breadcrumb__proj-name">{p.data.name}</span>
                      <svg class="link-arrow breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
                        <line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline>
                      </svg>
                    </a>
                  ))
                }
              </div>
            );
          })}
        </div>

      </div>
    </div>

    {nextProjectUrl && (
      <a href={nextProjectUrl} class="breadcrumb__arrow breadcrumb__arrow--next" aria-label="Next project">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </a>
    )}
  </div>

  <div class="breadcrumb__backdrop" id="breadcrumb-backdrop"></div>
</nav>

<style>
  /* ── Shell ─────────────────────────────────────────────────── */
  .breadcrumb {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 7px;
    position: relative;
    z-index: 500;
  }

  .breadcrumb__list {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 7px;
  }

  .breadcrumb__sep { display: none; }

  /* ── Nav pills ─────────────────────────────────────────────── */
  .breadcrumb__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    text-decoration: none;
    font-family: var(--_tokens---font--mono);
    font-size: var(--_tokens---type--micro);
    letter-spacing: 0.05em;
    white-space: nowrap;
    opacity: 0.8;
    transition: background-color 0.2s, color 0.2s, border-color 0.2s, opacity 0.2s;
  }

  .breadcrumb__link:hover,
  .breadcrumb__link:focus-visible {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    color: var(--_tokens---color--fg);
    border-color: color-mix(in srgb, var(--_tokens---color--fg) 22%, transparent);
    opacity: 1;
    outline: none;
  }

  .breadcrumb__link.is-active {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 14%, transparent);
    color: var(--_tokens---color--fg);
    border-color: color-mix(in srgb, var(--_tokens---color--fg) 30%, transparent);
    opacity: 1;
    font-weight: 500;
  }

  /* Desktop text / Mobile icon */
  .crumb-icon { display: none; }

  @media (max-width: 640px) {
    .crumb-full { display: none; }
    .crumb-icon {
      display: inline-block;
      width: 11px; height: 11px;
      flex-shrink: 0;
      vertical-align: middle;
    }
  }

  /* ── Project-nav wrapper ───────────────────────────────────── */
  .breadcrumb__project-nav {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
    position: relative;
    z-index: 500;
  }

  /* Prev / Next arrows */
  .breadcrumb__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.8em; height: 1.8em;
    border-radius: 50%;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    transition: background-color 0.2s, color 0.2s;
    flex-shrink: 0;
  }
  .breadcrumb__arrow:hover { background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent); color: var(--_tokens---color--fg); }
  .breadcrumb__arrow svg { width: 1em; height: 1em; }

  @media (max-width: 640px) {
    .breadcrumb__arrow--prev,
    .breadcrumb__arrow--next { display: none; }
  }

  /* ── Trigger button ────────────────────────────────────────── */
  .breadcrumb__custom-dropdown { position: relative; }

  .breadcrumb__dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    font-family: var(--_tokens---font--mono);
    font-size: var(--_tokens---type--micro);
    font-weight: 500;
    letter-spacing: 0.05em;
    white-space: nowrap;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s, border-color 0.2s;
    outline: none;
  }

  .breadcrumb__dropdown-trigger:hover,
  .breadcrumb__dropdown-trigger:focus-visible,
  .breadcrumb__dropdown-trigger[aria-expanded="true"] {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    color: var(--_tokens---color--fg);
    border-color: color-mix(in srgb, var(--_tokens---color--fg) 22%, transparent);
    outline: none;
  }

  .breadcrumb__project-nav.is-active .breadcrumb__dropdown-trigger {
    color: var(--_tokens---color--fg);
    border-color: var(--_tokens---color--fg);
  }

  .breadcrumb__trigger-chevron {
    width: 10px; height: 10px;
    flex-shrink: 0;
    opacity: 0.6;
    transition: transform 0.2s ease, opacity 0.2s;
  }
  .breadcrumb__dropdown-trigger[aria-expanded="true"] .breadcrumb__trigger-chevron {
    transform: rotate(180deg);
    opacity: 1;
  }

  /* ── Dropdown panel ────────────────────────────────────────── */
  .breadcrumb__dropdown-panel {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    z-index: 500;
    display: none;
    grid-template-columns: 110px;
    width: 110px;
    align-items: start;
    transition: width 0.15s ease, grid-template-columns 0.15s ease;
  }

  .breadcrumb__dropdown-panel.is-open {
    display: grid;
  }

  /* Expand to two columns on desktop when a category is active */
  @media (min-width: 768px) {
    .breadcrumb__dropdown-panel.has-active-cat {
      grid-template-columns: 110px 190px;
      width: 308px;
      gap: 8px;
    }
  }

  /* On mobile: open upward (breadcrumb is docked at bottom) */
  @media (max-width: 767px) and (orientation: portrait) {
    .breadcrumb__dropdown-panel {
      top: auto;
      bottom: calc(100% + 6px);
      left: auto;
      right: 0;
    }
  }

  /* On narrow screens: right-align so it doesn't clip */
  @media (max-width: 767px) {
    .breadcrumb__dropdown-panel {
      left: auto;
      right: 0;
      grid-template-columns: 180px;
      width: 180px;
    }
  }

  /* ── Menu columns ──────────────────────────────────────────── */
  .breadcrumb__menu-column {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 8px;
    background-color: color-mix(in srgb, var(--_tokens---color--bg) 75%, transparent);
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    border-radius: 8px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
    /* Scroll only when taller than the viewport */
    max-height: calc(100dvh - 100px);
    overflow-y: auto;
    scrollbar-width: none; /* hide scrollbar visually, still scrollable */
  }
  .breadcrumb__menu-column::-webkit-scrollbar { display: none; }

  /* Projects column: hidden on mobile, shown on desktop when category active */
  .breadcrumb__menu-column--projects { display: none; }

  @media (min-width: 768px) {
    .breadcrumb__dropdown-panel.has-active-cat .breadcrumb__menu-column--projects {
      display: flex;
      flex-direction: column;
    }
  }

  /* ── Mobile nav links (Home / About / All Projects) ────────── */
  .breadcrumb__mobile-nav { display: none; }

  @media (max-width: 767px) {
    .breadcrumb__mobile-nav {
      display: flex;
      flex-direction: column;
      gap: 1px;
      margin-bottom: 4px;
    }
  }

  .breadcrumb__mobile-divider {
    height: 1px;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    margin: 4px 0;
  }

  .breadcrumb__nav-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 5px 10px;
    border-radius: 999px;
    border: 1px solid transparent;
    color: var(--_tokens---color--muted);
    font-family: var(--_tokens---font--mono);
    font-size: var(--_tokens---type--micro);
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.2s, color 0.2s, border-color 0.2s;
  }

  .breadcrumb__nav-item:hover,
  .breadcrumb__nav-item.is-active,
  .breadcrumb__nav-item:focus-visible {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    color: var(--_tokens---color--fg);
    border-color: color-mix(in srgb, var(--_tokens---color--fg) 22%, transparent);
    outline: none;
  }

  /* ── Category + Project items ──────────────────────────────── */
  .breadcrumb__cat-item,
  .breadcrumb__proj-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 5px 10px;
    border-radius: 999px;
    border: 1px solid transparent;
    background-color: transparent;
    color: var(--_tokens---color--muted);
    font-family: var(--_tokens---font--mono);
    font-size: var(--_tokens---type--micro);
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s, border-color 0.2s;
  }

  .breadcrumb__cat-item:hover,
  .breadcrumb__cat-item.is-active,
  .breadcrumb__cat-item:focus-visible,
  .breadcrumb__proj-item:hover,
  .breadcrumb__proj-item.is-active,
  .breadcrumb__proj-item:focus-visible {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    color: var(--_tokens---color--fg);
    border-color: color-mix(in srgb, var(--_tokens---color--fg) 22%, transparent);
    outline: none;
  }

  .breadcrumb__proj-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    text-align: left;
    flex: 1;
  }

  .breadcrumb__proj-list { display: none; }
  .breadcrumb__proj-list.is-active { display: flex; flex-direction: column; gap: 1px; }

  .breadcrumb__proj-empty {
    font-size: var(--_tokens---type--micro);
    color: var(--_tokens---color--muted);
    padding: 12px;
    text-align: center;
  }

  .breadcrumb__arrow-icon {
    width: 8px; height: 8px;
    flex-shrink: 0;
    opacity: 0.55;
    transition: opacity 0.2s;
  }
  .breadcrumb__cat-item:hover .breadcrumb__arrow-icon,
  .breadcrumb__cat-item:focus-visible .breadcrumb__arrow-icon,
  .breadcrumb__cat-item.is-active .breadcrumb__arrow-icon,
  .breadcrumb__proj-item:hover .breadcrumb__arrow-icon,
  .breadcrumb__proj-item:focus-visible .breadcrumb__arrow-icon,
  .breadcrumb__nav-item:hover .breadcrumb__arrow-icon,
  .breadcrumb__nav-item:focus-visible .breadcrumb__arrow-icon { opacity: 1; }

  /* ── Backdrop ──────────────────────────────────────────────── */
  .breadcrumb__backdrop {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.25);
    z-index: 450;
    display: none;
    pointer-events: auto;
  }
  .breadcrumb__backdrop.is-open { display: block; }

  /* ── Project-page pill hiding on mobile ────────────────────── */
  @media (max-width: 767px) {
    .breadcrumb__list--project-page .breadcrumb__link--home,
    .breadcrumb__list--project-page .breadcrumb__link--about { display: none; }
  }

  /* Focus styles */
  .breadcrumb__link:focus-visible,
  .breadcrumb__dropdown-trigger:focus-visible,
  .breadcrumb__cat-item:focus-visible,
  .breadcrumb__proj-item:focus-visible,
  .breadcrumb__nav-item:focus-visible,
  .breadcrumb__arrow:focus-visible { outline: none !important; }
</style>

<script>
  function setupDropdown() {
    const trigger  = document.getElementById('breadcrumb-dropdown-trigger') as HTMLButtonElement | null;
    const panel    = document.getElementById('breadcrumb-dropdown-panel');
    const dropdown = document.getElementById('breadcrumb-custom-dropdown');
    if (!trigger || !panel || !dropdown) return;

    // Shuffle project lists so order varies each visit
    dropdown.querySelectorAll('.breadcrumb__proj-list').forEach(list => {
      const items = Array.from(list.querySelectorAll('.breadcrumb__proj-item')) as HTMLElement[];
      for (let i = items.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [items[i], items[j]] = [items[j], items[i]];
      }
      items.forEach(el => list.appendChild(el));
    });

    // ── Open / close ─────────────────────────────────────────
    function openDropdown() {
      panel.classList.add('is-open');
      trigger.setAttribute('aria-expanded', 'true');
      const backdrop = document.getElementById('breadcrumb-backdrop');
      if (backdrop) backdrop.classList.add('is-open');
      activateCategory('all');
    }

    function closeDropdown() {
      panel.classList.remove('is-open', 'has-active-cat');
      trigger.setAttribute('aria-expanded', 'false');
      const backdrop = document.getElementById('breadcrumb-backdrop');
      if (backdrop) backdrop.classList.remove('is-open');
      // Reset categories highlight
      dropdown.querySelectorAll('.breadcrumb__cat-item').forEach(el => el.classList.remove('is-active'));
      dropdown.querySelectorAll('.breadcrumb__proj-list').forEach(el => el.classList.remove('is-active'));
      (dropdown.querySelector('.breadcrumb__proj-list[data-cat-id="all"]') as HTMLElement | null)?.classList.add('is-active');
    }
    (window as any).closeBreadcrumbDropdown = closeDropdown;

    trigger.addEventListener('click', () => {
      panel.classList.contains('is-open') ? closeDropdown() : openDropdown();
    });

    // Close on backdrop click or click outside
    document.getElementById('breadcrumb-backdrop')?.addEventListener('click', closeDropdown);
    document.addEventListener('click', e => {
      if (panel.classList.contains('is-open') && !dropdown.contains(e.target as Node)) closeDropdown();
    });

    // ── Category activation ──────────────────────────────────
    const catItems = Array.from(dropdown.querySelectorAll('.breadcrumb__cat-item')) as HTMLAnchorElement[];
    const projLists = Array.from(dropdown.querySelectorAll('.breadcrumb__proj-list')) as HTMLDivElement[];

    function activateCategory(catId: string) {
      catItems.forEach(item => item.classList.toggle('is-active', item.dataset.catId === catId));
      projLists.forEach(list => list.classList.toggle('is-active', list.dataset.catId === catId));
      if (catId) panel.classList.add('has-active-cat');
    }

    catItems.forEach(item => {
      const catId = item.dataset.catId || '';
      // Desktop: hover reveals project column
      item.addEventListener('mouseenter', () => {
        if (window.innerWidth >= 768) activateCategory(catId);
      });
      // Keyboard focus also activates category
      item.addEventListener('focus', () => activateCategory(catId));
    });

    // ── Full keyboard navigation ─────────────────────────────
    // All focusable items in order for arrow-key traversal
    function getFocusableItems(): HTMLElement[] {
      const isMobile = window.innerWidth < 768;
      const items: HTMLElement[] = [];

      // Mobile nav links first (mobile only)
      if (isMobile) {
        items.push(...Array.from(dropdown.querySelectorAll('.breadcrumb__nav-item')) as HTMLElement[]);
      }

      // Category items
      items.push(...catItems);

      // Project items (desktop: whichever list is active; mobile: none)
      if (!isMobile) {
        const activeList = panel.querySelector('.breadcrumb__proj-list.is-active');
        if (activeList) {
          items.push(...Array.from(activeList.querySelectorAll('.breadcrumb__proj-item')) as HTMLElement[]);
        }
      }

      return items;
    }

    dropdown.addEventListener('keydown', (e: KeyboardEvent) => {
      if (!panel.classList.contains('is-open')) return;

      if (e.key === 'Escape') {
        e.preventDefault();
        closeDropdown();
        trigger.focus();
        return;
      }

      if (e.key === 'ArrowDown' || e.key === 'ArrowUp' || e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
        e.preventDefault();
        const items = getFocusableItems();
        const active = document.activeElement as HTMLElement;
        const idx = items.indexOf(active);

        if (e.key === 'ArrowDown') {
          const next = items[idx + 1] ?? items[0];
          next?.focus();
        } else if (e.key === 'ArrowUp') {
          const prev = items[idx - 1] ?? items[items.length - 1];
          prev?.focus();
        } else if (e.key === 'ArrowRight' && window.innerWidth >= 768) {
          // Move into the projects column
          const activeList = panel.querySelector('.breadcrumb__proj-list.is-active');
          const firstProj = activeList?.querySelector('.breadcrumb__proj-item') as HTMLElement | null;
          firstProj?.focus();
        } else if (e.key === 'ArrowLeft' && window.innerWidth >= 768) {
          // Move back to categories
          const activeCat = panel.querySelector('.breadcrumb__cat-item.is-active') as HTMLElement | null;
          (activeCat ?? catItems[0])?.focus();
        }
      }
    });

    // Open dropdown on ArrowDown when trigger is focused
    trigger.addEventListener('keydown', (e: KeyboardEvent) => {
      if ((e.key === 'ArrowDown' || e.key === 'Enter' || e.key === ' ') && !panel.classList.contains('is-open')) {
        e.preventDefault();
        openDropdown();
        // Focus first item after paint
        requestAnimationFrame(() => getFocusableItems()[0]?.focus());
      }
    });

    // ── Sync active project label & arrows ───────────────────
    function syncActiveProject(projectId: string) {
      const label = document.getElementById('breadcrumb-trigger-label');
      const path  = window.location.pathname.replace(/\/$/, '') || '/';
      const isProjPage = path.startsWith('/projects/') && path !== '/projects';

      // Update all proj-item active states
      dropdown.querySelectorAll('.breadcrumb__proj-item').forEach(el => {
        el.classList.toggle('is-active', el.getAttribute('href') === `/projects/${projectId}`);
      });

      // Update prev/next arrows
      const allItems = Array.from(
        dropdown.querySelectorAll('.breadcrumb__proj-list[data-cat-id="all"] .breadcrumb__proj-item')
      ) as HTMLAnchorElement[];
      const idx = allItems.findIndex(el => el.getAttribute('href') === `/projects/${projectId}`);
      if (idx !== -1) {
        const prev = document.querySelector('.breadcrumb__arrow--prev') as HTMLAnchorElement | null;
        const next = document.querySelector('.breadcrumb__arrow--next') as HTMLAnchorElement | null;
        if (prev) prev.href = allItems[(idx - 1 + allItems.length) % allItems.length].getAttribute('href') || '#';
        if (next) next.href = allItems[(idx + 1) % allItems.length].getAttribute('href') || '#';
      }
    }

    const path = window.location.pathname.replace(/\/$/, '') || '/';
    const isProjPage = path.startsWith('/projects/') && path !== '/projects';
    if (isProjPage) {
      const id = path.split('/').filter(Boolean)[1] || '';
      if (id) localStorage.setItem('latestProject', id);
    } else {
      const latest = localStorage.getItem('latestProject');
      if (latest) syncActiveProject(latest);
    }

    // Arrow-key page nav when dropdown is closed (desktop)
    if (!(window as any).hasKbGlobalNav) {
      (window as any).hasKbGlobalNav = true;
      window.addEventListener('keydown', (e: KeyboardEvent) => {
        const active = document.activeElement as HTMLElement | null;
        if (active && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA' || active.isContentEditable)) return;
        if (panel.classList.contains('is-open')) return;
        if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;

        const p = window.location.pathname.replace(/\/$/, '') || '/';
        if (p.startsWith('/projects/') && p !== '/projects') {
          if (e.key === 'ArrowRight') {
            const n = document.querySelector('.breadcrumb__arrow--next') as HTMLAnchorElement | null;
            if (n) { e.preventDefault(); window.location.href = n.href; }
          } else {
            const pv = document.querySelector('.breadcrumb__arrow--prev') as HTMLAnchorElement | null;
            if (pv) { e.preventDefault(); window.location.href = pv.href; }
          }
        } else {
          const pages = ['/', '/about', '/projects'];
          const ci = pages.indexOf(p);
          if (e.key === 'ArrowRight' && ci < pages.length - 1) { e.preventDefault(); window.location.href = pages[ci + 1]; }
          if (e.key === 'ArrowLeft'  && ci > 0)                 { e.preventDefault(); window.location.href = pages[ci - 1]; }
        }
      });
    }
  }

  setupDropdown();
  document.addEventListener('astro:after-swap', () => {
    (window as any).hasKbGlobalNav = false;
    setupDropdown();
  });
</script>
