---
import { getCollection } from 'astro:content';

export interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

// Fetch projects and categories
const allProjects = await getCollection('projects');
const allCats = await getCollection('categories');

const categoryDisplayNames: Record<string, string> = {
  'studio-823': '823',
  'faizan-khatri': 'FKD',
  'archv': 'ARCHV',
  'scad': 'SCAD',
  'collaboration': 'COLLAB',
  'freelancer': 'FREE'
};

const getCatDisplayName = (id: string, def: string) => categoryDisplayNames[id] || def;

const projects = [...allProjects].sort((a, b) => a.data.name.localeCompare(b.data.name));
const categories = [...allCats].sort((a, b) => 
  getCatDisplayName(a.id, a.data.displayName).localeCompare(getCatDisplayName(b.id, b.data.displayName))
);

// Normalize path for matching (ignoring trailing slash)
const normalizedPath = currentPath.replace(/\/$/, '') || '/';

// Determine active state for parent links
const isHome = normalizedPath === '/';
const isAbout = normalizedPath === '/about';
const isProjectsIndex = normalizedPath === '/projects';
const isProjectPage = normalizedPath.startsWith('/projects/') && !isProjectsIndex;

// Extract current project ID, name, and category ID if on a project page
let currentProjectId = '';
let currentProjectCatId = '';
let currentProjectName = '';
let prevProjectUrl = '';
let nextProjectUrl = '';

if (isProjectPage) {
  // Extract id from path (e.g. /projects/carlo -> carlo)
  const parts = normalizedPath.split('/').filter(Boolean);
  currentProjectId = parts[1] || '';
  
  const currentProject = projects.find(p => p.id === currentProjectId);
  if (currentProject) {
    currentProjectName = currentProject.data.name;
    if (currentProject.data.category) {
      currentProjectCatId = currentProject.data.category.id;
    }
  }
  
  const idx = projects.findIndex(p => p.id === currentProjectId);
  if (idx !== -1) {
    const prevIdx = (idx - 1 + projects.length) % projects.length;
    const nextIdx = (idx + 1) % projects.length;
    prevProjectUrl = `/projects/${projects[prevIdx].id}`;
    nextProjectUrl = `/projects/${projects[nextIdx].id}`;
  }
}
---

<nav class="breadcrumb" aria-label="Secondary navigation">
  <div class:list={["breadcrumb__list", isProjectPage && "breadcrumb__list--project-page"]}>
    <!-- Home -->
    <a href="/" class:list={["breadcrumb__link", "breadcrumb__link--home", isHome && "is-active"]}>Home</a>
    <span class="breadcrumb__sep breadcrumb__sep--home" aria-hidden="true">/</span>

    <!-- About Me -->
    <a href="/about" class:list={["breadcrumb__link", "breadcrumb__link--about", isAbout && "is-active"]}>About Me</a>
    <span class="breadcrumb__sep breadcrumb__sep--about" aria-hidden="true">/</span>

    <!-- Projects -->
    <a href="/projects" class:list={["breadcrumb__link", "breadcrumb__link--projects", isProjectsIndex && "is-active"]}>Projects</a>
    <span class="breadcrumb__sep breadcrumb__sep--projects" aria-hidden="true">/</span>
  </div>

  <!-- Select Category & Project Dropdown Menu (outside links wrapper to prevent clipping) -->
  <div class:list={["breadcrumb__project-nav", isProjectPage && "is-active"]}>
    {isProjectPage && prevProjectUrl && (
      <a href={prevProjectUrl} class="breadcrumb__arrow breadcrumb__arrow--prev" title="Previous Project" aria-label="Previous Project">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </a>
    )}

    <!-- Custom Dropdown Menu System -->
    <div class="breadcrumb__custom-dropdown" id="breadcrumb-custom-dropdown">
      <button class="breadcrumb__dropdown-trigger" id="breadcrumb-dropdown-trigger" aria-haspopup="true" aria-expanded="false" type="button">
        <span>{isProjectPage && currentProjectName ? currentProjectName : 'Select Project'}</span>
        <span class="breadcrumb__select-arrow" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </span>
      </button>

      <div class="breadcrumb__dropdown-panel" id="breadcrumb-dropdown-panel">
        <!-- Column 1: Categories -->
        <div class="breadcrumb__menu-column breadcrumb__menu-column--categories">
          <button class="breadcrumb__cat-item is-active" data-cat-id="all" type="button">
            All
          </button>
          {categories.map(c => (
            <button class="breadcrumb__cat-item" data-cat-id={c.id} type="button">
              {categoryDisplayNames[c.id] || c.data.displayName}
            </button>
          ))}
        </div>

        <!-- Column 2: Projects -->
        <div class="breadcrumb__menu-column breadcrumb__menu-column--projects">
          <!-- All projects list -->
          <div class="breadcrumb__proj-list is-active" data-cat-id="all">
            {projects.map(p => (
              <a href={`/projects/${p.id}`} class:list={["breadcrumb__proj-item", currentProjectId === p.id && "is-active"]}>
                {p.data.name}
              </a>
            ))}
          </div>

          <!-- Categorized projects lists -->
          {categories.map(c => {
            const catProjects = projects.filter(p => p.data.category?.id === c.id);
            return (
              <div class="breadcrumb__proj-list" data-cat-id={c.id}>
                {catProjects.length === 0 ? (
                  <div class="breadcrumb__proj-empty">No projects</div>
                ) : (
                  catProjects.map(p => (
                    <a href={`/projects/${p.id}`} class:list={["breadcrumb__proj-item", currentProjectId === p.id && "is-active"]}>
                      {p.data.name}
                    </a>
                  ))
                )}
              </div>
            );
          })}
        </div>
      </div>
    </div>

    {isProjectPage && nextProjectUrl && (
      <a href={nextProjectUrl} class="breadcrumb__arrow breadcrumb__arrow--next" title="Next Project" aria-label="Next Project">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </a>
    )}
  </div>
</nav>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    width: 100%;
    gap: 8px;
  }

  .breadcrumb__list {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 0;
    font-family: var(--_tokens---font--mono);
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.08em;
    text-transform: none;
    color: var(--_tokens---color--muted);
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    flex: 1; /* occupy remaining space */
  }

  .breadcrumb__list::-webkit-scrollbar {
    display: none;
  }

  .breadcrumb__link {
    color: var(--_tokens---color--muted);
    text-decoration: none;
    transition: color 0.2s ease, opacity 0.2s ease;
    opacity: 0.6;
    white-space: nowrap;
  }

  .breadcrumb__link:hover {
    color: var(--_tokens---color--fg);
    opacity: 1;
  }

  .breadcrumb__link.is-active {
    color: var(--_tokens---color--fg);
    opacity: 1;
    font-weight: 300;
  }

  .breadcrumb__sep {
    margin-inline: 0.6em;
    opacity: 0.35;
    user-select: none;
    flex-shrink: 0;
  }

  /* Dropdown & Nav container styling */
  .breadcrumb__project-nav {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  /* Custom Dropdown Menu System styling */
  .breadcrumb__custom-dropdown {
    position: relative;
    display: inline-block;
  }

  .breadcrumb__dropdown-trigger {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 20px;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    font-family: inherit;
    font-size: 9px;
    font-weight: 300;
    text-transform: none;
    letter-spacing: 0.06em;
    border: 1.5px solid transparent;
    border-radius: 6px;
    padding: 6px 30px 6px 12px;
    cursor: pointer;
    outline: none;
    white-space: nowrap;
    transition: background-color 0.2s, color 0.2s;
  }

  .breadcrumb__project-nav.is-active .breadcrumb__dropdown-trigger {
    color: var(--_tokens---color--fg);
    border-color: var(--_tokens---color--fg);
  }

  .breadcrumb__dropdown-trigger:hover {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
    color: var(--_tokens---color--fg);
  }

  .breadcrumb__select-arrow {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    width: 10px;
    height: 10px;
    pointer-events: none;
    color: currentColor;
    opacity: 0.7;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .breadcrumb__select-arrow svg {
    width: 100%;
    height: 100%;
  }

  .breadcrumb__dropdown-panel {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    z-index: 500;
    background-color: var(--_tokens---color--bg);
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
    display: none; /* toggled via js */
    grid-template-columns: 85px 175px;
    overflow: hidden;
  }

  /* When docked on mobile bottom, let the dropdown open upwards! */
  @media (max-width: 767px) and (orientation: portrait) {
    .breadcrumb__dropdown-panel {
      top: auto;
      bottom: calc(100% + 6px);
      box-shadow: 0 -10px 30px rgba(0, 0, 0, 0.25);
    }
  }

  .breadcrumb__dropdown-panel.is-open {
    display: grid;
  }

  .breadcrumb__menu-column {
    display: flex;
    flex-direction: column;
    max-height: 220px;
    overflow-y: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .breadcrumb__menu-column::-webkit-scrollbar {
    display: none;
  }

  .breadcrumb__menu-column--categories {
    border-right: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 2.5%, transparent);
    padding: 6px 0;
  }

  .breadcrumb__menu-column--projects {
    padding: 6px 0;
    background-color: var(--_tokens---color--bg);
  }

  .breadcrumb__cat-item {
    font-family: inherit;
    font-size: 9px;
    font-weight: 400;
    text-align: left;
    padding: 8px 12px;
    border: none;
    background: none;
    color: var(--_tokens---color--muted);
    cursor: pointer;
    width: 100%;
    transition: background-color 0.15s, color 0.15s;
    letter-spacing: 0.05em;
  }

  .breadcrumb__cat-item:hover,
  .breadcrumb__cat-item.is-active {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--fg);
  }

  .breadcrumb__proj-list {
    display: none;
  }

  .breadcrumb__proj-list.is-active {
    display: block;
  }

  .breadcrumb__proj-item {
    font-family: inherit;
    font-size: 9px;
    font-weight: 300;
    text-align: left;
    padding: 8px 12px;
    text-decoration: none;
    color: var(--_tokens---color--muted);
    display: block;
    transition: background-color 0.15s, color 0.15s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    letter-spacing: 0.04em;
  }

  .breadcrumb__proj-item:hover,
  .breadcrumb__proj-item.is-active {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--fg);
  }

  .breadcrumb__proj-empty {
    font-size: 8px;
    color: var(--_tokens---color--muted);
    padding: 12px;
    text-align: center;
  }

  /* Arrows */
  .breadcrumb__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.8em;
    height: 1.8em;
    border-radius: 50%;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    transition: background-color 0.2s, color 0.2s, transform 0.2s;
    cursor: pointer;
    flex-shrink: 0;
  }

  .breadcrumb__arrow:hover {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    color: var(--_tokens---color--fg);
  }

  .breadcrumb__arrow svg {
    width: 1em;
    height: 1em;
  }

  /* Mobile Portrait responsive optimization: on project pages hide Home & About Me to fit dropdowns */
  @media (max-width: 767px) {
    .breadcrumb__list--project-page .breadcrumb__link--home,
    .breadcrumb__list--project-page .breadcrumb__sep--home,
    .breadcrumb__list--project-page .breadcrumb__link--about,
    .breadcrumb__list--project-page .breadcrumb__sep--about {
      display: none;
    }
  }
</style>

<script>
  function setupCustomDropdown() {
    const trigger = document.getElementById('breadcrumb-dropdown-trigger');
    const panel = document.getElementById('breadcrumb-dropdown-panel');
    const dropdown = document.getElementById('breadcrumb-custom-dropdown');
    if (!trigger || !panel || !dropdown) return;

    // Toggle dropdown panel open/close
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = panel.classList.toggle('is-open');
      trigger.setAttribute('aria-expanded', String(isOpen));

      if (isOpen) {
        // Reset category view to the current project's category on open
        const activeProjItem = dropdown.querySelector('.breadcrumb__proj-item.is-active');
        if (activeProjItem) {
          const parentList = activeProjItem.closest('.breadcrumb__proj-list');
          if (parentList) {
            const catId = parentList.getAttribute('data-cat-id');
            if (catId && catId !== 'all') {
              activateCategory(catId);
            }
          }
        } else {
          activateCategory('all');
        }
      }
    });

    // Close when clicking anywhere outside
    document.addEventListener('click', (e) => {
      if (!dropdown.contains(e.target as Node)) {
        panel.classList.remove('is-open');
        trigger.setAttribute('aria-expanded', 'false');
      }
    });

    // Handle category hover / click selections to filter projects list
    const catItems = Array.from(dropdown.querySelectorAll('.breadcrumb__cat-item')) as HTMLButtonElement[];
    const projLists = Array.from(dropdown.querySelectorAll('.breadcrumb__proj-list')) as HTMLDivElement[];

    function activateCategory(catId: string) {
      catItems.forEach(item => {
        item.classList.toggle('is-active', item.getAttribute('data-cat-id') === catId);
      });
      projLists.forEach(list => {
        list.classList.toggle('is-active', list.getAttribute('data-cat-id') === catId);
      });
    }

    catItems.forEach(item => {
      const catId = item.getAttribute('data-cat-id') || '';

      // Desktop Hover
      item.addEventListener('mouseenter', () => {
        activateCategory(catId);
      });

      // Mobile Click
      item.addEventListener('click', (e) => {
        e.stopPropagation();
        activateCategory(catId);
      });
    });

    // On page load: auto-activate correct category if on a project detail view
    const activeProjItem = dropdown.querySelector('.breadcrumb__proj-item.is-active');
    if (activeProjItem) {
      const parentList = activeProjItem.closest('.breadcrumb__proj-list');
      if (parentList) {
        const catId = parentList.getAttribute('data-cat-id');
        if (catId && catId !== 'all') {
          activateCategory(catId);
        }
      }
    }
  }

  // Initial load
  setupCustomDropdown();

  // Support Astro View Transitions
  document.addEventListener('astro:after-swap', setupCustomDropdown);
</script>
