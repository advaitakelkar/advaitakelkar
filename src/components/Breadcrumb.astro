---
import { getCollection } from 'astro:content';

export interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const allProjects = await getCollection('projects');
const allCats     = await getCollection('categories');

const categoryDisplayNames: Record<string, string> = {
  'studio-823':    '823',
  'faizan-khatri': 'FKD',
  'archv':         'ARCHV',
  'scad':          'SCAD',
  'collaboration': 'COLLAB',
  'freelancer':    'FREE',
};

const categories = [...allCats].sort((a, b) =>
  (categoryDisplayNames[a.id] || a.data.displayName)
    .localeCompare(categoryDisplayNames[b.id] || b.data.displayName)
);

// Desktop project list (alphabetical)
const projects = [...allProjects].sort((a, b) => a.data.name.localeCompare(b.data.name));

// Mobile list: featured (by numbr) first, then the rest alphabetically
const featuredProjects = [...allProjects]
  .filter(p => p.data.featured)
  .sort((a, b) => (a.data.numbr ?? 999) - (b.data.numbr ?? 999));
const featuredIds = new Set(featuredProjects.map(p => p.id));
const otherProjects = [...allProjects]
  .filter(p => !featuredIds.has(p.id))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
const mobileProjects = [...featuredProjects, ...otherProjects];

const normalizedPath  = currentPath.replace(/\/$/, '') || '/';
const isHome          = normalizedPath === '/';
const isAbout         = normalizedPath === '/about';
const isProjectsIndex = normalizedPath === '/projects';
const isProjectPage   = normalizedPath.startsWith('/projects/') && !isProjectsIndex;

let currentProjectId   = '';
let currentProjectName = '';
let prevProjectUrl     = '';
let nextProjectUrl     = '';

let activeProject = isProjectPage
  ? projects.find(p => p.id === normalizedPath.split('/').filter(Boolean)[1])
  : null;
if (!activeProject && projects.length > 0) activeProject = projects[0];

if (activeProject) {
  currentProjectId   = activeProject.id;
  currentProjectName = activeProject.data.name;
  const idx = projects.findIndex(p => p.id === currentProjectId);
  // Prev/next arrows only make sense on an actual project page — not on
  // Home / About / Projects / category pages, where there's no project context.
  if (idx !== -1 && isProjectPage) {
    prevProjectUrl = `/projects/${projects[(idx - 1 + projects.length) % projects.length].id}`;
    nextProjectUrl = `/projects/${projects[(idx + 1) % projects.length].id}`;
  }
}
---

<nav class="breadcrumb" aria-label="Secondary navigation">

  <!-- Left pills: Home / About / Projects -->
  <div class:list={["breadcrumb__list", isProjectPage && "breadcrumb__list--project-page"]}>
    <a href="/" class:list={["breadcrumb__link", isHome && "is-active"]}>
      <span class="crumb-full">Home</span>
      <svg class="crumb-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
        <polyline points="9 22 9 12 15 12 15 22"></polyline>
      </svg>
    </a>
    <span class="breadcrumb__sep" aria-hidden="true">/</span>
    <a href="/about" class:list={["breadcrumb__link", isAbout && "is-active"]}>
      <span class="crumb-full">About</span>
      <svg class="crumb-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
        <rect x="4" y="4" width="16" height="16" rx="2"></rect>
      </svg>
    </a>
    <span class="breadcrumb__sep" aria-hidden="true">/</span>
    <a href="/projects" class:list={["breadcrumb__link", isProjectsIndex && "is-active"]}>
      <span class="crumb-full">Projects</span>
      <svg class="crumb-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
        <circle cx="12" cy="12" r="9"></circle>
      </svg>
    </a>
    <span class="breadcrumb__sep" aria-hidden="true">/</span>

    <!-- Desktop: category quick-links next to Projects -->
    {categories.map(c => (
      <a href={`/${c.id}`} class:list={["breadcrumb__link", "breadcrumb__cat-link", normalizedPath === `/${c.id}` && "is-active"]}>
        <span class="crumb-full">{categoryDisplayNames[c.id] || c.data.displayName}</span>
      </a>
    ))}
  </div>

  <!-- Right: prev / dropdown / next -->
  <div class:list={["breadcrumb__project-nav", isProjectPage && "is-active"]}>
    {prevProjectUrl && (
      <a href={prevProjectUrl} class="breadcrumb__arrow breadcrumb__arrow--prev" aria-label="Previous project">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </a>
    )}

    <div class="breadcrumb__custom-dropdown" id="breadcrumb-custom-dropdown">
      <button class="breadcrumb__dropdown-trigger" id="breadcrumb-dropdown-trigger" type="button" aria-haspopup="true" aria-expanded="false">
        <span id="breadcrumb-trigger-label">
          {isProjectPage && currentProjectName ? currentProjectName : 'Categories'}
        </span>
        <svg class="breadcrumb__trigger-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>

      <div class="breadcrumb__dropdown-panel" id="breadcrumb-dropdown-panel">

        <!-- ── MOBILE: single flat scrollable list (reversed — scroll up to explore) ─ -->
        <!-- DOM order is inverted: projects at top, Home/About at bottom.            -->
        <!-- JS scrolls to bottom on open so Home/About sits near the thumb.         -->
        <div class="breadcrumb__mobile-list" id="breadcrumb-mobile-list">
          <!-- Projects (furthest from thumb — scroll up to reach) -->
          {[...mobileProjects].reverse().map(p => (
            <a
              href={`/projects/${p.id}`}
              class:list={["breadcrumb__list-item", currentProjectId === p.id && "is-active"]}
            >
              <span class="breadcrumb__proj-name">{p.data.name}</span>
              <svg class="breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true"><line x1="6" y1="18" x2="18" y2="6"/><polyline points="10 6 18 6 18 14"/></svg>
            </a>
          ))}

          <div class="breadcrumb__divider" aria-hidden="true"></div>

          <!-- Category pages -->
          {[...categories].reverse().map(c => (
            <a href={`/${c.id}`} class="breadcrumb__list-item breadcrumb__list-item--cat">
              <span>{categoryDisplayNames[c.id] || c.data.displayName}</span>
              <svg class="breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true"><line x1="6" y1="18" x2="18" y2="6"/><polyline points="10 6 18 6 18 14"/></svg>
            </a>
          ))}

          <div class="breadcrumb__divider" aria-hidden="true"></div>

          <!-- Page links (nearest thumb — visible first on open) -->
          <a href="/projects" class:list={["breadcrumb__list-item", isProjectsIndex && "is-active"]}>
            <span>Projects</span>
            <svg class="breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true"><line x1="6" y1="18" x2="18" y2="6"/><polyline points="10 6 18 6 18 14"/></svg>
          </a>
          <a href="/about" class:list={["breadcrumb__list-item", isAbout && "is-active"]}>
            <span>About</span>
            <svg class="breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true"><line x1="6" y1="18" x2="18" y2="6"/><polyline points="10 6 18 6 18 14"/></svg>
          </a>
          <a href="/" class:list={["breadcrumb__list-item", isHome && "is-active"]}>
            <span>Home</span>
            <svg class="breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true"><line x1="6" y1="18" x2="18" y2="6"/><polyline points="10 6 18 6 18 14"/></svg>
          </a>
        </div>

        <!-- ── DESKTOP: two columns ───────────────────────────── -->
        <div class="breadcrumb__menu-column breadcrumb__menu-column--categories">
          <a href="/projects" class="breadcrumb__cat-item" data-cat-id="all">
            <span>All</span>
            <svg class="breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true"><line x1="6" y1="18" x2="18" y2="6"/><polyline points="10 6 18 6 18 14"/></svg>
          </a>
          {categories.map(c => (
            <a href={`/${c.id}`} class="breadcrumb__cat-item" data-cat-id={c.id}>
              <span>{categoryDisplayNames[c.id] || c.data.displayName}</span>
              <svg class="breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true"><line x1="6" y1="18" x2="18" y2="6"/><polyline points="10 6 18 6 18 14"/></svg>
            </a>
          ))}
        </div>

        <div class="breadcrumb__menu-column breadcrumb__menu-column--projects">
          <!-- all projects -->
          <div class="breadcrumb__proj-list is-active" data-cat-id="all">
            {projects.map(p => (
              <a href={`/projects/${p.id}`} class:list={["breadcrumb__proj-item", currentProjectId === p.id && "is-active"]} data-cat-id={p.data.category?.id || ''}>
                <span class="breadcrumb__proj-name">{p.data.name}</span>
                <svg class="breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true"><line x1="6" y1="18" x2="18" y2="6"/><polyline points="10 6 18 6 18 14"/></svg>
              </a>
            ))}
          </div>
          <!-- per-category lists -->
          {categories.map(c => {
            const catProjs = projects.filter(p => p.data.category?.id === c.id);
            return (
              <div class="breadcrumb__proj-list" data-cat-id={c.id}>
                {catProjs.length === 0
                  ? <div class="breadcrumb__proj-empty">No projects</div>
                  : catProjs.map(p => (
                    <a href={`/projects/${p.id}`} class:list={["breadcrumb__proj-item", currentProjectId === p.id && "is-active"]} data-cat-id={p.data.category?.id || ''}>
                      <span class="breadcrumb__proj-name">{p.data.name}</span>
                      <svg class="breadcrumb__arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true"><line x1="6" y1="18" x2="18" y2="6"/><polyline points="10 6 18 6 18 14"/></svg>
                    </a>
                  ))
                }
              </div>
            );
          })}
        </div>

      </div>
    </div>

    {nextProjectUrl && (
      <a href={nextProjectUrl} class="breadcrumb__arrow breadcrumb__arrow--next" aria-label="Next project">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </a>
    )}
  </div>

  <div class="breadcrumb__backdrop" id="breadcrumb-backdrop"></div>
</nav>

<style>
  /* ── Shell ──────────────────────────────────────────────────── */
  .breadcrumb {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 7px;
    position: relative;
    z-index: 500;
  }

  .breadcrumb__list {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 7px;
  }

  .breadcrumb__sep { display: none; }

  /* ── Left nav pills ─────────────────────────────────────────── */
  .breadcrumb__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    text-decoration: none;
    font-family: var(--_tokens---font--mono);
    font-size: var(--_tokens---type--micro);
    letter-spacing: 0.05em;
    white-space: nowrap;
    opacity: 0.8;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s, opacity 0.15s;
  }

  .breadcrumb__link:hover,
  .breadcrumb__link:focus-visible {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    border-color: var(--_tokens---color--fg);
    opacity: 1;
    outline: none;
  }

  .breadcrumb__link.is-active {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 14%, transparent);
    color: var(--_tokens---color--fg);
    border-color: color-mix(in srgb, var(--_tokens---color--fg) 30%, transparent);
    opacity: 1;
    font-weight: 500;
  }

  .crumb-icon { display: none; }

  /* Category quick-links sit in the bar on desktop only (mobile uses the dropdown) */
  @media (max-width: 767px) {
    .breadcrumb__cat-link { display: none; }
  }

  @media (max-width: 640px) {
    .crumb-full { display: none; }
    .crumb-icon { display: inline-block; width: 11px; height: 11px; flex-shrink: 0; vertical-align: middle; }
  }

  /* On project pages on mobile: hide Home & About pills */
  @media (max-width: 767px) {
    .breadcrumb__list--project-page .breadcrumb__link:nth-child(-n+4) { display: none; }
  }

  /* ── Dropdown trigger ───────────────────────────────────────── */
  .breadcrumb__project-nav {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
    position: relative;
    z-index: 500;
  }

  .breadcrumb__custom-dropdown { position: relative; }

  .breadcrumb__dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    font-family: var(--_tokens---font--mono);
    font-size: var(--_tokens---type--micro);
    font-weight: 500;
    letter-spacing: 0.05em;
    white-space: nowrap;
    cursor: pointer;
    outline: none;
    opacity: 0.55;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s, opacity 0.15s;
  }

  .breadcrumb__dropdown-trigger:hover,
  .breadcrumb__dropdown-trigger:focus-visible,
  .breadcrumb__dropdown-trigger[aria-expanded="true"] {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    border-color: var(--_tokens---color--fg);
    opacity: 1;
    outline: none;
  }

  /* When on a project page, give the trigger a stronger border to signal it's the "active" crumb */
  .breadcrumb__project-nav.is-active .breadcrumb__dropdown-trigger {
    color: var(--_tokens---color--fg);
    border-color: var(--_tokens---color--fg);
    opacity: 0.9;
  }
  .breadcrumb__project-nav.is-active .breadcrumb__dropdown-trigger:hover,
  .breadcrumb__project-nav.is-active .breadcrumb__dropdown-trigger[aria-expanded="true"] {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  .breadcrumb__trigger-chevron {
    width: 10px; height: 10px;
    flex-shrink: 0;
    opacity: 0.6;
    transition: transform 0.2s ease, opacity 0.2s;
  }
  .breadcrumb__dropdown-trigger[aria-expanded="true"] .breadcrumb__trigger-chevron,
  .breadcrumb__dropdown-trigger:hover .breadcrumb__trigger-chevron {
    opacity: 1;
  }
  .breadcrumb__dropdown-trigger[aria-expanded="true"] .breadcrumb__trigger-chevron {
    transform: rotate(180deg);
  }

  /* Prev / Next project arrows */
  .breadcrumb__arrow {
    display: flex; align-items: center; justify-content: center;
    width: 1.8em; height: 1.8em;
    border-radius: 50%;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    transition: background-color 0.15s, color 0.15s;
    flex-shrink: 0;
    text-decoration: none;
  }
  .breadcrumb__arrow:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }
  .breadcrumb__arrow svg { width: 1em; height: 1em; }

  @media (max-width: 640px) {
    .breadcrumb__arrow--prev,
    .breadcrumb__arrow--next { display: none; }
  }

  /* ── Dropdown panel ─────────────────────────────────────────── */
  .breadcrumb__dropdown-panel {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    z-index: 500;
    display: none;
    /* desktop: two-col grid; mobile: single block */
    grid-template-columns: 110px;
    width: 110px;
    gap: 0;
    align-items: start;
  }

  .breadcrumb__dropdown-panel.is-open { display: grid; }

  /* Desktop: widen to two columns when a category is active */
  @media (min-width: 768px) {
    .breadcrumb__dropdown-panel {
      left: auto;
      right: 0;
    }
    .breadcrumb__dropdown-panel.has-active-cat {
      grid-template-columns: 190px 110px;
      width: 308px;
      gap: 8px;
    }
    .breadcrumb__menu-column--categories {
      order: 2;
    }
    .breadcrumb__menu-column--projects {
      order: 1;
    }
    /* Mobile list invisible on desktop */
    .breadcrumb__mobile-list { display: none !important; }
  }

  /* Mobile: open upward (breadcrumb docked at bottom), right-aligned */
  @media (max-width: 767px) {
    .breadcrumb__dropdown-panel {
      top: auto;
      bottom: calc(100% + 6px);
      left: auto;
      right: 0;
      grid-template-columns: min(260px, calc(100vw - 64px));
      width: min(260px, calc(100vw - 64px));
    }
    /* Desktop columns invisible on mobile */
    .breadcrumb__menu-column { display: none !important; }
  }

  /* ── Menu columns (desktop) ─────────────────────────────────── */
  .breadcrumb__menu-column {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 8px;
    background-color: color-mix(in srgb, var(--_tokens---color--bg) 35%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    border-radius: 8px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
    max-height: calc(100dvh - 100px);
    overflow-y: auto;
    scrollbar-width: none;
  }
  .breadcrumb__menu-column::-webkit-scrollbar { display: none; }

  .breadcrumb__menu-column--projects { display: none; }

  @media (min-width: 768px) {
    .breadcrumb__dropdown-panel.has-active-cat .breadcrumb__menu-column--projects {
      display: flex;
      flex-direction: column;
    }
  }

  /* ── Mobile flat list ───────────────────────────────────────── */
  .breadcrumb__mobile-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 8px;
    background-color: color-mix(in srgb, var(--_tokens---color--bg) 35%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    border-radius: 8px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
    max-height: calc(80dvh - 60px);
    overflow-y: auto;
    scrollbar-width: none;
  }
  .breadcrumb__mobile-list::-webkit-scrollbar { display: none; }

  .breadcrumb__divider {
    height: 1px;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    margin: 4px 2px;
    flex-shrink: 0;
  }

  /* ── Shared item style ──────────────────────────────────────── */
  .breadcrumb__list-item,
  .breadcrumb__cat-item,
  .breadcrumb__proj-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 5px 10px;
    border-radius: 999px;
    border: 1px solid transparent;
    background-color: transparent;
    color: var(--_tokens---color--muted);
    font-family: var(--_tokens---font--mono);
    font-size: var(--_tokens---type--micro);
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
    flex-shrink: 0;
  }

  /* Full invert on hover / focus */
  .breadcrumb__list-item:hover,
  .breadcrumb__list-item:focus-visible,
  .breadcrumb__cat-item:hover,
  .breadcrumb__cat-item:focus-visible,
  .breadcrumb__proj-item:hover,
  .breadcrumb__proj-item:focus-visible {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    border-color: var(--_tokens---color--fg);
    outline: none;
  }

  /* Active item (current page / project) — muted invert */
  .breadcrumb__list-item.is-active,
  .breadcrumb__proj-item.is-active {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 14%, transparent);
    color: var(--_tokens---color--fg);
    border-color: color-mix(in srgb, var(--_tokens---color--fg) 28%, transparent);
    font-weight: 500;
  }

  /* Active category (desktop: showing its projects in right column) */
  .breadcrumb__cat-item.is-active {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
    color: var(--_tokens---color--fg);
    border-color: color-mix(in srgb, var(--_tokens---color--fg) 20%, transparent);
  }

  /* Category items slightly muted to distinguish from page links */
  .breadcrumb__list-item--cat { opacity: 0.85; }
  .breadcrumb__list-item--cat:hover { opacity: 1; }

  .breadcrumb__proj-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    text-align: left;
    flex: 1;
  }

  .breadcrumb__proj-list { display: none; }
  .breadcrumb__proj-list.is-active { display: flex; flex-direction: column; gap: 1px; }

  .breadcrumb__proj-empty {
    font-size: var(--_tokens---type--micro);
    color: var(--_tokens---color--muted);
    padding: 12px;
    text-align: center;
  }

  .breadcrumb__arrow-icon {
    width: 8px; height: 8px;
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 0.15s;
  }
  .breadcrumb__list-item:hover .breadcrumb__arrow-icon,
  .breadcrumb__list-item:focus-visible .breadcrumb__arrow-icon,
  .breadcrumb__cat-item:hover .breadcrumb__arrow-icon,
  .breadcrumb__cat-item:focus-visible .breadcrumb__arrow-icon,
  .breadcrumb__cat-item.is-active .breadcrumb__arrow-icon,
  .breadcrumb__proj-item:hover .breadcrumb__arrow-icon,
  .breadcrumb__proj-item:focus-visible .breadcrumb__arrow-icon { opacity: 1; }

  /* ── Backdrop ───────────────────────────────────────────────── */
  .breadcrumb__backdrop {
    position: fixed; inset: 0;
    background-color: rgba(0, 0, 0, 0.2);
    z-index: 450;
    display: none;
    pointer-events: auto;
  }
  .breadcrumb__backdrop.is-open { display: block; }

  /* Focus outlines suppressed in favour of background invert */
  .breadcrumb__link:focus-visible,
  .breadcrumb__dropdown-trigger:focus-visible,
  .breadcrumb__list-item:focus-visible,
  .breadcrumb__cat-item:focus-visible,
  .breadcrumb__proj-item:focus-visible,
  .breadcrumb__arrow:focus-visible { outline: none !important; }
</style>

<script>
  function setupDropdown() {
    const trigger  = document.getElementById('breadcrumb-dropdown-trigger') as HTMLButtonElement | null;
    const panel    = document.getElementById('breadcrumb-dropdown-panel');
    const dropdown = document.getElementById('breadcrumb-custom-dropdown');
    if (!trigger || !panel || !dropdown) return;

    // Shuffle desktop project lists so order varies each visit
    dropdown.querySelectorAll('.breadcrumb__proj-list').forEach(list => {
      const items = Array.from(list.querySelectorAll('.breadcrumb__proj-item')) as HTMLElement[];
      for (let i = items.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [items[i], items[j]] = [items[j], items[i]];
      }
      items.forEach(el => list.appendChild(el));
    });

    // ── Open / close ───────────────────────────────────────────
    function openDropdown() {
      panel.classList.add('is-open');
      trigger.setAttribute('aria-expanded', 'true');
      document.getElementById('breadcrumb-backdrop')?.classList.add('is-open');
      // Lock page scroll — must close the dropdown before scrolling the page behind
      document.documentElement.style.overflow = 'hidden';
      document.body.style.overflow = 'hidden';
      activateCategory('all');
      // Scroll mobile list to bottom so Home/About are visible near thumb
      const mobileList = document.getElementById('breadcrumb-mobile-list');
      if (mobileList) requestAnimationFrame(() => { mobileList.scrollTop = mobileList.scrollHeight; });
    }

    function closeDropdown() {
      panel.classList.remove('is-open', 'has-active-cat');
      trigger.setAttribute('aria-expanded', 'false');
      document.getElementById('breadcrumb-backdrop')?.classList.remove('is-open');
      // Restore page scroll
      document.documentElement.style.overflow = '';
      document.body.style.overflow = '';
      dropdown.querySelectorAll('.breadcrumb__cat-item.is-active').forEach(el => el.classList.remove('is-active'));
      const allList = dropdown.querySelector('.breadcrumb__proj-list[data-cat-id="all"]');
      dropdown.querySelectorAll('.breadcrumb__proj-list.is-active').forEach(el => el.classList.remove('is-active'));
      allList?.classList.add('is-active');
    }
    (window as any).closeBreadcrumbDropdown = closeDropdown;

    trigger.addEventListener('click', () =>
      panel.classList.contains('is-open') ? closeDropdown() : openDropdown()
    );

    document.getElementById('breadcrumb-backdrop')?.addEventListener('click', closeDropdown);
    document.addEventListener('click', e => {
      if (panel.classList.contains('is-open') && !dropdown.contains(e.target as Node)) closeDropdown();
    });

    // ── Category activation (desktop only) ────────────────────
    const catItems  = Array.from(dropdown.querySelectorAll('.breadcrumb__cat-item'))  as HTMLAnchorElement[];
    const projLists = Array.from(dropdown.querySelectorAll('.breadcrumb__proj-list')) as HTMLDivElement[];

    function activateCategory(catId: string) {
      catItems.forEach(el => el.classList.toggle('is-active', el.dataset.catId === catId));
      projLists.forEach(el => el.classList.toggle('is-active', el.dataset.catId === catId));
      if (catId) panel.classList.add('has-active-cat');
    }

    catItems.forEach(item => {
      const id = item.dataset.catId || '';
      item.addEventListener('mouseenter', () => { if (window.innerWidth >= 768) activateCategory(id); });
      item.addEventListener('focus', () => { if (window.innerWidth >= 768) activateCategory(id); });
    });

    // ── Keyboard navigation ────────────────────────────────────
    function getFocusableItems(): HTMLElement[] {
      if (window.innerWidth < 768) {
        return Array.from(dropdown.querySelectorAll('.breadcrumb__mobile-list .breadcrumb__list-item')) as HTMLElement[];
      }
      const items: HTMLElement[] = [...catItems];
      const active = panel.querySelector('.breadcrumb__proj-list.is-active');
      if (active) items.push(...Array.from(active.querySelectorAll('.breadcrumb__proj-item')) as HTMLElement[]);
      return items;
    }

    dropdown.addEventListener('keydown', (e: KeyboardEvent) => {
      if (!panel.classList.contains('is-open')) return;

      if (e.key === 'Escape') {
        e.preventDefault();
        closeDropdown();
        trigger.focus();
        return;
      }

      if (!['ArrowDown','ArrowUp','ArrowRight','ArrowLeft'].includes(e.key)) return;
      e.preventDefault();

      const items  = getFocusableItems();
      const active = document.activeElement as HTMLElement;
      const idx    = items.indexOf(active);

      if (e.key === 'ArrowDown') {
        (items[idx + 1] ?? items[0])?.focus();
      } else if (e.key === 'ArrowUp') {
        (items[idx - 1] ?? items[items.length - 1])?.focus();
      } else if (e.key === 'ArrowLeft' && window.innerWidth >= 768) {
        const first = panel.querySelector('.breadcrumb__proj-list.is-active .breadcrumb__proj-item') as HTMLElement | null;
        first?.focus();
      } else if (e.key === 'ArrowRight' && window.innerWidth >= 768) {
        (panel.querySelector('.breadcrumb__cat-item.is-active') as HTMLElement | null ?? catItems[0])?.focus();
      }
    });

    // Open on ArrowDown / Enter / Space while trigger is focused
    trigger.addEventListener('keydown', (e: KeyboardEvent) => {
      if (['ArrowDown','Enter',' '].includes(e.key) && !panel.classList.contains('is-open')) {
        e.preventDefault();
        openDropdown();
        requestAnimationFrame(() => getFocusableItems()[0]?.focus());
      }
    });

    // ── Sync active project & prev/next arrows ─────────────────
    function syncActiveProject(projectId: string) {
      dropdown.querySelectorAll('.breadcrumb__proj-item').forEach(el =>
        el.classList.toggle('is-active', el.getAttribute('href') === `/projects/${projectId}`)
      );
      const allItems = Array.from(
        dropdown.querySelectorAll('.breadcrumb__proj-list[data-cat-id="all"] .breadcrumb__proj-item')
      ) as HTMLAnchorElement[];
      const i = allItems.findIndex(el => el.getAttribute('href') === `/projects/${projectId}`);
      if (i !== -1) {
        const prev = document.querySelector('.breadcrumb__arrow--prev') as HTMLAnchorElement | null;
        const next = document.querySelector('.breadcrumb__arrow--next') as HTMLAnchorElement | null;
        if (prev) prev.href = allItems[(i - 1 + allItems.length) % allItems.length].getAttribute('href') || '#';
        if (next) next.href = allItems[(i + 1) % allItems.length].getAttribute('href') || '#';
      }
    }

    const path = window.location.pathname.replace(/\/$/, '') || '/';
    if (path.startsWith('/projects/') && path !== '/projects') {
      const id = path.split('/').filter(Boolean)[1] || '';
      if (id) localStorage.setItem('latestProject', id);
    } else {
      const latest = localStorage.getItem('latestProject');
      if (latest) syncActiveProject(latest);
    }

    // ── Global arrow-key page navigation ─────────────────────
    if (!(window as any).hasKbGlobalNav) {
      (window as any).hasKbGlobalNav = true;
      window.addEventListener('keydown', (e: KeyboardEvent) => {
        const el = document.activeElement as HTMLElement | null;
        if (el && (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA' || el.isContentEditable)) return;
        if (panel?.classList.contains('is-open')) return;
        if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;

        const p = window.location.pathname.replace(/\/$/, '') || '/';
        if (p.startsWith('/projects/') && p !== '/projects') {
          const arrow = e.key === 'ArrowRight'
            ? document.querySelector('.breadcrumb__arrow--next') as HTMLAnchorElement | null
            : document.querySelector('.breadcrumb__arrow--prev') as HTMLAnchorElement | null;
          if (arrow) { e.preventDefault(); window.location.href = arrow.href; }
        } else {
          const pages = ['/', '/about', '/projects'];
          const ci = pages.indexOf(p);
          if (e.key === 'ArrowRight' && ci < pages.length - 1) { e.preventDefault(); window.location.href = pages[ci + 1]; }
          if (e.key === 'ArrowLeft'  && ci > 0)                 { e.preventDefault(); window.location.href = pages[ci - 1]; }
        }
      });
    }
  }

  setupDropdown();
  document.addEventListener('astro:after-swap', () => {
    (window as any).hasKbGlobalNav = false;
    setupDropdown();
  });
</script>
