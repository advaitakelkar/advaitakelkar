---
import Base from './Base.astro';
import SideNav from '../components/SideNav.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  crumbs?: Array<{ label: string; href?: string }>;
  label?: string;
}

const { title, description, ogImage, crumbs = [], label } = Astro.props;
const currentPath = Astro.url.pathname;
---

<Base title={title} description={description} ogImage={ogImage}>
  <div class="page-wrap">
    <SideNav currentPath={currentPath} label={label} />

    <main class="page-main">
      <div class="page-breadcrumb">
        <Breadcrumb currentPath={currentPath} />
      </div>
      <slot />
    </main>
  </div>
</Base>

<style>
  .page-wrap {
    display: flex;
    min-height: 100dvh;
  }

  .page-main {
    flex: 1;
    margin-left: 64px; /* Offset adjusted for 64px wide sidebar */
    padding: var(--_tokens---space--small);
    transition: padding 0.3s ease;
  }

  /* Sticky breadcrumb bar */
  .page-breadcrumb {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--_tokens---color--bg);
    margin-left: calc(-1 * var(--_tokens---space--small));
    margin-right: calc(-1 * var(--_tokens---space--small));
    padding-inline: var(--_tokens---space--small);
    padding-block: 20px 16px; /* expanded vertical size */
    margin-bottom: var(--_tokens---space--small);
    opacity: 1;
    border-bottom: 1px solid var(--_tokens---color--line);
    transition: background-color 0.3s ease;
  }

  /* Padding for really big screens (above laptop screens, >= 1200px) */
  @media (min-width: 1200px) {
    .page-main {
      padding-inline: clamp(6rem, 12vw, 16rem); /* Squeezes body text in */
      padding-top: clamp(6rem, 8vh, 9rem); /* Switched down */
    }
    
    .page-breadcrumb {
      margin-left: calc(-1 * clamp(6rem, 12vw, 16rem));
      margin-right: calc(-1 * clamp(6rem, 12vw, 16rem));
      padding-inline: clamp(6rem, 12vw, 16rem);
      padding-top: 24px;
    }
  }

  /* Mobile Portrait docking on bottom */
  @media (max-width: 767px) and (orientation: portrait) {
    .page-breadcrumb {
      position: fixed !important;
      bottom: 0 !important;
      top: auto !important;
      left: 64px !important;
      right: 0 !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
      margin-bottom: 0 !important;
      padding-inline: var(--_tokens---space--small) !important;
      padding-block: 16px !important;
      background-color: var(--_tokens---color--bg) !important;
      border-top: 1px solid var(--_tokens---color--line) !important;
      border-bottom: none !important;
      box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.15);
      z-index: 150 !important;
    }

    .page-main {
      padding-bottom: 80px !important;
    }
  }
</style>
