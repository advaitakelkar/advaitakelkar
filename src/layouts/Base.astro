---
import '../styles/tokens.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Advaita Kelkar — Architect & Designer', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/ak-favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} — AK</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- ── Scheme: runs synchronously in <head> → no FOUC, correct on every page load ── -->
    <script is:inline>
      (function () {
        var ALL_SCH = ['sch1','sch2','sch3','sch4','sch5','sch6','sch7','sch8','sch9'];
        var VALID   = ['default','sch1','sch2','sch3','sch4','sch5','sch6','sch7','sch8','sch9'];

        function setClass(id) {
          ALL_SCH.forEach(function (s) { document.documentElement.classList.remove(s); });
          if (id !== 'default') document.documentElement.classList.add(id);
        }

        function randomSch() {
          return 'sch' + Math.ceil(Math.random() * 9);
        }

        // Reload detection — Navigation Timing Level 2
        var navEntry = performance.getEntriesByType && performance.getEntriesByType('navigation')[0];
        var isReload = navEntry ? navEntry.type === 'reload' : false;

        var stored = sessionStorage.getItem('aks');
        var valid  = stored && VALID.indexOf(stored) !== -1;

        if (isReload || !valid) {
          // Hard reload or first-ever visit → fresh random, clear manual mode
          var cls = randomSch();
          setClass(cls);
          sessionStorage.setItem('aks', cls);
          sessionStorage.removeItem('aks-mode');
        } else {
          // Page navigation → restore scheme + manual mode if set
          setClass(stored);
          var storedMode = sessionStorage.getItem('aks-mode');
          if (storedMode === 'dark')  document.documentElement.classList.add('mode-dark');
          if (storedMode === 'light') document.documentElement.classList.add('mode-light');
        }

        // ── Keyboard cycling: < = prev scheme  > = next scheme ──
        document.addEventListener('keydown', function (e) {
          var tag = (e.target && e.target.tagName) || '';
          if (tag === 'INPUT' || tag === 'TEXTAREA' || e.target.isContentEditable) return;
          if (e.key !== '<' && e.key !== '>') return;
          var cur = sessionStorage.getItem('aks') || 'default';
          var idx = VALID.indexOf(cur);
          if (idx < 0) idx = 0;
          var next = e.key === '>'
            ? VALID[(idx + 1) % VALID.length]
            : VALID[(idx - 1 + VALID.length) % VALID.length];
          setClass(next);
          sessionStorage.setItem('aks', next);
          // Tell SideNav to sync its active-option highlight
          document.dispatchEvent(new CustomEvent('aks-scheme', { detail: next }));
        });
      })();
    </script>
  </head>
  <body>
    <!-- Global background watermark logo (inline SVG → crisp vector at any size) -->
    <div class="watermark-container" aria-hidden="true">
      <svg class="watermark-logo" id="watermark-logo" viewBox="88 211 419 419" xmlns="http://www.w3.org/2000/svg">
        <path d="M432.1,534.82l23.1,21.24c-8.9,10.9-18.69,20.48-30.03,29.3l-25.37-21.34-38.6-31.92-36.41-28.9-2.98,48.7-2.29,70.14c-13.83.96-27.6.86-41.54.05l-1.94-56.63-2.19-43.56-1.35-18.62c-22.23,17.07-43.62,34.31-64.89,52.3l-35.26,29.83-9.63-8c-7.56-6.28-13.66-13.59-20.39-21.26l27.74-25.56,9.02-8.39,54.34-51.21-36.86-2.33-97.71-1.74c-1.5-14.03-2.44-27.4-2.51-41.4l88.38-1.81c9.12-.08,17.67.46,26.47,3.52l-51.31,15.36,63.22-10.11c6.27,4.44,11.41,9.62,16.62,15.16l10.24,10.89c6.53,6.94,13.47,12.98,22.03,17.26,10.93,5.47,23.05,6.45,34.71,2.78,15.97-5.03,28.29-16.11,40.53-27.11l14.67-13.18c5.49-4.93,11.71-8.35,18.79-10.52,7.64-2.34,15.36-4,23.44-3.96l25.5.11,69.93,1.61-.38,15.16-2.12,26.23-30.09.27-65.8,1.61-37.24,2.12,20.43,19.33,47.71,44.6Z"/>
        <path d="M338.79,376.68c-5.79-5.79-12.64-9.54-20.1-12.3-24.12-8.95-45.8,4.72-63.57,20.83l-20.38,18.47c-12.63,11.45-29.24,14.43-46.19,14.89l-92.23-1.99c.11-13.77.97-27.41,2.51-41.39l85.45-1.27,48.95-2.72-31.3-29.35-59.94-55.5c8.81-10.6,18.37-20.47,29.56-29.21l40.59,33.78,60.41,48.27,2.9-55.03,2.18-64.11c13.97-.86,27.77-.99,41.61.05l2.13,64.52,3.07,54.55,63.11-50.96,37.19-31.04c11.26,8.59,21.19,18.15,29.63,29.2l-22.21,20.58-68.35,64.22,38.95,2.23c31.62,1.35,62.77,1.77,94.37,1.79,1.66,14.02,2.22,27.58,2.59,41.38l-88.29,1.91c-14.2.13-29.24-1.89-40.49-10.3l62.9-10.32.89-.28-4.24-.32h-71.6s-7.53-8.01-7.53-8.01l-12.57-12.58Z"/>
        <path d="M301.13,460.16c-10,2.48-19.65.98-28.12-4.04-10.05-6.37-15.44-17.49-14.89-29.42l21.3-3.55c-1.87-.35-3.79-.23-5.83,0l-15.28.47c2.15-22.78,22.76-42.17,45.64-42.72,19.26-.47,33.81,13.54,34.13,32.76l-53.68,8.79-.24.33,4.84-.23,48.64-1.49c-3.31,18.91-17.65,34.41-36.51,39.1Z"/>
      </svg>
    </div>

    <style is:global>
      /* Big muted watermark logo, anchored in the bottom-right corner,
         ~75% visible (a quarter bleeds off the corner). Breathes (shrink/grow)
         from the corner, continuously, at a different speed than the nav logo.
         Follows the active colour scheme via the foreground token. */
       .watermark-container {
        position: fixed;
        bottom: 0;
        right: 0;
        width: 100%;
        height: 100%;
        z-index: 9999;          /* on top of all elements, acting as overlay watermark */
        pointer-events: none;
        overflow: hidden;
      }

      .watermark-logo {
        position: absolute;
        top: 0;
        left: 0;
        width: 200px;
        height: 200px;
        fill: var(--_tokens---color--fg);   /* inline SVG → crisp vector at any size */
        opacity: 0.04;          /* subtle watermark overlay — blends with bg */
        transform-origin: center center;  /* rotate around its own center axis */
        transform: translate(0, 0) rotate(0deg);
        transition: fill 0.3s ease;
        will-change: width, height, transform;
      }

      /* Physics balls — darker tint of the background, so they feel like
         the background itself is breathing. Adapts to every colour scheme automatically. */
      .watermark-ball {
        fill: color-mix(in srgb, var(--_tokens---color--bg) 60%, black);
      }

      /* Dead (zombie) balls: filled circle, slightly more opaque + a slow pulse */
      .watermark-ball--dead {
        fill: color-mix(in srgb, var(--_tokens---color--fg) 30%, var(--_tokens---color--bg));
        animation: dead-pulse 2.4s ease-in-out infinite;
      }

      @keyframes dead-pulse {
        0%, 100% { opacity: 0.14; }
        50%       { opacity: 0.22; }
      }

      @media (prefers-reduced-motion: reduce) {
        .watermark-logo { animation: none; }
      }
    </style>

    <slot />
    <script>
      // Global Arrow Hover Random Rotation
      document.addEventListener('mouseover', (e) => {
        const target = e.target as HTMLElement;
        const hoverContainer = target.closest('a, button, .project-card, .about-link-row, .qs-row, .home-slider__slide, .sn-panel__link, .sn-panel__secondary-link');
        if (hoverContainer) {
          const arrow = hoverContainer.querySelector('.link-arrow') as HTMLElement;
          if (arrow && !arrow.dataset.hasRandomHover) {
            arrow.dataset.hasRandomHover = 'true';
            arrow.style.transition = 'transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease';
            
            const onMouseEnter = () => {
              const randomAngle = Math.floor(Math.random() * 360);
              arrow.style.transform = `rotate(${randomAngle}deg)`;
            };
            
            const onMouseLeave = () => {
              arrow.style.transform = '';
            };
            
            hoverContainer.addEventListener('mouseenter', onMouseEnter);
            hoverContainer.addEventListener('mouseleave', onMouseLeave);
            
            // Trigger immediately on first hover detection
            onMouseEnter();
          }
        }
      });
    </script>
    <script>
      // Global Text Scramble (Matrix Decode) Hover Effect
      const GLYPHS = '01XYZ%$#@?*+=#-_[]{}<>/';

      class TextScrambler {
        el: HTMLElement;
        originalText: string;
        frame: number = 0;
        queue: Array<{ from: string; to: string; start: number; end: number; char?: string }> = [];
        resolveQueue: () => void = () => {};
        animationFrameId: number = 0;

        constructor(el: HTMLElement) {
          this.el = el;
          this.originalText = el.dataset.scrambleText || el.textContent || '';
          if (!el.dataset.scrambleText) {
            el.dataset.scrambleText = this.originalText;
          }
        }

        scramble() {
          const currentText = this.el.textContent || '';
          const length = Math.max(this.originalText.length, currentText.length);
          this.queue = [];
          
          for (let i = 0; i < length; i++) {
            const from = currentText[i] || '';
            const to = this.originalText[i] || '';
            const start = Math.floor(Math.random() * 8);
            const end = start + Math.floor(Math.random() * 12) + 4;
            this.queue.push({ from, to, start, end });
          }

          cancelAnimationFrame(this.animationFrameId);
          this.frame = 0;
          
          return new Promise((resolve) => {
            this.resolveQueue = () => resolve(undefined);
            this.tick();
          });
        }

        tick() {
          let output = '';
          let complete = 0;

          for (let i = 0, n = this.queue.length; i < n; i++) {
            let { from, to, start, end, char } = this.queue[i];
            if (this.frame >= end) {
              complete++;
              output += to;
            } else if (this.frame >= start) {
              if (!char || Math.random() < 0.28) {
                char = GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
                this.queue[i].char = char;
              }
              output += char;
            } else {
              output += from;
            }
          }

          this.el.textContent = output;

          if (complete === this.queue.length) {
            this.resolveQueue();
          } else {
            this.frame++;
            this.animationFrameId = requestAnimationFrame(() => this.tick());
          }
        }

        stop() {
          cancelAnimationFrame(this.animationFrameId);
          this.el.textContent = this.originalText;
        }
      }

      function getScrambleTarget(target: HTMLElement): HTMLElement | null {
        // 0. Direct match: if the target (or close ancestor) is one of our designated safe text components,
        // use it immediately if it does not contain child elements (to preserve inner tags/SVGs).
        const directTextSpan = target.closest(
          '.home-nav-row__text, .about-link-row__text, ' +
          '.sn-panel__link span, .proj-bubble__name, ' +
          '.project-card__stack-name, .project-card__title, ' +
          '.education-card__school, .about-card__title, .stacked-name, .about-card__collab'
        );
        if (directTextSpan && directTextSpan.children.length === 0) {
          return directTextSpan as HTMLElement;
        }

        // Find the closest potential scramble container/element candidate
        let candidate: HTMLElement | null = null;

        // 1. Explicit scramble attribute
        const scrambleAttr = target.closest('[data-scramble]');
        if (scrambleAttr) {
          candidate = scrambleAttr as HTMLElement;
        } else {
          // 2. Headings (h1-h6)
          const heading = target.closest('h1, h2, h3, h4, h5, h6');
          if (heading) {
            candidate = heading as HTMLElement;
          } else {
            // 3. Links and navigation items
            const link = target.closest('a');
            if (link) {
              // Exclude breadcrumbs from ever scrambling
              if (link.closest('.breadcrumb, .page-breadcrumb')) {
                return null;
              }
              // Exclude long paragraphs or paragraph links
              if (link.closest('p, .home-intro__desc, .about-card__desc, .project-card__desc')) {
                const text = link.textContent?.trim() || '';
                if (text.length > 50) return null;
              }
              const textSpan = link.querySelector(
                '.home-nav-row__text, .about-link-row__text, ' +
                '.sn-panel__link span, .proj-bubble__name, ' +
                '.project-card__stack-name'
              );
              if (textSpan) return textSpan as HTMLElement;
              candidate = link;
            } else {
              // 4. Card headers and titles
              const title = target.closest(
                '.project-card__title, .education-card__school, ' +
                '.about-card__role, .about-card__org, .about-card__title, .stacked-name, .about-card__collab'
              );
              if (title) {
                candidate = title as HTMLElement;
              }
            }
          }
        }

        // Safety check: if the candidate exists and is safe (no element children), scramble it.
        // This ensures nested HTML structure (such as SVG icons or spans) is never deleted.
        if (candidate) {
          if (candidate.children.length === 0) {
            return candidate;
          }
          // If it has children, attempt to find a child that is safe to scramble
          const safeChild = candidate.querySelector(
            '.home-nav-row__text, .about-link-row__text, ' +
            '.sn-panel__link span, .proj-bubble__name, ' +
            '.project-card__stack-name, .project-card__title, ' +
            '.education-card__school, .about-card__title, .stacked-name, .about-card__collab'
          );
          if (safeChild && safeChild.children.length === 0) {
            return safeChild as HTMLElement;
          }
        }

        return null;
      }

      function getTriggerElement(scrambleEl: HTMLElement): HTMLElement {
        return scrambleEl.closest(
          'a, button, .home-nav-row, .about-link-row, .home-slider__slide, ' +
          '.sn-panel__link, .project-card, .education-card, .about-card, ' +
          '.skill-pill, .proj-bubble'
        ) as HTMLElement || scrambleEl;
      }

      document.addEventListener('mouseover', (e) => {
        const target = e.target as HTMLElement;
        const scrambleEl = getScrambleTarget(target);

        if (scrambleEl) {
          if (!scrambleEl.dataset.hasScrambleListener) {
            scrambleEl.dataset.hasScrambleListener = 'true';
            const scrambler = new TextScrambler(scrambleEl);

            const onMouseEnter = () => {
              scrambler.scramble();
            };

            const onMouseLeave = () => {
              scrambler.stop();
            };

            const triggerEl = getTriggerElement(scrambleEl);
            triggerEl.addEventListener('mouseenter', onMouseEnter);
            triggerEl.addEventListener('mouseleave', onMouseLeave);

            // Trigger immediately for the current hover
            onMouseEnter();
          }
        }
      });
    </script>
    <script>
      function initWatermarkLogo() {
        const container  = document.querySelector('.watermark-container') as HTMLElement | null;
        const templateEl = document.getElementById('watermark-logo') as SVGSVGElement | null;
        if (!container || !templateEl) return;

        templateEl.style.display = 'none';

        let W = window.innerWidth, H = window.innerHeight;

        // ── Constants (single source of truth — no duplicates) ──
        const NAV_W        = 44;
        const BREADCRUMB_H = 48;
        const MIN_FIB      = 3;       // smallest allowed Fibonacci level
        const MAX_FIB      = 7;       // F7 is the one big singleton at top
        const FIB_FRACS    = [0, 0.040, 0.065, 0.105, 0.170, 0.275, 0.445, 0.445];
        // Pyramid: F7=1 (singleton), F6=2, F5=4, F4=8, F3=fills the rest
        const TARGET_COUNT = [0, 0, 0, 99, 8, 4, 2, 1]; // index = fibLevel
        const GRAV_BASE    = 0.10;    // base gravity — scaled per ball by sizeRatio
        const BOUNCE       = 0.65;
        const DRAG         = 0.993;
        const PACK_GAP     = 10;      // px gap between ball edges
        const RESTITUTION  = 0.55;
        const WIND_FORCE   = 5.0;
        const MAX_SPEED_SM = 9.0;     // speed cap for smallest ball (F3)
        const MAX_SPEED_LG = 1.8;     // speed cap for largest ball (F7) — very slow
        const VROT_MAX_SM  = 2.2;     // max rotation speed for smallest
        const VROT_MAX_LG  = 0.15;    // max rotation speed for largest (barely moves)
        const SPAWN_CD_G   = 90;      // global cooldown frames after any size event
        const SPAWN_CD_B   = 110;     // per-ball cooldown frames after a size event

        type Ball = {
          el: SVGSVGElement;
          x: number; y: number;
          vx: number; vy: number;
          size: number;
          radius: number;
          sizeFrac: number;
          maxSizeFrac: number;
          baseSize: number;
          rot: number; vrot: number;
          cd: number;
          fibLevel: number;
          idleFrames: number;
          isDead: boolean;      // true = zombie mode (filled circle, random motion)
        };

        const balls: Ball[] = [];
        let gSpawnCd      = 0;
        let prevNavIsOpen = false;
        let navLeftBound  = NAV_W;
        let fibCount      = new Array(MAX_FIB + 1).fill(0);

        // ── F7 stepped-Fibonacci oscillator state ──
        const F7_STEP_FRAMES = 80;   // frames between each Fibonacci step (~1.3 s at 60 fps)
        let f7TargetLevel = MIN_FIB; // the level F7 is currently lerping toward
        let f7StepDir     = 1;       // +1 = ascending, -1 = descending
        let f7StepCd      = F7_STEP_FRAMES;

        // ── Utility ──
        const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

        // sizeRatio: 0 = smallest (MIN_FIB), 1 = largest (MAX_FIB)
        const sr = (b: Ball) => (b.fibLevel - MIN_FIB) / Math.max(1, MAX_FIB - MIN_FIB);

        function makeEl(size: number): SVGSVGElement {
          const el = templateEl!.cloneNode(true) as SVGSVGElement;
          el.removeAttribute('id');
          el.classList.add('watermark-ball');
          el.style.cssText = `position:absolute;top:0;left:0;width:${size}px;height:${size}px;opacity:0.15;will-change:transform;`;
          container!.appendChild(el);
          return el;
        }

        // Creates a filled-circle SVG for dead (zombie) balls
        function makeDeadEl(size: number): SVGSVGElement {
          const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
          svg.setAttribute('viewBox', '0 0 100 100');
          svg.classList.add('watermark-ball', 'watermark-ball--dead');
          svg.style.cssText = `position:absolute;top:0;left:0;width:${size}px;height:${size}px;opacity:0.18;will-change:transform;`;
          const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
          circle.setAttribute('cx', '50'); circle.setAttribute('cy', '50'); circle.setAttribute('r', '48');
          circle.setAttribute('fill', 'currentColor');
          svg.appendChild(circle);
          container!.appendChild(svg);
          return svg;
        }

        function makeBall(el: SVGSVGElement, x: number, y: number, vx: number, vy: number, fib: number, dead = false): Ball {
          const frac = FIB_FRACS[Math.max(MIN_FIB, Math.min(MAX_FIB, fib))];
          const base = Math.min(W, H) * frac;
          return {
            el, x, y, vx, vy,
            size: base, radius: base * 0.5,
            sizeFrac: frac, maxSizeFrac: frac, baseSize: base,
            rot: Math.random() * 360,
            vrot: (Math.random() - 0.5) * 0.6,
            cd: 0, fibLevel: fib, idleFrames: 0, isDead: dead,
          };
        }

        // Shrink a ball one Fibonacci step (diversity-aware: jumps to sparsest level below)
        function shrinkBall(ball: Ball, impulseX = 0, impulseY = 0): boolean {
          if (ball.cd > 0) return false;
          // Find the most underpopulated level below
          let targetLvl = ball.fibLevel - 1;
          for (let l = ball.fibLevel - 1; l >= MIN_FIB; l--) {
            if ((fibCount[l] || 0) < (fibCount[targetLvl] || 0)) targetLvl = l;
          }
          targetLvl = Math.max(MIN_FIB, targetLvl);
          if (targetLvl === ball.fibLevel) return false;
          ball.fibLevel    = targetLvl;
          ball.maxSizeFrac = FIB_FRACS[targetLvl];
          ball.sizeFrac    = FIB_FRACS[targetLvl] * 0.88;
          ball.baseSize    = Math.min(W, H) * ball.sizeFrac;
          // Anti-glitch: collapse rendered size 2 levels below new target so
          // the lerp always grows upward — never snaps from a larger old size.
          const collapseToLvl = Math.max(MIN_FIB, targetLvl - 2);
          ball.size   = Math.min(W, H) * FIB_FRACS[collapseToLvl];
          ball.radius = ball.size * 0.5;
          ball.vx = ball.vx * 0.45 + impulseX;
          ball.vy = ball.vy * 0.45 + impulseY;
          ball.cd = SPAWN_CD_B;
          return true;
        }

        // Grow a ball one Fibonacci step (only if pyramid has room)
        function growBall(ball: Ball): boolean {
          if (ball.cd > 0) return false;
          const nextLvl = ball.fibLevel + 1;
          if (nextLvl > MAX_FIB) return false;
          if ((fibCount[nextLvl] || 0) >= (TARGET_COUNT[nextLvl] ?? 0)) return false;
          ball.fibLevel    = nextLvl;
          ball.maxSizeFrac = FIB_FRACS[nextLvl];
          ball.sizeFrac    = FIB_FRACS[nextLvl] * 0.80;
          ball.baseSize    = Math.min(W, H) * ball.sizeFrac;
          // Anti-glitch: collapse rendered size 2 levels below new target so
          // the lerp grows upward cleanly into the new (larger) size.
          const collapseToLvl = Math.max(MIN_FIB, nextLvl - 2);
          ball.size   = Math.min(W, H) * FIB_FRACS[collapseToLvl];
          ball.radius = ball.size * 0.5;
          ball.cd = SPAWN_CD_B;
          return true;
        }

        // ── Initial layout: pyramid (1×F7, 2×F6, 4×F5, 4×F4, 4×F3) = 15 balls ──
        const cx = W * 0.50, cy = H * 0.46;
        ([
          // F7 — the one big ball, dead centre
          { fib: 7, angle:   0, dist: 0.00 },
          // F6 × 2
          { fib: 6, angle:  72, dist: 0.24 },
          { fib: 6, angle: 252, dist: 0.24 },
          // F5 × 4
          { fib: 5, angle:  36, dist: 0.38 },
          { fib: 5, angle: 144, dist: 0.38 },
          { fib: 5, angle: 216, dist: 0.38 },
          { fib: 5, angle: 324, dist: 0.38 },
          // F4 × 4
          { fib: 4, angle:   0, dist: 0.52 },
          { fib: 4, angle:  90, dist: 0.52 },
          { fib: 4, angle: 180, dist: 0.52 },
          { fib: 4, angle: 270, dist: 0.52 },
          // F3 × 4
          { fib: 3, angle:  45, dist: 0.62 },
          { fib: 3, angle: 135, dist: 0.62 },
          { fib: 3, angle: 225, dist: 0.62 },
          { fib: 3, angle: 315, dist: 0.62 },
        ] as { fib: number; angle: number; dist: number }[]).forEach(({ fib, angle, dist }) => {
          const rad   = angle * Math.PI / 180;
          const r     = Math.min(W, H) * dist;
          const speed = fib === MAX_FIB ? 0.2 : (MAX_FIB + 1 - fib) * 1.2 + Math.random() * 1.5;
          const el    = makeEl(Math.min(W, H) * FIB_FRACS[fib]);
          balls.push(makeBall(
            el,
            cx + Math.cos(rad) * r,
            cy + Math.sin(rad) * r,
            Math.cos(rad + Math.PI / 2) * speed,
            Math.sin(rad + Math.PI / 2) * speed,
            fib,
          ));
        });

        // ── Event listeners ──
        const onResize    = () => { W = window.innerWidth; H = window.innerHeight; };
        const onMouseMove  = (e: MouseEvent) => { mouseX = e.clientX; mouseY = e.clientY; };
        const onMouseLeave = () => { mouseX = -9999; mouseY = -9999; };
        window.addEventListener('resize',     onResize,    { passive: true });
        window.addEventListener('mousemove',  onMouseMove, { passive: true });
        window.addEventListener('mouseleave', onMouseLeave,{ passive: true });

        let mouseX = -9999, mouseY = -9999;
        let scrollVelY  = 0;   // upward impulse from scroll, decays each frame
        let lastScrollY = window.scrollY;
        const onScroll = () => {
          const cur   = window.scrollY;
          const delta = cur - lastScrollY;   // positive = scrolled down
          lastScrollY = cur;
          if (delta > 0) {
            // User scrolled down — bounce balls upward proportional to scroll speed
            scrollVelY += Math.min(delta * 0.28, 6.0); // cap single-event contribution
          }
        };
        window.addEventListener('scroll', onScroll, { passive: true });

        // Spacebar: hold = 2× gravity, release = upward jump impulse
        let spaceDown = false;
        const onKeyDown = (e: KeyboardEvent) => {
          if (e.code === 'Space' && !e.repeat) {
            e.preventDefault(); // stop page from scrolling
            spaceDown = true;
          }
        };
        const onKeyUp = (e: KeyboardEvent) => {
          if (e.code === 'Space') {
            spaceDown = false;
            // Jump impulse — bigger balls jump higher (more energy stored from 2× gravity)
            for (const b of balls) {
              const jumpStrength = lerp(5.0, 10.0, sr(b)); // F3→5, F7→10
              b.vy -= jumpStrength;
            }
          }
        };
        window.addEventListener('keydown', onKeyDown);
        window.addEventListener('keyup',   onKeyUp);
        let frameId: number;

        function step() {
          if (gSpawnCd > 0) gSpawnCd--;

          // Nav tracking
          const navTarget = ((window as any).__navPanelTarget as number) || NAV_W;
          navLeftBound   += (navTarget - navLeftBound) * 0.30;
          const navIsOpen = navLeftBound > NAV_W + 40;
          const usableW   = Math.max(1, W - navLeftBound);
          const navScale  = navIsOpen ? Math.max(0.22, usableW / (W - NAV_W)) : 1;

          // ── Per-frame histogram & fill ratio ──
          fibCount.fill(0);
          let totalArea = 0;
          for (const b of balls) {
            const r = b.size * 0.5;
            totalArea += Math.PI * r * r;
            if (b.fibLevel >= MIN_FIB && b.fibLevel <= MAX_FIB) fibCount[b.fibLevel]++;
          }
          const availArea = Math.max(1000, usableW * (H - BREADCRUMB_H));
          const fillRatio = totalArea / availArea;

          // ── Collision loop ──
          for (let i = 0; i < balls.length; i++) {
            for (let j = i + 1; j < balls.length; j++) {
              const a = balls[i], b = balls[j];

              const dx = b.x - a.x, dy = b.y - a.y;
              const dist = Math.hypot(dx, dy) || 0.001;
              const minD = a.radius + b.radius + PACK_GAP;

              if (dist >= minD * 1.3) continue;

              const nx = dx / dist, ny = dy / dist;

              // Push apart (positional correction)
              if (dist < minD) {
                const push = (minD - dist) * 0.5;
                a.x -= nx * push; a.y -= ny * push;
                b.x += nx * push; b.y += ny * push;
              }

              // Elastic velocity impulse
              const dvn = (b.vx - a.vx) * nx + (b.vy - a.vy) * ny;
              if (dvn < 0) {
                const imp = dvn * RESTITUTION;
                a.vx += nx * imp; a.vy += ny * imp;
                b.vx -= nx * imp; b.vy -= ny * imp;
              }

              // F7 special: touches anything → randomly grow or shrink it (25% grow / 75% shrink)
              // At max (F6) → always shrink; at min (F3) → always grow; else 25/75
              // Dead ball touching F7 → resurrect as F6
              const touching = (dist - a.radius - b.radius) <= PACK_GAP + 8;
              if (touching && (a.fibLevel === MAX_FIB || b.fibLevel === MAX_FIB)) {
                const f7   = a.fibLevel === MAX_FIB ? a : b;
                const nonF7 = a.fibLevel === MAX_FIB ? b : a;
                void f7;
                if (nonF7.isDead && gSpawnCd === 0) {
                  // Resurrect: dead ball → F6
                  const rEl = makeEl(Math.min(W, H) * FIB_FRACS[MAX_FIB - 1]);
                  const rb  = makeBall(rEl, nonF7.x, nonF7.y,
                    (Math.random() - 0.5) * 4, -3 - Math.random() * 2, MAX_FIB - 1);
                  const collapseToLvl = Math.max(MIN_FIB, MAX_FIB - 3);
                  rb.size = Math.min(W, H) * FIB_FRACS[collapseToLvl];
                  rb.radius = rb.size * 0.5;
                  rb.cd = SPAWN_CD_B;
                  balls.push(rb);
                  nonF7.el.remove();
                  balls.splice(balls.indexOf(nonF7), 1);
                  gSpawnCd = SPAWN_CD_G;
                } else if (!nonF7.isDead && nonF7.cd === 0 && gSpawnCd === 0) {
                  let doGrow: boolean;
                  if (nonF7.fibLevel >= MAX_FIB - 1)   doGrow = false;  // at F6 — must shrink
                  else if (nonF7.fibLevel <= MIN_FIB)   doGrow = true;   // at F3 — must grow
                  else                                   doGrow = Math.random() < 0.50; // 50/50
                  if (doGrow) {
                    if (growBall(nonF7)) gSpawnCd = SPAWN_CD_G;
                  } else {
                    const perpX = -ny, perpY = nx;
                    const kick  = 1.5 + Math.random() * 1.5;
                    if (shrinkBall(nonF7, perpX * kick, perpY * kick)) gSpawnCd = SPAWN_CD_G;
                  }
                }
              } else if (touching && !a.isDead && !b.isDead &&
                         a.fibLevel === MIN_FIB && b.fibLevel === MIN_FIB &&
                         dvn < -1.8 && gSpawnCd === 0) {
                // Death: two F3 balls collide hard → merge into one dead filled circle
                const mx  = (a.x + b.x) * 0.5, my = (a.y + b.y) * 0.5;
                const deadSize = Math.min(W, H) * FIB_FRACS[MIN_FIB] * 0.6;
                const dEl = makeDeadEl(deadSize);
                const db  = makeBall(dEl, mx, my,
                  (a.vx + b.vx) * 0.3, (a.vy + b.vy) * 0.3, MIN_FIB, true);
                db.size = deadSize; db.radius = deadSize * 0.5;
                db.baseSize = deadSize; db.sizeFrac = FIB_FRACS[MIN_FIB] * 0.6;
                db.maxSizeFrac = db.sizeFrac;
                balls.push(db);
                a.el.remove(); b.el.remove();
                balls.splice(balls.indexOf(a), 1);
                const bIdx = balls.indexOf(b); if (bIdx >= 0) balls.splice(bIdx, 1);
                gSpawnCd = SPAWN_CD_G;
              } else if (touching && dvn < -1.2 && gSpawnCd === 0 && !a.isDead && !b.isDead) {
                // Normal size-change logic for non-F7 collisions
                const target = a.size >= b.size ? a : b;

                // Pyramid enforcement: how overcrowded is this level?
                const cap  = TARGET_COUNT[target.fibLevel] ?? 1;
                const cur  = fibCount[target.fibLevel] ?? 0;
                const overcrowded = cur > cap;

                // Shrink probability: fill-ratio base + pyramid pressure
                let shrinkP = Math.max(0, (fillRatio - 0.12) / 0.22);
                if (overcrowded) shrinkP = Math.max(shrinkP, 0.65);
                shrinkP = Math.min(0.88, shrinkP);

                // Grow only when near-empty AND next level has room
                const nextHasRoom = target.fibLevel < MAX_FIB &&
                  (fibCount[target.fibLevel + 1] || 0) < (TARGET_COUNT[target.fibLevel + 1] ?? 0);
                const growP = (fillRatio < 0.08 && nextHasRoom) ? 0.28 : 0;

                const rng = Math.random();
                if (rng < shrinkP && target.cd === 0) {
                  const perpX = -ny, perpY = nx;
                  const kick  = 2.0 + Math.random() * 2.0;
                  if (shrinkBall(target, perpX * kick, perpY * kick)) gSpawnCd = SPAWN_CD_G;
                } else if (rng < shrinkP + growP && target.cd === 0) {
                  if (growBall(target)) gSpawnCd = SPAWN_CD_G;
                }
              }
            }
          }

          // ── F7 singleton enforcement ──
          // If somehow more than 1 F7 ball exists, immediately demote extras to F6
          if (fibCount[MAX_FIB] > 1) {
            let demoted = 0;
            for (const b of balls) {
              if (b.fibLevel === MAX_FIB && demoted < fibCount[MAX_FIB] - 1 && b.cd === 0) {
                b.fibLevel    = MAX_FIB - 1;
                b.maxSizeFrac = FIB_FRACS[MAX_FIB - 1];
                b.sizeFrac    = FIB_FRACS[MAX_FIB - 1] * 0.90;
                b.baseSize    = Math.min(W, H) * b.sizeFrac;
                // Anti-glitch: collapse rendered size before lerping to new target
                const collapseToLvl = Math.max(MIN_FIB, MAX_FIB - 3);
                b.size   = Math.min(W, H) * FIB_FRACS[collapseToLvl];
                b.radius = b.size * 0.5;
                b.cd     = SPAWN_CD_B;
                demoted++;
              }
            }
          }

          // ── Scroll impulse decay (applied once per frame, not per ball) ──
          if (scrollVelY > 0.05) scrollVelY *= 0.82; else scrollVelY = 0;

          // ── Wind blast on nav open (fires once on rising edge) ──
          const navJustOpened = navIsOpen && !prevNavIsOpen;
          prevNavIsOpen = navIsOpen;

          // ── PHASE 1: Per-ball physics ──
          for (const b of balls) {
            if (b.cd > 0) b.cd--;

            const ratio        = sr(b);                                   // 0=F3, 1=F6
            const ballGrav     = GRAV_BASE * lerp(0.35, 1.30, ratio);   // big=heavy, small=light
            const ballSpeedCap = lerp(MAX_SPEED_SM, MAX_SPEED_LG, ratio);
            const ballVrotMax  = lerp(VROT_MAX_SM,  VROT_MAX_LG,  ratio);

            b.baseSize = Math.min(W, H) * b.sizeFrac * navScale;

            // F7 stepped-Fibonacci oscillator: steps up/down through levels on a timer
            if (b.fibLevel === MAX_FIB) {
              if (f7StepCd <= 0) {
                // Advance one Fibonacci step
                f7TargetLevel += f7StepDir;
                if (f7TargetLevel >= MAX_FIB - 1) { f7TargetLevel = MAX_FIB - 1; f7StepDir = -1; }
                else if (f7TargetLevel <= MIN_FIB) { f7TargetLevel = MIN_FIB;     f7StepDir =  1; }
                f7StepCd = F7_STEP_FRAMES;
              } else { f7StepCd--; }
              const breathFrac  = FIB_FRACS[f7TargetLevel];
              b.sizeFrac    = breathFrac;
              b.maxSizeFrac = breathFrac;
              b.baseSize    = Math.min(W, H) * breathFrac * navScale;
            }

            // Passive regrowth when uncrowded (no cooldown needed — gentle lerp)
            if (b.cd === 0 && b.sizeFrac < b.maxSizeFrac * 0.995 && b.fibLevel !== MAX_FIB && !b.isDead) {
              b.sizeFrac = Math.min(b.maxSizeFrac, b.sizeFrac * 1.010);
              b.baseSize = Math.min(W, H) * b.sizeFrac * navScale;
            }

            // Gravity — bigger balls fall harder; spacebar doubles it
            // Dead balls: skip all normal physics, just drift randomly
            if (b.isDead) {
              b.vx += (Math.random() - 0.5) * 0.35;
              b.vy += (Math.random() - 0.5) * 0.35;
              const dspd = Math.hypot(b.vx, b.vy);
              if (dspd > 2.5) { b.vx = b.vx / dspd * 2.5; b.vy = b.vy / dspd * 2.5; }
              b.x += b.vx; b.y += b.vy;
              b.radius = b.size * 0.5;
              // Wall bounce
              if (b.x - b.radius < navLeftBound) { b.x = navLeftBound + b.radius; b.vx =  Math.abs(b.vx); }
              if (b.x + b.radius > W)            { b.x = W - b.radius;            b.vx = -Math.abs(b.vx); }
              if (b.y - b.radius < BREADCRUMB_H) { b.y = BREADCRUMB_H + b.radius; b.vy =  Math.abs(b.vy); }
              if (b.y + b.radius > H)            { b.y = H - b.radius;            b.vy = -Math.abs(b.vy); }
              b.rot += 0.8; // slow constant spin
              b.el.style.transform = `translate(${b.x - b.radius}px,${b.y - b.radius}px) rotate(${b.rot}deg)`;
              continue; // skip all other physics
            }

            const gravMultiplier = spaceDown ? 2.0 : 1.0;
            b.vy += ballGrav * gravMultiplier;

            // Scroll bounce: upward impulse on scroll-down, decays exponentially
            if (scrollVelY > 0.05) {
              b.vy -= scrollVelY * lerp(0.6, 1.0, ratio); // big balls get full impulse, small get 60%
            }

            // Nav left-side push
            const leftGap = b.x - navLeftBound - b.radius;
            if (leftGap < b.size * 1.2) {
              b.vx += (1 - Math.max(0, leftGap / (b.size * 1.2))) * 0.35;
            }

            // Wind blast — proximity-weighted rightward impulse
            if (navJustOpened) {
              const proximity = 1 - Math.max(0, Math.min(1, (b.x - navLeftBound) / usableW));
              b.vx += WIND_FORCE * (0.3 + proximity * 0.7);
              b.vy += (Math.random() - 0.5) * WIND_FORCE * 0.4;
            }

            // Mouse repulsion
            const mdx   = b.x - mouseX, mdy = b.y - mouseY;
            const mdist = Math.hypot(mdx, mdy) || 0.001;
            const maura = b.size * 2.0;
            if (mdist < maura) {
              const mt = 1 - mdist / maura;
              b.vx += (mdx / mdist) * mt * mt * 1.0;
              b.vy += (mdy / mdist) * mt * mt * 1.0;
            }

            b.vx *= DRAG; b.vy *= DRAG;
            const spd = Math.hypot(b.vx, b.vy);
            if (spd > ballSpeedCap) { b.vx = b.vx / spd * ballSpeedCap; b.vy = b.vy / spd * ballSpeedCap; }

            b.x += b.vx; b.y += b.vy;
            b.size   += (b.baseSize - b.size) * 0.15;
            b.radius  = b.size * 0.5;

            // Wall bounce
            if (b.x - b.radius < navLeftBound) { b.x = navLeftBound + b.radius; b.vx =  Math.abs(b.vx) * BOUNCE; }
            if (b.x + b.radius > W)            { b.x = W - b.radius;            b.vx = -Math.abs(b.vx) * BOUNCE; }
            if (b.y - b.radius < BREADCRUMB_H) { b.y = BREADCRUMB_H + b.radius; b.vy =  Math.abs(b.vy) * BOUNCE; }
            if (b.y + b.radius > H)            { b.y = H - b.radius;            b.vy = -Math.abs(b.vy) * BOUNCE; }

            // ── F7 idle decay: if the singleton is static and not hugging any wall, shrink ──
            if (b.fibLevel === MAX_FIB) {
              const spd      = Math.hypot(b.vx, b.vy);
              const nearWall = (b.x - b.radius - navLeftBound) < b.size  // left wall
                            || (W - (b.x + b.radius))          < b.size  // right wall
                            || (b.y - b.radius - BREADCRUMB_H) < b.size  // top wall
                            || (H - (b.y + b.radius))           < b.size; // bottom wall
              if (spd < 0.5 && !nearWall) {
                b.idleFrames++;
              } else {
                b.idleFrames = 0;
              }
              if (b.idleFrames > 180 && b.cd === 0) { // ~3 s at 60 fps
                shrinkBall(b, (Math.random() - 0.5) * 1.5, (Math.random() - 0.5) * 1.5);
                b.idleFrames = 0;
              }
            }

            // Rotation — small=fast & jittery, big=slow & smooth
            const rotBlend = lerp(0.014, 0.003, ratio); // how fast rot tracks heading
            const rotDamp  = lerp(0.80,  0.94,  ratio); // small: spins freely, big: damped
            const heading  = Math.atan2(b.vy, b.vx) * 180 / Math.PI;
            const diff     = ((heading - b.rot + 540) % 360) - 180;
            b.vrot += diff * rotBlend;
            b.vrot *= rotDamp;
            b.vrot  = Math.max(-ballVrotMax, Math.min(ballVrotMax, b.vrot));
            b.rot  += b.vrot;
          }

          // ── PHASE 2: Hard separation sweep (up to 8 iterations) ──
          for (let iter = 0; iter < 8; iter++) {
            let anyOverlap = false;
            for (let i = 0; i < balls.length; i++) {
              for (let j = i + 1; j < balls.length; j++) {
                const a = balls[i], b = balls[j];
                const dx   = b.x - a.x, dy = b.y - a.y;
                const dist = Math.hypot(dx, dy) || 0.001;
                const minD = a.radius + b.radius + PACK_GAP;
                if (dist < minD) {
                  anyOverlap = true;
                  const overlap = minD - dist;
                  const nx = dx / dist, ny = dy / dist;
                  a.x -= nx * overlap * 0.5; a.y -= ny * overlap * 0.5;
                  b.x += nx * overlap * 0.5; b.y += ny * overlap * 0.5;
                  a.x = Math.max(navLeftBound + a.radius, Math.min(W - a.radius, a.x));
                  a.y = Math.max(BREADCRUMB_H  + a.radius, Math.min(H - a.radius, a.y));
                  b.x = Math.max(navLeftBound + b.radius, Math.min(W - b.radius, b.x));
                  b.y = Math.max(BREADCRUMB_H  + b.radius, Math.min(H - b.radius, b.y));
                }
              }
            }
            if (!anyOverlap) break;
          }

          // ── PHASE 3: DOM commit ──
          for (const b of balls) {
            const s = Math.round(b.size);
            b.el.style.width  = s + 'px';
            b.el.style.height = s + 'px';
            b.el.style.transform = `translate(${Math.round(b.x - b.radius)}px,${Math.round(b.y - b.radius)}px) rotate(${Math.round(b.rot)}deg)`;
          }

          frameId = requestAnimationFrame(step);
        }

        frameId = requestAnimationFrame(step);

        return () => {
          window.removeEventListener('resize',     onResize);
          window.removeEventListener('mousemove',  onMouseMove);
          window.removeEventListener('mouseleave', onMouseLeave);
          window.removeEventListener('scroll',     onScroll);
          window.removeEventListener('keydown',    onKeyDown);
          window.removeEventListener('keyup',      onKeyUp);
          cancelAnimationFrame(frameId);
          balls.forEach(b => b.el.remove());
          balls.length = 0;
          templateEl!.style.display = '';
        };
      }

      let cleanupWatermark: (() => void) | undefined;

      function setup() {
        if (cleanupWatermark) {
          cleanupWatermark();
        }
        cleanupWatermark = initWatermarkLogo();
      }

      // Initialize
      setup();
      
      // Support Astro View Transitions
      document.addEventListener('astro:after-swap', setup);
    </script>
  </body>
</html>
