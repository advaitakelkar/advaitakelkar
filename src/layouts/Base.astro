---
import '../styles/tokens.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Advaita Kelkar — Architect & Designer', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} — AK</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}
  </head>
  <body>
    <!-- Global background watermark logo -->
    <div class="watermark-container" aria-hidden="true">
      <div class="watermark-logo" id="watermark-logo"></div>
    </div>

    <style is:global>
      /* Big muted watermark logo, anchored in the bottom-right corner,
         ~75% visible (a quarter bleeds off the corner). Breathes (shrink/grow)
         from the corner, continuously, at a different speed than the nav logo.
         Follows the active colour scheme via the foreground token. */
       .watermark-container {
        position: fixed;
        bottom: 0;
        right: 0;
        width: 100%;
        height: 100%;
        z-index: -1;            /* behind content, above the body background */
        pointer-events: none;
        overflow: hidden;       /* clip any rotated edges that go past the corner */
      }

      .watermark-logo {
        position: absolute;
        bottom: 0;
        right: 0;
        width: clamp(400px, 70vmin, 900px);
        height: clamp(400px, 70vmin, 900px);
        background-color: var(--_tokens---color--fg);
        -webkit-mask: url('/ak-logo.svg') center / contain no-repeat;
        mask: url('/ak-logo.svg') center / contain no-repeat;
        opacity: 0.05;          /* really light */
        transform-origin: right bottom;  /* anchor at the bottom-right corner */
        transform: rotate(0deg) scale(1);
        transition: background-color 0.3s ease;
        will-change: transform;
      }

      @media (prefers-reduced-motion: reduce) {
        .watermark-logo { animation: none; }
      }
    </style>

    <slot />
    <script>
      // Scheme persistence: restore from sessionStorage
      const stored = sessionStorage.getItem('aks');
      if (stored && /^sch[1-9]$/.test(stored)) {
        document.documentElement.className = stored;
      } else {
        // Random scheme on first load
        const n = Math.ceil(Math.random() * 9);
        const cls = `sch${n}`;
        document.documentElement.className = cls;
        sessionStorage.setItem('aks', cls);
      }
    </script>
    <script>
      // Global Arrow Hover Random Rotation
      document.addEventListener('mouseover', (e) => {
        const target = e.target as HTMLElement;
        const hoverContainer = target.closest('a, button, .project-card, .about-link-row, .qs-row, .home-slider__slide, .sn-panel__link, .sn-panel__secondary-link');
        if (hoverContainer) {
          const arrow = hoverContainer.querySelector('.link-arrow') as HTMLElement;
          if (arrow && !arrow.dataset.hasRandomHover) {
            arrow.dataset.hasRandomHover = 'true';
            arrow.style.transition = 'transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease';
            
            const onMouseEnter = () => {
              const randomAngle = Math.floor(Math.random() * 360);
              arrow.style.transform = `rotate(${randomAngle}deg)`;
            };
            
            const onMouseLeave = () => {
              arrow.style.transform = '';
            };
            
            hoverContainer.addEventListener('mouseenter', onMouseEnter);
            hoverContainer.addEventListener('mouseleave', onMouseLeave);
            
            // Trigger immediately on first hover detection
            onMouseEnter();
          }
        }
      });
    </script>
    <script>
      // Global Text Scramble (Matrix Decode) Hover Effect
      const GLYPHS = '01XYZ%$#@?*+=#-_[]{}<>/';

      class TextScrambler {
        el: HTMLElement;
        originalText: string;
        frame: number = 0;
        queue: Array<{ from: string; to: string; start: number; end: number; char?: string }> = [];
        resolveQueue: () => void = () => {};
        animationFrameId: number = 0;

        constructor(el: HTMLElement) {
          this.el = el;
          this.originalText = el.dataset.scrambleText || el.textContent || '';
          if (!el.dataset.scrambleText) {
            el.dataset.scrambleText = this.originalText;
          }
        }

        scramble() {
          const currentText = this.el.textContent || '';
          const length = Math.max(this.originalText.length, currentText.length);
          this.queue = [];
          
          for (let i = 0; i < length; i++) {
            const from = currentText[i] || '';
            const to = this.originalText[i] || '';
            const start = Math.floor(Math.random() * 8);
            const end = start + Math.floor(Math.random() * 12) + 4;
            this.queue.push({ from, to, start, end });
          }

          cancelAnimationFrame(this.animationFrameId);
          this.frame = 0;
          
          return new Promise((resolve) => {
            this.resolveQueue = () => resolve(undefined);
            this.tick();
          });
        }

        tick() {
          let output = '';
          let complete = 0;

          for (let i = 0, n = this.queue.length; i < n; i++) {
            let { from, to, start, end, char } = this.queue[i];
            if (this.frame >= end) {
              complete++;
              output += to;
            } else if (this.frame >= start) {
              if (!char || Math.random() < 0.28) {
                char = GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
                this.queue[i].char = char;
              }
              output += char;
            } else {
              output += from;
            }
          }

          this.el.textContent = output;

          if (complete === this.queue.length) {
            this.resolveQueue();
          } else {
            this.frame++;
            this.animationFrameId = requestAnimationFrame(() => this.tick());
          }
        }

        stop() {
          cancelAnimationFrame(this.animationFrameId);
          this.el.textContent = this.originalText;
        }
      }

      function getScrambleTarget(target: HTMLElement): HTMLElement | null {
        // 0. Direct match: if the target (or close ancestor) is one of our designated safe text components,
        // use it immediately if it does not contain child elements (to preserve inner tags/SVGs).
        const directTextSpan = target.closest(
          '.home-nav-row__text, .about-link-row__text, ' +
          '.sn-panel__link span, .proj-bubble__name, ' +
          '.project-card__stack-name, .project-card__title, ' +
          '.education-card__school, .about-card__title, .stacked-name, .about-card__collab'
        );
        if (directTextSpan && directTextSpan.children.length === 0) {
          return directTextSpan as HTMLElement;
        }

        // Find the closest potential scramble container/element candidate
        let candidate: HTMLElement | null = null;

        // 1. Explicit scramble attribute
        const scrambleAttr = target.closest('[data-scramble]');
        if (scrambleAttr) {
          candidate = scrambleAttr as HTMLElement;
        } else {
          // 2. Headings (h1-h6)
          const heading = target.closest('h1, h2, h3, h4, h5, h6');
          if (heading) {
            candidate = heading as HTMLElement;
          } else {
            // 3. Links and navigation items
            const link = target.closest('a');
            if (link) {
              // Exclude breadcrumbs from ever scrambling
              if (link.closest('.breadcrumb, .page-breadcrumb')) {
                return null;
              }
              // Exclude long paragraphs or paragraph links
              if (link.closest('p, .home-intro__desc, .about-card__desc, .project-card__desc')) {
                const text = link.textContent?.trim() || '';
                if (text.length > 50) return null;
              }
              const textSpan = link.querySelector(
                '.home-nav-row__text, .about-link-row__text, ' +
                '.sn-panel__link span, .proj-bubble__name, ' +
                '.project-card__stack-name'
              );
              if (textSpan) return textSpan as HTMLElement;
              candidate = link;
            } else {
              // 4. Card headers and titles
              const title = target.closest(
                '.project-card__title, .education-card__school, ' +
                '.about-card__role, .about-card__org, .about-card__title, .stacked-name, .about-card__collab'
              );
              if (title) {
                candidate = title as HTMLElement;
              }
            }
          }
        }

        // Safety check: if the candidate exists and is safe (no element children), scramble it.
        // This ensures nested HTML structure (such as SVG icons or spans) is never deleted.
        if (candidate) {
          if (candidate.children.length === 0) {
            return candidate;
          }
          // If it has children, attempt to find a child that is safe to scramble
          const safeChild = candidate.querySelector(
            '.home-nav-row__text, .about-link-row__text, ' +
            '.sn-panel__link span, .proj-bubble__name, ' +
            '.project-card__stack-name, .project-card__title, ' +
            '.education-card__school, .about-card__title, .stacked-name, .about-card__collab'
          );
          if (safeChild && safeChild.children.length === 0) {
            return safeChild as HTMLElement;
          }
        }

        return null;
      }

      function getTriggerElement(scrambleEl: HTMLElement): HTMLElement {
        return scrambleEl.closest(
          'a, button, .home-nav-row, .about-link-row, .home-slider__slide, ' +
          '.sn-panel__link, .project-card, .education-card, .about-card, ' +
          '.skill-pill, .proj-bubble'
        ) as HTMLElement || scrambleEl;
      }

      document.addEventListener('mouseover', (e) => {
        const target = e.target as HTMLElement;
        const scrambleEl = getScrambleTarget(target);

        if (scrambleEl) {
          if (!scrambleEl.dataset.hasScrambleListener) {
            scrambleEl.dataset.hasScrambleListener = 'true';
            const scrambler = new TextScrambler(scrambleEl);

            const onMouseEnter = () => {
              scrambler.scramble();
            };

            const onMouseLeave = () => {
              scrambler.stop();
            };

            const triggerEl = getTriggerElement(scrambleEl);
            triggerEl.addEventListener('mouseenter', onMouseEnter);
            triggerEl.addEventListener('mouseleave', onMouseLeave);

            // Trigger immediately for the current hover
            onMouseEnter();
          }
        }
      });
    </script>
    <script>
      function initWatermarkLogo() {
        const watermarkLogo = document.getElementById('watermark-logo');
        if (!watermarkLogo) return;

        let currentRotation = 0;
        let targetRotation = 0;
        let currentScale = 1;
        let targetScale = 1;
        let frameId: number;

        // Mouse move listener to update targetScale (breathing based on mouse position)
        const onMouseMove = (e: MouseEvent) => {
          const dx = window.innerWidth - e.clientX;
          const dy = window.innerHeight - e.clientY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const maxD = Math.sqrt(window.innerWidth**2 + window.innerHeight**2) || 1000;
          // Scale ranges from 0.6 (far away) to 1.8 (very close to bottom-right corner)
          targetScale = 0.6 + (1 - dist / maxD) * 1.2;
        };

        // Scroll listener to update targetRotation (smooth roll on scroll)
        const onScroll = () => {
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const scrollPct = docHeight > 0 ? window.scrollY / docHeight : 0;
          // One full page scroll rotates it by 360 degrees
          targetRotation = scrollPct * 360;
        };

        window.addEventListener('mousemove', onMouseMove, { passive: true });
        window.addEventListener('scroll', onScroll, { passive: true });

        // Smooth interpolation animation loop
        function updateLogo() {
          currentRotation += (targetRotation - currentRotation) * 0.08;
          currentScale += (targetScale - currentScale) * 0.08;

          if (watermarkLogo) {
            watermarkLogo.style.transform = `rotate(${currentRotation}deg) scale(${currentScale})`;
          }
          frameId = requestAnimationFrame(updateLogo);
        }
        
        // Start values based on center of screen
        const maxD = Math.sqrt(window.innerWidth**2 + window.innerHeight**2) || 1000;
        const dist = Math.sqrt((window.innerWidth/2)**2 + (window.innerHeight/2)**2);
        targetScale = 0.6 + (1 - dist / maxD) * 1.2;
        currentScale = targetScale;
        
        frameId = requestAnimationFrame(updateLogo);

        // Cleanup function for view transitions
        return () => {
          window.removeEventListener('mousemove', onMouseMove);
          window.removeEventListener('scroll', onScroll);
          cancelAnimationFrame(frameId);
        };
      }

      let cleanupWatermark: (() => void) | undefined;

      function setup() {
        if (cleanupWatermark) {
          cleanupWatermark();
        }
        cleanupWatermark = initWatermarkLogo();
      }

      // Initialize
      setup();
      
      // Support Astro View Transitions
      document.addEventListener('astro:after-swap', setup);
    </script>
  </body>
</html>
