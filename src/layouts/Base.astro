---
import '../styles/tokens.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Advaita Kelkar — Architect & Designer', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/ak-favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} — AK</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- ── Scheme: runs synchronously in <head> → no FOUC, correct on every page load ── -->
    <script is:inline>
      (function () {
        var ALL_SCH = ['sch1','sch2','sch3','sch4','sch5','sch6','sch7','sch8','sch9'];
        var VALID   = ['default','sch1','sch2','sch3','sch4','sch5','sch6','sch7','sch8','sch9'];

        function setClass(id) {
          ALL_SCH.forEach(function (s) { document.documentElement.classList.remove(s); });
          if (id !== 'default') document.documentElement.classList.add(id);
        }

        function randomSch() {
          return 'sch' + Math.ceil(Math.random() * 9);
        }

        // Reload detection — Navigation Timing Level 2
        var navEntry = performance.getEntriesByType && performance.getEntriesByType('navigation')[0];
        var isReload = navEntry ? navEntry.type === 'reload' : false;

        var stored = sessionStorage.getItem('aks');
        var valid  = stored && VALID.indexOf(stored) !== -1;

        if (isReload || !valid) {
          // Hard reload or first-ever visit → fresh random, clear manual mode
          var cls = randomSch();
          setClass(cls);
          sessionStorage.setItem('aks', cls);
          sessionStorage.removeItem('aks-mode');
        } else {
          // Page navigation → restore scheme + manual mode if set
          setClass(stored);
          var storedMode = sessionStorage.getItem('aks-mode');
          if (storedMode === 'dark')  document.documentElement.classList.add('mode-dark');
          if (storedMode === 'light') document.documentElement.classList.add('mode-light');
        }

        // ── Keyboard cycling: < = prev scheme  > = next scheme ──
        document.addEventListener('keydown', function (e) {
          var tag = (e.target && e.target.tagName) || '';
          if (tag === 'INPUT' || tag === 'TEXTAREA' || e.target.isContentEditable) return;
          if (e.key !== '<' && e.key !== '>') return;
          var cur = sessionStorage.getItem('aks') || 'default';
          var idx = VALID.indexOf(cur);
          if (idx < 0) idx = 0;
          var next = e.key === '>'
            ? VALID[(idx + 1) % VALID.length]
            : VALID[(idx - 1 + VALID.length) % VALID.length];
          setClass(next);
          sessionStorage.setItem('aks', next);
          // Tell SideNav to sync its active-option highlight
          document.dispatchEvent(new CustomEvent('aks-scheme', { detail: next }));
        });
      })();
    </script>
  </head>
  <body>
    <!-- Global background watermark logo (inline SVG → crisp vector at any size) -->
    <div class="watermark-container" aria-hidden="true">
      <svg class="watermark-logo" id="watermark-logo" viewBox="88 211 419 419" xmlns="http://www.w3.org/2000/svg">
        <path d="M432.1,534.82l23.1,21.24c-8.9,10.9-18.69,20.48-30.03,29.3l-25.37-21.34-38.6-31.92-36.41-28.9-2.98,48.7-2.29,70.14c-13.83.96-27.6.86-41.54.05l-1.94-56.63-2.19-43.56-1.35-18.62c-22.23,17.07-43.62,34.31-64.89,52.3l-35.26,29.83-9.63-8c-7.56-6.28-13.66-13.59-20.39-21.26l27.74-25.56,9.02-8.39,54.34-51.21-36.86-2.33-97.71-1.74c-1.5-14.03-2.44-27.4-2.51-41.4l88.38-1.81c9.12-.08,17.67.46,26.47,3.52l-51.31,15.36,63.22-10.11c6.27,4.44,11.41,9.62,16.62,15.16l10.24,10.89c6.53,6.94,13.47,12.98,22.03,17.26,10.93,5.47,23.05,6.45,34.71,2.78,15.97-5.03,28.29-16.11,40.53-27.11l14.67-13.18c5.49-4.93,11.71-8.35,18.79-10.52,7.64-2.34,15.36-4,23.44-3.96l25.5.11,69.93,1.61-.38,15.16-2.12,26.23-30.09.27-65.8,1.61-37.24,2.12,20.43,19.33,47.71,44.6Z"/>
        <path d="M338.79,376.68c-5.79-5.79-12.64-9.54-20.1-12.3-24.12-8.95-45.8,4.72-63.57,20.83l-20.38,18.47c-12.63,11.45-29.24,14.43-46.19,14.89l-92.23-1.99c.11-13.77.97-27.41,2.51-41.39l85.45-1.27,48.95-2.72-31.3-29.35-59.94-55.5c8.81-10.6,18.37-20.47,29.56-29.21l40.59,33.78,60.41,48.27,2.9-55.03,2.18-64.11c13.97-.86,27.77-.99,41.61.05l2.13,64.52,3.07,54.55,63.11-50.96,37.19-31.04c11.26,8.59,21.19,18.15,29.63,29.2l-22.21,20.58-68.35,64.22,38.95,2.23c31.62,1.35,62.77,1.77,94.37,1.79,1.66,14.02,2.22,27.58,2.59,41.38l-88.29,1.91c-14.2.13-29.24-1.89-40.49-10.3l62.9-10.32.89-.28-4.24-.32h-71.6s-7.53-8.01-7.53-8.01l-12.57-12.58Z"/>
        <path d="M301.13,460.16c-10,2.48-19.65.98-28.12-4.04-10.05-6.37-15.44-17.49-14.89-29.42l21.3-3.55c-1.87-.35-3.79-.23-5.83,0l-15.28.47c2.15-22.78,22.76-42.17,45.64-42.72,19.26-.47,33.81,13.54,34.13,32.76l-53.68,8.79-.24.33,4.84-.23,48.64-1.49c-3.31,18.91-17.65,34.41-36.51,39.1Z"/>
      </svg>
    </div>

    <style is:global>
      /* Big muted watermark logo, anchored in the bottom-right corner,
         ~75% visible (a quarter bleeds off the corner). Breathes (shrink/grow)
         from the corner, continuously, at a different speed than the nav logo.
         Follows the active colour scheme via the foreground token. */
       .watermark-container {
        position: fixed;
        bottom: 0;
        right: 0;
        width: 100%;
        height: 100%;
        z-index: 9999;          /* on top of all elements, acting as overlay watermark */
        pointer-events: none;
        overflow: hidden;
      }

      .watermark-logo {
        position: absolute;
        top: 0;
        left: 0;
        width: 200px;
        height: 200px;
        fill: var(--_tokens---color--fg);   /* inline SVG → crisp vector at any size */
        opacity: 0.04;          /* subtle watermark overlay — blends with bg */
        transform-origin: center center;  /* rotate around its own center axis */
        transform: translate(0, 0) rotate(0deg);
        transition: fill 0.3s ease;
        will-change: width, height, transform;
      }

      @media (prefers-reduced-motion: reduce) {
        .watermark-logo { animation: none; }
      }
    </style>

    <slot />
    <script>
      // Global Arrow Hover Random Rotation
      document.addEventListener('mouseover', (e) => {
        const target = e.target as HTMLElement;
        const hoverContainer = target.closest('a, button, .project-card, .about-link-row, .qs-row, .home-slider__slide, .sn-panel__link, .sn-panel__secondary-link');
        if (hoverContainer) {
          const arrow = hoverContainer.querySelector('.link-arrow') as HTMLElement;
          if (arrow && !arrow.dataset.hasRandomHover) {
            arrow.dataset.hasRandomHover = 'true';
            arrow.style.transition = 'transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease';
            
            const onMouseEnter = () => {
              const randomAngle = Math.floor(Math.random() * 360);
              arrow.style.transform = `rotate(${randomAngle}deg)`;
            };
            
            const onMouseLeave = () => {
              arrow.style.transform = '';
            };
            
            hoverContainer.addEventListener('mouseenter', onMouseEnter);
            hoverContainer.addEventListener('mouseleave', onMouseLeave);
            
            // Trigger immediately on first hover detection
            onMouseEnter();
          }
        }
      });
    </script>
    <script>
      // Global Text Scramble (Matrix Decode) Hover Effect
      const GLYPHS = '01XYZ%$#@?*+=#-_[]{}<>/';

      class TextScrambler {
        el: HTMLElement;
        originalText: string;
        frame: number = 0;
        queue: Array<{ from: string; to: string; start: number; end: number; char?: string }> = [];
        resolveQueue: () => void = () => {};
        animationFrameId: number = 0;

        constructor(el: HTMLElement) {
          this.el = el;
          this.originalText = el.dataset.scrambleText || el.textContent || '';
          if (!el.dataset.scrambleText) {
            el.dataset.scrambleText = this.originalText;
          }
        }

        scramble() {
          const currentText = this.el.textContent || '';
          const length = Math.max(this.originalText.length, currentText.length);
          this.queue = [];
          
          for (let i = 0; i < length; i++) {
            const from = currentText[i] || '';
            const to = this.originalText[i] || '';
            const start = Math.floor(Math.random() * 8);
            const end = start + Math.floor(Math.random() * 12) + 4;
            this.queue.push({ from, to, start, end });
          }

          cancelAnimationFrame(this.animationFrameId);
          this.frame = 0;
          
          return new Promise((resolve) => {
            this.resolveQueue = () => resolve(undefined);
            this.tick();
          });
        }

        tick() {
          let output = '';
          let complete = 0;

          for (let i = 0, n = this.queue.length; i < n; i++) {
            let { from, to, start, end, char } = this.queue[i];
            if (this.frame >= end) {
              complete++;
              output += to;
            } else if (this.frame >= start) {
              if (!char || Math.random() < 0.28) {
                char = GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
                this.queue[i].char = char;
              }
              output += char;
            } else {
              output += from;
            }
          }

          this.el.textContent = output;

          if (complete === this.queue.length) {
            this.resolveQueue();
          } else {
            this.frame++;
            this.animationFrameId = requestAnimationFrame(() => this.tick());
          }
        }

        stop() {
          cancelAnimationFrame(this.animationFrameId);
          this.el.textContent = this.originalText;
        }
      }

      function getScrambleTarget(target: HTMLElement): HTMLElement | null {
        // 0. Direct match: if the target (or close ancestor) is one of our designated safe text components,
        // use it immediately if it does not contain child elements (to preserve inner tags/SVGs).
        const directTextSpan = target.closest(
          '.home-nav-row__text, .about-link-row__text, ' +
          '.sn-panel__link span, .proj-bubble__name, ' +
          '.project-card__stack-name, .project-card__title, ' +
          '.education-card__school, .about-card__title, .stacked-name, .about-card__collab'
        );
        if (directTextSpan && directTextSpan.children.length === 0) {
          return directTextSpan as HTMLElement;
        }

        // Find the closest potential scramble container/element candidate
        let candidate: HTMLElement | null = null;

        // 1. Explicit scramble attribute
        const scrambleAttr = target.closest('[data-scramble]');
        if (scrambleAttr) {
          candidate = scrambleAttr as HTMLElement;
        } else {
          // 2. Headings (h1-h6)
          const heading = target.closest('h1, h2, h3, h4, h5, h6');
          if (heading) {
            candidate = heading as HTMLElement;
          } else {
            // 3. Links and navigation items
            const link = target.closest('a');
            if (link) {
              // Exclude breadcrumbs from ever scrambling
              if (link.closest('.breadcrumb, .page-breadcrumb')) {
                return null;
              }
              // Exclude long paragraphs or paragraph links
              if (link.closest('p, .home-intro__desc, .about-card__desc, .project-card__desc')) {
                const text = link.textContent?.trim() || '';
                if (text.length > 50) return null;
              }
              const textSpan = link.querySelector(
                '.home-nav-row__text, .about-link-row__text, ' +
                '.sn-panel__link span, .proj-bubble__name, ' +
                '.project-card__stack-name'
              );
              if (textSpan) return textSpan as HTMLElement;
              candidate = link;
            } else {
              // 4. Card headers and titles
              const title = target.closest(
                '.project-card__title, .education-card__school, ' +
                '.about-card__role, .about-card__org, .about-card__title, .stacked-name, .about-card__collab'
              );
              if (title) {
                candidate = title as HTMLElement;
              }
            }
          }
        }

        // Safety check: if the candidate exists and is safe (no element children), scramble it.
        // This ensures nested HTML structure (such as SVG icons or spans) is never deleted.
        if (candidate) {
          if (candidate.children.length === 0) {
            return candidate;
          }
          // If it has children, attempt to find a child that is safe to scramble
          const safeChild = candidate.querySelector(
            '.home-nav-row__text, .about-link-row__text, ' +
            '.sn-panel__link span, .proj-bubble__name, ' +
            '.project-card__stack-name, .project-card__title, ' +
            '.education-card__school, .about-card__title, .stacked-name, .about-card__collab'
          );
          if (safeChild && safeChild.children.length === 0) {
            return safeChild as HTMLElement;
          }
        }

        return null;
      }

      function getTriggerElement(scrambleEl: HTMLElement): HTMLElement {
        return scrambleEl.closest(
          'a, button, .home-nav-row, .about-link-row, .home-slider__slide, ' +
          '.sn-panel__link, .project-card, .education-card, .about-card, ' +
          '.skill-pill, .proj-bubble'
        ) as HTMLElement || scrambleEl;
      }

      document.addEventListener('mouseover', (e) => {
        const target = e.target as HTMLElement;
        const scrambleEl = getScrambleTarget(target);

        if (scrambleEl) {
          if (!scrambleEl.dataset.hasScrambleListener) {
            scrambleEl.dataset.hasScrambleListener = 'true';
            const scrambler = new TextScrambler(scrambleEl);

            const onMouseEnter = () => {
              scrambler.scramble();
            };

            const onMouseLeave = () => {
              scrambler.stop();
            };

            const triggerEl = getTriggerElement(scrambleEl);
            triggerEl.addEventListener('mouseenter', onMouseEnter);
            triggerEl.addEventListener('mouseleave', onMouseLeave);

            // Trigger immediately for the current hover
            onMouseEnter();
          }
        }
      });
    </script>
    <script>
      function initWatermarkLogo() {
        const container  = document.querySelector('.watermark-container') as HTMLElement | null;
        const templateEl = document.getElementById('watermark-logo') as SVGElement | null;
        if (!container || !templateEl) return;

        let W = window.innerWidth, H = window.innerHeight;
        const NAV_W        = 44;
        const BREADCRUMB_H = 48;

        // Lerped left boundary — tracks nav panel opening/closing
        let navLeftBound = NAV_W;

        // ── Constants ──
        const GRAV           = 0.07;    // gentle — fish-in-water float
        const BOUNCE_SIDE    = 0.78;    // walls absorb energy
        const BOUNCE_FLOOR   = 0.48;    // floor settles balls
        const DRAG           = 0.990;
        const MAX_SPEED      = 55;   // high enough for first ball's launch velocity
        const MAX_BALLS      = 20;
        const FADE_DUR       = 90;
        const SPAWN_CD       = 70;
        const PUSH_FORCE     = 18;
        const NAV_PROX       = 280;
        const CELL_GAP       = 10;       // minimum px gap between ball surfaces
        const NATURAL_SHRINK = 0.00035;  // fractional deflation per frame
        const MIN_SIZE_RATIO = 0.14;     // fade out below 14% of spawn size
        const PACK_GROW      = 0.018;    // grow per frame when in aura (resists shrink when clustered)
        const AURA_MULT      = 2.4;      // attraction zone = 2.4× sumR

        type Ball = {
          el: SVGElement;
          x: number; y: number;
          vx: number; vy: number;
          size: number;
          baseSize: number;
          spawnBase: number;
          rot: number; vrot: number;
          born: number;
          fadeTick: number;
          bounces: number;
        };

        const balls: Ball[] = [];
        let birthClock    = 0;
        let spawnCooldown = 0;
        let lastScrollY   = window.scrollY;

        // Subsequent balls: 13–18% of viewport
        function randBaseSize(): number {
          return Math.min(W, H) * (0.13 + Math.random() * 0.05);
        }

        function makeEl(size: number): SVGElement {
          const el = templateEl!.cloneNode(true) as SVGElement;
          el.removeAttribute('id');
          el.style.cssText = `position:absolute;top:0;left:0;width:${size}px;height:${size}px;opacity:0.05;will-change:transform;`;
          container!.appendChild(el);
          return el;
        }

        // Balls enter from left edge at FULL base size (big → shrinks over time)
        function spawnBall(vxOverride?: number, vyOverride?: number, useTemplate = false): Ball {
          const base    = randBaseSize();
          const startSz = base;
          const vx = vxOverride !== undefined ? vxOverride : 7 + Math.random() * 5;
          const vy = vyOverride !== undefined ? vyOverride : (Math.random() - 0.5) * 3;
          const el = useTemplate ? templateEl! : makeEl(startSz);
          if (useTemplate) {
            el.style.width   = startSz + 'px';
            el.style.height  = startSz + 'px';
            el.style.opacity = '0.05';
          }
          const b: Ball = {
            el,
            x: NAV_W + startSz * 0.5 + 2,
            y: H * 0.10 + Math.random() * H * 0.40,
            vx, vy,
            size: startSz, baseSize: base, spawnBase: base,
            rot: Math.random() * 360, vrot: 0,
            born: birthClock++, fadeTick: -1, bounces: 0
          };
          balls.push(b);
          return b;
        }

        // ── First ball: huge + extreme velocity — right wall → floor → nav → duplicate ──
        // Size: 24–28% of the shorter viewport side
        const firstBase = Math.min(W, H) * (0.24 + Math.random() * 0.04);
        templateEl.style.width   = firstBase + 'px';
        templateEl.style.height  = firstBase + 'px';
        templateEl.style.opacity = '0.05';
        balls.push({
          el: templateEl!,
          x: NAV_W + firstBase * 0.5 + 2,
          y: H * 0.20 + Math.random() * H * 0.15,   // upper third so it arcs down to floor
          vx: 42 + Math.random() * 8,                // very fast rightward throw
          vy: 3  + Math.random() * 3,                // slight downward so it hits floor after right wall
          size: firstBase, baseSize: firstBase, spawnBase: firstBase,
          rot: Math.random() * 360, vrot: 0,
          born: birthClock++, fadeTick: -1, bounces: 0
        });

        // ── Spacebar / nav-bar click: push balls near the nav ──
        function navPush() {
          for (const b of balls) {
            if (b.fadeTick >= 0) continue;
            const distFromNav = b.x - NAV_W;
            if (distFromNav > NAV_PROX) continue;
            const pct = 1 - distFromNav / NAV_PROX;
            const dx  = b.x - NAV_W, dy = b.y - H * 0.5;
            const mag = Math.hypot(dx, dy) || 1;
            b.vx += (dx / mag) * PUSH_FORCE * pct;
            b.vy += (dy / mag) * PUSH_FORCE * 0.35 * pct;
          }
        }

        const onKeydown = (e: KeyboardEvent) => {
          const active = document.activeElement as HTMLElement | null;
          if (active && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA' || active.isContentEditable)) return;
          if (e.key === ' ' || e.code === 'Space') { e.preventDefault(); navPush(); }
        };

        const onResize = () => { W = window.innerWidth; H = window.innerHeight; };

        // Scroll → knock balls downward so they fall and re-settle at bottom-right
        const onScroll = () => {
          const cur   = window.scrollY;
          const delta = cur - lastScrollY;
          lastScrollY = cur;
          if (delta > 2) {
            for (const b of balls) {
              if (b.fadeTick >= 0) continue;
              b.vy += Math.min(delta * 0.05 + 1.2, 6);
            }
          }
        };

        window.addEventListener('resize', onResize, { passive: true });
        window.addEventListener('scroll', onScroll, { passive: true });
        document.addEventListener('keydown', onKeydown);

        const snBar = document.getElementById('sn-bar');
        snBar?.addEventListener('click', navPush);

        let frameId: number;

        function step() {
          if (spawnCooldown > 0) spawnCooldown--;

          // Nav paddle lerp
          const navTarget = ((window as any).__navPanelTarget as number) || NAV_W;
          navLeftBound += (navTarget - navLeftBound) * 0.09;

          // ── Ball-ball: aura → attract + pack-grow; contact → repel with gap ──
          for (let i = 0; i < balls.length; i++) {
            for (let j = i + 1; j < balls.length; j++) {
              const a = balls[i], b = balls[j];
              if (a.fadeTick >= 0 || b.fadeTick >= 0) continue;
              const dx = b.x - a.x, dy = b.y - a.y;
              const dist = Math.hypot(dx, dy) || 0.001;
              // sumR includes mandatory cell gap → balls never actually touch
              const sumR = (a.size + b.size) * 0.5 + CELL_GAP;

              // Aura zone: gentle mutual attraction + slight growth (packing effect)
              if (dist < sumR * AURA_MULT && dist > sumR) {
                const t  = 1 - (dist - sumR) / (sumR * (AURA_MULT - 1));
                const f  = t * 0.010;
                const nx = dx / dist, ny = dy / dist;
                a.vx += nx * f; a.vy += ny * f;
                b.vx -= nx * f; b.vy -= ny * f;
                // Packing growth: slows natural deflation when clustered
                const g = PACK_GROW * t * 0.4;
                a.baseSize = Math.min(a.spawnBase, a.baseSize + g);
                b.baseSize = Math.min(b.spawnBase, b.baseSize + g);
              }

              // Contact: push apart + size-swing pulse (spring snaps back via normal size lerp)
              if (dist < sumR) {
                const overlap = (sumR - dist) * 0.52;
                const nx = dx / dist, ny = dy / dist;
                a.x -= nx * overlap; a.y -= ny * overlap;
                b.x += nx * overlap; b.y += ny * overlap;
                const nudge = 0.22;
                a.vx -= nx * nudge; a.vy -= ny * nudge;
                b.vx += nx * nudge; b.vy += ny * nudge;
                // Size pulse: temporarily swell — spring equation damps it back naturally
                a.size = Math.min(a.size * 1.13, a.spawnBase * 1.25);
                b.size = Math.min(b.size * 1.13, b.spawnBase * 1.25);
              }
            }
          }

          // ── Per-ball physics ──
          for (let i = 0; i < balls.length; i++) {
            const b = balls[i];

            if (b.fadeTick >= 0) {
              b.fadeTick--;
              b.el.style.opacity = (0.05 * b.fadeTick / FADE_DUR).toFixed(4);
            }

            // Natural deflation
            b.baseSize = Math.max(b.spawnBase * MIN_SIZE_RATIO, b.baseSize * (1 - NATURAL_SHRINK));

            // Gravity + corner attractor (bottom-right)
            b.vy += GRAV;
            const pullX = (W - 80 - b.x) / W;
            const pullY = (H - 80 - b.y) / H;
            b.vx += pullX * 0.014;
            b.vy += pullY * 0.007;

            b.vx *= DRAG; b.vy *= DRAG;

            const spd = Math.hypot(b.vx, b.vy);
            if (spd > MAX_SPEED) { b.vx = b.vx / spd * MAX_SPEED; b.vy = b.vy / spd * MAX_SPEED; }

            b.x += b.vx; b.y += b.vy;

            // Size tracks baseSize smoothly
            b.size += (b.baseSize - b.size) * 0.04;
            const r = b.size * 0.5;

            // ── Walls ──
            if (b.x - r < navLeftBound) {
              b.x  = navLeftBound + r;
              b.vx = Math.abs(b.vx) * BOUNCE_SIDE;
              b.vrot -= b.vx * 0.12;
              b.bounces++;
              // Nav bar contact → spawn duplicate
              if (navLeftBound < NAV_W + 20 && spawnCooldown === 0 && balls.length < MAX_BALLS && b.fadeTick < 0) {
                spawnBall();
                spawnCooldown = SPAWN_CD;
              }
            }
            if (b.x + r > W) {
              b.x  = W - r;
              b.vx = -Math.abs(b.vx) * BOUNCE_SIDE;
              b.vrot += Math.abs(b.vx) * 0.12;
              b.bounces++;
            }
            if (b.y - r < BREADCRUMB_H) {
              b.y  = BREADCRUMB_H + r;
              b.vy = Math.abs(b.vy) * BOUNCE_SIDE;
              b.bounces++;
            }
            if (b.y + r > H) {
              b.y  = H - r;
              b.vy = -Math.abs(b.vy) * BOUNCE_FLOOR;
              b.vrot += b.vx * 0.15;
              b.bounces++;
            }

            // ── Rotation: slow and smooth — fishes, not spinning tops ──
            const targetVrot = b.vx * 0.07;
            b.vrot += (targetVrot - b.vrot) * 0.05;
            b.vrot  = Math.max(-2.0, Math.min(2.0, b.vrot)); // hard cap
            b.rot  += b.vrot;

            // Render
            const s = Math.round(b.size);
            b.el.style.width  = s + 'px';
            b.el.style.height = s + 'px';
            b.el.style.transform = `translate(${Math.round(b.x - r)}px,${Math.round(b.y - r)}px) rotate(${b.rot.toFixed(1)}deg)`;
          }

          // ── Fade balls that have shrunk to minimum ──
          for (const b of balls) {
            if (b.fadeTick < 0 && b.baseSize <= b.spawnBase * MIN_SIZE_RATIO + 0.5) {
              b.fadeTick = FADE_DUR;
            }
          }

          // ── Also fade oldest when at hard cap ──
          if (balls.length >= MAX_BALLS) {
            let oldest: Ball | null = null;
            for (const b of balls) {
              if (b.fadeTick < 0 && (!oldest || b.born < oldest.born)) oldest = b;
            }
            if (oldest) oldest.fadeTick = FADE_DUR;
          }

          // ── Remove fully faded ──
          for (let i = balls.length - 1; i >= 0; i--) {
            if (balls[i].fadeTick === 0) {
              balls[i].el.remove();
              balls.splice(i, 1);
            }
          }

          frameId = requestAnimationFrame(step);
        }

        frameId = requestAnimationFrame(step);

        return () => {
          window.removeEventListener('resize', onResize);
          window.removeEventListener('scroll', onScroll);
          document.removeEventListener('keydown', onKeydown);
          snBar?.removeEventListener('click', navPush);
          cancelAnimationFrame(frameId);
          balls.slice(1).forEach(b => b.el.remove());
          balls.length = 0;
        };
      }

      let cleanupWatermark: (() => void) | undefined;

      function setup() {
        if (cleanupWatermark) {
          cleanupWatermark();
        }
        cleanupWatermark = initWatermarkLogo();
      }

      // Initialize
      setup();
      
      // Support Astro View Transitions
      document.addEventListener('astro:after-swap', setup);
    </script>
  </body>
</html>
