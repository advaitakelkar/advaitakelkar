---
import '../styles/tokens.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Advaita Kelkar — Architect & Designer', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/ak-favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} — AK</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- ── Scheme: runs synchronously in <head> → no FOUC, correct on every page load ── -->
    <script is:inline>
      (function () {
        var ALL_SCH = ['sch1','sch2','sch3','sch4','sch5','sch6','sch7','sch8','sch9'];
        var VALID   = ['default','sch1','sch2','sch3','sch4','sch5','sch6','sch7','sch8','sch9'];

        function setClass(id) {
          ALL_SCH.forEach(function (s) { document.documentElement.classList.remove(s); });
          if (id !== 'default') document.documentElement.classList.add(id);
        }

        function randomSch() {
          return 'sch' + Math.ceil(Math.random() * 9);
        }

        // Reload detection — Navigation Timing Level 2
        var navEntry = performance.getEntriesByType && performance.getEntriesByType('navigation')[0];
        var isReload = navEntry ? navEntry.type === 'reload' : false;

        var stored = sessionStorage.getItem('aks');
        var valid  = stored && VALID.indexOf(stored) !== -1;

        if (isReload || !valid) {
          // Hard reload or first-ever visit → fresh random, clear manual mode
          var cls = randomSch();
          setClass(cls);
          sessionStorage.setItem('aks', cls);
          sessionStorage.removeItem('aks-mode');
        } else {
          // Page navigation → restore scheme + manual mode if set
          setClass(stored);
          var storedMode = sessionStorage.getItem('aks-mode');
          if (storedMode === 'dark')  document.documentElement.classList.add('mode-dark');
          if (storedMode === 'light') document.documentElement.classList.add('mode-light');
        }

        // ── Keyboard cycling: < = prev scheme  > = next scheme ──
        document.addEventListener('keydown', function (e) {
          var tag = (e.target && e.target.tagName) || '';
          if (tag === 'INPUT' || tag === 'TEXTAREA' || e.target.isContentEditable) return;
          if (e.key !== '<' && e.key !== '>') return;
          var cur = sessionStorage.getItem('aks') || 'default';
          var idx = VALID.indexOf(cur);
          if (idx < 0) idx = 0;
          var next = e.key === '>'
            ? VALID[(idx + 1) % VALID.length]
            : VALID[(idx - 1 + VALID.length) % VALID.length];
          setClass(next);
          sessionStorage.setItem('aks', next);
          // Tell SideNav to sync its active-option highlight
          document.dispatchEvent(new CustomEvent('aks-scheme', { detail: next }));
        });
      })();
    </script>
  </head>
  <body>
    <!-- Global background watermark logo (inline SVG → crisp vector at any size) -->
    <div class="watermark-container" aria-hidden="true">
      <svg class="watermark-logo" id="watermark-logo" viewBox="88 211 419 419" xmlns="http://www.w3.org/2000/svg">
        <path d="M432.1,534.82l23.1,21.24c-8.9,10.9-18.69,20.48-30.03,29.3l-25.37-21.34-38.6-31.92-36.41-28.9-2.98,48.7-2.29,70.14c-13.83.96-27.6.86-41.54.05l-1.94-56.63-2.19-43.56-1.35-18.62c-22.23,17.07-43.62,34.31-64.89,52.3l-35.26,29.83-9.63-8c-7.56-6.28-13.66-13.59-20.39-21.26l27.74-25.56,9.02-8.39,54.34-51.21-36.86-2.33-97.71-1.74c-1.5-14.03-2.44-27.4-2.51-41.4l88.38-1.81c9.12-.08,17.67.46,26.47,3.52l-51.31,15.36,63.22-10.11c6.27,4.44,11.41,9.62,16.62,15.16l10.24,10.89c6.53,6.94,13.47,12.98,22.03,17.26,10.93,5.47,23.05,6.45,34.71,2.78,15.97-5.03,28.29-16.11,40.53-27.11l14.67-13.18c5.49-4.93,11.71-8.35,18.79-10.52,7.64-2.34,15.36-4,23.44-3.96l25.5.11,69.93,1.61-.38,15.16-2.12,26.23-30.09.27-65.8,1.61-37.24,2.12,20.43,19.33,47.71,44.6Z"/>
        <path d="M338.79,376.68c-5.79-5.79-12.64-9.54-20.1-12.3-24.12-8.95-45.8,4.72-63.57,20.83l-20.38,18.47c-12.63,11.45-29.24,14.43-46.19,14.89l-92.23-1.99c.11-13.77.97-27.41,2.51-41.39l85.45-1.27,48.95-2.72-31.3-29.35-59.94-55.5c8.81-10.6,18.37-20.47,29.56-29.21l40.59,33.78,60.41,48.27,2.9-55.03,2.18-64.11c13.97-.86,27.77-.99,41.61.05l2.13,64.52,3.07,54.55,63.11-50.96,37.19-31.04c11.26,8.59,21.19,18.15,29.63,29.2l-22.21,20.58-68.35,64.22,38.95,2.23c31.62,1.35,62.77,1.77,94.37,1.79,1.66,14.02,2.22,27.58,2.59,41.38l-88.29,1.91c-14.2.13-29.24-1.89-40.49-10.3l62.9-10.32.89-.28-4.24-.32h-71.6s-7.53-8.01-7.53-8.01l-12.57-12.58Z"/>
        <path d="M301.13,460.16c-10,2.48-19.65.98-28.12-4.04-10.05-6.37-15.44-17.49-14.89-29.42l21.3-3.55c-1.87-.35-3.79-.23-5.83,0l-15.28.47c2.15-22.78,22.76-42.17,45.64-42.72,19.26-.47,33.81,13.54,34.13,32.76l-53.68,8.79-.24.33,4.84-.23,48.64-1.49c-3.31,18.91-17.65,34.41-36.51,39.1Z"/>
      </svg>
    </div>

    <style is:global>
      html, body {
        scroll-snap-type: none !important;
        scroll-behavior: smooth !important;
        overflow-x: hidden;
      }

      /* Big muted watermark logo, anchored in the bottom-right corner,
         ~75% visible (a quarter bleeds off the corner). Breathes (shrink/grow)
         from the corner, continuously, at a different speed than the nav logo.
         Follows the active colour scheme. */
      .watermark-container {
        position: fixed;
        bottom: 0;
        right: 0;
        width: 100%;
        height: 100%;
        z-index: 99999;          /* Render on top of everything including page content */
        pointer-events: none;
        overflow: hidden;
      }

      .watermark-logo {
        position: absolute;
        top: 0;
        left: 0;
        width: 200px;
        height: 200px;
        fill: color-mix(in srgb, var(--_tokens---color--bg) 82%, var(--_tokens---color--fg)); /* bg-toned, slightly darker */
        opacity: 0.55;          /* visible as a near-bg shape */
        transform-origin: center center;  /* rotate around its own center axis */
        transform: translate(0, 0) rotate(0deg);
        transition: fill 0.3s ease;
        will-change: width, height, transform;
      }

      /* Physics balls — 10% lighter than the background, so they blend in beautifully.
         Adapts to every colour scheme automatically. */
      .watermark-ball {
        fill: color-mix(in srgb, var(--_tokens---color--bg) 90%, white);
        pointer-events: none;
        overflow: hidden;
      }

      /* Dead (zombie) balls: distinct darker logo SVG style */
      .watermark-ball--dead {
        fill: color-mix(in srgb, var(--_tokens---color--fg) 100%, black) !important;
        opacity: 0.85 !important; /* Extremely visible on top of page content */
        background: none !important;
        border: none !important;
        box-shadow: none !important;
        animation: dead-pulse 2.4s ease-in-out infinite;
      }

      @keyframes dead-pulse {
        0%, 100% { opacity: 0.75; transform: scale(0.96); }
        50%       { opacity: 0.95; transform: scale(1.04); }
      }

      @media (prefers-reduced-motion: reduce) {
        .watermark-logo { animation: none; }
      }
    </style>

    <slot />
    <script>
      // Global Arrow Hover Random Rotation
      document.addEventListener('mouseover', (e) => {
        const target = e.target as HTMLElement;
        const hoverContainer = target.closest('a, button, .project-card, .about-link-row, .qs-row, .home-slider__slide, .sn-panel__link, .sn-panel__secondary-link');
        if (hoverContainer) {
          const arrow = hoverContainer.querySelector('.link-arrow') as HTMLElement;
          if (arrow && !arrow.dataset.hasRandomHover) {
            arrow.dataset.hasRandomHover = 'true';
            arrow.style.transition = 'transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease';
            
            const onMouseEnter = () => {
              const randomAngle = Math.floor(Math.random() * 360);
              arrow.style.transform = `rotate(${randomAngle}deg)`;
            };
            
            const onMouseLeave = () => {
              arrow.style.transform = '';
            };
            
            hoverContainer.addEventListener('mouseenter', onMouseEnter);
            hoverContainer.addEventListener('mouseleave', onMouseLeave);
            
            // Trigger immediately on first hover detection
            onMouseEnter();
          }
        }
      });
    </script>
    <script>
      // Global Text Scramble (Matrix Decode) Hover Effect
      const GLYPHS = '01XYZ%$#@?*+=#-_[]{}<>/';

      class TextScrambler {
        el: HTMLElement;
        originalText: string;
        frame: number = 0;
        queue: Array<{ from: string; to: string; start: number; end: number; char?: string }> = [];
        resolveQueue: () => void = () => {};
        animationFrameId: number = 0;

        constructor(el: HTMLElement) {
          this.el = el;
          this.originalText = el.dataset.scrambleText || el.textContent || '';
          if (!el.dataset.scrambleText) {
            el.dataset.scrambleText = this.originalText;
          }
        }

        scramble() {
          const currentText = this.el.textContent || '';
          const length = Math.max(this.originalText.length, currentText.length);
          this.queue = [];
          
          for (let i = 0; i < length; i++) {
            const from = currentText[i] || '';
            const to = this.originalText[i] || '';
            const start = Math.floor(Math.random() * 8);
            const end = start + Math.floor(Math.random() * 12) + 4;
            this.queue.push({ from, to, start, end });
          }

          cancelAnimationFrame(this.animationFrameId);
          this.frame = 0;
          
          return new Promise((resolve) => {
            this.resolveQueue = () => resolve(undefined);
            this.tick();
          });
        }

        tick() {
          let output = '';
          let complete = 0;

          for (let i = 0, n = this.queue.length; i < n; i++) {
            let { from, to, start, end, char } = this.queue[i];
            if (this.frame >= end) {
              complete++;
              output += to;
            } else if (this.frame >= start) {
              if (!char || Math.random() < 0.28) {
                char = GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
                this.queue[i].char = char;
              }
              output += char;
            } else {
              output += from;
            }
          }

          this.el.textContent = output;

          if (complete === this.queue.length) {
            this.resolveQueue();
          } else {
            this.frame++;
            this.animationFrameId = requestAnimationFrame(() => this.tick());
          }
        }

        stop() {
          cancelAnimationFrame(this.animationFrameId);
          this.el.textContent = this.originalText;
        }
      }

      function getScrambleTarget(target: HTMLElement): HTMLElement | null {
        // 0. Direct match: if the target (or close ancestor) is one of our designated safe text components,
        // use it immediately if it does not contain child elements (to preserve inner tags/SVGs).
        const directTextSpan = target.closest(
          '.home-nav-row__text, .about-link-row__text, ' +
          '.sn-panel__link span, ' +
          // .proj-bubble__name is excluded: pills have their own JS hover that swaps abbreviated↔full name
          '.project-card__stack-name, .project-card__title, ' +
          '.education-card__school, .about-card__title, .stacked-name, .about-card__collab'
        );
        if (directTextSpan && directTextSpan.children.length === 0) {
          return directTextSpan as HTMLElement;
        }

        // Find the closest potential scramble container/element candidate
        let candidate: HTMLElement | null = null;

        // 1. Explicit scramble attribute
        const scrambleAttr = target.closest('[data-scramble]');
        if (scrambleAttr) {
          candidate = scrambleAttr as HTMLElement;
        } else {
          // 2. Headings (h1-h6)
          const heading = target.closest('h1, h2, h3, h4, h5, h6');
          if (heading) {
            candidate = heading as HTMLElement;
          } else {
            // 3. Links and navigation items
            const link = target.closest('a');
            if (link) {
              // Exclude breadcrumbs from ever scrambling
              if (link.closest('.breadcrumb, .page-breadcrumb')) {
                return null;
              }
              // Exclude proj-bubble pills: they have their own JS hover for abbreviated↔full name
              if (link.classList.contains('proj-bubble')) {
                return null;
              }
              // Exclude long paragraphs or paragraph links
              if (link.closest('p, .home-intro__desc, .about-card__desc, .project-card__desc')) {
                const text = link.textContent?.trim() || '';
                if (text.length > 50) return null;
              }
              const textSpan = link.querySelector(
                '.home-nav-row__text, .about-link-row__text, ' +
                '.sn-panel__link span, ' +
                '.project-card__stack-name'
              );
              if (textSpan) return textSpan as HTMLElement;
              candidate = link;
            } else {
              // 4. Card headers and titles
              const title = target.closest(
                '.project-card__title, .education-card__school, ' +
                '.about-card__role, .about-card__org, .about-card__title, .stacked-name, .about-card__collab'
              );
              if (title) {
                candidate = title as HTMLElement;
              }
            }
          }
        }

        // Safety check: if the candidate exists and is safe (no element children), scramble it.
        // This ensures nested HTML structure (such as SVG icons or spans) is never deleted.
        if (candidate) {
          if (candidate.children.length === 0) {
            return candidate;
          }
          // If it has children, attempt to find a child that is safe to scramble
          const safeChild = candidate.querySelector(
            '.home-nav-row__text, .about-link-row__text, ' +
            '.sn-panel__link span, ' +
            '.project-card__stack-name, .project-card__title, ' +
            '.education-card__school, .about-card__title, .stacked-name, .about-card__collab'
          );
          if (safeChild && safeChild.children.length === 0) {
            return safeChild as HTMLElement;
          }
        }

        return null;
      }

      function getTriggerElement(scrambleEl: HTMLElement): HTMLElement {
        return scrambleEl.closest(
          'a, button, .home-nav-row, .about-link-row, .home-slider__slide, ' +
          '.sn-panel__link, .project-card, .education-card, .about-card, ' +
          '.skill-pill, .proj-bubble'
        ) as HTMLElement || scrambleEl;
      }

      document.addEventListener('mouseover', (e) => {
        const target = e.target as HTMLElement;
        const scrambleEl = getScrambleTarget(target);

        if (scrambleEl) {
          if (!scrambleEl.dataset.hasScrambleListener) {
            scrambleEl.dataset.hasScrambleListener = 'true';
            const scrambler = new TextScrambler(scrambleEl);

            const onMouseEnter = () => {
              scrambler.scramble();
            };

            const onMouseLeave = () => {
              scrambler.stop();
            };

            const triggerEl = getTriggerElement(scrambleEl);
            triggerEl.addEventListener('mouseenter', onMouseEnter);
            triggerEl.addEventListener('mouseleave', onMouseLeave);

            // Trigger immediately for the current hover
            onMouseEnter();
          }
        }
      });
    </script>
    <script>
      function initWatermarkLogo() {
        const container  = document.querySelector('.watermark-container') as HTMLElement | null;
        const templateEl = document.getElementById('watermark-logo') as SVGSVGElement | null;
        if (!container || !templateEl) return;

        templateEl.style.display = 'none';

        let W = window.innerWidth, H = window.innerHeight;

        // ── 1. LEVEL HIERARCHY & CONSTANTS ──
        const LEVEL_MIN          = 3; // F3 size level
        const LEVEL_MAX_NORMAL   = 6; // F6 size level
        const LEVEL_SPECIAL_F7   = 7; // F7 special size level

        // Index 3 to 7 corresponds to F3 to F7 size ratios relative to viewport min(W,H)
        const LEVEL_SIZE_FRACS = [0, 0.040, 0.065, 0.050, 0.080, 0.120, 0.180, 0.250];

        // Physics Coefficients
        const NAV_W        = 44;
        const BREADCRUMB_H = 48;
        const GRAV_BASE    = 0.10;    // base gravity
        const BOUNCE       = 0.65;    // wall bounce
        const DRAG         = 0.993;   // air drag
        const PACK_GAP     = 10;      // gap between ball boundaries
        const RESTITUTION  = 0.55;    // collision elasticity
        const WIND_FORCE   = 5.0;     // nav menu open push force
        const MAX_SPEED_SM = 9.0;     // max speed for F3
        const MAX_SPEED_LG = 1.8;     // max speed for F7
        const VROT_MAX_SM  = 2.2;     // max rotation speed for F3
        const VROT_MAX_LG  = 0.15;    // max rotation speed for F7
        const SPAWN_CD_G   = 90;      // global size-change cooldown
        const SPAWN_CD_B   = 110;     // ball size-change cooldown

        type Ball = {
          el: SVGSVGElement | HTMLDivElement;
          x: number; y: number;
          vx: number; vy: number;
          size: number;
          radius: number;
          sizeFrac: number;
          maxSizeFrac: number;
          baseSize: number;
          rot: number; vrot: number;
          cd: number;
          level: number;
          idleFrames: number;
          isZombie: boolean;
          hasHitTop: boolean;
          hasFallen: boolean;
          breathingPhase: number;
        };

        const balls: Ball[] = [];
        let gSpawnCd        = 0;
        let prevNavIsOpen   = false;
        let navLeftBound    = NAV_W;

        // ── 2. F7 ORGANIC BREATHING STATE ──
        let f7Time = 0;
        let f7TargetFrac = LEVEL_SIZE_FRACS[LEVEL_SPECIAL_F7];

        // ── 2b. SNACKS SYSTEM ──
        type Snack = {
          el: HTMLDivElement;
          x: number;
          y: number;
          vx: number;
          vy: number;
          radius: number;
        };
        const snacks: Snack[] = [];

        function createSnack(x: number, y: number) {
          const el = document.createElement('div');
          el.className = 'watermark-snack';
          el.style.cssText = `
            position: absolute;
            top: 0;
            left: 0;
            width: 12px;
            height: 12px;
            background: color-mix(in srgb, var(--_tokens---color--fg) 60%, transparent);
            border-radius: 50%;
            box-shadow: 0 0 8px var(--_tokens---color--fg);
            pointer-events: none;
            z-index: 9998;
            will-change: transform;
          `;
          container!.appendChild(el);
          const angle = Math.random() * Math.PI * 2;
          const speed = 1 + Math.random() * 2;
          snacks.push({
            el,
            x,
            y,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed - 2, // slight upward kick on drop
            radius: 6
          });
        }

        // ── 3. HELPER FUNCTIONS ──
        const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

        const getSizeRatio = (b: Ball) => (b.level - LEVEL_MIN) / Math.max(1, LEVEL_MAX_NORMAL - LEVEL_MIN);

        function createBallSVG(size: number): SVGSVGElement {
          const el = templateEl!.cloneNode(true) as SVGSVGElement;
          el.removeAttribute('id');
          el.classList.add('watermark-ball');
          el.style.cssText = `position:absolute;top:0;left:0;width:${size}px;height:${size}px;opacity:0.09;will-change:transform;pointer-events:none;transform:translate(-9999px,-9999px);`;
          container!.appendChild(el);
          return el;
        }

        function createZombieSVG(size: number): SVGSVGElement {
          const el = templateEl!.cloneNode(true) as SVGSVGElement;
          el.removeAttribute('id');
          el.classList.add('watermark-ball', 'watermark-ball--dead');
          el.style.cssText = `position:absolute;top:0;left:0;width:${size}px;height:${size}px;will-change:transform;pointer-events:none;transform:translate(-9999px,-9999px);`;
          container!.appendChild(el);
          return el;
        }

        function createBallState(el: SVGSVGElement | HTMLDivElement, x: number, y: number, vx: number, vy: number, level: number, isZombie = false): Ball {
          const frac = LEVEL_SIZE_FRACS[Math.max(LEVEL_MIN, Math.min(LEVEL_SPECIAL_F7, level))];
          const base = Math.min(W, H) * frac;
          return {
            el, x, y, vx, vy,
            size: base, radius: base * 0.5,
            sizeFrac: frac, maxSizeFrac: frac, baseSize: base,
            rot: Math.random() * 360,
            vrot: (Math.random() - 0.5) * 0.6,
            cd: 0, level, idleFrames: 0, isZombie,
            hasHitTop: false,
            hasFallen: false,
            breathingPhase: Math.random() * 100,
          };
        }

        function demoteBallLevel(ball: Ball, impulseX = 0, impulseY = 0): boolean {
          if (ball.cd > 0) return false;
          const targetLvl = Math.max(LEVEL_MIN, ball.level - 1);
          if (targetLvl === ball.level) return false;

          ball.level       = targetLvl;
          ball.maxSizeFrac = LEVEL_SIZE_FRACS[targetLvl];
          ball.sizeFrac    = LEVEL_SIZE_FRACS[targetLvl] * 0.88;
          ball.baseSize    = Math.min(W, H) * ball.sizeFrac;

          const collapseToLvl = Math.max(LEVEL_MIN, targetLvl - 2);
          ball.size   = Math.min(W, H) * LEVEL_SIZE_FRACS[collapseToLvl];
          ball.radius = ball.size * 0.5;
          ball.vx     = ball.vx * 0.45 + impulseX;
          ball.vy     = ball.vy * 0.45 + impulseY;
          ball.cd     = SPAWN_CD_B;
          return true;
        }

        function promoteBallLevel(ball: Ball): boolean {
          if (ball.cd > 0) return false;
          const targetLvl = Math.min(LEVEL_MAX_NORMAL, ball.level + 1);
          if (targetLvl === ball.level) return false;

          ball.level       = targetLvl;
          ball.maxSizeFrac = LEVEL_SIZE_FRACS[targetLvl];
          ball.sizeFrac    = LEVEL_SIZE_FRACS[targetLvl] * 0.80;
          ball.baseSize    = Math.min(W, H) * ball.sizeFrac;

          const collapseToLvl = Math.max(LEVEL_MIN, targetLvl - 2);
          ball.size   = Math.min(W, H) * LEVEL_SIZE_FRACS[collapseToLvl];
          ball.radius = ball.size * 0.5;
          ball.cd     = SPAWN_CD_B;
          return true;
        }

        // ── 4. INITIAL SPAWNING SETUP ──
        const cx = W * 0.50, cy = H * 0.46;
        const initialSpawnList: { lvl: number; xOffset: number; yOffset: number }[] = [];
        
        // 4 Special F7 balls (spawned near the bottom floor to start at their natural habitat)
        for (let k = 0; k < 4; k++) {
          initialSpawnList.push({ 
            lvl: LEVEL_SPECIAL_F7, 
            xOffset: (k - 1.5) * (W * 0.18), 
            yOffset: H * 0.32 
          });
        }
        // 16 F6 (LEVEL_MAX_NORMAL) balls (increased from 11)
        for (let k = 0; k < 16; k++) {
          const rad = k * (360 / 16) * Math.PI / 180;
          initialSpawnList.push({ lvl: LEVEL_MAX_NORMAL, xOffset: Math.cos(rad) * Math.min(W, H) * 0.22, yOffset: Math.sin(rad) * Math.min(W, H) * 0.22 });
        }
        // 25 Level 5 balls (increased from 17)
        for (let k = 0; k < 25; k++) {
          const rad = (k * (360 / 25) + 15) * Math.PI / 180;
          initialSpawnList.push({ lvl: 5, xOffset: Math.cos(rad) * Math.min(W, H) * 0.35, yOffset: Math.sin(rad) * Math.min(W, H) * 0.35 });
        }
        // 35 Level 4 balls (increased from 22)
        for (let k = 0; k < 35; k++) {
          const rad = (k * (360 / 35) + 5) * Math.PI / 180;
          initialSpawnList.push({ lvl: 4, xOffset: Math.cos(rad) * Math.min(W, H) * 0.48, yOffset: Math.sin(rad) * Math.min(W, H) * 0.48 });
        }
        // 55 Level 3 (LEVEL_MIN) balls (increased from 26)
        for (let k = 0; k < 55; k++) {
          const rad = (k * (360 / 55) + 20) * Math.PI / 180;
          initialSpawnList.push({ lvl: LEVEL_MIN, xOffset: Math.cos(rad) * Math.min(W, H) * 0.58, yOffset: Math.sin(rad) * Math.min(W, H) * 0.58 });
        }

        initialSpawnList.forEach(({ lvl, xOffset, yOffset }) => {
          const speed = lvl === LEVEL_SPECIAL_F7 ? 0.1 : (LEVEL_SPECIAL_F7 + 1 - lvl) * 1.2 + Math.random() * 1.5;
          const el    = createBallSVG(Math.min(W, H) * LEVEL_SIZE_FRACS[lvl]);
          const bState = createBallState(
            el,
            cx + xOffset,
            cy + yOffset,
            (Math.random() - 0.5) * speed,
            (Math.random() - 0.5) * speed,
            lvl,
          );
          bState.size = 1; // start tiny for smooth growing birth
          balls.push(bState);
        });

        // ── 5. EVENT LISTENERS & PHYSICS TRIGGERS ──
        const onResize    = () => { W = window.innerWidth; H = window.innerHeight; };
        const onMouseMove  = (e: MouseEvent) => { mouseX = e.clientX; mouseY = e.clientY; };
        const onMouseLeave = () => { mouseX = -9999; mouseY = -9999; };
        window.addEventListener('resize',     onResize,    { passive: true });
        window.addEventListener('mousemove',  onMouseMove, { passive: true });
        window.addEventListener('mouseleave', onMouseLeave,{ passive: true });

        let mouseX = -9999, mouseY = -9999;
        let scrollVelY  = 0;
        let lastScrollY = window.scrollY;
        
        const onScroll = () => {
          const cur   = window.scrollY;
          const delta = cur - lastScrollY;
          lastScrollY = cur;
          if (delta > 0) {
            scrollVelY += Math.min(delta * 0.28, 6.0);
          }
        };
        window.addEventListener('scroll', onScroll, { passive: true });

        let spaceDown = false;
        const onKeyDown = (e: KeyboardEvent) => {
          if (e.code === 'Space' && !e.repeat) {
            e.preventDefault();
            spaceDown = true;
          }
        };
        const onKeyUp = (e: KeyboardEvent) => {
          if (e.code === 'Space') {
            spaceDown = false;
            for (const b of balls) {
              const jumpStrength = lerp(5.0, 10.0, getSizeRatio(b));
              b.vy -= jumpStrength;
            }
          }
        };
        window.addEventListener('keydown', onKeyDown);
        window.addEventListener('keyup',   onKeyUp);
        const onClick = (e: MouseEvent) => {
          if ((e.target as HTMLElement).closest('a, button')) return;
          createSnack(e.clientX, e.clientY);
        };
        window.addEventListener('click', onClick);
        let frameId: number;

        // ── 6. PHYSICS LOOP (STEP) ──
        function step() {
          if (gSpawnCd > 0) gSpawnCd--;

          // Left menu navigation adjustment
          const navTarget = ((window as any).__navPanelTarget as number) || NAV_W;
          navLeftBound   += (navTarget - navLeftBound) * 0.30;
          const navIsOpen = navLeftBound > NAV_W + 40;
          const usableW   = Math.max(1, W - navLeftBound);
          const navScale  = navIsOpen ? Math.max(0.22, usableW / (W - NAV_W)) : 1;

          // Collision Check
          const toRemove = new Set<Ball>();
          const toSpawn: Ball[] = [];

          for (let i = 0; i < balls.length; i++) {
            for (let j = i + 1; j < balls.length; j++) {
              const a = balls[i], b = balls[j];
              if (toRemove.has(a) || toRemove.has(b)) continue;

              const dx = b.x - a.x, dy = b.y - a.y;
              const dist = Math.hypot(dx, dy) || 0.001;
              const minD = a.radius + b.radius + PACK_GAP;

              if (dist >= minD * 1.3) continue;

              const nx = dx / dist, ny = dy / dist;

              // Push apart overlaps
              if (dist < minD) {
                const push = (minD - dist) * 0.5;
                a.x -= nx * push; a.y -= ny * push;
                b.x += nx * push; b.y += ny * push;
              }

              // Elastic impulse physics
              const dvn = (b.vx - a.vx) * nx + (b.vy - a.vy) * ny;
              if (dvn < 0) {
                const imp = dvn * RESTITUTION;
                a.vx += nx * imp; a.vy += ny * imp;
                b.vx -= nx * imp; b.vy -= ny * imp;
              }

              // ── SPECIAL COLLISION ACTIONS ──
              const touching = (dist - a.radius - b.radius) <= PACK_GAP + 8;
              
              // Dead ball interactions
              if (a.isZombie || b.isZombie) {
                const zombie = a.isZombie ? a : b;
                const other = a.isZombie ? b : a;

                // Dead ball exerts strong push force on elements around it while rising
                if (!zombie.hasHitTop && !other.isZombie) {
                  const pushForce = 2.5 * dt;
                  other.vx += nx * pushForce * (other.x < zombie.x ? -1 : 1);
                  other.vy += ny * pushForce * (other.y < zombie.y ? -1 : 1);
                }

                // During descent, if it successfully reaches and makes contact with balls
                if (zombie.hasHitTop && touching) {
                  if (other.level === LEVEL_SPECIAL_F7) {
                    // Contact with F7 -> Create a repulsion wave and disappear completely
                    for (const bTarget of balls) {
                      if (bTarget === zombie) continue;
                      const rdx = bTarget.x - zombie.x;
                      const rdy = bTarget.y - zombie.y;
                      const rdist = Math.hypot(rdx, rdy) || 0.1;
                      if (rdist < 300) {
                        const wavePower = 10 * (1 - rdist / 300);
                        bTarget.vx += (rdx / rdist) * wavePower;
                        bTarget.vy += (rdy / rdist) * wavePower;
                      }
                    }
                    toRemove.add(zombie);
                  } else if (!other.isZombie) {
                    // Randomly changes the standard ball level
                    if (Math.random() < 0.5) {
                      promoteBallLevel(other);
                    } else {
                      demoteBallLevel(other);
                    }
                  }
                }
              }

              if (touching && (a.level === LEVEL_SPECIAL_F7 || b.level === LEVEL_SPECIAL_F7)) {
                const nonF7 = a.level === LEVEL_SPECIAL_F7 ? b : a;

                if (nonF7.isZombie && gSpawnCd === 0) {
                  // Resurrect Zombie
                  const rEl = createBallSVG(Math.min(W, H) * LEVEL_SIZE_FRACS[LEVEL_MAX_NORMAL]);
                  const rb  = createBallState(rEl, nonF7.x, nonF7.y,
                    (Math.random() - 0.5) * 4, -3 - Math.random() * 2, LEVEL_MAX_NORMAL);
                  const collapseToLvl = Math.max(LEVEL_MIN, LEVEL_MAX_NORMAL - 3);
                  rb.size = Math.min(W, H) * LEVEL_SIZE_FRACS[collapseToLvl];
                  rb.radius = rb.size * 0.5;
                  rb.cd = SPAWN_CD_B;
                  toSpawn.push(rb);
                  toRemove.add(nonF7);
                  gSpawnCd = SPAWN_CD_G;
                } else if (!nonF7.isZombie && nonF7.cd === 0 && gSpawnCd === 0) {
                  // Contact scaling for F7 collisions:
                  // The heavier balls (F6/F5) need a harder contact (high negative approach velocity dvn)
                  // The smaller balls (F4) need a lighter contact to divide.
                  let reqDvn = -1.2;
                  if (nonF7.level >= 6) {
                    reqDvn = -2.8; // F6 needs extremely hard contact
                  } else if (nonF7.level === 5) {
                    reqDvn = -2.0; // F5 needs harder contact
                  } else if (nonF7.level === 4) {
                    reqDvn = -1.2; // F4 needs lighter contact
                  }

                  if (dvn < reqDvn) {
                    // Middle levels/F6/F5/F4: promote or demote (split)
                    let doGrow: boolean;
                    if (nonF7.level >= LEVEL_MAX_NORMAL)     doGrow = false;
                    else if (nonF7.level <= LEVEL_MIN)       doGrow = true;
                    else                                     doGrow = Math.random() < 0.50;
                    
                    if (doGrow) {
                      if (promoteBallLevel(nonF7)) gSpawnCd = SPAWN_CD_G;
                    } else {
                      const perpX = -ny, perpY = nx;
                      const kick  = 1.5 + Math.random() * 1.5;
                      if (demoteBallLevel(nonF7, perpX * kick, perpY * kick)) gSpawnCd = SPAWN_CD_G;
                    }
                  }
                }
              } else if (touching && !a.isZombie && !b.isZombie &&
                         a.level === LEVEL_MIN && b.level === LEVEL_MIN &&
                         gSpawnCd === 0) {
                 // Death event: two F3 balls collide/touch even barely -> instantly merge into a zombie (dead ball)
                 const mx  = (a.x + b.x) * 0.5, my = (a.y + b.y) * 0.5;
                 
                 // One size smaller than the smallest (F3 is level 3, so size level 2 which is index 2 -> 0.040)
                 const deadSizeFrac = 0.040; 
                 const deadSize = Math.min(W, H) * deadSizeFrac;
                 
                 const dEl = createZombieSVG(deadSize);
                 const db  = createBallState(dEl, mx, my, 0, -8, LEVEL_MIN - 1, true); // vy=-8 for high force straight rise
                 
                 db.size = 1; // start tiny for smooth growing birth
                 db.radius = 0.5;
                 db.baseSize = deadSize;
                 db.sizeFrac = deadSizeFrac;
                 db.maxSizeFrac = deadSizeFrac;
                 db.cd = 240; // Cooldown frames for rise behavior
                 
                 toSpawn.push(db);
                 toRemove.add(a);
                 toRemove.add(b);
                 gSpawnCd = SPAWN_CD_G;
              }
            }
          }

          // Apply deferred removals and additions
          toRemove.forEach(p => {
            p.el.remove();
            const i = balls.indexOf(p);
            if (i >= 0) balls.splice(i, 1);
          });
          balls.push(...toSpawn);

          // Refiller: maintain exactly 135 normal balls in the viewport
          const normalCount = balls.filter(b => !b.isZombie).length;
          if (normalCount < 135) {
            const need = 135 - normalCount;
            for (let k = 0; k < need; k++) {
              const randLvl = Math.floor(Math.random() * 3) + 3; // F3, F4, or F5
              const spawnX = navLeftBound + Math.random() * (W - navLeftBound);
              const spawnY = BREADCRUMB_H + Math.random() * 30; // Spawn near top
              const el = createBallSVG(Math.min(W, H) * LEVEL_SIZE_FRACS[randLvl]);
              const newBall = createBallState(
                el,
                spawnX,
                spawnY,
                (Math.random() - 0.5) * 2,
                1.0 + Math.random() * 1.5,
                randLvl
              );
              newBall.cd = SPAWN_CD_B;
              newBall.size = 1; // start tiny so we see the growth animation!
              newBall.radius = 0.5;
              balls.push(newBall);
            }
          }

          const navJustOpened = navIsOpen && !prevNavIsOpen;
          prevNavIsOpen = navIsOpen;

          // ── GLOBAL TIMING & FIBONACCI SLOWDOWN ──
          const fibSequence = [1, 2, 3, 5, 8, 13, 21];
          if (!(window as any).__fibStepTime || navJustOpened) {
            (window as any).__fibStepTime = 0;
            (window as any).__fibStepIndex = 0;
            (window as any).__fibStepDir = 1;
            for (const b of balls) { if (b.level === LEVEL_SPECIAL_F7) b.breathingPhase = 0; }
          }
          (window as any).__fibStepTime++;
          
          // 360 frames = 6 seconds (base time per step)
          if ((window as any).__fibStepTime >= 360) {
            (window as any).__fibStepTime = 0;
            let idx = (window as any).__fibStepIndex;
            let dir = (window as any).__fibStepDir;
            idx += dir;
            if (idx >= 6) { idx = 6; (window as any).__fibStepDir = -1; }
            else if (idx <= 0) { idx = 0; (window as any).__fibStepDir = 1; }
            (window as any).__fibStepIndex = idx;
          }

          const fibVal = fibSequence[(window as any).__fibStepIndex];
          const dt = 1.0 / fibVal;
          f7Time += 0.016 * dt;

          if (scrollVelY > 0.05) scrollVelY *= Math.pow(0.82, dt); else scrollVelY = 0;

        // ── 7. PER-BALL POSITION & SIZE UPDATES ──
          for (const b of balls) {
            if (b.cd > 0) b.cd--;

            const ratio        = getSizeRatio(b);
            let ballGrav       = GRAV_BASE * dt;
            
            // F7 special balls and zombie balls drop down quicker
            if (b.level === LEVEL_SPECIAL_F7) {
              ballGrav = GRAV_BASE * 6.5 * dt; // Significantly heavier downward force
            } else if (b.isZombie) {
              ballGrav = GRAV_BASE * 1.5 * dt;
            }

            const ballSpeedCap = lerp(MAX_SPEED_SM, MAX_SPEED_LG, ratio);
            const ballVrotMax  = lerp(VROT_MAX_SM,  VROT_MAX_LG,  ratio);

            b.baseSize = Math.min(W, H) * b.sizeFrac * navScale;

            // ── F7 Natural Breathing Oscillator ──
            if (b.level === LEVEL_SPECIAL_F7) {
              // Base breathing speed: 1 full cycle every 6 seconds (360 frames)
              const baseBreathingSpeed = (Math.PI * 2) / 360;
              b.breathingPhase += baseBreathingSpeed * dt;

              const rawSin = Math.sin(b.breathingPhase);
              const wave = Math.pow((rawSin + 1) * 0.5, 1.6);
              
              const baseF7Frac = LEVEL_SIZE_FRACS[LEVEL_SPECIAL_F7];
              f7TargetFrac += (baseF7Frac - f7TargetFrac) * 0.0005 * dt;

              const breathFrac = lerp(LEVEL_SIZE_FRACS[LEVEL_MIN], f7TargetFrac, wave);
              b.sizeFrac    = breathFrac;
              b.maxSizeFrac = breathFrac;
              b.baseSize    = Math.min(W, H) * breathFrac * navScale;
            }

            // Passive Regrowth
            if (b.cd === 0 && b.sizeFrac < b.maxSizeFrac * 0.995 && b.level !== LEVEL_SPECIAL_F7 && !b.isZombie) {
              b.sizeFrac = Math.min(b.maxSizeFrac, b.sizeFrac + (b.sizeFrac * 0.010 * dt));
              b.baseSize = Math.min(W, H) * b.sizeFrac * navScale;
            }

            if (b.isZombie) {
               b.vx *= Math.pow(0.85, dt);

               if (!b.hasHitTop) {
                 b.vy -= 0.55 * dt; 
                 if (b.vy < -7.0) b.vy = -7.0;
               } else {
                 b.vy += ballGrav * 2.5;
                 if (b.vy > 9.0) b.vy = 9.0;
               }

               b.vx += (Math.random() - 0.5) * 0.15 * dt;
               b.vy += (Math.random() - 0.5) * 0.15 * dt;

               b.x += b.vx * dt; b.y += b.vy * dt;
               b.radius = b.size * 0.5;

               if (b.x - b.radius < navLeftBound) { b.x = navLeftBound + b.radius; b.vx =  Math.abs(b.vx); }
               if (b.x + b.radius > W)            { b.x = W - b.radius;            b.vx = -Math.abs(b.vx); }
               
               if (b.y - b.radius < BREADCRUMB_H) { 
                 b.y = BREADCRUMB_H + b.radius; 
                 b.hasHitTop = true;
                 b.vy = 8.5; // Impulse bounce
                 b.vx = (Math.random() - 0.5) * 3;
               }
               
               if (b.y + b.radius > H) { 
                 b.y = H - b.radius;
                 const f5El = createBallSVG(Math.min(W, H) * LEVEL_SIZE_FRACS[5]);
                 const f5Ball = createBallState(f5El, b.x, b.y, b.vx, -3.0, 5); 
                 f5Ball.cd = SPAWN_CD_B;
                 toSpawn.push(f5Ball);
                 toRemove.add(b);
               }

               b.rot += 0.8 * dt;
               b.el.style.transform = `translate(${b.x - b.radius}px,${b.y - b.radius}px) rotate(${b.rot}deg)`;
               continue;
             }

            if (snacks.length > 0) {
              let nearestSnack: Snack | null = null;
              let minDist = 250;
              for (const s of snacks) {
                const sdist = Math.hypot(s.x - b.x, s.y - b.y);
                if (sdist < minDist) { minDist = sdist; nearestSnack = s; }
              }
              if (nearestSnack) {
                const sdx = nearestSnack.x - b.x;
                const sdy = nearestSnack.y - b.y;
                const sdist = Math.hypot(sdx, sdy) || 0.001;
                const pull = 0.12 * (1 - sdist / 250) * dt;
                b.vx += (sdx / sdist) * pull;
                b.vy += (sdy / sdist) * pull;
              }
            }

            if (b.level === LEVEL_SPECIAL_F7) {
              b.vx += Math.sin(f7Time * 2.0) * 0.18 * dt;
              b.vy += ballGrav * 1.5;
              const gravMultiplier = spaceDown ? 2.0 : 1.0;
              b.vy += ballGrav * gravMultiplier;
              b.vy += 0.25 * dt; 
            } else {
              const gravMultiplier = spaceDown ? 2.0 : 1.0;
              b.vy += ballGrav * gravMultiplier;
            }

            if (scrollVelY > 0.05) {
              const scrollSens = b.level === LEVEL_SPECIAL_F7 ? 0.05 : lerp(0.6, 1.0, ratio);
              b.vy -= scrollVelY * scrollSens * dt;
            }

            const leftGap = b.x - navLeftBound - b.radius;
            if (leftGap < b.size * 1.2) {
              b.vx += (1 - Math.max(0, leftGap / (b.size * 1.2))) * 0.35 * dt;
            }

            if (navJustOpened) {
              const proximity = 1 - Math.max(0, Math.min(1, (b.x - navLeftBound) / usableW));
              b.vx += WIND_FORCE * (0.3 + proximity * 0.7); // Impulse
              b.vy += (Math.random() - 0.5) * WIND_FORCE * 0.4;
            }

            b.vx *= Math.pow(DRAG, dt); 
            b.vy *= Math.pow(DRAG, dt);
            const spd = Math.hypot(b.vx, b.vy);
            if (spd > ballSpeedCap) { b.vx = b.vx / spd * ballSpeedCap; b.vy = b.vy / spd * ballSpeedCap; }

            b.x += b.vx * dt; b.y += b.vy * dt;
            b.size   += (b.baseSize - b.size) * 0.035 * dt;
            b.radius  = b.size * 0.5;

            if (b.x - b.radius < navLeftBound) { b.x = navLeftBound + b.radius; b.vx =  Math.abs(b.vx) * BOUNCE; }
            if (b.x + b.radius > W)            { b.x = W - b.radius;            b.vx = -Math.abs(b.vx) * BOUNCE; }
            if (b.y - b.radius < BREADCRUMB_H) { b.y = BREADCRUMB_H + b.radius; b.vy =  Math.abs(b.vy) * BOUNCE; }
            if (b.y + b.radius > H)            { b.y = H - b.radius;            b.vy = -Math.abs(b.vy) * BOUNCE; }

            if (b.level === LEVEL_SPECIAL_F7) {
              const bSpd     = Math.hypot(b.vx, b.vy);
              const nearWall = (b.x - b.radius - navLeftBound) < b.size
                            || (W - (b.x + b.radius))          < b.size
                            || (b.y - b.radius - BREADCRUMB_H) < b.size
                            || (H - (b.y + b.radius))           < b.size;
              if (bSpd < 0.5 && !nearWall) {
                b.idleFrames += dt;
              } else {
                b.idleFrames = 0;
              }
              if (b.idleFrames > 180 && b.cd === 0) {
                demoteBallLevel(b, (Math.random() - 0.5) * 1.5, (Math.random() - 0.5) * 1.5);
                b.idleFrames = 0;
              }
            }

            const rotBlend = lerp(0.014, 0.003, ratio);
            const rotDamp  = lerp(0.80,  0.94,  ratio);
            const heading  = Math.atan2(b.vy, b.vx) * 180 / Math.PI;
            const diff     = ((heading - b.rot + 540) % 360) - 180;
            b.vrot += diff * rotBlend * dt;
            b.vrot *= Math.pow(rotDamp, dt);
            b.vrot  = Math.max(-ballVrotMax, Math.min(ballVrotMax, b.vrot));
            b.rot  += b.vrot * dt;
          }

          // ── 8. OVERLAP RESOLUTION SWEEP (RELAXATION) ──
          for (let iter = 0; iter < 8; iter++) {
            let anyOverlap = false;
            for (let i = 0; i < balls.length; i++) {
              for (let j = i + 1; j < balls.length; j++) {
                const a = balls[i], b = balls[j];
                const dx   = b.x - a.x, dy = b.y - a.y;
                const dist = Math.hypot(dx, dy) || 0.001;
                const minD = a.radius + b.radius + PACK_GAP;
                if (dist < minD) {
                  anyOverlap = true;
                  const overlap = minD - dist;
                  const nx = dx / dist, ny = dy / dist;
                  a.x -= nx * overlap * 0.5; a.y -= ny * overlap * 0.5;
                  b.x += nx * overlap * 0.5; b.y += ny * overlap * 0.5;
                  a.x = Math.max(navLeftBound + a.radius, Math.min(W - a.radius, a.x));
                  a.y = Math.max(BREADCRUMB_H  + a.radius, Math.min(H - a.radius, a.y));
                  b.x = Math.max(navLeftBound + b.radius, Math.min(W - b.radius, b.x));
                  b.y = Math.max(BREADCRUMB_H  + b.radius, Math.min(H - b.radius, b.y));
                }
              }
            }
            if (!anyOverlap) break;
          }

          // ── SNACK PHYSICS & EATING COLLISIONS ──
          for (let si = snacks.length - 1; si >= 0; si--) {
            const s = snacks[si];
            s.vy += GRAV_BASE * 0.5 * dt; // fall slightly slower
            s.vx *= Math.pow(DRAG, dt); s.vy *= Math.pow(DRAG, dt);
            s.x += s.vx * dt; s.y += s.vy * dt;

            // Wall bounce
            if (s.x - s.radius < navLeftBound) { s.x = navLeftBound + s.radius; s.vx =  Math.abs(s.vx) * BOUNCE; }
            if (s.x + s.radius > W)            { s.x = W - s.radius;            s.vx = -Math.abs(s.vx) * BOUNCE; }
            if (s.y - s.radius < BREADCRUMB_H) { s.y = BREADCRUMB_H + s.radius; s.vy =  Math.abs(s.vy) * BOUNCE; }
            if (s.y + s.radius > H)            { s.y = H - s.radius;            s.vy = -Math.abs(s.vy) * BOUNCE; }

            // Render snack DOM position
            s.el.style.transform = `translate(${Math.round(s.x - s.radius)}px,${Math.round(s.y - s.radius)}px)`;

            let eaten = false;
            for (const b of balls) {
              if (b.isZombie) continue;
              const dist = Math.hypot(b.x - s.x, b.y - s.y);
              if (dist < b.radius + s.radius) {
                eaten = true;
                if (b.level === LEVEL_SPECIAL_F7) {
                  f7TargetFrac = Math.min(LEVEL_SIZE_FRACS[LEVEL_SPECIAL_F7], f7TargetFrac + 0.05);
                } else {
                  promoteBallLevel(b);
                }
                break;
              }
            }

            if (eaten) {
              s.el.remove();
              snacks.splice(si, 1);
            }
          }

          // ── 9. DOM RENDER COMMIT ──
          for (const b of balls) {
            const s = Math.round(b.size);
            b.el.style.width  = s + 'px';
            b.el.style.height = s + 'px';
            b.el.style.transform = `translate(${Math.round(b.x - b.radius)}px,${Math.round(b.y - b.radius)}px) rotate(${Math.round(b.rot)}deg)`;
          }

          frameId = requestAnimationFrame(step);
        }

        frameId = requestAnimationFrame(step);

        return () => {
          window.removeEventListener('resize',     onResize);
          window.removeEventListener('mousemove',  onMouseMove);
          window.removeEventListener('mouseleave', onMouseLeave);
          window.removeEventListener('scroll',     onScroll);
          window.removeEventListener('keydown',    onKeyDown);
          window.removeEventListener('keyup',      onKeyUp);
          window.removeEventListener('click',      onClick);
          cancelAnimationFrame(frameId);
          balls.forEach(b => b.el.remove());
          balls.length = 0;
          snacks.forEach(s => s.el.remove());
          snacks.length = 0;
          templateEl!.style.display = '';
        };
      }

      let cleanupWatermark: (() => void) | undefined;

      function setup() {
        if (cleanupWatermark) {
          cleanupWatermark();
        }
        cleanupWatermark = initWatermarkLogo();
      }

      // Initialize
      setup();
      
      // Support Astro View Transitions
      document.addEventListener('astro:after-swap', setup);
    </script>
  </body>
</html>
