  .home-slider__slide {
    --img-w: 66%; /* image width as a share of the content; gutters hold name + arrow */
    position: relative;
    flex: 0 0 100%; /* bound to the content width (same margins as About) */
    height: 100%;   /* fill the track so the photo can flex */
    scroll-snap-align: center;
    scroll-snap-stop: always;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--_tokens---color--fg);
  }

  /* wraps image-wrap + both captions so absolute captions scope to this area */
  .home-slider__image-area {
    position: relative;
    width: 100%;
    flex: 1 1 auto;  /* takes whatever height the text rows leave over */
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  .home-slider__image-wrap {
    width: var(--img-w);   /* fixed width, centred in the full-width slide */
