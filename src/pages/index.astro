    height: 100%;          /* photo absorbs the flexible height */
    min-height: 0;
    overflow: hidden;
    border-radius: 8px;
    background: transparent;
  }

  .home-slider__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;   /* keep aspect — no crop, no stretch */
