---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

const allProjects = await getCollection('projects');
const featured = allProjects.filter(p => p.data.featured).sort((a, b) =>
  (a.data.numbr ?? 999) - (b.data.numbr ?? 999)
);
const recent = allProjects
  .sort((a, b) => parseInt(b.data.year ?? '0') - parseInt(a.data.year ?? '0'))
  .slice(0, 6);
---

<PageLayout title="Home" label="Index" crumbs={[{ label: 'Home' }]}>
  <section class="home-hero">
    <h1 class="home-title">Advaita<br/>Kelkar</h1>
    <p class="home-sub">Architect · Designer · Researcher</p>
    <p class="home-tagline text-muted">
      Working across interior, architecture, product, and visual practice —
      from Mumbai to Savannah.
    </p>
    <div class="home-cta">
      <a href="/projects" class="btn">View Projects</a>
      <a href="/about" class="btn btn--ghost">About</a>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="home-section">
      <h2 class="section-label">Featured</h2>
      <div class="project-grid">
        {featured.map(p => (
          <a href={`/projects/${p.id}`} class="project-card">
            {p.data.coverImage && (
              <div class="project-card__img">
                <img src={p.data.coverImage} alt={p.data.name} loading="lazy" />
              </div>
            )}
            <div class="project-card__body">
              <span class="project-card__name">{p.data.name}</span>
              {p.data.smallIntro && <span class="project-card__intro text-muted">{p.data.smallIntro}</span>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="home-section">
    <h2 class="section-label">Recent Work</h2>
    <div class="project-list">
      {recent.map(p => (
        <a href={`/projects/${p.id}`} class="project-row">
          <span class="project-row__name">{p.data.name}</span>
          <span class="project-row__meta text-muted">{p.data.year} · {p.data.location}</span>
        </a>
      ))}
    </div>
    <a href="/projects" class="see-all text-muted">All Projects →</a>
  </section>
</PageLayout>

<style>
  .home-hero {
    padding-block: var(--_tokens---space--big) var(--_tokens---space--medium);
    max-width: var(--_tokens---layout--measure);
  }

  .home-title {
    font-size: var(--_tokens---type--big);
    font-weight: 600;
    line-height: 1.05;
    color: var(--_tokens---color--fg);
    margin-bottom: var(--_tokens---space--micro);
  }

  .home-sub {
    font-size: var(--_tokens---type--small);
    color: var(--_tokens---color--muted);
    margin-bottom: var(--_tokens---space--small);
  }

  .home-tagline {
    font-size: var(--_tokens---type--small);
    max-width: 40ch;
    line-height: 1.5;
    margin-bottom: var(--_tokens---space--small);
  }

  .home-cta {
    display: flex;
    gap: var(--_tokens---space--micro);
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.6em 1.2em;
    border: 1px solid var(--_tokens---color--fg);
    border-radius: var(--_tokens---radius--small);
    color: var(--_tokens---color--bg);
    background-color: var(--_tokens---color--fg);
    font-size: var(--_tokens---type--micro);
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .btn:hover {
    background-color: transparent;
    color: var(--_tokens---color--fg);
  }

  .btn--ghost {
    background-color: transparent;
    color: var(--_tokens---color--fg);
  }

  .btn--ghost:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  .home-section {
    padding-block: var(--_tokens---space--medium);
    border-top: 1px solid var(--_tokens---color--line);
  }

  .section-label {
    font-size: var(--_tokens---type--micro);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--_tokens---color--muted);
    margin-bottom: var(--_tokens---space--small);
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--_tokens---space--small);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    border: 1px solid var(--_tokens---color--line);
    border-radius: var(--_tokens---radius--medium);
    overflow: hidden;
    transition: opacity 0.2s ease;
  }

  .project-card:hover {
    opacity: 0.8;
  }

  .project-card__img {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background-color: var(--_tokens---color--muted);
  }

  .project-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-card__body {
    padding: var(--_tokens---space--micro);
    display: flex;
    flex-direction: column;
    gap: 0.25em;
  }

  .project-card__name {
    font-size: var(--_tokens---type--small);
    color: var(--_tokens---color--fg);
  }

  .project-card__intro {
    font-size: var(--_tokens---type--micro);
  }

  .project-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .project-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-block: var(--_tokens---space--micro);
    border-bottom: 1px solid var(--_tokens---color--line);
    text-decoration: none;
    color: var(--_tokens---color--fg);
    transition: opacity 0.2s ease;
  }

  .project-row:hover {
    opacity: 0.7;
  }

  .project-row__name {
    font-size: var(--_tokens---type--small);
  }

  .project-row__meta {
    font-size: var(--_tokens---type--micro);
  }

  .see-all {
    display: inline-block;
    margin-top: var(--_tokens---space--small);
    font-size: var(--_tokens---type--micro);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .see-all:hover {
    color: var(--_tokens---color--fg);
  }
</style>
