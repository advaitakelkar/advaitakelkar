  }


  /* Caption spans the slide = the content width, so the name sits at the same
     left margin as About and the arrow at the same right margin. */
  .home-slider__caption {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    /* top, right, bottom, left — extra right+bottom room so the arrow's ring
       never gets clipped; left stays 0 so the name keeps the About margin */
    padding: clamp(8px, 1.4vw, 22px) clamp(22px, 2.6vw, 40px) clamp(22px, 2.6vw, 40px) 0;
    color: var(--_tokens---color--fg);
