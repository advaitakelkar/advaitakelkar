---
import { getCollection, getEntry } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import Footer from '../components/Footer.astro';
import { realText, publicFileExists } from '../lib/content';

// PDF links only render once the files actually exist in public/
const hasPortfolio = publicFileExists('/advaita-kelkar-portfolio.pdf');
const hasCv = publicFileExists('/advaita-kelkar-resume.pdf');

// ── Data ──────────────────────────────────────────────────────
const allProjects = await getCollection('projects');

// Editable home copy (inline edit mode writes src/content/pages/home.yaml).
const home = await getEntry('pages', 'home');
const homeTagline = home?.data.tagline ?? 'Architectural Designer';
const homeIntro = home?.data.intro ?? [];

// Featured slider (featured:true, sorted by numbr)
const featured = allProjects
  .filter(p => p.data.featured && p.data.coverImage)
  .sort((a, b) => (a.data.numbr ?? 999) - (b.data.numbr ?? 999));

// Resolve a category relationship → its display name
const categories = await getCollection('categories');
const catName = (id) => categories.find(c => c.id === id)?.data.displayName ?? id;

// Tag relationships → names
const allTags = await getCollection('tags');
const tagMap = Object.fromEntries(allTags.map(t => [t.id, t.data.name]));

// Studio tags get a pill in the bottom-left; everything else is a normal tag
const STUDIO = { 'studio-823': 'Studio 823', 'faizan-khatri': 'FKD Workshop' };

function getWords(name: string): string[] {
  return name.trim().split(/\s+/).filter(Boolean);
}
---

<PageLayout
  title="Home"
  crumbs={[{ label: 'Home' }]}
  showFooter={false}
>

  <!-- ══ Section 1: Hero (About Me intro + Featured slider) ════════ -->
  <section class="home-section home-section--hero" id="home-hero-section">
    <div class="home-intro home-intro--animated">
      <div class="home-intro__header">
        <h1 class="home-intro__label" id="tagline-main" data-scramble data-edit="pages/home/tagline">{homeTagline}</h1>
      </div>

      <!-- Small About Me — flexible, responsive 3-column structure.
           Mobile: both bio columns start hidden; the "Bio" pill in the
           contact column reveals them. Desktop: all three always visible. -->
      <div class="home-intro__body" id="home-intro-body">
        <div class="home-intro__column home-intro__column--bio">
          <p class="home-intro__desc" data-edit="pages/home/intro.0">
            {homeIntro[0] ?? 'Hey, I’m Adi — Advaita Kelkar — an architectural designer from Mumbai, currently at SCAD in Savannah, USA. I work across architecture, interiors, urban design and everything in between — computation, sculpture, graphic design, product. Not isolated projects, but interconnected expressions of one way of seeing the world. Always curious, always making. Glad you’re here!'}
          </p>
        </div>
        <div class="home-intro__column home-intro__column--bio">
          <p class="home-intro__desc" data-edit="pages/home/intro.1">
            {homeIntro[1] ?? 'I’m an architect at heart — I think in systems, in how many parts come together to form a coherent whole. Every discipline I work across — designing, ideating, prototyping, making, documenting — is just a different medium for the same architectural way of thinking. Like my work, this archive doesn’t compartmentalise: it invites fluid navigation, tracing the threads of form, material and concept as they recur and evolve from one project to the next.'}
          </p>
        </div>
        <div class="home-intro__column">
          <button class="intro-bio-btn" id="intro-bio-btn" type="button" aria-expanded="false">
            <span>Bio</span>
            <svg class="link-arrow intro-bio-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
              <line x1="6" y1="18" x2="18" y2="6"></line>
              <polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </button>
          <p class="home-intro__desc">
            This is the living archive of my design work — an ecosystem bringing together everything I design, draw, research and make.
          </p>
          <p class="home-intro__desc home-intro__desc--follow">
            Reach me at <span class="intro-email-row"><a href="mailto:advaitakelkar@gmail.com" class="intro-inline-link">advaitakelkar@gmail.com</a><button class="intro-copy-email" id="intro-copy-email" title="Copy email" aria-label="Copy email address"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="intro-copy-icon"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="intro-check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg></button></span>
          </p>
          <p class="home-intro__desc home-intro__desc--follow">
            <a href="https://linkedin.com/in/advaitakelkar" target="_blank" rel="noopener" class="intro-inline-link">LinkedIn<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>, <a href="https://instagram.com/advaitakelkar" target="_blank" rel="noopener" class="intro-inline-link">Instagram<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>, <a href="https://github.com/advaitakelkar" target="_blank" rel="noopener" class="intro-inline-link">GitHub<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>, <a href="https://instagram.com/3xpmnts" target="_blank" rel="noopener" class="intro-inline-link">3xpmnts<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>, <a href="https://instagram.com/archv.in" target="_blank" rel="noopener" class="intro-inline-link">ARCHV<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>.
          </p>
          {(hasCv || hasPortfolio) && (
            <p class="home-intro__desc home-intro__desc--follow">
              Download my {hasCv && <a href="/advaita-kelkar-resume.pdf" target="_blank" rel="noopener" class="intro-inline-link">Resume<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>}{hasCv && hasPortfolio && ' or '}{hasPortfolio && <a href="/advaita-kelkar-portfolio.pdf" target="_blank" rel="noopener" class="intro-inline-link">Portfolio<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>}.
            </p>
          )}
        </div>
      </div>
    </div>

    <!-- Featured Slider -->
    {featured.length > 0 && (
      <div class="home-slider" aria-label="Featured projects">
        <div class="home-slider__track" id="slider-track">
          {featured.map((p, i) => {
            const tagIds = (p.data.tags ?? []).map((t) => t.id);
            const studio = tagIds.find((id) => STUDIO[id]);
            const otherTags = tagIds.filter((id) => !STUDIO[id]);
            return (
              <a
                href={`/projects/${p.id}`}
                class="home-slider__slide"
                data-index={i}
                aria-label={p.data.name}
              >
                {/* Mobile: project name above the photo */}
                <div class="home-slider__mobile-head" aria-hidden="true">
                  <span class="home-slider__name-mobile">{p.data.name}</span>
                </div>
                {/* image + captions scoped together so captions position relative to this area */}
                <div class="home-slider__image-area">
                  <div class="home-slider__image-wrap">
                    <img src={p.data.coverImage} alt={p.data.name} loading={i === 0 ? 'eager' : 'lazy'} />
                  </div>
                  {/* Mobile: arrow + timer ring floats over the photo's top-right corner */}
                  <span class="home-slider__arrow-mobile" aria-hidden="true">
                    <svg class="home-slider__ring" viewBox="0 0 100 100" aria-hidden="true">
                      <circle class="home-slider__ring-track" cx="50" cy="50" r="46"></circle>
                      <circle class="home-slider__ring-fill" cx="50" cy="50" r="46"></circle>
                    </svg>
                    <svg class="home-slider__name-arrow link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
                      <line x1="6" y1="18" x2="18" y2="6"></line>
                      <polyline points="10 6 18 6 18 14"></polyline>
                    </svg>
                  </span>
                  {[false, true].map((ko) => (
                    <div class:list={["home-slider__caption", ko && "home-slider__caption--knockout"]} aria-hidden={ko ? 'true' : undefined}>
                      <div class="home-slider__top">
                        <div class="home-slider__head">
                          {(() => {
                            const words = getWords(p.data.name);
                            return (
                              <span class="home-slider__name">
                                {words.map((w, idx) => (
                                  <span class={`home-slider__name-line home-slider__name-line--${idx}`}>
                                    {idx > 0 && <span class="desktop-space"> </span>}
                                    {w}
                                  </span>
                                ))}
                              </span>
                            );
                          })()}
                          <ul class="home-slider__facts">
                            {p.data.year && <li><span class="home-slider__fact-k">Year</span> — <span class="home-slider__fact-v">{p.data.year}</span></li>}
                            {p.data.location && <li><span class="home-slider__fact-k">Location</span> — <span class="home-slider__fact-v">{p.data.location}</span></li>}
                            {p.data.category && <li><span class="home-slider__fact-k">Category</span> — <span class="home-slider__fact-v">{catName(p.data.category.id)}</span></li>}
                            {otherTags.map((id) => <li><span class="home-slider__fact-k">Tag</span> — <span class="home-slider__fact-v home-slider__fact-v--tag">{tagMap[id] || id}</span></li>)}
                          </ul>
                        </div>
                        <div class="home-slider__about">
                          {realText(p.data.smallIntro) && <p class="home-slider__intro">{p.data.smallIntro}</p>}
                          {realText(p.data.description) && <div class="home-slider__desc" set:html={p.data.description} />}
                        </div>
                      </div>
                      <div class="home-slider__bottom">
                        {studio && <span class="home-slider__studio">{STUDIO[studio]}</span>}
                        <span class="home-slider__arrow" aria-hidden="true">
                          <svg class="home-slider__ring" viewBox="0 0 100 100" aria-hidden="true">
                            <circle class="home-slider__ring-track" cx="50" cy="50" r="46"></circle>
                            <circle class="home-slider__ring-fill" cx="50" cy="50" r="46"></circle>
                          </svg>
                          <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                            <line x1="6" y1="18" x2="18" y2="6"></line>
                            <polyline points="10 6 18 6 18 14"></polyline>
                          </svg>
                        </span>
                      </div>
                    </div>
                  ))}
                </div>
                {/* Mobile: one row under the photo —
                    left: year, location, tag (values only)
                    right: Category — <name>, tappable, opens the category page */}
                <div class="home-slider__mobile-bottom" aria-hidden="true">
                  <span class="home-slider__mobile-facts">
                    {[p.data.year, p.data.location, ...otherTags.map((id) => tagMap[id] || id)].filter(Boolean).join(', ')}
                  </span>
                  {p.data.category && (
                    <span class="home-slider__mobile-cat"><span class="home-slider__fact-k">Category — </span><span class="home-slider__cat-link" data-href={`/${p.data.category.id}`}>{catName(p.data.category.id)}</span></span>
                  )}
                </div>
              </a>
            );
          })}
        </div>
        {/* Pagination dots — at the very bottom, below image and all text */}
        <div class="home-slider__dots" role="tablist" aria-label="Slide navigation">
          {featured.map((_, i) => (
            <button
              class={`home-slider__dot${i === 0 ? ' is-active' : ''}`}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-label={`Slide ${i + 1}`}
              data-dot={i}
            />
          ))}
        </div>
      </div>
    )}
  </section>

  <!-- ══ Section 2: Page Navigation (top) + Quick Search (below) ═══ -->
  <section class="home-section home-section--search" id="home-search-section" aria-label="Page navigation and project quick search">
    <!-- Page Navigation: links to About Me, Portfolio and Projects -->
    <nav class="home-nav" aria-label="Primary pages">
      <a href="/about" class="home-nav-row">
        <span class="home-nav-row__text" data-scramble>About</span>
        <span class="home-nav-row__arrow" aria-hidden="true">
          <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <line x1="6" y1="18" x2="18" y2="6"></line>
            <polyline points="10 6 18 6 18 14"></polyline>
          </svg>
        </span>
      </a>
      {hasPortfolio && (
        <a href="/advaita-kelkar-portfolio.pdf" class="home-nav-row" target="_blank" rel="noopener">
          <span class="home-nav-row__text" data-scramble>Portfolio</span>
          <span class="home-nav-row__arrow" aria-hidden="true">
            <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <line x1="6" y1="18" x2="18" y2="6"></line>
              <polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </span>
        </a>
      )}
      <a href="/projects" class="home-nav-row">
        <span class="home-nav-row__text" data-scramble>Projects</span>
        <span class="home-nav-row__arrow" aria-hidden="true">
          <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <line x1="6" y1="18" x2="18" y2="6"></line>
            <polyline points="10 6 18 6 18 14"></polyline>
          </svg>
        </span>
      </a>
    </nav>

    <!-- Quick Search footer element -->
    <Footer isEmbedded={true} />
  </section>

</PageLayout>

<!-- ══ DATA + JS ══════════════════════════════════════════════ -->
<script>
  import { shuffle } from '../lib/random';

  // ── Slider (seamless infinite loop) ─────────────────────────
  const track = document.getElementById('slider-track');
  const dots  = Array.from(document.querySelectorAll('.home-slider__dot'));

  // Scramble both name copies (base + colour-flip) in sync — on slide-in & hover
  const SCRAMBLE_CHARS = '!<>-_\\/[]{}=+*^?#$%&@012';
  function scrambleName(slide) {
    const els = slide.querySelectorAll('.home-slider__name, .home-slider__name-mobile');
    if (!els.length) return;
    const text = els[0].dataset.text || els[0].textContent || '';
    els.forEach(e => { e.dataset.text = text; });
    const settle = Array.from(text, () => 6 + Math.floor(Math.random() * 9));
    const maxF = settle.length ? Math.max(...settle) : 0;
    let frame = 0;
    clearInterval(slide._scr);
    slide._scr = setInterval(() => {
      let out = '';
      for (let i = 0; i < text.length; i++) {
        out += text[i] === ' ' ? ' '
          : (frame >= settle[i] ? text[i]
             : SCRAMBLE_CHARS[Math.floor(Math.random() * SCRAMBLE_CHARS.length)]);
      }
      els.forEach(e => { e.textContent = out; });
      if (frame++ >= maxF) { clearInterval(slide._scr); els.forEach(e => { e.textContent = text; }); }
    }, 35);
  }

  if (track) {
    const reals = Array.from(track.querySelectorAll('.home-slider__slide'));

    // Shuffle the slides so every visit opens on a different project order
    shuffle(reals).forEach(s => track.appendChild(s));
    // The originally-first slide had loading=eager; make the new first one load instantly too
    reals[0]?.querySelector('img')?.setAttribute('loading', 'eager');

    const n = reals.length;

    if (n > 1) {
      // Clone last→prepend and first→append so an image always peeks on both
      // sides and the strip reads as one continuous loop.
      const firstClone = reals[0].cloneNode(true);
      const lastClone  = reals[n - 1].cloneNode(true);
      [firstClone, lastClone].forEach(c => {
        c.classList.add('is-clone');
        c.setAttribute('aria-hidden', 'true');
        c.setAttribute('tabindex', '-1');
        c.removeAttribute('href');
      });
      track.insertBefore(lastClone, reals[0]); // clone of last, before the start
      track.appendChild(firstClone);           // clone of first, after the end

      // DOM order is now: [lastClone, real0..realN-1, firstClone]
      const realAt = i => track.querySelectorAll('.home-slider__slide')[i + 1];

      let current = 0;
      let timer;
      let jumping = false;

      // Scroll ONLY the track horizontally. scrollIntoView also scrolls the
      // page vertically, which yanked the viewport back to the slider on
      // every auto-advance while scrolling away (worst on mobile, no hover
      // to pause the timer) — the page felt stuck on the slider.
      const center = (el, smooth = true) => {
        const left = el.offsetLeft - (track.clientWidth - el.offsetWidth) / 2;
        track.scrollTo({ left, behavior: smooth ? 'smooth' : 'auto' });
      };

      function updateDots(i) {
        dots.forEach((d, k) => {
          d.classList.toggle('is-active', k === i);
          d.setAttribute('aria-selected', String(k === i));
        });
      }

      // Mark the centred slide active (reveals its text) + scramble its name
      let activeSlide = null;
      function activate(slide) {
        if (!slide || activeSlide === slide) return;
        if (activeSlide) activeSlide.classList.remove('is-active');
        activeSlide = slide;
        slide.classList.add('is-active');
        scrambleName(slide);
      }

      // Scramble the name when hovering any slide
      track.querySelectorAll('.home-slider__slide').forEach(s =>
        s.addEventListener('mouseenter', () => scrambleName(s)));

      function goTo(i, smooth = true) {
        current = (i + n) % n;
        center(realAt(current), smooth);
        updateDots(current);
        activate(realAt(current));
      }

      function advance() {
        if (current + 1 >= n) {
          // Slide forward onto the appended clone of slide 0, then snap the
          // scroll position back to the real slide 0 with no animation.
          jumping = true;
          center(firstClone, true);
          updateDots(0);
          current = 0;
          setTimeout(() => { center(realAt(0), false); activate(realAt(0)); jumping = false; }, 700);
        } else {
          goTo(current + 1, true);
        }
      }

      function restartRing() {
        if (!activeSlide) return;
        activeSlide.querySelectorAll('.home-slider__ring-fill').forEach(r => {
          r.style.animation = 'none';
          void r.offsetWidth;      // reflow → restart the fill from empty
          r.style.animation = '';
        });
      }
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      // The slider never rests: it always auto-advances so the page has
      // constant motion. Interactions only pause it for their own duration
      // (mid-swipe / mid-drag) and it resumes immediately after. Clicking
      // a slide navigates to the project. Only "reduce motion" disables it.
      function startAuto() {
        if (reduceMotion) return;
        clearInterval(timer);     // never stack a second timer
        restartRing();
        timer = setInterval(advance, 3000);
      }
      function stopAuto()  { clearInterval(timer); }

      // Start centered on the real first slide (last/next slides peek at edges).
      requestAnimationFrame(() => { center(realAt(0), false); activate(realAt(0)); });
      startAuto();

      dots.forEach((d, i) => d.addEventListener('click', () => {
        if (jumping) return;
        stopAuto(); goTo(i); startAuto();
      }));
      // Touch: hold the timer only while a finger is on the slider so an
      // in-progress swipe never gets yanked; it restarts on release.
      track.addEventListener('touchstart', stopAuto, { passive: true });
      track.addEventListener('touchend', startAuto, { passive: true });

      // Pause whenever the slider is mostly off-screen; resume when it's
      // back. No point animating a carousel nobody can see.
      new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting) startAuto(); else stopAuto();
      }, { threshold: 0.3 }).observe(track);

      // ── Manual swipe sync ────────────────────────────────────
      // Scroll-snap moves the strip without telling us, so hand-swiped
      // slides never got is-active — name and facts stayed hidden (only
      // the arrow showed). Watch the scroll; when it settles, activate
      // whichever slide is centred: name scrambles in, facts reveal,
      // dots update — identical to the auto-advance reveal.
      let settleTimer;
      // Category line in the mobile facts → its category page. The slide
      // itself is already an <a>, so a nested link is invalid HTML —
      // delegate the click and navigate manually (covers the clones too).
      track.addEventListener('click', (e) => {
        const cat = e.target.closest('.home-slider__cat-link');
        if (cat && cat.dataset.href) {
          e.preventDefault();
          e.stopPropagation();
          window.location.href = cat.dataset.href;
        }
      });

      track.addEventListener('scroll', () => {
        scheduleFit(); // update clip-path in real-time as user swipes/scrolls
        if (jumping) return;
        clearTimeout(settleTimer);
        settleTimer = setTimeout(() => {
          const slides = Array.from(track.querySelectorAll('.home-slider__slide'));
          const tc = track.getBoundingClientRect();
          const cx = tc.left + tc.width / 2;
          let bi = -1, bd = Infinity;
          slides.forEach((s, i) => {
            const r = s.getBoundingClientRect();
            const d = Math.abs(r.left + r.width / 2 - cx);
            if (d < bd) { bd = d; bi = i; }
          });
          if (bi === -1) return;
          const realIdx = (bi - 1 + n) % n; // DOM: [lastClone, real0..realN-1, firstClone]
          if (slides[bi].classList.contains('is-clone')) {
            // Swiped onto an edge clone — snap invisibly to its real twin
            jumping = true;
            current = realIdx;
            center(realAt(realIdx), false);
            updateDots(realIdx);
            activate(realAt(realIdx));
            setTimeout(() => { jumping = false; }, 60);
          } else if (realIdx !== current || activeSlide !== slides[bi]) {
            current = realIdx;
            updateDots(realIdx);
            activate(slides[bi]);
          }
          startAuto(); // swipe settled — the loop resumes from this slide
        }, 90);
      }, { passive: true });
    }
  }

  // ── Invert the name/arrow only where they overlap the photo ──
  // Clip the background-colour copy to the actual rendered image rect
  // (object-fit: contain leaves bars, so measure the real pixels).
  function fitKnockouts() {
    document.querySelectorAll('.home-slider__slide').forEach(slide => {
      const cap = slide.querySelector('.home-slider__caption--knockout');
      const wrap = slide.querySelector('.home-slider__image-wrap');
      const img = wrap && wrap.querySelector('img');
      if (!cap || !img || !img.naturalWidth) return;
      const wb = wrap.getBoundingClientRect();
      const cover = getComputedStyle(img).objectFit === 'cover';
      const s = cover
        ? Math.max(wb.width / img.naturalWidth, wb.height / img.naturalHeight)
        : Math.min(wb.width / img.naturalWidth, wb.height / img.naturalHeight);
      const pw = img.naturalWidth * s, ph = img.naturalHeight * s;
      const pLeft = wb.left + (wb.width - pw) / 2;
      const pTop  = wb.top + (wb.height - ph) / 2;
      const cb = cap.getBoundingClientRect();
      const top    = Math.max(0, pTop - cb.top);
      const left   = Math.max(0, pLeft - cb.left);
      const right  = Math.max(0, cb.right - (pLeft + pw));
      const bottom = Math.max(0, cb.bottom - (pTop + ph));
      cap.style.clipPath = `inset(${top}px ${right}px ${bottom}px ${left}px)`;
    });
  }
  function scheduleFit() { requestAnimationFrame(fitKnockouts); }
  window.addEventListener('load', scheduleFit);
  window.addEventListener('resize', scheduleFit);
  document.querySelectorAll('.home-slider__image-wrap img').forEach(img => {
    if (!img.complete) img.addEventListener('load', scheduleFit);
  });
  scheduleFit();

  // ── Scramble Tagline on load ───────────────────────────────
  function triggerTaglineScramble() {
    const tagline = document.getElementById('tagline-main');
    if (tagline) {
      setTimeout(() => {
        tagline.dispatchEvent(new Event('mouseover', { bubbles: true }));
      }, 150);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', triggerTaglineScramble);
  } else {
    triggerTaglineScramble();
  }
  document.addEventListener('astro:after-swap', triggerTaglineScramble);

  // ── Email Copy Button ──────────────────────────────────────
  function setupEmailCopy() {
    const btn = document.getElementById('intro-copy-email');
    if (!btn) return;
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText('advaitakelkar@gmail.com').then(() => {
        btn.classList.add('is-copied');
        setTimeout(() => btn.classList.remove('is-copied'), 2000);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupEmailCopy);
  } else {
    setupEmailCopy();
  }
  document.addEventListener('astro:after-swap', setupEmailCopy);

  // ── Bio pill (mobile): reveals the two hidden bio columns ──
  function setupIntroToggle() {
    const bioBtn = document.getElementById('intro-bio-btn');
    const body = document.getElementById('home-intro-body');
    bioBtn?.addEventListener('click', () => {
      if (!body) return;
      const expanded = body.classList.toggle('is-expanded');
      bioBtn.setAttribute('aria-expanded', String(expanded));
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupIntroToggle);
  } else {
    setupIntroToggle();
  }
  document.addEventListener('astro:after-swap', setupIntroToggle);

  // ── Scroll to Top on Home Tagline Header Tap ────────────────
  function setupHomeHeaderScroll() {
    const homeHeader = document.querySelector('.home-intro__header');
    homeHeader?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupHomeHeaderScroll);
  } else {
    setupHomeHeaderScroll();
  }
  document.addEventListener('astro:after-swap', setupHomeHeaderScroll);
</script>

<style>
  /* ══ Global Snapping Scope ══════════════════════════════════ */
  :global(html) {
