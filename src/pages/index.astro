    scrollbar-width: none;
    gap: 32px;
    flex: 1 1 auto; /* the photo absorbs the leftover hero height */
    min-height: 0;
    align-items: stretch; /* slides take the full track height */
    position: relative;
    padding-top: 4px;
  }

  .home-slider__track::-webkit-scrollbar { display: none; }

  /* Centring buffer hack using pseudo-elements */
  .home-slider__track::before,
