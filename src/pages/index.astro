---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import Footer from '../components/Footer.astro';

// ── Data ──────────────────────────────────────────────────────
const allProjects = await getCollection('projects');

// Featured slider (featured:true, sorted by numbr)
const featured = allProjects
  .filter(p => p.data.featured && p.data.coverImage)
  .sort((a, b) => (a.data.numbr ?? 999) - (b.data.numbr ?? 999));

// Resolve a category relationship → its display name
const categories = await getCollection('categories');
const catName = (id) => categories.find(c => c.id === id)?.data.displayName ?? id;

// Tag relationships → names
const allTags = await getCollection('tags');
const tagMap = Object.fromEntries(allTags.map(t => [t.id, t.data.name]));

// Studio tags get a pill in the bottom-left; everything else is a normal tag
const STUDIO = { 'studio-823': 'Studio 823', 'faizan-khatri': 'FKD Workshop' };
---

<PageLayout
  title="Home"
  crumbs={[{ label: 'Home' }]}
  showFooter={false}
>

  <!-- ══ Section 1: Hero (About Me intro + Featured slider) ════════ -->
  <section class="home-section home-section--hero" id="home-hero-section">
    <div class="home-intro home-intro--animated">
      <div class="home-intro__header">
        <h1 class="home-intro__label" id="tagline-main" data-scramble>Architectural Designer and Researcher</h1>
      </div>

      <!-- Small About Me — flexible, responsive 3-column structure -->
      <div class="home-intro__body">
        <div class="home-intro__column">
          <p class="home-intro__desc">
            Welcome. This is the living archive of my design practice — a unified ecosystem bringing together everything I build, draw, research, and make. Projects across architecture, interiors, computation, sculpture, graphic design, and product — not isolated endeavours, but interconnected expressions of one way of seeing the world.
          </p>
        </div>
        <div class="home-intro__column home-intro__column--collapsible">
          <div class="home-intro__collapsed-content" id="intro-collapsed-content">
            <p class="home-intro__desc">
              I’m an architect at heart. Every discipline I work across — building, image-making, code, object — is just a different medium for the same singular idea. This archive doesn’t compartmentalise. It invites fluid navigation, tracing the threads of form, material, and concept that recur and evolve from one project to the next.
            </p>
          </div>
          <button class="intro-read-more-btn" id="intro-read-more-btn" type="button">Read More</button>
        </div>
        <div class="home-intro__column">
          <p class="home-intro__desc">
            This site is an extension of me. Reach me at <span class="intro-email-row"><a href="mailto:advaitakelkar@gmail.com" class="intro-inline-link">advaitakelkar@gmail.com</a><button class="intro-copy-email" id="intro-copy-email" title="Copy email" aria-label="Copy email address"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="intro-copy-icon"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="intro-check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg></button></span> or on <a href="https://instagram.com/advaitakelkar" target="_blank" rel="noopener" class="intro-inline-link">Instagram<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>. View my <a href="https://linkedin.com/in/advaitakelkar" target="_blank" rel="noopener" class="intro-inline-link">LinkedIn<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>, download my <a href="/advaita-kelkar-portfolio.pdf" target="_blank" rel="noopener" class="intro-inline-link">Portfolio<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a> or <a href="/advaita-kelkar-cv.pdf" target="_blank" rel="noopener" class="intro-inline-link">CV<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>. Other work: <a href="https://github.com/advaitakelkar" target="_blank" rel="noopener" class="intro-inline-link">GitHub<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>, <a href="https://instagram.com/3xpmnts" target="_blank" rel="noopener" class="intro-inline-link">3xpmnts<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a> (computation), <a href="https://instagram.com/archv.in" target="_blank" rel="noopener" class="intro-inline-link">ARCHV<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>.
          </p>
        </div>
      </div>
    </div>

    <!-- Featured Slider -->
    {featured.length > 0 && (
      <div class="home-slider" aria-label="Featured projects">
        <div class="home-slider__dots" role="tablist" aria-label="Slide navigation">
          {featured.map((_, i) => (
            <button
              class={`home-slider__dot${i === 0 ? ' is-active' : ''}`}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-label={`Slide ${i + 1}`}
              data-dot={i}
            />
          ))}
        </div>
        <div class="home-slider__track" id="slider-track">
          {featured.map((p, i) => {
            const tagIds = (p.data.tags ?? []).map((t) => t.id);
            const studio = tagIds.find((id) => STUDIO[id]);
            const otherTags = tagIds.filter((id) => !STUDIO[id]);
            return (
              <a
                href={`/projects/${p.id}`}
                class="home-slider__slide"
                data-index={i}
                aria-label={p.data.name}
              >
                <div class="home-slider__image-wrap">
                  <img src={p.data.coverImage || '/images/admin/placeholder.webp'} alt={p.data.name} loading={i === 0 ? 'eager' : 'lazy'} />
                </div>
                {[false, true].map((ko) => (
                  <div class:list={["home-slider__caption", ko && "home-slider__caption--knockout"]} aria-hidden={ko ? 'true' : undefined}>
                    <div class="home-slider__top">
                      <div class="home-slider__head">
                        <span class="home-slider__name">{p.data.name}</span>
                        <div class="home-slider__meta-right">
                          <ul class="home-slider__facts">
                            {p.data.year && <li><span class="home-slider__fact-k">Year</span> — {p.data.year}</li>}
                            {p.data.location && <li><span class="home-slider__fact-k">Location</span> — {p.data.location}</li>}
                            {p.data.category && <li><span class="home-slider__fact-k">Category</span> — {catName(p.data.category.id)}</li>}
                          </ul>
                          {otherTags.length > 0 && (
                            <ul class="home-slider__tags">
                              {otherTags.map((id) => <li>{tagMap[id] || id}</li>)}
                            </ul>
                          )}
                        </div>
                      </div>
                      <div class="home-slider__about">
                        {p.data.smallIntro && <p class="home-slider__intro">{p.data.smallIntro}</p>}
                        {p.data.description && <div class="home-slider__desc" set:html={p.data.description} />}
                      </div>
                    </div>
                    <div class="home-slider__bottom">
                      {studio && <span class="home-slider__studio">{STUDIO[studio]}</span>}
                      <span class="home-slider__arrow" aria-hidden="true">
                        <svg class="home-slider__ring" viewBox="0 0 100 100" aria-hidden="true">
                          <circle class="home-slider__ring-track" cx="50" cy="50" r="46"></circle>
                          <circle class="home-slider__ring-fill" cx="50" cy="50" r="46"></circle>
                        </svg>
                        <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                          <line x1="6" y1="18" x2="18" y2="6"></line>
                          <polyline points="10 6 18 6 18 14"></polyline>
                        </svg>
                      </span>
                    </div>
                  </div>
                ))}
              </a>
            );
          })}
        </div>
      </div>
    )}
  </section>

  <!-- ══ Section 2: Page Navigation (top) + Quick Search (below) ═══ -->
  <section class="home-section home-section--search" id="home-search-section" aria-label="Page navigation and project quick search">
    <!-- Page Navigation: links to About Me, Portfolio and Projects -->
    <nav class="home-nav" aria-label="Primary pages">
      <a href="/about" class="home-nav-row">
        <span class="home-nav-row__text" data-scramble>About</span>
        <span class="home-nav-row__arrow" aria-hidden="true">
          <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <line x1="6" y1="18" x2="18" y2="6"></line>
            <polyline points="10 6 18 6 18 14"></polyline>
          </svg>
        </span>
      </a>
      <a href="/advaita-kelkar-portfolio.pdf" class="home-nav-row" target="_blank" rel="noopener">
        <span class="home-nav-row__text" data-scramble>Portfolio</span>
        <span class="home-nav-row__arrow" aria-hidden="true">
          <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <line x1="6" y1="18" x2="18" y2="6"></line>
            <polyline points="10 6 18 6 18 14"></polyline>
          </svg>
        </span>
      </a>
      <a href="/projects" class="home-nav-row">
        <span class="home-nav-row__text" data-scramble>Projects</span>
        <span class="home-nav-row__arrow" aria-hidden="true">
          <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <line x1="6" y1="18" x2="18" y2="6"></line>
            <polyline points="10 6 18 6 18 14"></polyline>
          </svg>
        </span>
      </a>
    </nav>

    <!-- Quick Search footer element -->
    <Footer isEmbedded={true} />
  </section>

</PageLayout>

<!-- ══ DATA + JS ══════════════════════════════════════════════ -->
<script>
  // ── Slider (seamless infinite loop) ─────────────────────────
  const track = document.getElementById('slider-track');
  const dots  = Array.from(document.querySelectorAll('.home-slider__dot'));

  // Scramble both name copies (base + colour-flip) in sync — on slide-in & hover
  const SCRAMBLE_CHARS = '!<>-_\\/[]{}=+*^?#$%&@012';
  function scrambleName(slide) {
    const els = slide.querySelectorAll('.home-slider__name');
    if (!els.length) return;
    const text = els[0].dataset.text || els[0].textContent || '';
    els.forEach(e => { e.dataset.text = text; });
    const settle = Array.from(text, () => 6 + Math.floor(Math.random() * 9));
    const maxF = settle.length ? Math.max(...settle) : 0;
    let frame = 0;
    clearInterval(slide._scr);
    slide._scr = setInterval(() => {
      let out = '';
      for (let i = 0; i < text.length; i++) {
        out += text[i] === ' ' ? ' '
          : (frame >= settle[i] ? text[i]
             : SCRAMBLE_CHARS[Math.floor(Math.random() * SCRAMBLE_CHARS.length)]);
      }
      els.forEach(e => { e.textContent = out; });
      if (frame++ >= maxF) { clearInterval(slide._scr); els.forEach(e => { e.textContent = text; }); }
    }, 35);
  }

  if (track) {
    const reals = Array.from(track.querySelectorAll('.home-slider__slide'));
    const n = reals.length;

    if (n > 1) {
      // Clone last→prepend and first→append so an image always peeks on both
      // sides and the strip reads as one continuous loop.
      const firstClone = reals[0].cloneNode(true);
      const lastClone  = reals[n - 1].cloneNode(true);
      [firstClone, lastClone].forEach(c => {
        c.classList.add('is-clone');
        c.setAttribute('aria-hidden', 'true');
        c.setAttribute('tabindex', '-1');
        c.removeAttribute('href');
      });
      track.insertBefore(lastClone, reals[0]); // clone of last, before the start
      track.appendChild(firstClone);           // clone of first, after the end

      // DOM order is now: [lastClone, real0..realN-1, firstClone]
      const realAt = i => track.querySelectorAll('.home-slider__slide')[i + 1];

      let current = 0;
      let timer;
      let jumping = false;

      const center = (el, smooth = true) =>
        el.scrollIntoView({ behavior: smooth ? 'smooth' : 'auto', block: 'nearest', inline: 'center' });

      function updateDots(i) {
        dots.forEach((d, k) => {
          d.classList.toggle('is-active', k === i);
          d.setAttribute('aria-selected', String(k === i));
        });
      }

      // Mark the centred slide active (reveals its text) + scramble its name
      let activeSlide = null;
      function activate(slide) {
        if (!slide || activeSlide === slide) return;
        if (activeSlide) activeSlide.classList.remove('is-active');
        activeSlide = slide;
        slide.classList.add('is-active');
        scrambleName(slide);
      }

      // Scramble the name when hovering any slide
      track.querySelectorAll('.home-slider__slide').forEach(s =>
        s.addEventListener('mouseenter', () => scrambleName(s)));

      function goTo(i, smooth = true) {
        current = (i + n) % n;
        center(realAt(current), smooth);
        updateDots(current);
        activate(realAt(current));
      }

      function advance() {
        if (current + 1 >= n) {
          // Slide forward onto the appended clone of slide 0, then snap the
          // scroll position back to the real slide 0 with no animation.
          jumping = true;
          center(firstClone, true);
          updateDots(0);
          current = 0;
          setTimeout(() => { center(realAt(0), false); activate(realAt(0)); jumping = false; }, 700);
        } else {
          goTo(current + 1, true);
        }
      }

      function restartRing() {
        if (!activeSlide) return;
        activeSlide.querySelectorAll('.home-slider__ring-fill').forEach(r => {
          r.style.animation = 'none';
          void r.offsetWidth;      // reflow → restart the fill from empty
          r.style.animation = '';
        });
      }
      function startAuto() { restartRing(); timer = setInterval(advance, 3000); }
      function stopAuto()  { clearInterval(timer); }

      // Start centered on the real first slide (last/next slides peek at edges).
      requestAnimationFrame(() => { center(realAt(0), false); activate(realAt(0)); });
      startAuto();

      dots.forEach((d, i) => d.addEventListener('click', () => {
        if (jumping) return;
        stopAuto(); goTo(i); startAuto();
      }));
      track.addEventListener('mouseenter', stopAuto);
      track.addEventListener('mouseleave', startAuto);
    }
  }

  // ── Invert the name/arrow only where they overlap the photo ──
  // Clip the background-colour copy to the actual rendered image rect
  // (object-fit: contain leaves bars, so measure the real pixels).
  function fitKnockouts() {
    document.querySelectorAll('.home-slider__slide').forEach(slide => {
      const cap = slide.querySelector('.home-slider__caption--knockout');
      const wrap = slide.querySelector('.home-slider__image-wrap');
      const img = wrap && wrap.querySelector('img');
      if (!cap || !img || !img.naturalWidth) return;
      const wb = wrap.getBoundingClientRect();
      const s = Math.min(wb.width / img.naturalWidth, wb.height / img.naturalHeight);
      const pw = img.naturalWidth * s, ph = img.naturalHeight * s;
      const pLeft = wb.left + (wb.width - pw) / 2;
      const pTop  = wb.top + (wb.height - ph) / 2;
      const cb = cap.getBoundingClientRect();
      const top    = Math.max(0, pTop - cb.top);
      const left   = Math.max(0, pLeft - cb.left);
      const right  = Math.max(0, cb.right - (pLeft + pw));
      const bottom = Math.max(0, cb.bottom - (pTop + ph));
      cap.style.clipPath = `inset(${top}px ${right}px ${bottom}px ${left}px)`;
    });
  }
  function scheduleFit() { requestAnimationFrame(fitKnockouts); }
  window.addEventListener('load', scheduleFit);
  window.addEventListener('resize', scheduleFit);
  document.querySelectorAll('.home-slider__image-wrap img').forEach(img => {
    if (!img.complete) img.addEventListener('load', scheduleFit);
  });
  scheduleFit();

  // ── Scramble Tagline on load ───────────────────────────────
  function triggerTaglineScramble() {
    const tagline = document.getElementById('tagline-main');
    if (tagline) {
      setTimeout(() => {
        tagline.dispatchEvent(new Event('mouseover', { bubbles: true }));
      }, 150);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', triggerTaglineScramble);
  } else {
    triggerTaglineScramble();
  }
  document.addEventListener('astro:after-swap', triggerTaglineScramble);

  // ── Email Copy Button ──────────────────────────────────────
  function setupEmailCopy() {
    const btn = document.getElementById('intro-copy-email');
    if (!btn) return;
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText('advaitakelkar@gmail.com').then(() => {
        btn.classList.add('is-copied');
        setTimeout(() => btn.classList.remove('is-copied'), 2000);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupEmailCopy);
  } else {
    setupEmailCopy();
  }
  document.addEventListener('astro:after-swap', setupEmailCopy);

  // ── Introduction Read More Toggle ──────────────────────────
  function setupIntroToggle() {
    const introReadMoreBtn = document.getElementById('intro-read-more-btn');
    const collapsibleCol = introReadMoreBtn?.closest('.home-intro__column--collapsible');
    introReadMoreBtn?.addEventListener('click', () => {
      if (collapsibleCol && introReadMoreBtn) {
        const isExpanded = collapsibleCol.classList.toggle('is-expanded');
        introReadMoreBtn.textContent = isExpanded ? 'Read Less' : 'Read More';
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupIntroToggle);
  } else {
    setupIntroToggle();
  }
  document.addEventListener('astro:after-swap', setupIntroToggle);
</script>

<style>
  /* ══ Global Snapping Scope ══════════════════════════════════ */
  :global(html) {
    scroll-snap-type: none !important;
    scroll-behavior: smooth;
  }

  /* ══ Snapped Layout Sections ════════════════════════════════ */
  .home-section {
    height: auto;
    min-height: 0; /* continuous scroll — no full-screen sections */
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    transition: padding 0.3s ease;
    overflow: visible;
  }

  .home-section--hero {
    justify-content: flex-start;
    gap: 20px;
    min-height: auto; /* fit content — no full-height gaps around the slider */
    padding-top: calc(clamp(2rem, 5vh, 3rem) + 48px); /* 48px for fixed breadcrumb */
    padding-bottom: clamp(2rem, 5vh, 3rem);
    overflow: hidden; /* clip slider to section */
  }

  .home-section--search {
    justify-content: flex-start;
    padding-top: clamp(1rem, 3vh, 2rem); /* small continuous gap after the slider */
    overflow-y: visible;
    position: relative;
  }

  /* ══ 1. Intro (small About Me — 3 flexible columns) ═════════ */
  .home-intro {
    display: flex;
    flex-direction: column;
    width: 100%;
    margin-bottom: 8px;
  }

  /* Entrance Animation for Tagline and Intro section */
  .home-intro--animated {
    opacity: 0;
    transform: translateY(-20px);
    animation: slideInFromTop 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes slideInFromTop {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .home-intro__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    width: 100%;
    margin-bottom: 8px;
  }

  .home-intro__label {
    font-size: var(--_tokens---type--small);
    font-weight: 600;
    letter-spacing: 0.01em;
    text-transform: none;
    color: var(--_tokens---color--fg);
    margin: 0;
  }

  .home-intro__body {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 32px;
    width: 100%;
  }

  .home-intro__column {
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(15px);
    animation: fadeUpIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .home-intro__column:nth-child(1) { animation-delay: 0.2s; }
  .home-intro__column:nth-child(2) { animation-delay: 0.4s; }
  .home-intro__column:nth-child(3) { animation-delay: 0.6s; }

  @keyframes fadeUpIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .home-intro__desc {
    font-size: var(--_tokens---type--micro);
    line-height: 1.55;
    color: var(--_tokens---color--muted);
    margin: 0;
  }

  /* Inline contact links that flow within the paragraph text */
  .intro-inline-link {
    color: var(--_tokens---color--fg);
    text-decoration: none;
    white-space: nowrap; /* keep label + arrow together */
    border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 30%, transparent);
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .intro-inline-link:hover {
    border-bottom-color: var(--_tokens---color--fg);
  }

  .intro-inline-link .intro-arrow {
    width: 0.78em;
    height: 0.78em;
    margin-left: 1px;
    vertical-align: -0.05em;
    transition: transform 0.25s ease;
  }

  .intro-inline-link:hover .intro-arrow {
    transform: translate(1px, -1px);
  }

  /* Inline email + copy button */
  .intro-email-row {
    display: inline-flex;
    align-items: baseline;
    gap: 3px;
    white-space: nowrap;
  }

  .intro-copy-email {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    padding: 0 2px;
    cursor: pointer;
    color: var(--_tokens---color--muted);
    transition: color 0.2s ease, transform 0.15s ease;
    vertical-align: middle;
    position: relative;
    top: -0.05em;
  }

  .intro-copy-email:hover {
    color: var(--_tokens---color--fg);
  }

  .intro-copy-icon,
  .intro-check-icon {
    width: 0.8em;
    height: 0.8em;
    display: block;
  }

  .intro-check-icon {
    display: none;
    color: var(--_tokens---color--fg);
  }

  .intro-copy-email.is-copied .intro-copy-icon { display: none; }
  .intro-copy-email.is-copied .intro-check-icon { display: block; }

  /* ══ 2. Slider ══════════════════════════════════════════════ */
  .home-slider {
    width: 100%;
    flex: 0 0 auto; /* size to content — don't stretch to fill the hero */
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    margin-top: 0;
  }

  .home-slider__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    gap: 32px;
    flex: 0 0 auto; /* size to the slide/image height */
    min-height: 0;
    align-items: center; /* Center slides vertically */
    position: relative;
    padding-top: 4px;
  }

  .home-slider__track::-webkit-scrollbar { display: none; }

  /* Centring buffer hack using pseudo-elements */
  .home-slider__track::before,
  .home-slider__track::after {
    content: '';
    flex: 0 0 0; /* full-width slides need no centring buffer */
  }

  .home-slider__slide {
    --img-w: 66%; /* image width as a share of the content; gutters hold name + arrow */
    position: relative; /* captions overlay the slide */
    flex: 0 0 100%; /* bound to the content width (same margins as About) */
    scroll-snap-align: center; /* snap to center! */
    scroll-snap-stop: always; /* a manual swipe always lands on a card */
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--_tokens---color--fg);
  }

  .home-slider__image-wrap {
    width: var(--img-w);   /* fixed width, centred in the full-width slide */
    align-self: center;    /* don't stretch — keep it centred */
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 8px;
    background: transparent;
    position: relative;
  }

  .home-slider__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;   /* keep aspect — no crop, no stretch */
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-slider__slide:hover img {
    transform: scale(1.02);
  }

  .home-slider__placeholder {
    width: 100%;
    height: 100%;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
  }

  /* Caption spans the slide = the content width, so the name sits at the same
     left margin as About and the arrow at the same right margin. */
  .home-slider__caption {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-block: clamp(8px, 1.4vw, 22px);
    color: var(--_tokens---color--fg);
    pointer-events: none;  /* clicks pass to the slide link */
  }

  .home-slider__name {
    align-self: flex-start; /* top-left, at the content margin */
    font-size: var(--_tokens---type--big); /* H1 — same as About */
    font-weight: 500;
    line-height: 0.95;
    letter-spacing: -0.02em;
    min-width: 0;           /* allow it to shrink/wrap beside the facts */
    overflow-wrap: anywhere;
  }

  /* name + supporting text grouped at the top, arrow stays at the bottom */
  .home-slider__top {
    align-self: stretch;
    display: flex;
    flex-direction: column;
    gap: clamp(8px, 1vw, 16px);
    min-width: 0;
  }

  .home-slider__about {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-width: min(440px, 52%); /* text stays a readable column, mostly in the gutter */
  }

  .home-slider__intro {
    font-size: var(--_tokens---type--small);
    font-weight: 500;
    line-height: 1.2;
  }

  .home-slider__desc {
    font-size: var(--_tokens---type--small);
    line-height: 1.35;
    opacity: 0.88;
    display: -webkit-box;
    -webkit-line-clamp: 3;   /* keep the card tidy */
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .home-slider__desc :global(p) { margin: 0; }

  /* name on the left, facts stacked at the top-right, aligned with the name */
  .home-slider__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: clamp(16px, 3vw, 48px);
  }

  .home-slider__facts {
    list-style: none;
    margin: 0;
    padding: 0;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    text-align: right;
    white-space: nowrap;
    font-size: var(--_tokens---type--small);
    line-height: 1.25;
  }

  .home-slider__fact-k { opacity: 0.6; } /* the label part, slightly muted */

  /* facts + tags stacked at the top-right */
  .home-slider__meta-right {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }

  .home-slider__tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end; /* tags on the right */
    gap: 6px;
    font-size: var(--_tokens---type--micro);
  }

  /* bottom row: studio pill (left) + arrow (right) */
  .home-slider__bottom {
    display: flex;
    align-items: flex-end;
    gap: 16px;
  }

  .home-slider__studio {
    align-self: flex-end;
    border: 1px solid currentColor;
    border-radius: 999px;
    padding: 5px 16px;
    font-size: var(--_tokens---type--micro);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .home-slider__tags li {
    border: 1px solid currentColor;
    border-radius: 999px;
    padding: 2px 10px;
    text-transform: lowercase;
    opacity: 0.8;
  }

  /* ── Reveal: supporting text animates in once the slide is centred ── */
  .home-slider__facts,
  .home-slider__intro,
  .home-slider__desc,
  .home-slider__tags,
  .home-slider__studio {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.55s ease, transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .home-slider__slide.is-active .home-slider__facts  { opacity: 1; transform: none; transition-delay: 0.10s; }
  .home-slider__slide.is-active .home-slider__intro  { opacity: 1; transform: none; transition-delay: 0.18s; }
  .home-slider__slide.is-active .home-slider__desc   { opacity: 1; transform: none; transition-delay: 0.26s; }
  .home-slider__slide.is-active .home-slider__tags   { opacity: 1; transform: none; transition-delay: 0.34s; }
  .home-slider__slide.is-active .home-slider__studio { opacity: 1; transform: none; transition-delay: 0.40s; }

  @media (prefers-reduced-motion: reduce) {
    .home-slider__facts, .home-slider__intro, .home-slider__desc,
    .home-slider__tags, .home-slider__studio {
      opacity: 1; transform: none; transition: none;
    }
  }

  /* Background-colour copy, layered on top and clipped (in JS) to exactly the
     rendered photo — so the part of the name/arrow over the image inverts. */
  .home-slider__caption--knockout {
    color: var(--_tokens---color--bg);
    pointer-events: none;
    clip-path: inset(0 100% 0 0); /* hidden until JS measures the photo */
    /* fatten the inverted copy so it fully covers the base text's anti-aliased
       rim — a clean solid invert with no foreground outline */
    -webkit-text-stroke: 0.7px var(--_tokens---color--bg);
    text-stroke: 0.7px var(--_tokens---color--bg);
  }

  .home-slider__caption--knockout .link-arrow {
    stroke-width: 3.4; /* match the text: cover the base arrow's rim too */
  }

  .home-slider__arrow {
    align-self: flex-end; /* bottom of the row */
    margin-left: auto;    /* always pinned to the right */
    position: relative;   /* the countdown ring centres on the arrow */
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: var(--_tokens---type--small); /* small arrow */
    transition: transform 0.3s ease;
  }

  /* Countdown ring around the arrow — fills over the auto-advance time (3s).
     Sized off --type--big (not the now-small arrow) so it keeps its size. */
  .home-slider__ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: calc(var(--_tokens---type--big) * 1.1);
    height: calc(var(--_tokens---type--big) * 1.1);
    transform: translate(-50%, -50%) rotate(-90deg); /* start the fill at 12 o'clock */
    overflow: visible;
    pointer-events: none;
  }
  .home-slider__ring circle { fill: none; stroke-width: 3; } /* thinner */
  .home-slider__ring-track { stroke: currentColor; opacity: 0.22; }
  .home-slider__ring-fill {
    stroke: currentColor;
    stroke-linecap: round;
    stroke-dasharray: 289.03;   /* 2·π·46 */
    stroke-dashoffset: 289.03;  /* empty */
  }
  .home-slider__slide.is-active .home-slider__ring-fill {
    animation: home-ring 3s linear forwards;
  }
  @keyframes home-ring {
    from { stroke-dashoffset: 289.03; }
    to   { stroke-dashoffset: 0; }
  }
  /* pause the ring while hovering (auto-advance is paused too) */
  .home-slider__track:hover .home-slider__slide.is-active .home-slider__ring-fill {
    animation-play-state: paused;
  }

  .home-slider__arrow .link-arrow {
    width: 1.1em;
    height: 1.1em;
  }

  .home-slider__slide:hover .home-slider__arrow {
    transform: translate(2px, -2px);
  }

  .link-arrow {
    width: 1em;
    height: 1em;
    vertical-align: middle;
    display: inline-block;
  }

  .home-slider__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 0 0 6px; /* Reduced from 16px */
  }

  /* Read More button styling */
  .intro-read-more-btn {
    display: none; /* Hidden on desktop */
    align-self: flex-start;
    font-family: inherit;
    font-size: var(--_tokens---type--micro);
    font-weight: 500;
    color: var(--_tokens---color--fg);
    background: none;
    border: none;
    padding: 0;
    margin-top: 8px;
    cursor: pointer;
    text-decoration: underline;
    opacity: 0.8;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .intro-read-more-btn:hover {
    opacity: 1;
    transform: translateX(2px);
  }

  .home-slider__dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    border: none;
    background-color: var(--_tokens---color--muted);
    cursor: pointer;
    padding: 0;
    transition: background-color 0.2s, transform 0.2s;
  }

  .home-slider__dot.is-active {
    background-color: var(--_tokens---color--fg);
    transform: scale(1.3);
  }



  /* ══ 4. Page Navigation (links above search) ════════════════ */
  .home-nav {
    display: flex;
    flex-direction: column;
    width: 100%;
    margin-bottom: 0px;
  }

  .home-section--search :global(.home-search-footer--embedded) {
    margin-top: 12px !important;
  }

  .home-nav-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-decoration: none;
    color: var(--_tokens---color--fg);
    border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    padding-block: 22px;
    transition: opacity 0.2s ease, padding-left 0.2s ease;
  }

  .home-nav-row:last-child {
    border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
  }

  .home-nav-row:hover {
    opacity: 0.75;
    padding-left: 8px;
  }

  .home-nav-row__text {
    font-size: var(--_tokens---type--big);
    font-weight: 500;
    line-height: 0.95;
    letter-spacing: -0.03em;
  }

  .home-nav-row__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    color: var(--_tokens---color--muted);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), color 0.3s ease;
  }

  .home-nav-row__arrow svg {
    width: 100%;
    height: 100%;
  }

  .home-nav-row:hover .home-nav-row__arrow {
    transform: rotate(45deg);
    color: var(--_tokens---color--fg);
  }



  /* ══ Responsive ═════════════════════════════════════════════ */
  @media (max-width: 1199px) {
    .home-intro__body {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 24px;
    }
    .home-slider__slide {
      flex: 0 0 100%;
      --img-w: 66%;
    }
    .home-slider__track::before,
    .home-slider__track::after {
      flex: 0 0 0;
    }
  }

  @media (max-width: 768px) {
    .home-section {
      height: auto;
      min-height: 0;
      overflow: visible;
      padding-block: 24px;
    }
    .home-section--search {
      overflow-y: visible;
    }
    .home-intro__body {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .intro-read-more-btn {
      display: inline-block; /* Show on mobile */
    }
    .home-intro__collapsed-content {
      display: none; /* Collapsed on mobile by default */
    }
    .home-intro__column--collapsible.is-expanded .home-intro__collapsed-content {
      display: block; /* Expanded when class is active */
    }
    .home-slider__slide {
      flex: 0 0 100%;
      --img-w: 76%;
    }
    .home-slider__track::before,
    .home-slider__track::after {
      flex: 0 0 0;
    }
  }

  @media (max-width: 600px) {
    .home-slider__slide {
      flex: 0 0 100%;
      --img-w: 84%;
    }
    .home-slider__track::before,
    .home-slider__track::after {
      flex: 0 0 0;
    }
  }

  /* Mobile Portrait Layout Adjustments for bottom breadcrumbs */
  @media (max-width: 767px) and (orientation: portrait) {
    :global(.page-main) {
      padding-bottom: 80px !important;
    }

    :global(.page-breadcrumb) {
      top: auto !important;
      bottom: 0 !important;
      background-color: var(--_tokens---color--bg) !important;
    }

    .home-section {
      padding-bottom: 80px !important;
    }
  }
</style>

<!-- Global keyframes for the runtime-injected search capsules -->
<style is:global>
  @keyframes capsuleIn {
    from { opacity: 0; transform: translateY(4px) scale(0.96); }
    to   { opacity: 1; transform: none; }
  }
</style>
