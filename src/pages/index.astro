---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

// ── Data ──────────────────────────────────────────────────────
const allProjects = await getCollection('projects');
const allTags     = await getCollection('tags');
const allCats     = await getCollection('categories');

// Lookup maps
const tagMap = Object.fromEntries(allTags.map(t => [t.id, t.data.name]));
const catMap = Object.fromEntries(allCats.map(c => [c.id, c.data.displayName]));

// Featured slider (featured:true, sorted by numbr)
const featured = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => (a.data.numbr ?? 999) - (b.data.numbr ?? 999));

// All projects for quick search — sorted by year desc
const sorted = [...allProjects].sort(
  (a, b) => parseInt(b.data.year ?? '0') - parseInt(a.data.year ?? '0')
);

// Serialise to JSON for client-side search
const projectsJson = JSON.stringify(
  sorted.map(p => ({
    id:   p.id,
    name: p.data.name,
    year: p.data.year ?? '',
    tag:  p.data.tags?.[0] ? (tagMap[p.data.tags[0].id] ?? p.data.tags[0].id) : '',
    cat:  p.data.category  ? (catMap[p.data.category.id] ?? p.data.category.id) : '',
  }))
);
---

<PageLayout
  title="Home"
>

  <!-- Section 1: Hero (Intro + Slider) -->
  <section class="home-section home-section--hero">
    <div class="home-intro">
      <p class="home-intro__label">Multidisciplinary Designer · Mumbai</p>
      
      <div class="home-intro__summary">
        <p class="home-intro__desc">
          This digital platform serves as the comprehensive, living archive of Advaita Kelkar’s multidisciplinary design practice. It is designed to function as a singular, unified ecosystem that seamlessly integrates a diverse and expansive body of work. Here, projects spanning across architecture, interior environments, physical sculpture, graphic design, product innovation, and fine art are not treated as isolated endeavors, but rather as interconnected expressions of a singular creative vision.
        </p>
        <button id="intro-read-more" class="intro-read-more-btn" aria-expanded="false" aria-controls="intro-expanded-content">
          <span>Read More</span>
          <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <line x1="6" y1="18" x2="18" y2="6"></line>
            <polyline points="10 6 18 6 18 14"></polyline>
          </svg>
        </button>
      </div>

      <div id="intro-expanded-content" class="home-intro__expanded">
        <div class="home-intro__left">
          <p class="home-intro__desc">
            Rather than compartmentalizing these various creative fields into rigid categories, this archive encourages fluid exploration. It invites visitors to navigate freely across different disciplines, uncovering the subtle threads and underlying dialogues that connect them. Through this unstructured journey, one can trace how foundational principles of form, tactile material choices, and core conceptual intentions recur, evolve, and echo from one project to the next, revealing a cohesive artistic philosophy.
          </p>
        </div>
        <div class="home-intro__right">
          <p class="home-intro__desc">
            Within these pages, you will find a curated blend of academic investigations, professional commissions, freelance collaborations, and purely experimental passion projects showcased side by side. This juxtaposition highlights the value of every stage of design thinking. Moreover, the archive goes beyond just displaying the final, polished outcomes; it provides a deep dive into the extensive research, iterative sketching, and rigorous process documentation that informs and shapes every individual piece.
          </p>
          <p class="home-intro__desc">
            Visitors are invited to immerse themselves in this body of work in whatever way suits their curiosity. You can begin by browsing through a curated selection of featured highlights, delve deeper by utilizing the search function to explore the full, comprehensive archive, or read more about the underlying philosophy, history, and methodology that define the practice itself.
          </p>
        </div>
      </div>
    </div>

    <!-- Featured Slider -->
    {featured.length > 0 && (
      <div class="home-slider" aria-label="Featured projects">
        <div class="home-slider__track" id="slider-track">
          {featured.map((p, i) => (
            <a
              href={`/projects/${p.id}`}
              class="home-slider__slide"
              data-index={i}
              aria-label={p.data.name}
            >
              {p.data.coverImage
                ? <img src={p.data.coverImage} alt={p.data.name} loading={i === 0 ? 'eager' : 'lazy'} />
                : <div class="home-slider__placeholder" aria-hidden="true" />
              }
              <div class="home-slider__caption">
                <span class="home-slider__name">{p.data.name}</span>
                <span class="home-slider__arrow" aria-hidden="true">
                  <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                    <line x1="6" y1="18" x2="18" y2="6"></line>
                    <polyline points="10 6 18 6 18 14"></polyline>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
        <div class="home-slider__dots" role="tablist" aria-label="Slide navigation">
          {featured.map((_, i) => (
            <button
              class={`home-slider__dot${i === 0 ? ' is-active' : ''}`}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-label={`Slide ${i + 1}`}
              data-dot={i}
            />
          ))}
        </div>
      </div>
    )}
  </section>

  <!-- Section 2: Teasers (About Me + Portfolio) -->
  <section class="home-section home-section--teasers">
    <div class="home-teasers-container">
      <div class="home-teaser">
        <p class="home-teaser__caption">
          Get to know the designer behind the work — my background, training,
          and the thinking that shapes each project.
        </p>
        <a href="/about" class="home-teaser__link">
          <span>About Me</span>
          <span class="home-teaser__arrow-wrap" aria-hidden="true">
            <svg class="status-circle" viewBox="0 0 44 44">
              <circle class="status-circle__bg" cx="22" cy="22" r="19" fill="none" stroke="currentColor" stroke-width="1.5"></circle>
              <circle class="status-circle__progress" cx="22" cy="22" r="19" fill="none" stroke="currentColor" stroke-width="1.5"></circle>
            </svg>
            <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <line x1="6" y1="18" x2="18" y2="6"></line>
              <polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </span>
        </a>
      </div>

      <div class="home-teaser">
        <p class="home-teaser__caption">
          A curated selection of built, drawn, and made work, gathered together in one place.
        </p>
        <a href="/projects" class="home-teaser__link">
          <span>Portfolio</span>
          <span class="home-teaser__arrow-wrap" aria-hidden="true">
            <svg class="status-circle" viewBox="0 0 44 44">
              <circle class="status-circle__bg" cx="22" cy="22" r="19" fill="none" stroke="currentColor" stroke-width="1.5"></circle>
              <circle class="status-circle__progress" cx="22" cy="22" r="19" fill="none" stroke="currentColor" stroke-width="1.5"></circle>
            </svg>
            <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <line x1="6" y1="18" x2="18" y2="6"></line>
              <polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Section 3: Quick Search -->
  <section class="home-section home-section--search" aria-label="Project quick search">
    <div class="home-search__header">
      <h2 class="home-search__title">Projects Quick Search</h2>
    </div>
    <div class="home-search__bar">
      <input
        type="search"
        id="qs-input"
        class="home-search__input"
        placeholder="Search"
        autocomplete="off"
        aria-label="Search projects"
      />
      <button class="home-search__clear" id="qs-clear" type="button">@Clear All</button>
    </div>
    <p class="home-search__count" id="qs-count" aria-live="polite"></p>
    <div class="home-search__grid" id="qs-grid" role="list"></div>
  </section>

</PageLayout>

<!-- ══ DATA + JS ══════════════════════════════════════════════ -->
<script define:vars={{ projectsJson }}>
  // ── Quick Search ────────────────────────────────────────────
  const projects = JSON.parse(projectsJson);
  const grid     = document.getElementById('qs-grid');
  const input    = document.getElementById('qs-input');
  const clearBtn = document.getElementById('qs-clear');
  const count    = document.getElementById('qs-count');

  function buildRow(p) {
    const el = document.createElement('a');
    el.href      = `/projects/${p.id}`;
    el.className = 'qs-row';
    el.setAttribute('role', 'listitem');
    el.innerHTML = `
      <span class="qs-row__meta">
        <span class="qs-row__tag">${p.tag || p.cat || '—'}</span>
        <span class="qs-row__year">${p.year}</span>
      </span>
      <span class="qs-row__name">${p.name}</span>
      <span class="qs-row__arrow" aria-hidden="true">
        <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" style="width:12px;height:12px;">
          <line x1="6" y1="18" x2="18" y2="6"></line>
          <polyline points="10 6 18 6 18 14"></polyline>
        </svg>
      </span>
    `;
    return el;
  }

  function render(query) {
    const q = query.trim().toLowerCase();
    const matches = q
      ? projects.filter(p =>
          p.name.toLowerCase().includes(q) ||
          p.tag.toLowerCase().includes(q)  ||
          p.cat.toLowerCase().includes(q)  ||
          p.year.includes(q)
        )
      : projects;

    grid.innerHTML = '';
    matches.forEach(p => grid.appendChild(buildRow(p)));
    count.textContent =
      `Results ${projects.length}   Showing Items 1 to ${matches.length} of ${projects.length}`;
  }

  render('');

  input.addEventListener('input', () => render(input.value));
  clearBtn.addEventListener('click', () => { input.value = ''; render(''); input.focus(); });

  // ── Slider ──────────────────────────────────────────────────
  const track = document.getElementById('slider-track');
  const dots  = Array.from(document.querySelectorAll('.home-slider__dot'));

  if (track && dots.length > 1) {
    let current = 0;
    let timer;
    const slides = Array.from(track.querySelectorAll('.home-slider__slide'));

    function setActive(idx) {
      current = (idx + slides.length) % slides.length;
      slides[current].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
      dots.forEach((d, i) => {
        d.classList.toggle('is-active', i === current);
        d.setAttribute('aria-selected', String(i === current));
      });
    }

    function startAuto() { timer = setInterval(() => setActive(current + 1), 3000); }
    function stopAuto()  { clearInterval(timer); }

    startAuto();

    dots.forEach((d, i) => d.addEventListener('click', () => { stopAuto(); setActive(i); startAuto(); }));
    track.addEventListener('mouseenter', stopAuto);
    track.addEventListener('mouseleave', startAuto);

    // Sync dots on scroll
    const io = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) {
          const idx = parseInt(e.target.dataset.index ?? '0');
          dots.forEach((d, i) => {
            d.classList.toggle('is-active', i === idx);
            d.setAttribute('aria-selected', String(i === idx));
          });
          current = idx;
        }
      }),
      { root: track, threshold: 0.5 }
    );
    slides.forEach(s => io.observe(s));
  }

  // ── Read More Toggle ────────────────────────────────────────
  const readMoreBtn = document.getElementById('intro-read-more');
  const expandedContent = document.getElementById('intro-expanded-content');
  if (readMoreBtn && expandedContent) {
    readMoreBtn.addEventListener('click', () => {
      const isOpen = expandedContent.classList.toggle('is-open');
      readMoreBtn.classList.toggle('is-open', isOpen);
      const btnText = readMoreBtn.querySelector('span');
      if (btnText) {
        btnText.textContent = isOpen ? 'Read Less' : 'Read More';
      }
      if (isOpen) {
        expandedContent.style.maxHeight = expandedContent.scrollHeight + 'px';
      } else {
        expandedContent.style.maxHeight = '0px';
      }
    });
  }
</script>

<style>
  /* ══ Global Snapping Scope ══════════════════════════════════ */
  :global(html) {
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
  }
  
  :global(.page-main) {
    padding: 0 !important; /* overrides standard page padding for fullscreen snapping */
  }

  /* ══ Snapped Layout Sections ════════════════════════════════ */
  .home-section {
    scroll-snap-align: start;
    height: 100dvh;
    min-height: 100dvh;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-inline: var(--_tokens---space--small);
    transition: padding 0.3s ease;
    overflow: hidden;
  }

  .home-section--hero {
    justify-content: space-between;
    padding-top: clamp(3rem, 6vh, 5rem);
    padding-bottom: 24px;
  }

  .home-section--teasers {
    justify-content: center;
  }

  .home-section--search {
    justify-content: flex-start;
    padding-top: clamp(4rem, 8vh, 6rem);
    overflow-y: auto; /* allows scrolling if results overflow 100vh */
  }

  /* ══ 1. Intro ═══════════════════════════════════════════════ */
  .home-intro {
    display: flex;
    flex-direction: column;
    width: 100%;
    margin-bottom: 16px;
  }

  .home-intro__label {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--_tokens---color--fg);
    margin-bottom: 16px;
    width: 100%;
  }

  .home-intro__summary {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
  }

  .home-intro__desc {
    font-size: var(--_tokens---type--small);
    line-height: 1.7;
    color: var(--_tokens---color--muted);
    max-width: 80ch;
  }

  .home-intro__expanded {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease, margin-top 0.3s ease;
  }

  .home-intro__expanded.is-open {
    opacity: 1;
    margin-top: 16px;
  }

  .home-intro__left, .home-intro__right {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .intro-read-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    color: var(--_tokens---color--muted);
    font-size: var(--_tokens---type--micro);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    cursor: pointer;
    margin-top: 12px;
    padding: 0;
    transition: color 0.2s ease;
  }

  .intro-read-more-btn:hover {
    color: var(--_tokens---color--fg);
  }

  .intro-read-more-btn .link-arrow {
    width: 10px;
    height: 10px;
    transform: rotate(90deg); /* point down */
    transition: transform 0.3s ease;
  }

  .intro-read-more-btn.is-open .link-arrow {
    transform: rotate(-90deg); /* point up */
  }

  /* ══ 2. Slider ══════════════════════════════════════════════ */
  .home-slider {
    width: 100%;
  }

  .home-slider__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    gap: 32px;
    height: 38vh; /* Scale slider dynamically with screen height */
    min-height: 250px;
    max-height: 380px;
  }

  .home-slider__track::-webkit-scrollbar { display: none; }

  .home-slider__slide {
    flex: 0 0 calc(50% - 16px);
    scroll-snap-align: start;
    position: relative;
    display: block;
    text-decoration: none;
    color: var(--_tokens---color--fg);
    overflow: hidden;
    height: 100%;
    aspect-ratio: auto;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    border-radius: 8px;
  }

  .home-slider__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-slider__slide:hover img { transform: scale(1.04); }

  .home-slider__placeholder {
    width: 100%;
    height: 100%;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
  }

  .home-slider__caption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 32px 24px 20px;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 100%);
    pointer-events: none;
  }

  .home-slider__name {
    font-size: var(--_tokens---type--small);
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #fff;
    text-shadow: 0 1px 3px rgba(0,0,0,0.4);
  }

  .home-slider__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    color: #fff;
    opacity: 0.85;
  }
  
  .home-slider__arrow .link-arrow {
    width: 14px;
    height: 14px;
  }

  .link-arrow {
    width: 1em;
    height: 1em;
    vertical-align: middle;
    display: inline-block;
  }

  .home-slider__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 16px 0 0;
  }

  .home-slider__dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    border: none;
    background-color: var(--_tokens---color--muted);
    cursor: pointer;
    padding: 0;
    transition: background-color 0.2s, transform 0.2s;
  }

  .home-slider__dot.is-active {
    background-color: var(--_tokens---color--fg);
    transform: scale(1.3);
  }

  /* ══ 3 & 4. Teasers ═════════════════════════════════════════ */
  .home-teasers-container {
    display: flex;
    flex-direction: column;
    gap: 24px; /* Reduced spacing to keep teasers close */
    width: 100%;
  }

  .home-teaser {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .home-teaser__caption {
    font-size: var(--_tokens---type--small);
    line-height: 1.7;
    color: var(--_tokens---color--muted);
    max-width: 68ch;
    margin-bottom: 8px;
  }

  .home-teaser__link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    text-decoration: none;
    color: var(--_tokens---color--fg);
    transition: opacity 0.2s;
  }

  .home-teaser__link:hover { opacity: 0.65; }

  .home-teaser__link > span:first-child {
    font-size: var(--_tokens---type--big);
    font-weight: 500; /* Medium thickness instead of bold */
    line-height: 0.95;
    letter-spacing: -0.03em;
  }

  .home-teaser__arrow-wrap {
    position: relative;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-left: 24px;
  }

  .status-circle {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }

  .status-circle__bg {
    opacity: 0.15;
  }

  .status-circle__progress {
    stroke-dasharray: 120;
    stroke-dashoffset: 120;
    transition: stroke-dashoffset 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-teaser__link:hover .status-circle__progress {
    stroke-dashoffset: 0;
  }

  .home-teaser__link:hover .link-arrow {
    transform: translate(4px, -4px);
  }

  .home-teaser__link:hover {
    opacity: 1;
  }

  .home-teaser__link .link-arrow {
    width: 18px;
    height: 18px;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ══ 5. Quick Search ════════════════════════════════════════ */
  .home-search__title {
    font-size: var(--_tokens---type--medium);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--_tokens---color--fg);
    margin-bottom: 32px;
  }

  .home-search__bar {
    display: flex;
    gap: 12px;
    margin-bottom: 16px;
  }

  .home-search__input {
    flex: 1;
    height: 48px;
    padding: 0 16px;
    font-size: var(--_tokens---type--small);
    font-family: inherit;
    background: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    color: var(--_tokens---color--fg);
    border-radius: 8px;
    outline: none;
    transition: background-color 0.2s;
  }

  .home-search__input::placeholder { color: var(--_tokens---color--muted); }
  .home-search__input:focus { background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent); }

  .home-search__clear {
    height: 48px;
    padding: 0 20px;
    font-size: var(--_tokens---type--micro);
    font-family: inherit;
    font-weight: 600;
    letter-spacing: 0.04em;
    background: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    color: var(--_tokens---color--fg);
    border-radius: 8px;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.2s, color 0.2s;
  }

  .home-search__clear:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  .home-search__count {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    color: var(--_tokens---color--muted);
    letter-spacing: 0.04em;
    margin-bottom: 24px;
  }

  /* 3-column project grid */
  .home-search__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px 32px;
  }

  /* Individual row */
  .qs-row {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    align-items: center;
    gap: 16px;
    padding: 16px 0;
    text-decoration: none;
    color: var(--_tokens---color--fg);
    transition: opacity 0.15s;
  }

  .qs-row:hover { opacity: 0.55; }

  .qs-row__meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .qs-row__tag {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    color: var(--_tokens---color--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-transform: capitalize;
  }

  .qs-row__year {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    color: var(--_tokens---color--muted);
    opacity: 0.7;
  }

  .qs-row__name {
    font-size: var(--_tokens---type--small);
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .qs-row__arrow {
