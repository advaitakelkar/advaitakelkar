    /* the category name is tappable — underline signals it */
    .home-slider__cat-link {
      text-decoration: underline;
      text-decoration-color: color-mix(in srgb, var(--_tokens---color--fg) 35%, transparent);
      text-underline-offset: 3px;
    }

    /* Dots inside the one-screen budget: small spacer above, a little
       breathing room below before the screen edge */
    .home-slider__dots {
      flex: 0 0 auto;
      padding-top: 0 !important;
      padding-bottom: 12px !important; /* spacer below dots */
    }

    /* Mobile reveal: name → floating ring → bottom row */
    .home-slider__mobile-head,
    .home-slider__mobile-bottom {
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.45s ease, transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .home-slider__arrow-mobile {
      opacity: 0;
      transition: opacity 0.45s ease;
    }
    .home-slider__slide.is-active .home-slider__mobile-head   { opacity: 1; transform: none; transition-delay: 0s; }
    .home-slider__slide.is-active .home-slider__arrow-mobile  { opacity: 1; transition-delay: 0.08s; }
    .home-slider__slide.is-active .home-slider__mobile-bottom { opacity: 1; transform: none; transition-delay: 0.12s; }
  }

  @media (max-width: 600px) {
    .home-slider__slide {
      flex: 0 0 100%;
      --img-w: 100%;
    }
    .home-slider__track::before,
    .home-slider__track::after {
      flex: 0 0 0;
    }
  }

  /* Mobile Portrait Layout Adjustments for bottom breadcrumbs */
  @media (max-width: 767px) and (orientation: portrait) {
    :global(.page-main) {
      padding-bottom: 80px !important;
    }

    :global(.page-breadcrumb) {
