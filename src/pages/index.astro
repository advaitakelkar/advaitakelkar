---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

// ── Data ──────────────────────────────────────────────────────
const allProjects = await getCollection('projects');
const allTags     = await getCollection('tags');
const allCats     = await getCollection('categories');

// Lookup maps
const tagMap = Object.fromEntries(allTags.map(t => [t.id, t.data.name]));
const catMap = Object.fromEntries(allCats.map(c => [c.id, c.data.displayName]));

// Featured slider (featured:true, sorted by numbr)
const featured = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => (a.data.numbr ?? 999) - (b.data.numbr ?? 999));

// All projects for quick search
const sorted = [...allProjects].sort((a, b) => {
  if (a.data.numbr && b.data.numbr) return a.data.numbr - b.data.numbr;
  if (a.data.numbr) return -1;
  if (b.data.numbr) return 1;
  return parseInt(b.data.year ?? '0') - parseInt(a.data.year ?? '0');
});

// Projects array for client-side search (name + tag are what's shown)
const projectsData = sorted.map(p => ({
  id:      p.id,
  name:    p.data.name,
  year:    p.data.year ?? '',
  tag:     p.data.tags?.[0] ? (tagMap[p.data.tags[0].id] ?? p.data.tags[0].id) : '',
  tags:    (p.data.tags ?? []).map(t => tagMap[t.id] ?? t.id).join(' '),
  cat:     p.data.category  ? (catMap[p.data.category.id] ?? p.data.category.id) : '',
  loc:     p.data.location ?? '',
  client:  p.data.client ?? '',
  status:  p.data.status ?? '',
  size:    p.data.size ?? '',
  program: p.data.program ?? '',
}));
---

<PageLayout
  title="Home"
  crumbs={[{ label: 'Home' }]}
  sections={[
    { id: 'home-hero-section', label: 'Intro & Featured' },
    { id: 'home-search-section', label: 'Search & Navigate' }
  ]}
>

  <!-- ══ Section 1: Hero (About Me intro + Featured slider) ════════ -->
  <section class="home-section home-section--hero" id="home-hero-section">
    <div class="home-intro home-intro--animated">
      <!-- LinkedIn-style profile header (dummy banner slider — swap in real photos later) -->
      <header class="profile-header">
        <div class="profile-banner" aria-label="Personal photos">
          <div class="profile-banner__track">
            <div class="profile-banner__slide is-active" data-bi="0"><span class="profile-banner__tag">Photo 1</span></div>
            <div class="profile-banner__slide" data-bi="1"><span class="profile-banner__tag">Photo 2</span></div>
            <div class="profile-banner__slide" data-bi="2"><span class="profile-banner__tag">Photo 3</span></div>
            <div class="profile-banner__slide" data-bi="3"><span class="profile-banner__tag">Photo 4</span></div>
            <div class="profile-banner__slide" data-bi="4"><span class="profile-banner__tag">Photo 5</span></div>
          </div>
          <div class="profile-banner__dots">
            <button class="profile-banner__dot is-active" data-bdot="0" aria-label="Photo 1" type="button"></button>
            <button class="profile-banner__dot" data-bdot="1" aria-label="Photo 2" type="button"></button>
            <button class="profile-banner__dot" data-bdot="2" aria-label="Photo 3" type="button"></button>
            <button class="profile-banner__dot" data-bdot="3" aria-label="Photo 4" type="button"></button>
            <button class="profile-banner__dot" data-bdot="4" aria-label="Photo 5" type="button"></button>
          </div>
        </div>

        <div class="profile-meta">
          <div class="profile-id">
            <div class="profile-photo" aria-hidden="true"></div>
            <div class="profile-id__text">
              <h1 class="profile-name">Advaita Kelkar</h1>
              <p class="profile-role" id="tagline-main" data-scramble>Architectural Designer + Researcher</p>
              <p class="profile-degree">Master of Architecture · SCAD ’27 · Mumbai</p>
            </div>
          </div>

          <nav class="profile-contact" aria-label="Contact">
            <a href="mailto:advaitakelkar@gmail.com" class="profile-contact__link">Email<svg class="link-arrow profile-contact__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>
            <a href="/advaita-kelkar-cv.pdf" target="_blank" rel="noopener" class="profile-contact__link">CV<svg class="link-arrow profile-contact__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>
            <a href="/advaita-kelkar-portfolio.pdf" target="_blank" rel="noopener" class="profile-contact__link">Portfolio<svg class="link-arrow profile-contact__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>
          </nav>
        </div>
      </header>

      <!-- Small About Me — flexible, responsive 3-column structure -->
      <div class="home-intro__body">
        <div class="home-intro__column">
          <p class="home-intro__desc">
            This digital platform serves as the comprehensive, living archive of Advaita Kelkar’s multidisciplinary design practice. It is designed to function as a singular, unified ecosystem that seamlessly integrates a diverse and expansive body of work. Here, projects spanning across architecture, interior environments, physical sculpture, graphic design, product innovation, and fine art are not treated as isolated endeavors, but rather as interconnected expressions of a singular creative vision.
          </p>
        </div>
        <div class="home-intro__column">
          <p class="home-intro__desc">
            Rather than compartmentalizing these various creative fields into rigid categories, this archive encourages fluid exploration. It invites visitors to navigate freely across different disciplines, uncovering the subtle threads and underlying dialogues that connect them. Through this unstructured journey, one can trace how foundational principles of form, tactile material choices, and core conceptual intentions recur, evolve, and echo from one project to the next.
          </p>
        </div>
        <div class="home-intro__column">
          <p class="home-intro__desc">
            Website is an extension of me, please make sure to contact me via <a href="mailto:advaitakelkar@gmail.com" class="intro-inline-link">email<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>. You can reach out to me via <a href="https://instagram.com/advaitakelkar" target="_blank" rel="noopener" class="intro-inline-link">Instagram<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>. Check my professional <a href="/advaita-kelkar-portfolio.pdf" target="_blank" rel="noopener" class="intro-inline-link">portfolio<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a> or <a href="/advaita-kelkar-cv.pdf" target="_blank" rel="noopener" class="intro-inline-link">resume<svg class="link-arrow intro-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg></a>. Also other places of contacting — Instagram, DMs and other social media links.
          </p>
        </div>
      </div>
    </div>

    <!-- Featured Slider -->
    {featured.length > 0 && (
      <div class="home-slider" aria-label="Featured projects">
        <div class="home-slider__track" id="slider-track">
          {featured.map((p, i) => (
            <a
              href={`/projects/${p.id}`}
              class="home-slider__slide"
              data-index={i}
              aria-label={p.data.name}
            >
              <div class="home-slider__image-wrap soft-image-container">
                {p.data.coverImage
                  ? <img src={p.data.coverImage} alt={p.data.name} loading={i === 0 ? 'eager' : 'lazy'} />
                  : <div class="home-slider__placeholder" aria-hidden="true" />
                }
              </div>
              <div class="home-slider__caption">
                <span class="home-slider__name" data-scramble>{p.data.name}</span>
                <span class="home-slider__arrow" aria-hidden="true">
                  <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                    <line x1="6" y1="18" x2="18" y2="6"></line>
                    <polyline points="10 6 18 6 18 14"></polyline>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
        <div class="home-slider__dots" role="tablist" aria-label="Slide navigation">
          {featured.map((_, i) => (
            <button
              class={`home-slider__dot${i === 0 ? ' is-active' : ''}`}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-label={`Slide ${i + 1}`}
              data-dot={i}
            />
          ))}
        </div>
      </div>
    )}
  </section>

  <!-- ══ Section 2: Page Navigation (top) + Quick Search (below) ═══ -->
  <section class="home-section home-section--search" id="home-search-section" aria-label="Page navigation and project quick search">
    <!-- Page Navigation: links to About Me and Projects -->
    <nav class="home-nav" aria-label="Primary pages">
      <a href="/about" class="home-nav-row">
        <span class="home-nav-row__text">About Me</span>
        <span class="home-nav-row__arrow" aria-hidden="true">
          <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <line x1="6" y1="18" x2="18" y2="6"></line>
            <polyline points="10 6 18 6 18 14"></polyline>
          </svg>
        </span>
      </a>
      <a href="/projects" class="home-nav-row">
        <span class="home-nav-row__text">Projects</span>
        <span class="home-nav-row__arrow" aria-hidden="true">
          <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <line x1="6" y1="18" x2="18" y2="6"></line>
            <polyline points="10 6 18 6 18 14"></polyline>
          </svg>
        </span>
      </a>
    </nav>

    <!-- Quick Search: simplified, shows project name + tag only -->
    <div class="home-search__header">
      <h2 class="home-search__title">Projects Quick Search</h2>
    </div>
    <div class="home-search__bar">
      <input
        type="search"
        id="qs-input"
        class="home-search__input"
        placeholder="Search projects by name or tag..."
        autocomplete="off"
        aria-label="Search projects"
      />
      <button class="home-search__clear" id="qs-clear" type="button">@Clear All</button>
    </div>
    <p class="home-search__count" id="qs-count" aria-live="polite"></p>
    <div class="home-search__grid" id="qs-grid" role="list"></div>
  </section>

</PageLayout>

<!-- ══ DATA + JS ══════════════════════════════════════════════ -->
<script define:vars={{ projectsData }}>
  // ── Quick Search ────────────────────────────────────────────
  const projects = projectsData;
  const grid     = document.getElementById('qs-grid');
  const input    = document.getElementById('qs-input');
  const clearBtn = document.getElementById('qs-clear');
  const count    = document.getElementById('qs-count');

  function buildRow(p) {
    const el = document.createElement('a');
    el.href      = `/projects/${p.id}`;
    el.className = 'qs-card';
    el.setAttribute('role', 'listitem');
    el.innerHTML = `
      <span class="qs-card__name" data-scramble>${p.name}</span>
      <span class="qs-card__tag">${p.tag || p.cat || 'Design'}</span>
      <span class="qs-card__arrow" aria-hidden="true">
        <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
          <line x1="6" y1="18" x2="18" y2="6"></line>
          <polyline points="10 6 18 6 18 14"></polyline>
        </svg>
      </span>
    `;
    return el;
  }

  function render(query) {
    if (!grid) return;
    const q = query.trim().toLowerCase();
    let matches;
    if (q) {
      const keywords = q.split(/\s+/).filter(Boolean);
      matches = projects.filter(p => {
        return keywords.every(kw =>
          p.name.toLowerCase().includes(kw) ||
          p.tags.toLowerCase().includes(kw)  ||
          p.cat.toLowerCase().includes(kw)  ||
          p.year.includes(kw) ||
          (p.loc && p.loc.toLowerCase().includes(kw)) ||
          (p.client && p.client.toLowerCase().includes(kw)) ||
          (p.status && p.status.toLowerCase().includes(kw)) ||
          (p.size && p.size.toLowerCase().includes(kw)) ||
          (p.program && p.program.toLowerCase().includes(kw))
        );
      });
    } else {
      matches = projects;
    }

    grid.innerHTML = '';
    matches.forEach(p => grid.appendChild(buildRow(p)));
    if (count) {
      count.textContent =
        `Results ${projects.length}   Showing Items 1 to ${matches.length} of ${projects.length}`;
    }
  }

  render('');

  input?.addEventListener('input', () => render(input.value));
  clearBtn?.addEventListener('click', () => { if (input) { input.value = ''; render(''); input.focus(); } });

  // ── Slider ──────────────────────────────────────────────────
  const track = document.getElementById('slider-track');
  const dots  = Array.from(document.querySelectorAll('.home-slider__dot'));

  if (track && dots.length > 1) {
    let current = 0;
    let timer;
    const slides = Array.from(track.querySelectorAll('.home-slider__slide'));

    function setActive(idx) {
      current = (idx + slides.length) % slides.length;
      slides[current].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      dots.forEach((d, i) => {
        d.classList.toggle('is-active', i === current);
        d.setAttribute('aria-selected', String(i === current));
      });
    }

    function startAuto() { timer = setInterval(() => setActive(current + 1), 3000); }
    function stopAuto()  { clearInterval(timer); }

    startAuto();

    dots.forEach((d, i) => d.addEventListener('click', () => { stopAuto(); setActive(i); startAuto(); }));
    track.addEventListener('mouseenter', stopAuto);
    track.addEventListener('mouseleave', startAuto);

    // Sync dots on scroll
    const io = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) {
          const idx = parseInt(e.target.dataset.index ?? '0');
          dots.forEach((d, i) => {
            d.classList.toggle('is-active', i === idx);
            d.setAttribute('aria-selected', String(i === idx));
          });
          current = idx;
        }
      }),
      { root: track, threshold: 0.5 }
    );
    slides.forEach(s => io.observe(s));
  }

  // ── Profile banner (dummy personal-photo slider) ───────────
  const bslides = Array.from(document.querySelectorAll('.profile-banner__slide'));
  const bdots   = Array.from(document.querySelectorAll('.profile-banner__dot'));
  if (bslides.length > 1) {
    let bcur = 0, btimer;
    function bset(i) {
      bcur = (i + bslides.length) % bslides.length;
      bslides.forEach((s, n) => s.classList.toggle('is-active', n === bcur));
      bdots.forEach((d, n) => d.classList.toggle('is-active', n === bcur));
    }
    function bstart() { btimer = setInterval(() => bset(bcur + 1), 3500); }
    function bstop()  { clearInterval(btimer); }
    bstart();
    bdots.forEach((d, i) => d.addEventListener('click', () => { bstop(); bset(i); bstart(); }));
    const banner = document.querySelector('.profile-banner');
    banner?.addEventListener('mouseenter', bstop);
    banner?.addEventListener('mouseleave', bstart);
  }

  // ── Scramble Tagline on load ───────────────────────────────
  function triggerTaglineScramble() {
    const tagline = document.getElementById('tagline-main');
    if (tagline) {
      setTimeout(() => {
        tagline.dispatchEvent(new Event('mouseover', { bubbles: true }));
      }, 150);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', triggerTaglineScramble);
  } else {
    triggerTaglineScramble();
  }
  document.addEventListener('astro:after-swap', triggerTaglineScramble);
</script>

<style>
  /* ══ Global Snapping Scope ══════════════════════════════════ */
  :global(html) {
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
  }

  /* ══ Snapped Layout Sections ════════════════════════════════ */
  .home-section {
    scroll-snap-align: start;
    height: 100dvh;
    min-height: 100dvh;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-inline: var(--_tokens---space--small);
    transition: padding 0.3s ease;
    overflow: hidden;
  }

  .home-section--hero {
    justify-content: flex-start;
    gap: 20px;
    padding-top: calc(clamp(2rem, 5vh, 3rem) + 48px); /* 48px for fixed breadcrumb */
    padding-bottom: 24px;
    overflow: hidden; /* clip slider to section */
  }

  .home-section--search {
    justify-content: flex-start;
    padding-top: calc(clamp(2rem, 4vh, 3rem) + 48px); /* 48px for fixed breadcrumb */
    overflow-y: auto; /* scrollable search */
    position: relative;
    scrollbar-width: thin;
  }

  /* ══ 1. Intro (small About Me — 3 flexible columns) ═════════ */
  .home-intro {
    display: flex;
    flex-direction: column;
    width: 100%;
    margin-bottom: 8px;
  }

  /* Entrance Animation for Tagline and Intro section */
  .home-intro--animated {
    opacity: 0;
    transform: translateY(-20px);
    animation: slideInFromTop 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes slideInFromTop {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .home-intro__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    width: 100%;
    margin-bottom: 8px;
  }

  .home-intro__label {
    font-size: var(--_tokens---type--small);
    font-weight: 600;
    letter-spacing: 0.01em;
    text-transform: none;
    color: var(--_tokens---color--fg);
    margin: 0;
  }

  /* ══ LinkedIn-style profile header ══════════════════════════ */
  .profile-header {
    width: 100%;
    margin-bottom: 20px;
  }

  .profile-banner {
    position: relative;
    width: 100%;
    height: clamp(110px, 16vh, 175px);
    border-radius: 12px;
    overflow: hidden;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
  }

  .profile-banner__track { position: absolute; inset: 0; }

  .profile-banner__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.9s ease;
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    padding: 12px;
  }

  .profile-banner__slide.is-active { opacity: 1; }

  /* Dummy gradient placeholders — replace with real photos */
  .profile-banner__slide[data-bi="0"] { background: linear-gradient(120deg, #2d3a5e, #5b7fa6); }
  .profile-banner__slide[data-bi="1"] { background: linear-gradient(120deg, #34564a, #6fae8d); }
  .profile-banner__slide[data-bi="2"] { background: linear-gradient(120deg, #5e3a4a, #a66b80); }
  .profile-banner__slide[data-bi="3"] { background: linear-gradient(120deg, #5e503a, #aa9a6b); }
  .profile-banner__slide[data-bi="4"] { background: linear-gradient(120deg, #3a4f5e, #6b97ae); }

  .profile-banner__tag {
    font-family: var(--_tokens---font--mono);
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    background: rgba(0, 0, 0, 0.22);
    padding: 3px 8px;
    border-radius: 999px;
  }

  .profile-banner__dots {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 2;
  }

  .profile-banner__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    padding: 0;
    transition: background-color 0.2s, transform 0.2s;
  }

  .profile-banner__dot.is-active { background: #fff; transform: scale(1.3); }

  .profile-meta {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-top: -30px;
    padding-inline: 6px;
  }

  .profile-id {
    display: flex;
    align-items: flex-end;
    gap: 14px;
    min-width: 0;
  }

  .profile-photo {
    width: clamp(60px, 7vw, 84px);
    height: clamp(60px, 7vw, 84px);
    border-radius: 50%;
    border: 3px solid var(--_tokens---color--bg);
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--_tokens---color--fg) 28%, transparent),
      color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent));
    flex-shrink: 0;
  }

  .profile-id__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-bottom: 4px;
    min-width: 0;
  }

  .profile-name {
    font-size: var(--_tokens---type--small);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--_tokens---color--fg);
    margin: 0;
  }

  .profile-role {
    font-size: var(--_tokens---type--micro);
    font-weight: 400;
    color: var(--_tokens---color--fg);
    margin: 0;
  }

  .profile-degree {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    color: var(--_tokens---color--muted);
    margin: 0;
  }

  .profile-contact {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding-bottom: 6px;
  }

  .profile-contact__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--_tokens---type--micro);
    color: var(--_tokens---color--fg);
    text-decoration: none;
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 14%, transparent);
    border-radius: 999px;
    padding: 5px 12px;
    transition: background-color 0.2s, border-color 0.2s;
  }

  .profile-contact__link:hover {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border-color: color-mix(in srgb, var(--_tokens---color--fg) 26%, transparent);
  }

  .profile-contact__arrow {
    width: 0.8em;
    height: 0.8em;
    transition: transform 0.25s ease;
  }

  .profile-contact__link:hover .profile-contact__arrow {
    transform: translate(1px, -1px);
  }

  @media (max-width: 640px) {
    .profile-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }
    .profile-contact { padding-bottom: 0; }
  }

  .home-intro__body {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 32px;
    width: 100%;
  }

  .home-intro__column {
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(15px);
    animation: fadeUpIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .home-intro__column:nth-child(1) { animation-delay: 0.2s; }
  .home-intro__column:nth-child(2) { animation-delay: 0.4s; }
  .home-intro__column:nth-child(3) { animation-delay: 0.6s; }

  @keyframes fadeUpIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .home-intro__desc {
    font-size: var(--_tokens---type--micro);
    line-height: 1.55;
    color: var(--_tokens---color--muted);
    margin: 0;
  }

  /* Inline contact links that flow within the paragraph text */
  .intro-inline-link {
    color: var(--_tokens---color--fg);
    text-decoration: none;
    white-space: nowrap; /* keep label + arrow together */
    border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 30%, transparent);
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .intro-inline-link:hover {
    border-bottom-color: var(--_tokens---color--fg);
  }

  .intro-inline-link .intro-arrow {
    width: 0.78em;
    height: 0.78em;
    margin-left: 1px;
    vertical-align: -0.05em;
    transition: transform 0.25s ease;
  }

  .intro-inline-link:hover .intro-arrow {
    transform: translate(1px, -1px);
  }

  /* ══ 2. Slider ══════════════════════════════════════════════ */
  .home-slider {
    width: 100%;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .home-slider__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    gap: 32px;
    flex: 1;
    min-height: 180px;
    align-items: center;
    position: relative;
  }

  .home-slider__track::-webkit-scrollbar { display: none; }

  /* Centring buffer hack using pseudo-elements */
  .home-slider__track::before,
  .home-slider__track::after {
    content: '';
    flex: 0 0 25vw;
  }

  .home-slider__slide {
    flex: 0 0 50vw;
    scroll-snap-align: center; /* snap to center! */
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-decoration: none;
    color: var(--_tokens---color--fg);
    min-width: 280px;
    max-width: 720px;
  }

  .home-slider__image-wrap {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 8px;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 3%, transparent);
    position: relative;
  }

  .home-slider__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain; /* Don't change proportions! */
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-slider__slide:hover img {
    transform: scale(1.02);
  }

  .home-slider__placeholder {
    width: 100%;
    height: 100%;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
  }

  .home-slider__caption {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-inline: 4px;
    color: var(--_tokens---color--fg);
  }

  .home-slider__name {
    font-size: var(--_tokens---type--small);
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  .home-slider__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .home-slider__slide:hover .home-slider__arrow {
    transform: translate(2px, -2px);
  }

  .link-arrow {
    width: 1em;
    height: 1em;
    vertical-align: middle;
    display: inline-block;
  }

  .home-slider__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 16px 0 0;
  }

  .home-slider__dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    border: none;
    background-color: var(--_tokens---color--muted);
    cursor: pointer;
    padding: 0;
    transition: background-color 0.2s, transform 0.2s;
  }

  .home-slider__dot.is-active {
    background-color: var(--_tokens---color--fg);
    transform: scale(1.3);
  }

  /* ══ 3. Projects Quick Search ══════════════════════════════ */
  .home-search__header {
    margin-bottom: 16px;
  }

  .home-search__title {
    font-size: var(--_tokens---type--small);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--_tokens---color--fg);
    margin: 0;
  }

  .home-search__bar {
    display: flex;
    gap: 10px;
    margin-bottom: 14px;
  }

  .home-search__input {
    flex: 1;
    height: 42px;
    padding: 0 16px;
    font-size: var(--_tokens---type--micro);
    font-family: inherit;
    background: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    color: var(--_tokens---color--fg);
    border-radius: 8px;
    outline: none;
    transition: background-color 0.2s;
  }

  .home-search__input::placeholder { color: var(--_tokens---color--muted); }
  .home-search__input:focus { background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent); }

  .home-search__clear {
    height: 42px;
    padding: 0 18px;
    font-size: var(--_tokens---type--micro);
    font-family: inherit;
    font-weight: 400;
    letter-spacing: 0.04em;
    background: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    color: var(--_tokens---color--fg);
    border-radius: 8px;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.2s, color 0.2s;
  }

  .home-search__clear:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  .home-search__count {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    color: var(--_tokens---color--muted);
    letter-spacing: 0.04em;
    margin-bottom: 24px;
  }

  /* Capsule "paragraph" layout — content-sized pills that wrap and reflow.
     No fixed columns: each card sizes to its own name + tag, packed like words. */
  .home-search__grid {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 7px;
  }

  @media (max-width: 768px) {
    .home-search__grid {
      gap: 6px;
    }
  }

  /* Card Sizing & Sibling elements style.
     NOTE: quick-search cards are injected at runtime via JS (buildRow),
     so Astro's scoped styles never reach them. These rules are :global
     so they apply to the dynamically-created card markup. */
  :global(.qs-card) {
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    gap: 6px;
    width: auto;
    max-width: 100%;
    padding: 6px 9px 6px 13px;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 3%, transparent);
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    border-radius: 999px; /* capsule / pill */
    text-decoration: none;
    color: var(--_tokens---color--fg);
    white-space: nowrap;
    transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    animation: capsuleIn 0.25s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  :global(.qs-card:hover) {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border-color: color-mix(in srgb, var(--_tokens---color--fg) 22%, transparent);
    transform: translateY(-1px);
  }

  /* Name — semibold, micro (compact) */
  :global(.qs-card__name) {
    font-size: var(--_tokens---type--micro);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--_tokens---color--fg);
  }

  /* Tag — tiny, regular, muted */
  :global(.qs-card__tag) {
    font-family: var(--_tokens---font--mono);
    font-size: 0.62rem;
    font-weight: 300;
    color: var(--_tokens---color--muted);
    text-transform: none;
    letter-spacing: 0.04em;
    line-height: 1;
  }

  /* Arrow — sits after a spacer at the capsule's end */
  :global(.qs-card__arrow) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 13px;
    height: 13px;
    margin-left: 6px; /* spacer before the arrow */
    color: var(--_tokens---color--muted);
    flex: 0 0 13px;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), color 0.2s ease;
  }

  :global(.qs-card:hover .qs-card__arrow) {
    transform: translate(2px, -2px);
    color: var(--_tokens---color--fg);
  }

  :global(.qs-card__arrow svg) {
    width: 13px;
    height: 13px;
  }

  /* ══ 4. Page Navigation (links above search) ════════════════ */
  .home-nav {
    display: flex;
    flex-direction: column;
    width: 100%;
    margin-bottom: 40px;
  }

  .home-nav-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-decoration: none;
    color: var(--_tokens---color--fg);
    border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    padding-block: 22px;
    transition: opacity 0.2s ease, padding-left 0.2s ease;
  }

  .home-nav-row:last-child {
    border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
  }

  .home-nav-row:hover {
    opacity: 0.75;
    padding-left: 8px;
  }

  .home-nav-row__text {
    font-size: var(--_tokens---type--big);
    font-weight: 500;
    line-height: 0.95;
    letter-spacing: -0.03em;
  }

  .home-nav-row__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    color: var(--_tokens---color--muted);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), color 0.3s ease;
  }

  .home-nav-row__arrow svg {
    width: 100%;
    height: 100%;
  }

  .home-nav-row:hover .home-nav-row__arrow {
    transform: rotate(45deg);
    color: var(--_tokens---color--fg);
  }

  @media (min-width: 1200px) {
    .home-section {
      padding-inline: clamp(6rem, 12vw, 16rem);
    }
  }

  /* ══ Responsive ═════════════════════════════════════════════ */
  @media (max-width: 1199px) {
    .home-intro__body {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 24px;
    }
    .home-slider__slide {
      flex: 0 0 65vw;
    }
    .home-slider__track::before,
    .home-slider__track::after {
      flex: 0 0 17.5vw; /* (100vw - 65vw) / 2 */
    }
  }

  @media (max-width: 768px) {
    .home-section {
      height: auto;
      min-height: 100dvh;
      overflow: visible;
      padding-block: 24px;
    }
    .home-section--search {
      overflow-y: visible;
    }
    .home-intro__body {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .home-slider__slide {
      flex: 0 0 75vw;
    }
    .home-slider__track::before,
    .home-slider__track::after {
      flex: 0 0 12.5vw; /* (100vw - 75vw) / 2 */
    }
    .home-nav-row__text {
      font-size: var(--_tokens---type--medium);
    }
  }

  @media (max-width: 600px) {
    .home-slider__slide {
      flex: 0 0 85vw;
    }
    .home-slider__track::before,
    .home-slider__track::after {
      flex: 0 0 7.5vw;
    }
  }

  /* Mobile Portrait Layout Adjustments for bottom breadcrumbs */
  @media (max-width: 767px) and (orientation: portrait) {
    :global(.page-main) {
      padding-bottom: 80px !important;
    }

    :global(.page-breadcrumb) {
      top: auto !important;
      bottom: 0 !important;
      background-color: var(--_tokens---color--bg) !important;
    }

    .home-section {
      padding-bottom: 80px !important;
    }
  }
</style>

<!-- Global keyframes for the runtime-injected search capsules -->
<style is:global>
  @keyframes capsuleIn {
    from { opacity: 0; transform: translateY(4px) scale(0.96); }
    to   { opacity: 1; transform: none; }
  }
</style>
