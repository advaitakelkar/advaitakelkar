---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

// ── Data ──────────────────────────────────────────────────────
const allProjects = await getCollection('projects');
const allTags     = await getCollection('tags');
const allCats     = await getCollection('categories');

// Lookup maps
const tagMap = Object.fromEntries(allTags.map(t => [t.id, t.data.name]));
const catMap = Object.fromEntries(allCats.map(c => [c.id, c.data.displayName]));

// Featured slider (featured:true, sorted by numbr)
const featured = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => (a.data.numbr ?? 999) - (b.data.numbr ?? 999));

// All projects for quick search and portfolio tab
const sorted = [...allProjects].sort((a, b) => {
  if (a.data.numbr && b.data.numbr) return a.data.numbr - b.data.numbr;
  if (a.data.numbr) return -1;
  if (b.data.numbr) return 1;
  return parseInt(b.data.year ?? '0') - parseInt(a.data.year ?? '0');
});

// Serialise to JSON for client-side search
const projectsJson = JSON.stringify(
  sorted.map(p => ({
    id:      p.id,
    name:    p.data.name,
    year:    p.data.year ?? '',
    tag:     p.data.tags?.[0] ? (tagMap[p.data.tags[0].id] ?? p.data.tags[0].id) : '',
    tags:    (p.data.tags ?? []).map(t => tagMap[t.id] ?? t.id).join(' '),
    cat:     p.data.category  ? (catMap[p.data.category.id] ?? p.data.category.id) : '',
    loc:     p.data.location ?? '',
    client:  p.data.client ?? '',
    status:  p.data.status ?? '',
    size:    p.data.size ?? '',
    program: p.data.program ?? '',
  }))
);
---

<PageLayout
  title="Home"
  crumbs={[{ label: 'Home' }]}
>

  <!-- Section 1: Hero (Intro + Slider) -->
  <section class="home-section home-section--hero" id="home-hero-section">
    <div class="home-intro">
      <div class="home-intro__header">
        <h1 class="home-intro__label">Multidisciplinary Designer · Mumbai</h1>
      </div>

      <div class="home-intro__body">
        <div class="home-intro__column">
          <p class="home-intro__desc">
            This digital platform serves as the comprehensive, living archive of Advaita Kelkar’s multidisciplinary design practice. It is designed to function as a singular, unified ecosystem that seamlessly integrates a diverse and expansive body of work. Here, projects spanning across architecture, interior environments, physical sculpture, graphic design, product innovation, and fine art are not treated as isolated endeavors, but rather as interconnected expressions of a singular creative vision.
          </p>
        </div>
        <div class="home-intro__column">
          <p class="home-intro__desc">
            Rather than compartmentalizing these various creative fields into rigid categories, this archive encourages fluid exploration. It invites visitors to navigate freely across different disciplines, uncovering the subtle threads and underlying dialogues that connect them. Through this unstructured journey, one can trace how foundational principles of form, tactile material choices, and core conceptual intentions recur, evolve, and echo from one project to the next.
          </p>
        </div>
      </div>
    </div>

    <!-- Featured Slider -->
    {featured.length > 0 && (
      <div class="home-slider" aria-label="Featured projects">
        <div class="home-slider__track" id="slider-track">
          {featured.map((p, i) => (
            <a
              href={`/projects/${p.id}`}
              class="home-slider__slide soft-image-container"
              data-index={i}
              aria-label={p.data.name}
            >
              {p.data.coverImage
                ? <img src={p.data.coverImage} alt={p.data.name} loading={i === 0 ? 'eager' : 'lazy'} />
                : <div class="home-slider__placeholder" aria-hidden="true" />
              }
              <div class="home-slider__caption">
                <span class="home-slider__name">{p.data.name}</span>
                <span class="home-slider__arrow" aria-hidden="true">
                  <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                    <line x1="6" y1="18" x2="18" y2="6"></line>
                    <polyline points="10 6 18 6 18 14"></polyline>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
        <div class="home-slider__dots" role="tablist" aria-label="Slide navigation">
          {featured.map((_, i) => (
            <button
              class={`home-slider__dot${i === 0 ? ' is-active' : ''}`}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-label={`Slide ${i + 1}`}
              data-dot={i}
            />
          ))}
        </div>
      </div>
    )}
  </section>

  <!-- Section 2: Combined Info & Stacking Section -->
  <section class="home-section home-section--info" id="home-info-section">
    <!-- Sticky 100% width tabs -->
    <div class="home-tabs-container" role="tablist" aria-label="Home info tabs">
      <button class="home-tab-btn is-active" role="tab" aria-selected="true" aria-controls="panel-qs" data-tab="qs">Quick Search</button>
      <button class="home-tab-btn" role="tab" aria-selected="false" aria-controls="panel-about" data-tab="about">About Me</button>
      <button class="home-tab-btn" role="tab" aria-selected="false" aria-controls="panel-portfolio" data-tab="portfolio">Portfolio</button>
    </div>

    <div class="home-tab-content">
      <!-- Panel 1: Quick Search -->
      <div class="home-tab-panel is-active" id="panel-qs" role="tabpanel" aria-label="Quick Search Panel">
        <div class="home-search__bar">
          <input
            type="search"
            id="qs-input"
            class="home-search__input"
            placeholder="Search projects by name, tag, location, client, status, year..."
            autocomplete="off"
            aria-label="Search projects"
          />
          <button class="home-search__clear" id="qs-clear" type="button">@Clear All</button>
        </div>
        <p class="home-search__count" id="qs-count" aria-live="polite"></p>
        <div class="home-search__grid" id="qs-grid" role="list"></div>
      </div>

      <!-- Panel 2: About Me Teaser -->
      <div class="home-tab-panel" id="panel-about" role="tabpanel" aria-label="About Me Panel" style="display: none;">
        <p class="home-about__tagline">
          Get to know the designer behind the work — my background, training, and the transdisciplinary thinking that shapes each individual project. Fusing leadership with parametric tools and physical fabrication.
        </p>
        
        <div class="home-about__links">
          <a href="/advaita-kelkar-cv.pdf" class="home-link-row" target="_blank" rel="noopener">
            <span class="home-link-row__text">Curriculum Vitae</span>
            <span class="home-link-row__arrow" aria-hidden="true">
              <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                <line x1="6" y1="18" x2="18" y2="6"></line>
                <polyline points="10 6 18 6 18 14"></polyline>
              </svg>
            </span>
          </a>

          <a href="/advaita-kelkar-portfolio.pdf" class="home-link-row" target="_blank" rel="noopener">
            <span class="home-link-row__text">Portfolio (PDF)</span>
            <span class="home-link-row__arrow" aria-hidden="true">
              <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                <line x1="6" y1="18" x2="18" y2="6"></line>
                <polyline points="10 6 18 6 18 14"></polyline>
              </svg>
            </span>
          </a>

          <a href="/about" class="home-link-row">
            <span class="home-link-row__text">More About Me</span>
            <span class="home-link-row__arrow" aria-hidden="true">
              <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                <line x1="6" y1="18" x2="18" y2="6"></line>
                <polyline points="10 6 18 6 18 14"></polyline>
              </svg>
            </span>
          </a>
        </div>
      </div>

      <!-- Panel 3: Stacking Portfolio Cards -->
      <div class="home-tab-panel" id="panel-portfolio" role="tabpanel" aria-label="Portfolio Panel" style="display: none;">
        <div class="home-projects-deck">
          {sorted.map((p, idx) => (
            <div class="home-project-card" style={`--card-index: ${idx};`}>
              <a href={`/projects/${p.id}`} class="home-project-card__link">
                <div class="home-project-card__details">
                  <div class="home-project-card__top">
                    <span class="home-project-card__collab">{p.data.collaborator || 'Advaita Kelkar'}</span>
                    <span class="home-project-card__dot-sep">·</span>
                    <span class="home-project-card__tag-cat">
                      {p.data.tags?.[0] ? (tagMap[p.data.tags[0].id] ?? p.data.tags[0].id) : (p.data.category ? (catMap[p.data.category.id] ?? p.data.category.id) : 'Design')}
                    </span>
                    <span class="home-project-card__stacked-title">
                      <span class="home-project-card__dot-sep">·</span>
                      <span class="stacked-name">{p.data.name}</span>
                    </span>
                  </div>
                  <div class="home-project-card__mid">
                    <h3 class="home-project-card__title">{p.data.name}</h3>
                    <div class="home-project-card__meta-grid">
                      <div class="meta-item">
                        <span class="meta-label text-muted">Year</span>
                        <span class="meta-val">{p.data.year}</span>
                      </div>
                      {p.data.location && (
                        <div class="meta-item">
                          <span class="meta-label text-muted">Location</span>
                          <span class="meta-val">{p.data.location}</span>
                        </div>
                      )}
                    </div>
                  </div>
                  <div class="home-project-card__bottom">
                    {p.data.smallIntro && (
                      <p class="home-project-card__desc text-muted">{p.data.smallIntro}</p>
                    )}
                  </div>
                </div>
                
                <div class="home-project-card__img-wrap soft-image-container">
                  {p.data.coverImage ? (
                    <img src={p.data.coverImage} alt={p.data.name} loading="lazy" />
                  ) : (
                    <div class="home-project-card__placeholder" />
                  )}
                  <span class="home-project-card__arrow" aria-hidden="true">
                    <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="square" stroke-linejoin="miter">
                      <line x1="6" y1="18" x2="18" y2="6"></line>
                      <polyline points="10 6 18 6 18 14"></polyline>
                    </svg>
                  </span>
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

</PageLayout>

<!-- ══ DATA + JS ══════════════════════════════════════════════ -->
<script define:vars={{ projectsJson }}>
  // ── Quick Search ────────────────────────────────────────────
  const projects = JSON.parse(projectsJson);
  const grid     = document.getElementById('qs-grid');
  const input    = document.getElementById('qs-input');
  const clearBtn = document.getElementById('qs-clear');
  const count    = document.getElementById('qs-count');

  function buildRow(p) {
    const el = document.createElement('a');
    el.href      = `/projects/${p.id}`;
    el.className = 'qs-row';
    el.setAttribute('role', 'listitem');
    el.innerHTML = `
      <span class="qs-row__meta">
        <span class="qs-row__tag">${p.tag || p.cat || '—'}</span>
        <span class="qs-row__year">${p.year}</span>
      </span>
      <span class="qs-row__name">${p.name}</span>
      <span class="qs-row__arrow" aria-hidden="true">
        <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" style="width:12px;height:12px;">
          <line x1="6" y1="18" x2="18" y2="6"></line>
          <polyline points="10 6 18 6 18 14"></polyline>
        </svg>
      </span>
    `;
    return el;
  }

  function render(query) {
    if (!grid) return;
    const q = query.trim().toLowerCase();
    let matches;
    if (q) {
      const keywords = q.split(/\s+/).filter(Boolean);
      matches = projects.filter(p => {
        return keywords.every(kw => 
          p.name.toLowerCase().includes(kw) ||
          p.tags.toLowerCase().includes(kw)  ||
          p.cat.toLowerCase().includes(kw)  ||
          p.year.includes(kw) ||
          (p.loc && p.loc.toLowerCase().includes(kw)) ||
          (p.client && p.client.toLowerCase().includes(kw)) ||
          (p.status && p.status.toLowerCase().includes(kw)) ||
          (p.size && p.size.toLowerCase().includes(kw)) ||
          (p.program && p.program.toLowerCase().includes(kw))
        );
      });
    } else {
      matches = projects;
    }

    grid.innerHTML = '';
    matches.forEach(p => grid.appendChild(buildRow(p)));
    if (count) {
      count.textContent =
        `Results ${projects.length}   Showing Items 1 to ${matches.length} of ${projects.length}`;
    }
  }

  render('');

  input?.addEventListener('input', () => render(input.value));
  clearBtn?.addEventListener('click', () => { if (input) { input.value = ''; render(''); input.focus(); } });

  // ── Slider ──────────────────────────────────────────────────
  const track = document.getElementById('slider-track');
  const dots  = Array.from(document.querySelectorAll('.home-slider__dot'));

  if (track && dots.length > 1) {
    let current = 0;
    let timer;
    const slides = Array.from(track.querySelectorAll('.home-slider__slide'));

    function setActive(idx) {
      current = (idx + slides.length) % slides.length;
      slides[current].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
      dots.forEach((d, i) => {
        d.classList.toggle('is-active', i === current);
        d.setAttribute('aria-selected', String(i === current));
      });
    }

    function startAuto() { timer = setInterval(() => setActive(current + 1), 3000); }
    function stopAuto()  { clearInterval(timer); }

    startAuto();

    dots.forEach((d, i) => d.addEventListener('click', () => { stopAuto(); setActive(i); startAuto(); }));
    track.addEventListener('mouseenter', stopAuto);
    track.addEventListener('mouseleave', startAuto);

    // Sync dots on scroll
    const io = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) {
          const idx = parseInt((e.target as HTMLElement).dataset.index ?? '0');
          dots.forEach((d, i) => {
            d.classList.toggle('is-active', i === idx);
            d.setAttribute('aria-selected', String(i === idx));
          });
          current = idx;
        }
      }),
      { root: track, threshold: 0.5 }
    );
    slides.forEach(s => io.observe(s));
  }

  // ── Tab Switching ───────────────────────────────────────────
  const tabs = document.querySelectorAll('.home-tab-btn');
  const panels = document.querySelectorAll('.home-tab-panel');
  const infoSection = document.getElementById('home-info-section');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab;
      
      tabs.forEach((t) => {
        const isMatched = t === tab;
        t.classList.toggle('is-active', isMatched);
        t.setAttribute('aria-selected', String(isMatched));
      });

      panels.forEach((p) => {
        const isMatched = p.id === `panel-${target}`;
        const panelEl = p as HTMLElement;
        if (isMatched) {
          panelEl.style.display = target === 'qs' ? 'block' : 'flex';
          panelEl.offsetHeight; // Reflow
          panelEl.classList.add('is-active');
        } else {
          panelEl.classList.remove('is-active');
          panelEl.style.display = 'none';
        }
      });

      // Reset scroll position of career section to start from top
      if (infoSection) {
        infoSection.scrollTop = 0;
      }

      // Re-trigger scroll stacking check for cards in new tab
      setTimeout(handleHomeCardStacking, 50);
    });
  });

  // ── Scroll-Driven Stacking Cards ────────────────────────────
  const homeCards = infoSection?.querySelectorAll('.home-project-card') ?? [];

  function handleHomeCardStacking() {
    if (!infoSection) return;
    const isMobile = window.innerWidth <= 768;

    homeCards.forEach((card) => {
      const cardEl = card as HTMLElement;
      
      // Skip if card belongs to a hidden panel
      if (cardEl.closest('.home-tab-panel')?.style.display === 'none') {
        cardEl.classList.remove('is-stacked');
        return;
      }

      if (isMobile) {
        cardEl.classList.remove('is-stacked');
        return;
      }

      const rect = cardEl.getBoundingClientRect();
      const computedTop = parseFloat(window.getComputedStyle(cardEl).top);
      // Stuck check
      const isStacked = rect.top <= computedTop + 2;
      cardEl.classList.toggle('is-stacked', isStacked);
    });
  }

  // Listen to scrolling within the Section 2 info container
  infoSection?.addEventListener('scroll', handleHomeCardStacking, { passive: true });
  window.addEventListener('resize', handleHomeCardStacking, { passive: true });

  // Run initial stack checks
  handleHomeCardStacking();
</script>

<style>
  /* ══ Global Snapping Scope ══════════════════════════════════ */
  :global(html) {
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
  }

  :global(.page-main) {
    padding: 0 !important; /* overrides standard page padding for fullscreen snapping */
  }

  /* ── Breadcrumb: fixed overlay (home page full-screen snap) ── */
  :global(.page-breadcrumb) {
    position: fixed !important;
    top: 0 !important;
    left: 64px !important;
    right: 0 !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    z-index: 150;
    padding-inline: var(--_tokens---space--small) !important;
    background-color: transparent !important;
    margin-bottom: 0 !important;
  }

  /* ══ Snapped Layout Sections ════════════════════════════════ */
  .home-section {
    scroll-snap-align: start;
    height: 100dvh;
    min-height: 100dvh;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-inline: var(--_tokens---space--small);
    transition: padding 0.3s ease;
    overflow: hidden;
  }

  .home-section--hero {
    justify-content: flex-start;
    gap: 20px;
    padding-top: calc(clamp(2rem, 5vh, 3rem) + 48px); /* 48px for fixed breadcrumb */
    padding-bottom: 24px;
    overflow: hidden; /* clip slider to section */
  }

  .home-section--info {
    justify-content: flex-start;
    padding-top: calc(clamp(2rem, 4vh, 3rem) + 48px); /* 48px for fixed breadcrumb */
    overflow-y: auto; /* scrollable card deck & search */
    position: relative;
    scrollbar-width: thin;
  }

  /* ══ 1. Intro ═══════════════════════════════════════════════ */
  .home-intro {
    display: flex;
    flex-direction: column;
    width: 100%;
    margin-bottom: 8px;
  }

  .home-intro__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    width: 100%;
    margin-bottom: 8px;
  }

  .home-intro__label {
    font-size: var(--_tokens---type--micro);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--_tokens---color--fg);
    margin: 0;
  }

  .home-intro__body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    width: 100%;
  }

  .home-intro__column {
    display: flex;
    flex-direction: column;
  }

  .home-intro__desc {
    font-size: var(--_tokens---type--small);
    line-height: 1.65;
    color: var(--_tokens---color--muted);
    margin: 0;
  }

  /* ══ 2. Slider ══════════════════════════════════════════════ */
  .home-slider {
    width: 100%;
    flex: 1;           /* fill remaining height in hero flex column */
    min-height: 0;     /* allow shrinking below content size */
    display: flex;
    flex-direction: column;
  }

  .home-slider__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    gap: 32px;
    flex: 1;           /* fill the slider's column space */
    min-height: 180px;
  }

  .home-slider__track::-webkit-scrollbar { display: none; }

  .home-slider__slide {
    flex: 0 0 calc(60% - 16px);
    scroll-snap-align: start;
    position: relative;
    display: block;
    text-decoration: none;
    color: var(--_tokens---color--fg);
    overflow: hidden;
    height: 100%;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    border-radius: 8px;
  }

  .home-slider__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .home-slider__slide:hover img { transform: scale(1.04); }

  .home-slider__placeholder {
    width: 100%;
    height: 100%;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
  }

  .home-slider__caption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 32px 24px 20px;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 100%);
    pointer-events: none;
    z-index: 5;
  }

  .home-slider__name {
    font-size: var(--_tokens---type--small);
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #fff;
    text-shadow: 0 1px 3px rgba(0,0,0,0.4);
  }

  .home-slider__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    color: #fff;
    opacity: 0.85;
  }
  
  .home-slider__arrow .link-arrow {
    width: 14px;
    height: 14px;
  }

  .link-arrow {
    width: 1em;
    height: 1em;
    vertical-align: middle;
    display: inline-block;
  }

  .home-slider__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 16px 0 0;
  }

  .home-slider__dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    border: none;
    background-color: var(--_tokens---color--muted);
    cursor: pointer;
    padding: 0;
    transition: background-color 0.2s, transform 0.2s;
  }

  .home-slider__dot.is-active {
    background-color: var(--_tokens---color--fg);
    transform: scale(1.3);
  }

  /* ══ 3. Tabs Pill Menu ══════════════════════════════════════ */
  .home-tabs-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    width: 100%;
    margin-block: 16px;
    border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    padding-bottom: 12px;
    position: sticky;
    top: 0;
    z-index: 10;
    background-color: var(--_tokens---color--bg);
  }

  .home-tab-btn {
    font-size: var(--_tokens---type--micro);
    font-family: inherit;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: none;
    border: none;
    color: var(--_tokens---color--muted);
    padding: 10px 0;
    cursor: pointer;
    transition: background-color 0.25s ease, color 0.25s ease;
    text-align: center;
    border-radius: 6px;
  }

  .home-tab-btn:hover {
    color: var(--_tokens---color--fg);
  }

  .home-tab-btn.is-active {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  .home-tab-content {
    width: 100%;
    position: relative;
