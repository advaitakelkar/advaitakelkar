</style>

<script>
  // --- Profile banner (dummy personal-photo slider) ---
  const bslides = Array.from(document.querySelectorAll('.profile-banner__slide'));
  const bdots = Array.from(document.querySelectorAll('.profile-banner__dot'));
  if (bslides.length > 1) {
    let bcur = 0;
    let btimer: ReturnType<typeof setInterval>;
    function bset(i: number) {
      bcur = (i + bslides.length) % bslides.length;
      bslides.forEach((s, n) => s.classList.toggle('is-active', n === bcur));
      bdots.forEach((d, n) => d.classList.toggle('is-active', n === bcur));
    }
    function bstart() { btimer = setInterval(() => bset(bcur + 1), 3500); }
    function bstop() { clearInterval(btimer); }
    bstart();
    bdots.forEach((d, i) => d.addEventListener('click', () => { bstop(); bset(i); bstart(); }));
    const banner = document.querySelector('.profile-banner');
    banner?.addEventListener('mouseenter', bstop);
    banner?.addEventListener('mouseleave', bstart);
  }

  // --- Tab Switching ---
  const tabs = document.querySelectorAll('.about-tab-btn');
  const panels = document.querySelectorAll('.about-tab-panel');
  const careerSection = document.getElementById('panel-career-section');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab;
      
      tabs.forEach((t) => {
        const isMatched = t === tab;
        t.classList.toggle('is-active', isMatched);
        t.setAttribute('aria-selected', String(isMatched));
      });

      panels.forEach((p) => {
        const isMatched = p.id === `panel-${target}`;
        const panelEl = p as HTMLElement;
        if (isMatched) {
          panelEl.style.display = 'flex';
          panelEl.offsetHeight; // Reflow
          panelEl.classList.add('is-active');
        } else {
          panelEl.classList.remove('is-active');
          panelEl.style.display = 'none';
        }
      });

      // Reset scroll position of career section to start from top
      if (careerSection) {
        careerSection.scrollTop = 0;
      }

      // Re-trigger scroll staking check for cards in new tab
      setTimeout(handleAboutCardStacking, 50);
    });
  });

  // --- Scroll-Driven About Card Stacking ---
  const careerCards = careerSection?.querySelectorAll('.about-card') ?? [];

  function handleAboutCardStacking() {
    if (!careerSection) return;
    const isMobile = window.innerWidth <= 768;

    careerCards.forEach((card) => {
      const cardEl = card as HTMLElement;
      
      // Skip if card belongs to a hidden panel
      if (cardEl.closest('.about-tab-panel')?.style.display === 'none') {
        cardEl.classList.remove('is-stacked');
        return;
      }

      if (isMobile) {
        cardEl.classList.remove('is-stacked');
        return;
      }

      const rect = cardEl.getBoundingClientRect();
      const computedTop = parseFloat(window.getComputedStyle(cardEl).top);
      // Stuck check
      const isStacked = rect.top <= computedTop + 2;
      cardEl.classList.toggle('is-stacked', isStacked);
    });
  }

  // Listen to scrolling within the Section 2 career container
  careerSection?.addEventListener('scroll', handleAboutCardStacking, { passive: true });
  window.addEventListener('resize', handleAboutCardStacking, { passive: true });

  // --- Skillset Live Search ---
  const skillSearch = document.getElementById('skill-search') as HTMLInputElement;
  const skillCards = document.querySelectorAll('.skillset-card');

  skillSearch?.addEventListener('input', () => {
    const q = skillSearch.value.trim().toLowerCase();
    
    skillCards.forEach((card) => {
      const keywords = (card as HTMLElement).dataset.keywords ?? '';
      const isMatch = !q || keywords.includes(q);
      
      card.classList.toggle('is-hidden', !isMatch);
      
      // Highlight matching pills
      card.querySelectorAll('.skill-pill').forEach((pill) => {
        const text = pill.textContent?.toLowerCase() ?? '';
        pill.classList.toggle('is-highlighted', q && text.includes(q));
      });
    });
  });

  // Run initial stack checks
  handleAboutCardStacking();
</script>
