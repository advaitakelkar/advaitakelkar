---
import PageLayout from '../layouts/PageLayout.astro';

// Structured career experience data
const experience = [
  {
    title: "Fabrication Monitor",
    role: "On Campus Employment",
    company: "SCAD Foundation Studies",
    dates: "Nov 2024 - Present",
    location: "Savannah, United States",
    desc: "Fabrication Monitor | SCAD Foundation Studies: Responsible for maintaining studio facilities, tools, and equipment while ensuring adherence to safe work practices. Tasks included designing and fabricating jigs, shop fixtures, signage, display fixtures, and light-duty repairs, as well as painting and shop upkeep. (Part Time)"
  },
  {
    title: "ARCHV",
    role: "Founder",
    company: "ARCHV Collective",
    dates: "Nov 2024 - Present",
    location: "Savannah, United States",
    desc: "Founder at ARCHV: Established an inclusive collective focused on collaborative learning and creation, prioritizing passion over constraints of money and time. Facilitated transdisciplinary projects with diverse participation, driven by collective effort and a shared love for design and innovation. (Part Time)"
