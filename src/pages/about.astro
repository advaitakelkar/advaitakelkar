    dates: "2018 - 2021",
    location: "Mumbai, India",
    desc: "Started as intern in final BArch year; contributed to hospitality, commercial, research, and residential interiors under mentorship – fusing dynamic environments with professional growth."
  },
  {
    title: "Pragrup",
    role: "Bangalore Intern",
    company: "Pragrup",
    dates: "Jan 2016 - Jun 2016",
    location: "Bangalore, India",
    desc: "Hands-on full-scale builds; teamwork on wood houses, competitions, commercial spaces, and experimental graphics – transforming learning into real-world impact."
  },
  {
    title: "Hiray College of Architecture",
    role: "Bachelor of Architecture",
    company: "Hiray College of Architecture",
    dates: "2012 - 2019",
    location: "Mumbai, India",
    desc: "Built core principles through hands-on projects; dissolved theory into practical exploration, laying foundations for innovation."
  }
];

// Structured skillset categories
const skillsets = [
  {
    category: "Languages",
    skills: ["English (Fluent)", "Hindi (Native)", "Marathi (Native)"]
  },
  {
    category: "3D Modelling",
    skills: ["Rhinoceros 3D", "SketchUp", "AutoCAD", "Revit", "Lumion"]
  },
  {
    category: "Visualisation",
    skills: ["V-Ray", "Lumion", "Enscape", "Unreal Engine", "Midjourney AI"]
  },
  {
    category: "Graphic Design",
    skills: ["Adobe Illustrator", "Photoshop", "InDesign", "Canva"]
  },
  {
    category: "Web Design",
    skills: ["Webflow", "Figma", "Framer"]
  },
  {
    category: "Various",
    skills: ["Grasshopper", "Microsoft Office", "Notion", "Miro"]
  }
];
---

<PageLayout
  title="About Me"
  label="About"
  crumbs={[{ label: 'Home', href: '/' }, { label: 'About Me' }]}
>
  <article class="about-page">
    <!-- Bio Intro -->
    <section class="about-intro">
      <p class="about-intro__desc">
        Throughout my career, I've dissolved boundaries across scales—architecture, interiors, sculpture, graphic design, product design, and art—all converging in this virtual archive, my digital twin.
      </p>
    </section>

    <!-- CV and Portfolio link rows -->
    <div class="about-links" aria-label="Downloads and pages">
      <p class="about-links__note text-muted">Click on the links to access downloadable PDF versions</p>
      
      <a href="/advaita-kelkar-cv.pdf" class="about-link-row" target="_blank" rel="noopener">
        <span class="about-link-row__text">Curriculum Vitae</span>
        <span class="about-link-row__arrow" aria-hidden="true">
          <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <line x1="6" y1="18" x2="18" y2="6"></line>
            <polyline points="10 6 18 6 18 14"></polyline>
          </svg>
        </span>
      </a>

      <a href="/advaita-kelkar-portfolio.pdf" class="about-link-row" target="_blank" rel="noopener">
        <span class="about-link-row__text">Portfolio</span>
        <span class="about-link-row__arrow" aria-hidden="true">
          <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <line x1="6" y1="18" x2="18" y2="6"></line>
            <polyline points="10 6 18 6 18 14"></polyline>
          </svg>
        </span>
      </a>

      <a href="/projects" class="about-link-row">
        <span class="about-link-row__text">Projects</span>
        <span class="about-link-row__arrow" aria-hidden="true">
          <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
            <line x1="6" y1="18" x2="18" y2="6"></line>
            <polyline points="10 6 18 6 18 14"></polyline>
          </svg>
        </span>
      </a>
    </div>

    <!-- Career Tabs Section -->
    <section class="about-career">
      <div class="about-tabs-container" role="tablist" aria-label="Career sections">
        <button class="about-tab-btn is-active" role="tab" aria-selected="true" aria-controls="panel-about" data-tab="about">About Me</button>
        <button class="about-tab-btn" role="tab" aria-selected="false" aria-controls="panel-exhibitions" data-tab="exhibitions">Exhibitions</button>
        <button class="about-tab-btn" role="tab" aria-selected="false" aria-controls="panel-timeline" data-tab="timeline">Timeline</button>
      </div>

      <p class="about-career__tagline text-muted">Dissolving roles and evolutions: Professional journey from Mumbai teams to SCAD fabrication, always fusing leadership with innovation.</p>

      <div class="about-tab-content">
        <!-- Panel 1: About Me (Experience) -->
        <div class="about-tab-panel is-active" id="panel-about" role="tabpanel" aria-labelledby="tab-about">
          {experience.map((item) => (
            <div class="about-card">
              <div class="about-card__details">
                <div class="about-card__top">
                  <span class="about-card__collab">{item.company}</span>
                  <span class="about-card__dot-sep">·</span>
                  <span class="about-card__tag-cat">{item.role}</span>
                </div>
                <div class="about-card__mid">
                  <h3 class="about-card__title">{item.title}</h3>
                  <div class="about-card__meta-grid">
                    <div class="meta-item">
                      <span class="meta-label text-muted">Dates</span>
                      <span class="meta-val">{item.dates}</span>
                    </div>
                    <div class="meta-item">
                      <span class="meta-label text-muted">Location</span>
                      <span class="meta-val">{item.location}</span>
                    </div>
                  </div>
                </div>
                <div class="about-card__bottom">
                  <p class="about-card__desc text-muted">{item.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Panel 2: Exhibitions -->
        <div class="about-tab-panel" id="panel-exhibitions" role="tabpanel" aria-labelledby="tab-exhibitions" style="display: none;">
          {exhibitions.map((item) => (
            <div class="about-card">
              <div class="about-card__details">
                <div class="about-card__top">
                  <span class="about-card__collab">{item.company}</span>
                  <span class="about-card__dot-sep">·</span>
                  <span class="about-card__tag-cat">{item.role}</span>
                </div>
                <div class="about-card__mid">
                  <h3 class="about-card__title">{item.title}</h3>
                  <div class="about-card__meta-grid">
                    <div class="meta-item">
                      <span class="meta-label text-muted">Dates</span>
                      <span class="meta-val">{item.dates}</span>
                    </div>
                    <div class="meta-item">
                      <span class="meta-label text-muted">Location</span>
                      <span class="meta-val">{item.location}</span>
                    </div>
                  </div>
                </div>
                <div class="about-card__bottom">
                  <p class="about-card__desc text-muted">{item.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Panel 3: Timeline -->
        <div class="about-tab-panel" id="panel-timeline" role="tabpanel" aria-labelledby="tab-timeline" style="display: none;">
          {timeline.map((item) => (
            <div class="about-card">
              <div class="about-card__details">
                <div class="about-card__top">
                  <span class="about-card__collab">{item.company}</span>
                  <span class="about-card__dot-sep">·</span>
                  <span class="about-card__tag-cat">{item.role}</span>
                </div>
                <div class="about-card__mid">
                  <h3 class="about-card__title">{item.title}</h3>
                  <div class="about-card__meta-grid">
                    <div class="meta-item">
                      <span class="meta-label text-muted">Dates</span>
                      <span class="meta-val">{item.dates}</span>
                    </div>
                    <div class="meta-item">
                      <span class="meta-label text-muted">Location</span>
                      <span class="meta-val">{item.location}</span>
                    </div>
                  </div>
                </div>
                <div class="about-card__bottom">
                  <p class="about-card__desc text-muted">{item.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Skillset Section -->
    <section class="about-skillset">
      <div class="skillset-header">
        <h2 class="skillset-title">Skillset</h2>
        <p class="skillset-subtitle text-muted">A searchable interface that blends all projects—academic, work, free, and experiments—into one seamless digital archive for holistic discovery</p>
        <div class="skillset-search">
          <input
            type="search"
            id="skill-search"
            class="skillset-search-input"
            placeholder="Search skillset (e.g. Rhinoceros, Figma, V-Ray, English...)"
            autocomplete="off"
            aria-label="Search skills"
          />
        </div>
      </div>

      <div class="skillset-grid">
        {skillsets.map((set) => (
          <div class="skillset-card" data-keywords={`${set.category} ${set.skills.join(' ')}`.toLowerCase()}>
            <h3 class="skillset-card__title">{set.category}</h3>
            <div class="skill-pills">
              {set.skills.map((skill) => (
                <a
                  href={`/projects?search=${encodeURIComponent(skill.replace(/\s*\(.*\)\s*/g, ''))}`}
                  class="skill-pill"
                  title={`Click to view projects using ${skill}`}
                >
                  {skill}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  </article>
</PageLayout>

<style>
  .about-page {
    padding-block: var(--_tokens---space--medium);
  }

  .about-intro {
    margin-bottom: 32px;
  }

  .about-intro__desc {
    font-size: var(--_tokens---type--small);
    line-height: 1.7;
    color: var(--_tokens---color--fg);
    max-width: 84ch;
    margin: 0;
  }

  /* Curriculum Vitae / Portfolio download link rows */
  .about-links {
    display: flex;
    flex-direction: column;
    margin-bottom: 48px;
    width: 100%;
  }

  .about-links__note {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    letter-spacing: 0.04em;
    margin-bottom: 12px;
  }

  .about-link-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-decoration: none;
    color: var(--_tokens---color--fg);
    border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    padding-block: 22px;
    transition: opacity 0.2s ease, padding-left 0.2s ease;
  }

  .about-link-row:last-child {
    border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
  }

  .about-link-row:hover {
    opacity: 0.75;
    padding-left: 8px;
  }

  .about-link-row__text {
    font-size: var(--_tokens---type--big);
    font-weight: 500;
    line-height: 0.95;
    letter-spacing: -0.03em;
  }

  .about-link-row__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about-link-row:hover .about-link-row__arrow {
    transform: rotate(45deg);
  }

  .link-arrow {
    width: 100%;
    height: 100%;
  }

  /* Career Tabs Pill Menu */
  .about-tabs-container {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-block: 48px 24px;
    border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    padding-bottom: 16px;
  }

  .about-tab-btn {
    font-size: var(--_tokens---type--micro);
    font-family: inherit;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: none;
    border: none;
    color: var(--_tokens---color--muted);
    padding: 8px 20px;
    border-radius: 20px;
    cursor: pointer;
    transition: background-color 0.25s ease, color 0.25s ease;
  }

  .about-tab-btn:hover {
    color: var(--_tokens---color--fg);
  }

  .about-tab-btn.is-active {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  .about-career__tagline {
    font-size: var(--_tokens---type--micro);
    line-height: 1.5;
    text-align: center;
    max-width: 80ch;
    margin-inline: auto;
    margin-bottom: 32px;
  }

  /* Tab Panel Transitions */
  .about-tab-panel {
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about-tab-panel.is-active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Career experience cards (matching projects cards layout) */
  .about-card {
    width: 100%;
    box-sizing: border-box;
    border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    padding-top: 24px;
    padding-bottom: 24px;
    transition: opacity 0.3s ease;
  }

  .about-card:hover {
    opacity: 0.85;
  }

  .about-card__top {
    display: flex;
    align-items: center;
    gap: 0;
    font-size: var(--_tokens---type--micro);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--_tokens---color--muted);
    margin-bottom: 8px;
  }

  .about-card__collab {
    color: var(--_tokens---color--fg);
    font-weight: 600;
  }

  .about-card__tag-cat {
    color: var(--_tokens---color--muted);
  }

  .about-card__dot-sep {
    margin-inline: 8px;
    color: color-mix(in srgb, var(--_tokens---color--fg) 25%, transparent);
    font-weight: 300;
  }

  .about-card__title {
    font-size: var(--_tokens---type--medium);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0 0 12px 0;
    color: var(--_tokens---color--fg);
  }

  .about-card__meta-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 16px;
    margin-bottom: 12px;
  }

  .meta-item {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .meta-label {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .meta-val {
    font-size: var(--_tokens---type--micro);
    font-weight: 400;
    color: var(--_tokens---color--fg);
  }

  .about-card__desc {
    font-size: var(--_tokens---type--micro);
    line-height: 1.6;
    max-width: 80ch;
    margin: 0;
  }

  /* Skillset Section */
  .about-skillset {
    margin-top: 64px;
    border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    padding-top: 48px;
  }

  .skillset-title {
    font-size: var(--_tokens---type--medium);
    font-weight: 700;
    color: var(--_tokens---color--fg);
    letter-spacing: -0.01em;
    margin: 0 0 12px 0;
  }

  .skillset-subtitle {
    font-size: var(--_tokens---type--micro);
    line-height: 1.5;
    max-width: 76ch;
    margin: 0 0 24px 0;
  }

  .skillset-search {
    margin-bottom: 32px;
    width: 100%;
  }

  .skillset-search-input {
    width: 100%;
    height: 48px;
    padding: 0 16px;
    font-size: var(--_tokens---type--small);
    font-family: inherit;
    background: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    color: var(--_tokens---color--fg);
    border-radius: 8px;
    outline: none;
    transition: background-color 0.2s;
  }

  .skillset-search-input::placeholder {
    color: var(--_tokens---color--muted);
  }

  .skillset-search-input:focus {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
  }

  /* 3-column Skillset Grid */
  .skillset-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .skillset-card {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 4%, transparent);
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    border-radius: 8px;
    padding: 20px;
    transition: opacity 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
  }

  .skillset-card:hover {
    border-color: color-mix(in srgb, var(--_tokens---color--fg) 18%, transparent);
  }

  .skillset-card.is-hidden {
    opacity: 0.15;
    transform: scale(0.98);
  }

  .skillset-card__title {
    font-size: var(--_tokens---type--micro);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--_tokens---color--fg);
    margin: 0 0 16px 0;
    border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
    padding-bottom: 8px;
  }

  .skill-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .skill-pill {
    font-size: var(--_tokens---type--micro);
    font-weight: 400;
    color: var(--_tokens---color--muted);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    border-radius: 4px;
    padding: 4px 10px;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .skill-pill:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    transform: translateY(-1px);
  }

  .skill-pill.is-highlighted {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    box-shadow: 0 0 8px color-mix(in srgb, var(--_tokens---color--fg) 40%, transparent);
  }

  @media (max-width: 900px) {
    .skillset-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .about-link-row__text {
      font-size: var(--_tokens---type--medium);
    }
    .about-tabs-container {
      gap: 8px;
      flex-wrap: wrap;
    }
    .about-tab-btn {
      padding: 6px 12px;
    }
    .skillset-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // --- Tab Switching ---
  const tabs = document.querySelectorAll('.about-tab-btn');
  const panels = document.querySelectorAll('.about-tab-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab;
      
      tabs.forEach((t) => {
        const isMatched = t === tab;
        t.classList.toggle('is-active', isMatched);
        t.setAttribute('aria-selected', String(isMatched));
      });

      panels.forEach((p) => {
        const isMatched = p.id === `panel-${target}`;
        const panelEl = p as HTMLElement;
        if (isMatched) {
          panelEl.style.display = 'flex';
          // Force layout recalculation to trigger CSS transitions
          panelEl.offsetHeight;
          panelEl.classList.add('is-active');
        } else {
          panelEl.classList.remove('is-active');
          panelEl.style.display = 'none';
        }
      });
    });
  });

  // --- Skillset Live Search ---
  const skillSearch = document.getElementById('skill-search') as HTMLInputElement;
  const skillCards = document.querySelectorAll('.skillset-card');

  skillSearch?.addEventListener('input', () => {
    const q = skillSearch.value.trim().toLowerCase();
    
    skillCards.forEach((card) => {
      const keywords = (card as HTMLElement).dataset.keywords ?? '';
      const isMatch = !q || keywords.includes(q);
      
      card.classList.toggle('is-hidden', !isMatch);
      
      // Highlight matching pill elements
      card.querySelectorAll('.skill-pill').forEach((pill) => {
        const text = pill.textContent?.toLowerCase() ?? '';
        pill.classList.toggle('is-highlighted', q && text.includes(q));
      });
    });
  });
</script>
