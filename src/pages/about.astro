    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    color: var(--_tokens---color--muted);
    margin: 0;
  }

</style>

<script>
  // --- Career Cards: click opens/closes ---
  document.querySelectorAll('.about-card').forEach((card) => {
    const el = card as HTMLElement;
    el.addEventListener('click', (e) => {
      // Prevent toggling if clicking a link or button inside the card
      if ((e.target as HTMLElement).closest('a, button')) return;
      el.classList.toggle('is-open');
    });
  });

  // --- Education Pills: click opens/closes ---
  document.querySelectorAll('.education-pill__trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const btn = trigger as HTMLButtonElement;
      const pill = btn.closest('.education-pill') as HTMLElement | null;
      if (pill) pill.classList.toggle('is-open');
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isExpanded));
    });
  });

  // --- Biography Read More Toggle ---
  const readMoreBtn = document.getElementById('bio-read-more-btn');
  const collapsedContent = document.getElementById('bio-collapsed-content');
  
  const toggleBio = () => {
    if (collapsedContent && readMoreBtn) {
      const isHidden = collapsedContent.style.display === 'none';
      collapsedContent.style.display = isHidden ? 'block' : 'none';
      const span = readMoreBtn.querySelector('span');
      if (span) span.textContent = isHidden ? 'Read Less' : 'Read More';
    }
  };

  readMoreBtn?.addEventListener('click', toggleBio);
  collapsedContent?.addEventListener('click', toggleBio);

  // --- Tab Switching ---
  const tabs = document.querySelectorAll('.about-tab-btn');
  const panels = document.querySelectorAll('.about-tab-panel');
  const careerSection = document.getElementById('panel-career-section');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab;
      
      tabs.forEach((t) => {
        const isMatched = t === tab;
        t.classList.toggle('is-active', isMatched);
        t.setAttribute('aria-selected', String(isMatched));
      });

      panels.forEach((p) => {
        const isMatched = p.id === `panel-${target}`;
        const panelEl = p as HTMLElement;
        if (isMatched) {
          panelEl.style.display = 'flex';
          panelEl.offsetHeight; // Reflow
          panelEl.classList.add('is-active');
        } else {
          panelEl.classList.remove('is-active');
          panelEl.style.display = 'none';
        }
      });

      // Reset scroll position of career section to start from top
      if (careerSection) {
        if (window.innerWidth <= 768) {
          const y = careerSection.getBoundingClientRect().top + window.pageYOffset - 48;
          window.scrollTo({ top: y, behavior: 'smooth' });
        } else {
          careerSection.scrollTop = 0;
        }
      }
    });
  });

  // --- Skillset Live Search ---
  const skillSearch = document.getElementById('skill-search') as HTMLInputElement;
  const skillCards = document.querySelectorAll('.skillset-card');

  skillSearch?.addEventListener('input', () => {
    const q = skillSearch.value.trim().toLowerCase();
    
    skillCards.forEach((card) => {
      const keywords = (card as HTMLElement).dataset.keywords ?? '';
      const isMatch = !q || keywords.includes(q);
      
      card.classList.toggle('is-hidden', !isMatch);
      
      // Highlight matching pills
      card.querySelectorAll('.skill-pill').forEach((pill) => {
        const text = pill.textContent?.toLowerCase() ?? '';
        pill.classList.toggle('is-highlighted', q && text.includes(q));
      });
    });
  });

  // (Removed: the JS "dynamic stack" pill row-builder that measured and
  // force-set pill widths — it was stretching every pill into a full-width
  // bar. The pills now flow naturally via flex-wrap, like the footer.)

  // --- Active Status Scramble Loop ---
  let activeStatusIntervals: number[] = [];
  let activeStatusFrames: number[] = [];

  function initActiveStatus() {
    activeStatusIntervals.forEach(clearTimeout);
    activeStatusFrames.forEach(cancelAnimationFrame);
    activeStatusIntervals = [];
    activeStatusFrames = [];

    const activeElements = document.querySelectorAll('.active-status-text');
    if (!activeElements.length) return;

    const GLYPHS = '01XYZ%$#@?*+=#-_[]{}<>/';
    const targetText = 'ACTIVE';
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    activeElements.forEach((el, idx) => {
      const activeEl = el as HTMLElement;

      // Disable the looping scramble on mobile, or when the OS asks for reduced motion
      if (reduceMotion || window.innerWidth <= 640) {
        activeEl.textContent = 'ACTIVE';
        return;
      }
      
      function scramble() {
        let frame = 0;
        const length = targetText.length;
        const queue: Array<{ from: string; to: string; start: number; end: number; char?: string }> = [];
        
        for (let i = 0; i < length; i++) {
          const start = Math.floor(Math.random() * 8);
          const end = start + Math.floor(Math.random() * 12) + 4;
          queue.push({ from: '', to: targetText[i], start, end });
        }
        
        function tick() {
          let output = '';
          let complete = 0;
          
          for (let i = 0; i < length; i++) {
            let { to, start, end, char } = queue[i];
            if (frame >= end) {
              complete++;
              output += to;
            } else if (frame >= start) {
              if (!char || Math.random() < 0.28) {
                char = GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
                queue[i].char = char;
              }
              output += char;
            } else {
              output += ' ';
            }
          }
          
          activeEl.textContent = output;
          
          if (complete === length) {
            activeEl.textContent = targetText;
            activeStatusIntervals[idx] = window.setTimeout(scramble, 2000);
          } else {
            frame++;
            activeStatusFrames[idx] = requestAnimationFrame(tick);
          }
        }
        
        tick();
      }
      
      scramble();
    });
  }

  function setupScrollToTop() {
    const nameHeader = document.querySelector('.profile-name');
    nameHeader?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
  setupScrollToTop();

  document.addEventListener('astro:after-swap', () => {
      initActiveStatus();
    setupScrollToTop();
  });
</script>
