---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="About"
  label="About"
  crumbs={[{ label: 'Home', href: '/' }, { label: 'About' }]}
>
  <article class="about-page measure">
    <header class="about-header">
      <h1 class="about-name">Advaita Kelkar</h1>
      <p class="about-role text-muted">Architect · Designer · Researcher</p>
    </header>

    <section class="about-bio">
      <p>
        I'm an architect and designer currently completing a Master of Architecture at SCAD,
        Savannah. My practice moves between interior, architecture, product, and visual
        design — with a persistent interest in material honesty, spatial research, and the
        design of civic and public environments.
      </p>
      <p>
        Before SCAD, I worked in Mumbai — collaborating with Faizan Khatri and Studio 823
        on a range of hospitality and residential projects, and independently through ARCHV,
        a design research collective exploring installation, urbanism, and digital space.
      </p>
      <p>
        I'm interested in architecture that is specific to its place and time — work that
        carries the weight of research without losing warmth or wit.
      </p>
    </section>

    <section class="about-section">
      <h2 class="about-section__label">Education</h2>
      <ul class="about-list">
        <li>MArch — SCAD, Savannah (2024–present)</li>
        <li>BArch — Rizvi College of Architecture, Mumbai (2016–2021)</li>
      </ul>
    </section>

    <section class="about-section">
      <h2 class="about-section__label">Collaborators</h2>
      <ul class="about-list">
        <li><a href="/type/faizan-khatri">Faizan Khatri</a></li>
        <li><a href="/type/studio-823">Studio 823</a></li>
        <li><a href="/type/archv">ARCHV Collective</a></li>
      </ul>
    </section>

    <section class="about-section">
      <h2 class="about-section__label">Contact</h2>
      <p><a href="mailto:advaitakelkar@gmail.com">advaitakelkar@gmail.com</a></p>
    </section>
  </article>
</PageLayout>

<style>
  .about-page {
    max-width: var(--_tokens---layout--measure);
    padding-block: var(--_tokens---space--medium);
  }

  .about-header {
    margin-bottom: var(--_tokens---space--medium);
  }

  .about-name {
    font-size: var(--_tokens---type--big);
    font-weight: 600;
    line-height: 1.05;
    color: var(--_tokens---color--fg);
    margin-bottom: 0.25em;
  }

  .about-role {
    font-size: var(--_tokens---type--small);
  }

  .about-bio {
    display: flex;
    flex-direction: column;
    gap: 1em;
    margin-bottom: var(--_tokens---space--medium);
    font-size: var(--_tokens---type--small);
    line-height: 1.65;
    color: var(--_tokens---color--fg);
    border-top: 1px solid var(--_tokens---color--line);
    padding-top: var(--_tokens---space--small);
  }

  .about-section {
    margin-bottom: var(--_tokens---space--small);
    padding-top: var(--_tokens---space--small);
    border-top: 1px solid var(--_tokens---color--line);
  }

  .about-section__label {
    font-size: var(--_tokens---type--micro);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--_tokens---color--muted);
    margin-bottom: 0.75em;
  }

  .about-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4em;
    font-size: var(--_tokens---type--small);
    color: var(--_tokens---color--fg);
  }

  a {
    color: var(--_tokens---color--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s ease;
  }

  a:hover {
    opacity: 0.7;
  }
</style>
