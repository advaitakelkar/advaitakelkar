    overflow: hidden;
    padding-bottom: 0;
    transition: padding-bottom 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .education-pill.is-open .education-pill__content-inner {
    padding-bottom: 16px;
  }

