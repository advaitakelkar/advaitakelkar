// Arrow SVG reused across all cards
const arrowSvg = `<svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>`;
---

<PageLayout
  title="About Me"
  label="About"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'About Me' }
  ]}
>
  <article class="about-page">

    <!-- ══ Section 1: Intro + Career (everything except skillset) ══ -->
    <section class="about-section-snap about-section--career" id="panel-career-section">

      <!-- Intro paragraph -->
      <div class="about-intro">
        <p class="about-intro__desc">
          Throughout my career, I've dissolved boundaries across scales—architecture, interiors, sculpture, graphic design, product design, and art—all converging in this virtual archive, my digital twin.
        </p>
      </div>

      <!-- Download / page links -->
      <div class="about-links" aria-label="Downloads and pages">
        <p class="about-links__note text-muted">Click on the links to access downloadable PDF versions</p>

        <a href="/advaita-kelkar-cv.pdf" class="about-link-row" target="_blank" rel="noopener">
          <span class="about-link-row__text">Curriculum Vitae</span>
          <span class="about-link-row__arrow" aria-hidden="true">
            <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <line x1="6" y1="18" x2="18" y2="6"></line>
              <polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </span>
        </a>

        <a href="/advaita-kelkar-portfolio.pdf" class="about-link-row" target="_blank" rel="noopener">
          <span class="about-link-row__text">Portfolio</span>
          <span class="about-link-row__arrow" aria-hidden="true">
            <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <line x1="6" y1="18" x2="18" y2="6"></line>
              <polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </span>
        </a>

        <a href="/projects" class="about-link-row">
          <span class="about-link-row__text">Projects</span>
          <span class="about-link-row__arrow" aria-hidden="true">
            <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <line x1="6" y1="18" x2="18" y2="6"></line>
              <polyline points="10 6 18 6 18 14"></polyline>
            </svg>
          </span>
        </a>
      </div>

      <!-- Career Tabs — compact flex, sticky within scroll container -->
      <div class="about-tabs-container" role="tablist" aria-label="Career sections">
        <button class="about-tab-btn is-active" role="tab" aria-selected="true" aria-controls="panel-about" data-tab="about">About Me</button>
        <button class="about-tab-btn" role="tab" aria-selected="false" aria-controls="panel-exhibitions" data-tab="exhibitions">Exhibitions</button>
        <button class="about-tab-btn" role="tab" aria-selected="false" aria-controls="panel-timeline" data-tab="timeline">Timeline</button>
      </div>

      <p class="about-career__tagline text-muted">Dissolving roles and evolutions: Professional journey from Mumbai teams to SCAD fabrication, always fusing leadership with innovation.</p>

      <div class="about-tab-content">

        <!-- Panel 1: About Me (Experience) -->
        <div class="about-tab-panel is-active" id="panel-about" role="tabpanel" aria-labelledby="tab-about">
          {experience.map((item, idx) => (
            <div class="about-card" style={`--card-index: ${idx};`}>
              <!-- Strip: always visible when stacked -->
              <div class="about-card__strip">
                <span class="about-card__collab">{item.company}</span>
                <span class="about-card__dot-sep">·</span>
                <span class="about-card__role">{item.role}</span>
                <span class="about-card__stacked-title">
                  <span class="about-card__dot-sep">·</span>
                  <span class="stacked-name">{item.title}</span>
                </span>
              </div>
              <!-- Body: two-column, fades out when stacked -->
              <div class="about-card__body">
                <div class="about-card__left">
                  <h3 class="about-card__title">{item.title}</h3>
                  <div class="about-card__meta-grid">
                    <div class="meta-item">
                      <span class="meta-label text-muted">Dates</span>
                      <span class="meta-val">{item.dates}</span>
                    </div>
                    <div class="meta-item">
                      <span class="meta-label text-muted">Location</span>
                      <span class="meta-val">{item.location}</span>
                    </div>
                  </div>
                </div>
                <div class="about-card__right">
                  <p class="about-card__desc text-muted">{item.desc}</p>
                  <span class="about-card__arrow" aria-hidden="true">
                    <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                      <line x1="6" y1="18" x2="18" y2="6"></line>
                      <polyline points="10 6 18 6 18 14"></polyline>
                    </svg>
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Panel 2: Exhibitions -->
        <div class="about-tab-panel" id="panel-exhibitions" role="tabpanel" aria-labelledby="tab-exhibitions" style="display: none;">
          {exhibitions.map((item, idx) => (
            <div class="about-card" style={`--card-index: ${idx};`}>
              <div class="about-card__strip">
                <span class="about-card__collab">{item.company}</span>
                <span class="about-card__dot-sep">·</span>
                <span class="about-card__role">{item.role}</span>
                <span class="about-card__stacked-title">
                  <span class="about-card__dot-sep">·</span>
                  <span class="stacked-name">{item.title}</span>
                </span>
              </div>
              <div class="about-card__body">
                <div class="about-card__left">
                  <h3 class="about-card__title">{item.title}</h3>
                  <div class="about-card__meta-grid">
                    <div class="meta-item">
                      <span class="meta-label text-muted">Dates</span>
                      <span class="meta-val">{item.dates}</span>
                    </div>
                    <div class="meta-item">
                      <span class="meta-label text-muted">Location</span>
                      <span class="meta-val">{item.location}</span>
                    </div>
                  </div>
                </div>
                <div class="about-card__right">
                  <p class="about-card__desc text-muted">{item.desc}</p>
                  <span class="about-card__arrow" aria-hidden="true">
                    <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                      <line x1="6" y1="18" x2="18" y2="6"></line>
                      <polyline points="10 6 18 6 18 14"></polyline>
                    </svg>
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Panel 3: Timeline -->
        <div class="about-tab-panel" id="panel-timeline" role="tabpanel" aria-labelledby="tab-timeline" style="display: none;">
          {timeline.map((item, idx) => (
            <div class="about-card" style={`--card-index: ${idx};`}>
              <div class="about-card__strip">
                <span class="about-card__collab">{item.company}</span>
                <span class="about-card__dot-sep">·</span>
                <span class="about-card__role">{item.role}</span>
                <span class="about-card__stacked-title">
                  <span class="about-card__dot-sep">·</span>
                  <span class="stacked-name">{item.title}</span>
                </span>
              </div>
              <div class="about-card__body">
                <div class="about-card__left">
                  <h3 class="about-card__title">{item.title}</h3>
                  <div class="about-card__meta-grid">
                    <div class="meta-item">
                      <span class="meta-label text-muted">Dates</span>
                      <span class="meta-val">{item.dates}</span>
                    </div>
                    <div class="meta-item">
                      <span class="meta-label text-muted">Location</span>
                      <span class="meta-val">{item.location}</span>
                    </div>
                  </div>
                </div>
                <div class="about-card__right">
                  <p class="about-card__desc text-muted">{item.desc}</p>
                  <span class="about-card__arrow" aria-hidden="true">
                    <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                      <line x1="6" y1="18" x2="18" y2="6"></line>
                      <polyline points="10 6 18 6 18 14"></polyline>
                    </svg>
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ══ Section 2: Skillset only ══ -->
    <section class="about-section-snap about-section--skillset" id="panel-skillset-section">

      <!-- Search IS the section header -->
      <div class="skillset-header-row">
        <input
          type="search"
          id="skill-search"
          class="skillset-search-input"
          placeholder="Skill Set"
          autocomplete="off"
          aria-label="Search skills"
        />
      </div>

      <p class="skillset-subtitle text-muted">A searchable interface that blends all projects — academic, work, free, and experiments — into one seamless digital archive for holistic discovery.</p>

      <div class="skillset-grid">
        {skillsets.map((set) => (
          <div class="skillset-card" data-keywords={`${set.category} ${set.skills.join(' ')}`.toLowerCase()}>
            <h3 class="skillset-card__title">{set.category}</h3>
            <div class="skill-pills">
              {set.skills.map((skill) => (
                <a
                  href={`/projects?search=${encodeURIComponent(skill.replace(/\s*\(.*\)\s*/g, ''))}`}
                  class="skill-pill"
                  title={`Click to view projects using ${skill}`}
                >
                  {skill}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

  </article>
</PageLayout>

<style>
  /* ── Scroll snap (page-wide) ── */
  :global(html) {
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
  }

  :global(.page-main) {
    padding: 0 !important;
  }

  /* ── Breadcrumb: fixed overlay on about page too ── */
  :global(.page-breadcrumb) {
    position: fixed !important;
    top: 0 !important;
    left: 64px !important;
    right: 0 !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    z-index: 150;
    padding-inline: var(--_tokens---space--small) !important;
    background-color: transparent !important;
    margin-bottom: 0 !important;
  }

  .about-page {
    position: relative;
    width: 100%;
  }

  /* ── Shared snap section ── */
  .about-section-snap {
    scroll-snap-align: start;
    height: 100dvh;
    min-height: 100dvh;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    padding-inline: var(--_tokens---space--small);
    transition: padding 0.3s ease;
  }

  /* ── Section 1: Career (intro + tabs + cards) ── */
  .about-section--career {
    justify-content: flex-start;
    padding-top: calc(clamp(2rem, 5vh, 4rem) + 48px); /* breadcrumb offset */
    overflow-y: auto;
    overflow-x: hidden;
    position: relative;
    scrollbar-width: thin;
    scrollbar-color: var(--_tokens---color--line) transparent;
  }

  /* ── Section 2: Skillset ── */
  .about-section--skillset {
    justify-content: flex-start;
    padding-top: calc(clamp(3rem, 6vh, 5rem) + 48px); /* breadcrumb offset */
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--_tokens---color--line) transparent;
  }

  /* ── Intro (top of section 1) ── */
  .about-intro {
    margin-bottom: 16px;
  }

  .about-intro__desc {
    font-size: var(--_tokens---type--small);
    line-height: 1.7;
    color: var(--_tokens---color--fg);
    max-width: 84ch;
    margin: 0;
  }

  /* ── Download links ── */
  .about-links {
    display: flex;
    flex-direction: column;
    margin-bottom: 0;
    width: 100%;
  }

  .about-links__note {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    letter-spacing: 0.04em;
    margin-bottom: 8px;
  }

  .about-link-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-decoration: none;
    color: var(--_tokens---color--fg);
    border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    padding-block: 18px;
    transition: opacity 0.2s ease, padding-left 0.2s ease;
  }

  .about-link-row:last-child {
    border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
  }

  .about-link-row:hover {
    opacity: 0.75;
    padding-left: 8px;
  }

  .about-link-row__text {
    font-size: var(--_tokens---type--big);
    font-weight: 500;
    line-height: 0.95;
    letter-spacing: -0.03em;
  }

  .about-link-row__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about-link-row:hover .about-link-row__arrow {
    transform: rotate(45deg);
  }

  /* ── Career Tabs — compact, auto-width, flex ── */
  .about-tabs-container {
    display: flex;
    gap: 6px;
    align-items: center;
    width: 100%;
    padding-top: 28px;
    padding-bottom: 12px;
    position: sticky;
    top: 0;
    z-index: 10;
    background-color: var(--_tokens---color--bg);
    border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    transition: background-color 0.3s ease;
  }

  .about-tab-btn {
    font-size: var(--_tokens---type--micro);
    font-family: inherit;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: none;
    border: none;
    color: var(--_tokens---color--muted);
    padding: 8px 16px;        /* equal padding on all sides */
    cursor: pointer;
    transition: background-color 0.25s ease, color 0.25s ease;
    border-radius: 6px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .about-tab-btn:hover {
    color: var(--_tokens---color--fg);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
  }

  .about-tab-btn.is-active {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  /* Tagline below tabs, above cards */
  .about-career__tagline {
    font-size: var(--_tokens---type--micro);
    line-height: 1.5;
    margin: 20px 0 24px;
    max-width: 80ch;
  }

  .about-tab-content {
    width: 100%;
    position: relative;
  }

  .about-tab-panel {
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about-tab-panel.is-active {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Stacking Cards ── */
  .about-card {
    width: 100%;
    box-sizing: border-box;
    position: sticky;
    top: calc(52px + var(--card-index, 0) * 36px); /* 52px = sticky tabs height */
    background-color: var(--_tokens---color--bg);
    border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    padding-top: 20px;
    padding-bottom: 20px;
    box-shadow: 0 -8px 24px -10px rgba(0, 0, 0, 0.3);
    transition: background-color 0.25s ease;
    cursor: default;
  }

  .about-card:hover {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 2%, transparent);
  }

  /* Strip: always visible (even when stacked) */
  .about-card__strip {
    display: flex;
    align-items: center;
    gap: 0;
    font-size: var(--_tokens---type--micro);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--_tokens---color--muted);
    margin-bottom: 16px;
    min-height: 18px;
  }

  .about-card__collab {
    color: var(--_tokens---color--fg);
    font-weight: 600;
  }

  .about-card__role {
    color: var(--_tokens---color--muted);
  }

  .about-card__dot-sep {
    margin-inline: 8px;
    color: color-mix(in srgb, var(--_tokens---color--fg) 25%, transparent);
    font-weight: 300;
  }

  /* Stacked title — slides in when card is stacked */
  .about-card__stacked-title {
    display: inline-flex;
    align-items: center;
    opacity: 0;
    max-width: 0;
    overflow: hidden;
    white-space: nowrap;
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                max-width 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    transform: translateX(10px);
  }

  .stacked-name {
    color: var(--_tokens---color--fg);
    font-weight: 700;
  }

  .about-card.is-stacked .about-card__stacked-title {
    opacity: 1;
    max-width: 600px;
    transform: translateX(0);
  }

  /* Body: two-column — left: title/meta, right: desc + arrow */
  .about-card__body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: start;
    transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about-card.is-stacked .about-card__body {
    opacity: 0;
    transform: translateY(-6px);
    pointer-events: none;
  }

  .about-card__left {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .about-card__title {
    font-size: var(--_tokens---type--medium);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0 0 4px 0;
    color: var(--_tokens---color--fg);
  }

  .about-card__meta-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 16px;
  }

  .about-card__right {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 16px;
    min-height: 72px;
  }

  .about-card__desc {
    font-size: var(--_tokens---type--micro);
    line-height: 1.65;
    margin: 0;
  }

  /* Arrow — bottom-right of right column, rotates on hover */
  .about-card__arrow {
    align-self: flex-end;
    width: 18px;
    height: 18px;
    opacity: 0.35;
    color: var(--_tokens---color--fg);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
    flex-shrink: 0;
  }

  .about-card:hover .about-card__arrow {
    opacity: 1;
    transform: rotate(45deg);
  }

  /* Shared meta styles */
  .meta-item {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .meta-label {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .meta-val {
    font-size: var(--_tokens---type--micro);
    font-weight: 400;
    color: var(--_tokens---color--fg);
  }

  .link-arrow {
    width: 100%;
    height: 100%;
  }

  /* ── Skillset Section ── */
  .skillset-header-row {
    margin-bottom: 12px;
    width: 100%;
  }

  /* Search IS the section heading — large, underline-only */
  .skillset-search-input {
    width: 100%;
    height: auto;
    padding: 0 0 12px;
    font-size: var(--_tokens---type--medium);  /* matches previous h2 size */
    font-weight: 700;
    font-family: inherit;
    letter-spacing: -0.01em;
    background: transparent;
    border: none;
    border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 15%, transparent);
    color: var(--_tokens---color--fg);
    border-radius: 0;
    outline: none;
    transition: border-color 0.2s;
  }

  .skillset-search-input::placeholder {
    color: color-mix(in srgb, var(--_tokens---color--fg) 35%, transparent);
  }

  .skillset-search-input:focus {
    border-color: var(--_tokens---color--fg);
  }

  .skillset-subtitle {
    font-size: var(--_tokens---type--micro);
    line-height: 1.5;
    max-width: 76ch;
    margin: 0 0 28px 0;
  }

  /* 3-col skillset grid */
  .skillset-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .skillset-card {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 4%, transparent);
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    border-radius: 8px;
    padding: 20px;
    transition: opacity 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
  }

  .skillset-card:hover {
    border-color: color-mix(in srgb, var(--_tokens---color--fg) 18%, transparent);
  }

  .skillset-card.is-hidden {
    opacity: 0.15;
    transform: scale(0.98);
  }

  .skillset-card__title {
    font-size: var(--_tokens---type--micro);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--_tokens---color--fg);
    margin: 0 0 16px 0;
    border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
    padding-bottom: 8px;
