---
import { getEntry } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import Footer from '../components/Footer.astro';
import { publicFileExists } from '../lib/content';

// PDF links only render once the files actually exist in public/
const hasPortfolio = publicFileExists('/advaita-kelkar-portfolio.pdf');
const hasCv = publicFileExists('/advaita-kelkar-resume.pdf');

// Editable about-page prose (inline edit mode writes src/content/pages/about.yaml).
const about = await getEntry('pages', 'about');
const aboutRole = about?.data.role ?? 'Architectural Designer + Researcher';
const aboutDegree = about?.data.degree ?? 'Master of Architecture · SCAD ‘27 · Mumbai';
const aboutBioLead = about?.data.bioLead ?? '';
const aboutBioMore = about?.data.bioMore ?? [];
const aboutCareerTagline = about?.data.careerTagline ?? 'Dissolving roles and evolutions: Professional journey from Mumbai teams to SCAD fabrication, always fusing leadership with innovation.';

// Structured career experience data
const experience = [
  {
    title: "Fabrication Monitor",
    role: "On Campus Employment",
    company: "SCAD Foundation Studies",
    dates: "Nov 2024 - Present",
    location: "Savannah, United States",
    desc: "Fabrication Monitor | SCAD Foundation Studies: Responsible for maintaining studio facilities, tools, and equipment while ensuring adherence to safe work practices. Tasks included designing and fabricating jigs, shop fixtures, signage, display fixtures, and light-duty repairs, as well as painting and shop upkeep. (Part Time)"
  },
  {
    title: "ARCHV",
    role: "Founder",
    company: "ARCHV Collective",
    dates: "Nov 2024 - Present",
    location: "Savannah, United States",
    desc: "Founder at ARCHV: Established an inclusive collective focused on collaborative learning and creation, prioritizing passion over constraints of money and time. Facilitated transdisciplinary projects with diverse participation, driven by collective effort and a shared love for design and innovation. (Part Time)"
  },
  {
    title: "F'KD Workshop",
    role: "Project Architect",
    company: "Faizan Khatri Design Workshop",
    dates: "2021 - 2023",
    location: "Mumbai, India",
    desc: "Project Architect at Faizan Khatri Design Workshop: Gained hands-on experience in establishing a new studio, building and leading teams, and mentoring junior professionals. Led architectural and interior design, visualization, rendering, and project management for hospitality, public spaces, and residential projects. Also contributed to crafting project proposals and coordinating multiple projects seamlessly. (Full Time)"
  },
  {
    title: "Studio 823",
    role: "Architect",
    company: "Studio Eight Twentythree",
    dates: "2018 - 2021",
    location: "Mumbai, India",
    desc: "Architect at Studio Eight Twentythree: Began as an intern during my final year of architecture studies and transitioned into a full-time role post-graduation. Contributed to diverse projects across hospitality, commercial spaces, architectural research, and residential interior design. Mentored by Samir Raut and Faizan Khatri, I honed my skills in a dynamic, enriching environment that laid the foundation for my professional growth. (Full Time)"
  }
];

// Structured exhibitions data
const exhibitions = [
  {
    title: "Indian Art Fair",
    role: "Public Art Exhibition",
    company: "Nayan Mote Studio",
    dates: "Nov 2024",
    location: "Mumbai, India",
    desc: "Public Art Exhibition by Nayan Mote Studio, showcasing the CARLO and Urban Dichotomy artwork collections."
  },
  {
    title: "Raw Collaborative",
    role: "Public Art Exhibition",
    company: "ARCHV Collective",
    dates: "Nov 2021",
    location: "Mumbai, India",
    desc: "Public Art Exhibition by ARCHV, featuring a diverse collection of collaborative works."
  },
  {
    title: "Celebrate Bandra",
    role: "Public Art Exhibition",
    company: "ARCHV Collective",
    dates: "2019",
    location: "Mumbai, India",
    desc: "Public Art Exhibition by ARCHV, featuring a diverse collection of collaborative works."
  },
  {
    title: "Traces and Territory",
    role: "Public Art Exhibition",
    company: "ARCHV Collective",
    dates: "2019",
    location: "Ahmedabad, India",
    desc: "Public Art Exhibition by ARCHV, featuring a diverse collection of collaborative works."
  }
];

// Structured timeline data
const timeline = [
  {
    title: "(SCAD) Savannah College of Art & Design",
    role: "Master of Architecture (NAAB-accredited)",
    company: "Savannah College of Art & Design",
    dates: "2024 - 2027",
    location: "Savannah, United States",
    desc: "Mastering parametric tools (Grasshopper, Midjourney, Unreal) and AI; thesis on cultural fusions – refining skills while balancing intensity with personal growth."
  },
  {
    title: "ARCHV",
    role: "Co-Founder, Architecture Collective",
    company: "ARCHV, Online",
    dates: "2018 - 2024",
    location: "Online",
    desc: "Inclusive collective prioritizing passion; led transdisciplinary projects driven by shared design love – dissolving constraints into collaborative innovation."
  },
  {
    title: "F'KD Workshop, Mumbai",
    role: "Project Architect",
    company: "Faizan Khatri Design Workshop",
    dates: "2021 - 2023",
    location: "Mumbai, India",
    desc: "Built studio, led teams, mentored juniors; managed architecture, interiors, visualization, and proposals for hospitality, public, and residential – blending execution with research."
  },
  {
    title: "Raw Collaborative Exhibition",
    role: "On ground Exhibition",
    company: "ARCHV Collective",
    dates: "2021",
    location: "Mumbai, India",
    desc: "Public Art by ARCHV – diverse works fusing transdisciplinary play and creativity."
  },
  {
    title: "Virtual Gods",
    role: "Co-Founded ARCHV Collective",
    company: "ARCHV Collective",
    dates: "2020",
    location: "Online",
    desc: "Virtual platform for innovative collaborations; hosted India's first online group art exhibit (still live) – connecting global creators via design and tech experiments."
  },
  {
    title: "Celebrate Bandra Exhibition",
    role: "Public Art by ARCHV collective",
    company: "ARCHV Collective",
    dates: "2019",
    location: "Mumbai, India",
    desc: "Public Art by ARCHV collective – urban joy through collaborative art, dissolving community with personal expression."
  },
  {
    title: "Dhal Ni Pol",
    role: "Public Art by ARCHV collective",
    company: "ARCHV Collective",
    dates: "2019",
    location: "Ahmedabad, India",
    desc: "Public Art by ARCHV collective – urban joy through collaborative art, dissolving community with personal expression."
  },
  {
    title: "Studio 823",
    role: "Architect, Full-Time",
    company: "Studio Eight Twentythree",
    dates: "2018 - 2021",
    location: "Mumbai, India",
    desc: "Started as intern in final BArch year; contributed to hospitality, commercial, research, and residential interiors under mentorship – fusing dynamic environments with professional growth."
  },
  {
    title: "Pragrup",
    role: "Bangalore Intern",
    company: "Pragrup",
    dates: "Jan 2016 - Jun 2016",
    location: "Bangalore, India",
    desc: "Hands-on full-scale builds; teamwork on wood houses, competitions, commercial spaces, and experimental graphics – transforming learning into real-world impact."
  },
  {
    title: "Hiray College of Architecture",
    role: "Bachelor of Architecture",
    company: "Hiray College of Architecture",
    dates: "2012 - 2019",
    location: "Mumbai, India",
    desc: "Built core principles through hands-on projects; dissolved theory into practical exploration, laying foundations for innovation."
  }
];

// Timeline grouped BY YEAR (an entry files under its start year), newest
// first — each year renders as one accordion card listing that year's
// events. Add entries above in any order; they self-organise.
const startYear = (d: string) => (d.match(/\d{4}/) ?? ['0'])[0];
const timelineByYear: Record<string, typeof timeline> = {};
timeline.forEach(t => {
  const y = startYear(t.dates);
  (timelineByYear[y] ??= []).push(t);
});
const timelineYears = Object.keys(timelineByYear)
  .sort((a, b) => Number(b) - Number(a))
  .map(y => ({ year: y, events: timelineByYear[y] }));

// The early years read better as one chapter: everything up to 2018 is
// folded into a single bottom card ("2012 – 2018"), events newest-first.
const EARLY_CUTOFF = 2018;
const timelineGroups = timelineYears.filter(g => Number(g.year) > EARLY_CUTOFF);
const early = timelineYears.filter(g => Number(g.year) <= EARLY_CUTOFF);
if (early.length) {
  const ys = early.map(g => Number(g.year));
  timelineGroups.push({
    year: `${Math.min(...ys)} – ${Math.max(...ys)}`,
    events: early.flatMap(g => g.events),
  });
}

// Structured skillset categories
const skillsets = [
  {
    category: "Languages",
    skills: [
      { name: "Hindi", level: "(Native)" },
      { name: "English", level: "(Fluent)" },
      { name: "Marathi", level: "(Native)" }
    ]
  },
  {
    category: "Software",
    skills: [
      { name: "Rhinoceros 3D", level: "(Intermediate)" },
      { name: "SketchUp", level: "(Expert)" },
      { name: "AutoCAD", level: "(Expert)" },
      { name: "Revit", level: "(Expert)" },
      { name: "Lumion", level: "(Expert)" },
      { name: "V-Ray", level: "(Intermediate)" },
      { name: "Enscape", level: "(Expert)" },
      { name: "Unreal Engine", level: "(Basic)" },
      { name: "Midjourney AI", level: "(Expert)" },
      { name: "Adobe Illustrator", level: "(Expert)" },
      { name: "Photoshop", level: "(Intermediate)" },
      { name: "InDesign", level: "(Expert)" },
      { name: "Canva", level: "(Expert)" },
      { name: "Webflow", level: "(Expert)" },
      { name: "Figma", level: "(Expert)" },
      { name: "Framer", level: "(Basic)" },
      { name: "Grasshopper", level: "(Basic)" },
      { name: "Microsoft Office", level: "(Expert)" },
      { name: "Notion", level: "(Expert)" },
      { name: "Miro", level: "(Expert)" }
    ]
  }
];
---

<PageLayout
  title="About"
  label="About"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'About' }
  ]}
  showFooter={false}
>
  <article class="about-page">
    
    <!-- Continuous scroll page — no section snapping -->
    <section class="about-section-snap about-section--intro">

      <!-- Full-width name header: text left, photo right (top-aligned) -->
      <header class="profile-header">
        <div class="profile-header__text">
          <h1 class="profile-name" data-scramble>Advaita Kelkar</h1>
          <p class="profile-role" data-scramble data-edit="pages/about/role">{aboutRole}</p>
          <p class="profile-degree" data-edit="pages/about/degree">{aboutDegree}</p>
        </div>
        <div class="profile-photo-circle" aria-hidden="true"></div>
      </header>

      <!-- Equal two-column grid: left = photo+bio, right = education -->
      <div class="about-top-grid">

        <!-- LEFT COLUMN: bio text + read more -->
        <div class="about-top-left">
          <div class="about-bio__text" id="bio-text-container">
            <p data-edit="pages/about/bioLead" data-edit-html set:html={aboutBioLead} />

            <div class="bio-collapsed-content" id="bio-collapsed-content" style="display: none;">
              {aboutBioMore.map((para, i) => (
                <p data-edit={`pages/about/bioMore.${i}`}>{para}</p>
              ))}
            </div>

            <div class="bio-buttons-row">
              <button class="bio-read-more-btn" id="bio-read-more-btn" type="button">
                <span>Read More</span>
                <svg class="link-arrow bio-read-more-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                  <line x1="6" y1="18" x2="18" y2="6"></line>
                  <polyline points="10 6 18 6 18 14"></polyline>
                </svg>
              </button>

              {hasCv && (
                <a href="/advaita-kelkar-resume.pdf" class="about-link-row" target="_blank" rel="noopener">
                  <span class="about-link-row__text">Resume</span>
                  <span class="about-link-row__arrow" aria-hidden="true">
                    <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                      <line x1="6" y1="18" x2="18" y2="6"></line>
                      <polyline points="10 6 18 6 18 14"></polyline>
                    </svg>
                  </span>
                </a>
              )}

              {hasPortfolio && (
                <a href="/advaita-kelkar-portfolio.pdf" class="about-link-row" target="_blank" rel="noopener">
                  <span class="about-link-row__text">Portfolio</span>
                  <span class="about-link-row__arrow" aria-hidden="true">
                    <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                      <line x1="6" y1="18" x2="18" y2="6"></line>
                      <polyline points="10 6 18 6 18 14"></polyline>
                    </svg>
                  </span>
                </a>
              )}
            </div>
          </div>
        </div>

        <!-- RIGHT COLUMN: education pills (top is intentionally open) -->
        <div class="about-top-right">
          <div class="about-education__list">
            <!-- Education pill 1: SCAD -->
            <div class="education-pill" data-pill="edu-scad">
              <button class="education-pill__trigger" aria-expanded="false" aria-controls="edu-scad-content" type="button">
                <span class="education-pill__name">
                  Master of Architecture
                  <span class="active-status-text">ACTIVE</span>
                </span>
                <div class="education-pill__trigger-right">
                  <span class="education-pill__years">2024 – 2027</span>
                  <svg class="edu-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
                    <line x1="6" y1="18" x2="18" y2="6"></line>
                    <polyline points="10 6 18 6 18 14"></polyline>
                  </svg>
                </div>
              </button>
              <div class="education-pill__content" id="edu-scad-content">
                <div class="education-pill__content-inner">
                  <p class="education-pill__degree">
                    MArch, Architecture - <a href="https://www.scad.edu/academics/programs/architecture/degrees/march" class="education-inline-link" data-no-scramble target="_blank" rel="noopener">Savannah College of Art and Design</a>
                  </p>
                </div>
              </div>
            </div>

            <!-- Education pill 2: University of Mumbai -->
            <div class="education-pill" data-pill="edu-mumbai">
              <button class="education-pill__trigger" aria-expanded="false" aria-controls="edu-mumbai-content" type="button">
                <span class="education-pill__name">Bachelor of Architecture</span>
                <div class="education-pill__trigger-right">
                  <span class="education-pill__years">2012 – 2019</span>
                  <svg class="edu-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
                    <line x1="6" y1="18" x2="18" y2="6"></line>
                    <polyline points="10 6 18 6 18 14"></polyline>
                  </svg>
                </div>
              </button>
              <div class="education-pill__content" id="edu-mumbai-content">
                <div class="education-pill__content-inner">
                  <p class="education-pill__degree">
                    BArch, Architecture - <a href="https://hiray.edu.in/home" class="education-inline-link" data-no-scramble target="_blank" rel="noopener">DBHCOA</a>, University of Mumbai
                  </p>
                </div>
              </div>
            </div>

            <a href="https://linkedin.com/in/advaitakelkar" class="education-more-link" target="_blank" rel="noopener">
              <span>+ LinkedIn / full resume</span>
              <svg class="link-arrow bio-read-more-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                <line x1="6" y1="18" x2="18" y2="6"></line>
                <polyline points="10 6 18 6 18 14"></polyline>
              </svg>
            </a>
          </div>
        </div>

      </div>


      <!-- Career Tabs + Card Deck -->
      <div class="about-career-container" id="panel-career-section">
        <!-- Tabs (Sticky 100% width, equally spaced) -->
        <div class="about-tabs-container" role="tablist" aria-label="Career sections">
          <button class="about-tab-btn is-active" role="tab" aria-selected="true" aria-controls="panel-about" data-tab="about">
            <span>
              <span class="tab-label-full">Work EXP</span>
              <span class="tab-label-short">EXP</span>
            </span>
            <svg class="pill-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
          </button>
          <button class="about-tab-btn" role="tab" aria-selected="false" aria-controls="panel-exhibitions" data-tab="exhibitions">
            <span>
              <span class="tab-label-full">Exhibitions</span>
              <span class="tab-label-short">EXHIB</span>
            </span>
            <svg class="pill-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
          </button>
          <button class="about-tab-btn" role="tab" aria-selected="false" aria-controls="panel-timeline" data-tab="timeline">
            <span>
              <span class="tab-label-full">Timeline</span>
              <span class="tab-label-short">TL</span>
            </span>
            <svg class="pill-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
          </button>
        </div>

        <p class="about-career__tagline text-muted" data-edit="pages/about/careerTagline">{aboutCareerTagline}</p>

        <div class="about-tab-content">
          <!-- Panel 1: About (Experience) -->
          <div class="about-tab-panel is-active" id="panel-about" role="tabpanel" aria-labelledby="tab-about">
            {experience.map((item, idx) => (
              <div class="about-card" style={`--card-index: ${idx};`}>
                <div class="about-card__header">
                  <h3 class="about-card__title">
                    {item.title}
                    {item.title === "Fabrication Monitor" && (
                      <span class="active-status-text">ACTIVE</span>
                    )}
                  </h3>
                  <div class="about-card__header-right">
                    <span class="about-card__dates">{item.dates}</span>
                    <svg class="about-card__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
                      <line x1="6" y1="18" x2="18" y2="6"></line>
                      <polyline points="10 6 18 6 18 14"></polyline>
                    </svg>
                  </div>
                </div>
                <div class="about-card__body">
                  <div class="about-card__body-inner">
                    <p class="about-card__meta text-muted">{item.company} · {item.role} · {item.location}</p>
                    {item.desc && <p class="about-card__desc text-muted">{item.desc}</p>}
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- Panel 2: Exhibitions -->
          <div class="about-tab-panel" id="panel-exhibitions" role="tabpanel" aria-labelledby="tab-exhibitions" style="display: none;">
            {exhibitions.map((item, idx) => (
              <div class="about-card" style={`--card-index: ${idx};`}>
                <div class="about-card__header">
                  <h3 class="about-card__title">{item.title}</h3>
                  <div class="about-card__header-right">
                    <span class="about-card__dates">{item.dates}</span>
                    <svg class="about-card__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
                      <line x1="6" y1="18" x2="18" y2="6"></line>
                      <polyline points="10 6 18 6 18 14"></polyline>
                    </svg>
                  </div>
                </div>
                <div class="about-card__body">
                  <div class="about-card__body-inner">
                    <p class="about-card__meta text-muted">{item.company} · {item.role} · {item.location}</p>
                    {item.desc && <p class="about-card__desc text-muted">{item.desc}</p>}
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- Panel 3: Timeline — one card per YEAR; open it to see the
               events that started that year -->
          <div class="about-tab-panel" id="panel-timeline" role="tabpanel" aria-labelledby="tab-timeline" style="display: none;">
            {timelineGroups.map((g, idx) => (
              <div class="about-card" style={`--card-index: ${idx};`}>
                <div class="about-card__header">
                  <h3 class="about-card__title">{g.year}</h3>
                  <div class="about-card__header-right">
                    <span class="about-card__dates">{g.events.length} {g.events.length === 1 ? 'entry' : 'entries'}</span>
                    <svg class="about-card__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
                      <line x1="6" y1="18" x2="18" y2="6"></line>
                      <polyline points="10 6 18 6 18 14"></polyline>
                    </svg>
                  </div>
                </div>
                <div class="about-card__body">
                  <div class="about-card__body-inner">
                    {g.events.map(item => (
                      <div class="timeline-event">
                        <p class="timeline-event__title">{item.title} <span class="timeline-event__dates">{item.dates}</span></p>
                        <p class="about-card__meta text-muted">{item.company} · {item.role} · {item.location}</p>
                        {item.desc && <p class="about-card__desc text-muted">{item.desc}</p>}
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Skillset (in same snap as career tabs) -->
      <div class="skillset-header-row">
        <h1 class="skillset-title">Skillset</h1>
        <input
          type="search"
          id="skill-search"
          class="skillset-search-input"
          placeholder="Search"
          autocomplete="off"
          aria-label="Search skillset"
        />
      </div>
      

      <div class="skillset-grid skillset-grid--two">
        <!-- Languages: show title -->
        <div class="skillset-card" data-keywords={`${skillsets[0].category} ${skillsets[0].skills.map(s => s.name).join(' ')}`.toLowerCase()}>
          <h3 class="skillset-card__title">{skillsets[0].category}</h3>
          <div class="skill-pills">
            {skillsets[0].skills.map((skill) => (
              <a
                href={`/projects?search=${encodeURIComponent(skill.name)}`}
                class="proj-bubble skill-pill"
                title={`Click to view projects using ${skill.name}`}
              >
                <span class="proj-bubble__name" data-short={skill.name} data-full={skill.name}>{skill.name}</span>
                <span class="proj-bubble__tag">{skill.level}</span>
                <svg class="link-arrow proj-bubble__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                  <line x1="6" y1="18" x2="18" y2="6"></line>
                  <polyline points="10 6 18 6 18 14"></polyline>
                </svg>
              </a>
            ))}
          </div>
        </div>
        <!-- Softwares: title + pills -->
        <div class="skillset-card" data-keywords={`${skillsets[1].category} ${skillsets[1].skills.map(s => s.name).join(' ')}`.toLowerCase()}>
          <h3 class="skillset-card__title">{skillsets[1].category}</h3>
          <div class="skill-pills">
            {skillsets[1].skills.map((skill) => (
              <a
                href={`/projects?search=${encodeURIComponent(skill.name)}`}
                class="proj-bubble skill-pill"
                title={`Click to view projects using ${skill.name}`}
              >
                <span class="proj-bubble__name" data-short={skill.name} data-full={skill.name}>{skill.name}</span>
                <span class="proj-bubble__tag">{skill.level}</span>
                <svg class="link-arrow proj-bubble__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                  <line x1="6" y1="18" x2="18" y2="6"></line>
                  <polyline points="10 6 18 6 18 14"></polyline>
                </svg>
              </a>
            ))}
          </div>
        </div>
