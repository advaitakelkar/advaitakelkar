---
import { getEntry } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import { isPlaceholder, realText } from '../../lib/content';
import fs from 'node:fs';
import path from 'node:path';

const project = await getEntry('projects', 'ai-works');
if (!project) {
  throw new Error("Could not find project 'ai-works' in content collection.");
}
const { data } = project;

// Resolve tag and category references
const tags = await Promise.all((data.tags ?? []).map(t => getEntry(t)));
const category = data.category ? await getEntry(data.category) : null;

// Dynamically read AI works project folders
const aiWorksDir = path.resolve('public/images/ai-works');
let folderProjects = [];

if (fs.existsSync(aiWorksDir)) {
  const folders = fs.readdirSync(aiWorksDir).filter(f => {
    const fullPath = path.join(aiWorksDir, f);
    return fs.statSync(fullPath).isDirectory();
  }).sort();

  for (const folder of folders) {
    const folderPath = path.join(aiWorksDir, folder);
    const files = fs.readdirSync(folderPath).filter(file => {
      const ext = path.extname(file).toLowerCase();
      return ['.png', '.jpg', '.jpeg', '.webp'].includes(ext);
    }).sort();

    const imagePaths = files.map(file => `/images/ai-works/${folder}/${file}`);
    if (imagePaths.length > 0) {
      folderProjects.push({
        name: folder.trim(),
        images: imagePaths
      });
    }
  }
}

const firstTag = tags.find(t => t);
const yearLoc = [data.year, data.location].filter(Boolean).join(', ');

const dynamicCrumbs = [
  { label: 'Home', href: '/' }
];

if (category) {
  dynamicCrumbs.push({ label: category.data.displayName, href: `/${category.id}` });
} else {
  dynamicCrumbs.push({ label: 'Projects', href: '/projects' });
}
dynamicCrumbs.push({ label: data.name });
---

<PageLayout
  title={data.name}
  description={realText(data.smallIntro) ?? `${data.name}${data.year ? ` (${data.year})` : ''} — a project by Advaita Kelkar.`}
  ogImage={data.coverImage}
  label={data.name}
  crumbs={dynamicCrumbs}
>
    <article class="project-detail" data-project-id={project.id} data-project-name={data.name}>
      
      <!-- Top Full Width Header -->
      <header class="project-top-header" id="project-top-header">
        <div class="project-header-title-row">
          <h1 class="project-name-title" id="project-name-click">
            <span class="project-name-main">{data.name}</span>
          </h1>
          <button class="project-detail-collapse-btn" id="project-detail-toggle" type="button" aria-expanded="true" aria-label="Toggle details">
            <svg class="toggle-icon-minus link-arrow" viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
            <svg class="toggle-icon-plus link-arrow" viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" style="display: none;"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
          </button>
        </div>
        
        <div class="project-card__metaline">
          {(yearLoc || data.status) && (
            <div class="project-meta-row">
              <span class="project-meta-left project-card__meta-val">{yearLoc}</span>
              {data.status && <span class="project-meta-right project-card__meta-val">{data.status}</span>}
            </div>
          )}
          {(firstTag || category) && (
            <div class="project-meta-row">
              <span class="project-meta-left project-card__meta-val">{firstTag ? firstTag.data.name : ''}</span>
              {category && <a href={`/${category.id}`} class="category-link project-meta-right project-card__meta-val">{category.data.displayName}</a>}
            </div>
          )}
        </div>
      </header>

      <!-- Main content body of Section 1 -->
      <div class="project-content-grid project-content-grid--no-images">
        <!-- Left Column: Text Content -->
        <div class="project-col-left">
          <div class="project-card-info">
            <div class="project-card__row project-card__row2">
              <div class="project-card__text-block">
                {data.smallIntro && <p class="project-card__intro">{data.smallIntro}</p>}
                {data.description && (
                  <div class="project-card__desc" set:html={data.description} />
                )}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Collapsible Sections for each project/folder -->
      {folderProjects.map((proj, projIdx) => (
        <section class="collapsible-project-section">
          <div class="project-header-title-row project-section-header">
            <h2 class="project-name-title project-section-subtitle">{proj.name}</h2>
            <button class="project-detail-collapse-btn" type="button" aria-expanded="false" aria-label={`Toggle ${proj.name} details`}>
              <svg class="toggle-icon-minus link-arrow" viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" style="display: none;"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
              <svg class="toggle-icon-plus link-arrow" viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
            </button>
          </div>
          
          <div class="project-section-content">
            <div class="project-content-grid">
              <!-- Left Column: Dummy Text Description -->
              <div class="project-col-left">
                <div class="project-card-info">
                  <div class="project-card__row project-card__row2">
                    <div class="project-card__text-block">
                      <p class="project-card__intro">Freelance AI experiment exploring advanced generative concepts.</p>
                      <div class="project-card__desc">
                        <p>This series investigates the convergence of generative visual models and digital design methodologies. By constructing custom prompt logic and styling parameters, each project represents a unique conceptual study in form, character generation, and thematic spatial narratives.</p>
                        <p>Through iterative rendering runs and curated selections, these works showcase the boundary between automated generation and intentional human direction.</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Right Column: Active Card Slider -->
              <div class="project-col-right">
                <div class="project-slider-wrapper" data-images={JSON.stringify(proj.images)} data-project-name={proj.name}>
                  <div class="project-detail__active-wrap">
                    <button class="project-detail__nav-arrow project-detail__nav-arrow--prev" type="button" aria-label="Previous image">
                      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
                    </button>
                    <img class="project-detail__active-img" src={proj.images[0]} alt={proj.name} />
                    
                    <!-- Dynamic Label Overlay -->
                    <div class="project-detail__active-label">
                      {(() => {
                        const firstImg = proj.images[0];
                        const filename = firstImg.substring(firstImg.lastIndexOf('/') + 1);
                        const ext = filename.substring(filename.lastIndexOf('.'));
                        let name = filename.slice(0, filename.length - ext.length);
                        name = name.replace(/^ADVT_[A-Z_]+_/, '').replace(/^ADVT_SP_\s*/, '').trim();
                        name = name.replace(/\s+\d+\s*$/, '').replace(/\s*\d+$/, '').trim();
                        if (proj.name === 'Space Pirates' || name === 'A' || name === 'B' || name === 'C') {
                          return 'Space Pirates';
                        }
                        if (name.toLowerCase() === 'winter soildier') return 'Winter Soldier';
                        if (name.toLowerCase() === 'wonder women') return 'Wonder Woman';
                        if (name.toLowerCase() === 'cygborg') return 'Cyborg';
                        if (name.toLowerCase() === 'scalet witch') return 'Scarlet Witch';
                        if (name.toLowerCase() === 'strom') return 'Storm';
                        return name;
                      })()}
                    </div>

                    <button class="project-detail__nav-arrow project-detail__nav-arrow--next" type="button" aria-label="Next image">
                      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                    </button>
                  </div>

                  <!-- Pagination Counter label below image -->
                  <div class="project-detail__pagination">
                    {(() => {
                      const firstImg = proj.images[0];
                      const filename = firstImg.substring(firstImg.lastIndexOf('/') + 1);
                      const ext = filename.substring(filename.lastIndexOf('.'));
                      let name = filename.slice(0, filename.length - ext.length);
                      name = name.replace(/^ADVT_[A-Z_]+_/, '').replace(/^ADVT_SP_\s*/, '').trim();
                      name = name.replace(/\s+\d+\s*$/, '').replace(/\s*\d+$/, '').trim();
                      if (proj.name === 'Space Pirates' || name === 'A' || name === 'B' || name === 'C') {
                        name = 'Space Pirates';
                      } else if (name.toLowerCase() === 'winter soildier') {
                        name = 'Winter Soldier';
                      } else if (name.toLowerCase() === 'wonder women') {
                        name = 'Wonder Woman';
                      } else if (name.toLowerCase() === 'cygborg') {
                        name = 'Cyborg';
                      } else if (name.toLowerCase() === 'scalet witch') {
                        name = 'Scarlet Witch';
                      } else if (name.toLowerCase() === 'strom') {
                        name = 'Storm';
                      }
                      return `${name} — 1 / ${proj.images.length}`;
                    })()}
                  </div>
                  
                  <!-- Thumbnails scrub bar -->
                  <div class="project-detail__thumbs">
                    {proj.images.map((img, idx) => (
                      <button
                        type="button"
                        class:list={[
                          "project-detail__thumb-item",
                          idx === 0 && "is-active"
                        ]}
                        data-index={idx}
                      >
                        <img src={img} alt={`${proj.name} thumbnail ${idx + 1}`} loading="lazy" />
                      </button>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      ))}

    </article>
</PageLayout>

<style>
  .project-detail {
    padding-bottom: clamp(4rem, 8vh, 8rem);
    min-height: 100dvh;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: var(--_tokens---space-5);
    position: relative;
    transition: padding-bottom 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-detail.is-collapsed {
    min-height: 100dvh !important;
    padding-bottom: 80px !important;
    overflow: hidden !important;
  }

  .project-content-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--_tokens---space-6);
    max-height: 3000px;
    opacity: 1;
    transition: max-height 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.4s ease,
                gap 0.5s ease;
  }

  .project-content-grid--no-images {
    grid-template-columns: 1fr !important;
  }

  .project-detail.is-collapsed .project-content-grid {
    max-height: 0 !important;
    opacity: 0 !important;
    gap: 0 !important;
    overflow: hidden !important;
  }

  @media (min-width: 1024px) {
    .project-content-grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  @media (min-width: 1200px) {
    .project-content-grid {
      grid-template-columns: 4.5fr 5.5fr;
    }
  }

  .project-top-header {
    position: static;
    padding-top: calc(clamp(2rem, 5vh, 3rem) + 48px);
    padding-bottom: 0;
    margin: 0 0 8px;
  }

  @media (max-width: 768px) {
    .project-top-header {
      padding-top: calc(1.5rem + 48px);
      margin: 0;
    }
  }

  .project-header-title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .project-name-title {
    font-size: var(--_tokens---type--big);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 0.95;
    color: var(--_tokens---color--fg);
    margin: 0;
    cursor: pointer;
  }

  .project-detail-collapse-btn {
    all: unset;
    cursor: pointer;
    color: var(--_tokens---color--fg);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .project-detail-collapse-btn:hover {
    transform: scale(1.08);
  }

  .project-col-left {
    width: 100%;
  }

  .project-card-info {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    padding: 16px 0;
  }

  .project-card__text-block {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .project-card__intro {
    font-size: var(--_tokens---type--micro);
    font-weight: 500;
    line-height: 1.55;
    color: var(--_tokens---color--fg);
    margin: 0;
  }

  .project-card__desc {
    font-size: var(--_tokens---type--micro);
    font-weight: 400;
    line-height: 1.55;
    color: var(--_tokens---color--muted);
    margin: 0;
  }

  .project-card__desc :global(p) {
    margin-bottom: 1em;
  }

  .project-card__metaline {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 16px;
    padding-top: 12px;
    width: 100%;
    border-top: 1px solid var(--_tokens---color--line-soft);
  }

  .project-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    width: 100%;
  }

  .project-card__meta-val {
    font-weight: 400;
    font-size: var(--_tokens---type--micro);
    color: var(--_tokens---color--muted);
  }

  .category-link {
    color: var(--_tokens---color--muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  .category-link:hover {
    color: var(--_tokens---color--fg);
  }

  .project-col-right {
    position: sticky;
    top: calc(clamp(2rem, 5vh, 3rem) + 48px);
  }

  .project-detail__active-wrap {
    width: 100%;
    aspect-ratio: 16/10;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    background: transparent;
  }

  .project-detail__active-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .project-detail__active-label {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    box-sizing: border-box;
    padding: 14px 20px;
    font-size: var(--_tokens---type--micro);
    font-family: var(--_tokens---font--mono);
    color: #ffffff;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0) 100%);
    text-transform: none;
    font-weight: 600;
    letter-spacing: 0.1em;
    z-index: 3;
    pointer-events: none;
    text-align: center;
  }

  .project-detail__nav-arrow {
    all: unset;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    cursor: pointer;
    color: var(--_tokens---color--fg);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease, color 0.2s ease;
  }

  .project-detail__active-wrap:hover .project-detail__nav-arrow {
    opacity: 0.6;
  }

  .project-detail__nav-arrow:hover {
    opacity: 1 !important;
    transform: translateY(-50%) scale(1.15);
  }

  .project-detail__nav-arrow--prev {
    left: 8px;
  }

  .project-detail__nav-arrow--next {
    right: 8px;
  }

  .project-detail__pagination {
    display: block;
    text-align: center;
    font-family: var(--_tokens---font--mono);
    font-size: var(--_tokens---type--micro);
    color: var(--_tokens---color--muted);
    margin-top: 8px;
    text-transform: none;
    font-weight: 600;
  }

  .project-detail__thumbs {
    display: flex;
    gap: 6px;
    margin-top: 12px;
    width: 100%;
    justify-content: flex-start;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .project-detail__thumbs::-webkit-scrollbar {
    display: none;
  }

  .project-detail__thumb-item {
    flex: 0 0 calc((100% - 24px) / 5);
    scroll-snap-align: start;
    aspect-ratio: 1;
    border-radius: 0;
    border: none;
    overflow: hidden;
    position: relative;
    padding: 0;
    cursor: pointer;
    background: transparent;
    transition: opacity 0.2s ease;
  }

  .project-detail__thumb-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1);
    opacity: 0.6;
    transition: filter 0.2s ease, opacity 0.2s ease;
  }

  .project-detail__thumb-item.is-active img,
  .project-detail__thumb-item:hover img {
    filter: grayscale(0);
    opacity: 1;
  }

  .project-slider-wrapper.is-previewing .project-detail__thumb-item img {
    filter: grayscale(1);
    opacity: 0.6;
  }

  /* ── Collapsible Sections ── */
  .collapsible-project-section {
    border-top: 1px solid var(--_tokens---color--line-soft);
    padding-top: var(--_tokens---space-4);
    margin-top: var(--_tokens---space-4);
  }

  .project-section-header {
    cursor: pointer;
  }

  .project-section-subtitle {
    font-size: var(--_tokens---type--normal);
    font-weight: 500;
  }

  .project-section-content {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.4s ease,
                padding 0.6s ease;
    padding: 0 0;
    box-sizing: border-box;
  }

  .collapsible-project-section.is-expanded .project-section-content {
    max-height: 2500px;
    opacity: 1;
    padding: 16px 0 32px;
  }

  .link-arrow {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (max-width: 768px) {
    .project-detail {
      padding-bottom: 96px !important;
    }
    .project-detail__thumb-item {
      flex: 0 0 calc((100% - 24px) / 5) !important;
      aspect-ratio: 1 !important;
      border-radius: 0 !important;
    }
    .project-detail__thumb-item img {
      filter: grayscale(1) !important;
      opacity: 0.6;
    }
    .project-detail__thumb-item.is-active img {
      filter: grayscale(0) !important;
      opacity: 1;
    }

    .collapsible-project-section {
      margin-top: 0 !important;
      padding-top: 0 !important;
    }
  }
</style>

<script>
  function initGalleries() {
    const sliders = Array.from(document.querySelectorAll('.project-slider-wrapper'));
    sliders.forEach(slider => {
      const activeImg = slider.querySelector('.project-detail__active-img') as HTMLImageElement | null;
      const thumbs = Array.from(slider.querySelectorAll<HTMLButtonElement>('.project-detail__thumb-item'));
      const strip = slider.querySelector<HTMLElement>('.project-detail__thumbs');
      const activePrev = slider.querySelector('.project-detail__nav-arrow--prev');
      const activeNext = slider.querySelector('.project-detail__nav-arrow--next');
      const pagination = slider.querySelector('.project-detail__pagination');
      const activeLabel = slider.querySelector('.project-detail__active-label');

      if (!activeImg || !strip) return;
      const images = JSON.parse(slider.getAttribute('data-images') || '[]');
      const projName = slider.getAttribute('data-project-name') || '';
      let currentIdx = 0;
      let autoplayInterval: number | null = null;

      const getCardName = (url: string): string => {
        const filename = url.substring(url.lastIndexOf('/') + 1);
        const ext = filename.substring(filename.lastIndexOf('.'));
        let name = filename.slice(0, filename.length - ext.length);
        name = name.replace(/^ADVT_[A-Z_]+_/, '').replace(/^ADVT_SP_\s*/, '').trim();
        name = name.replace(/\s+\d+\s*$/, '').replace(/\s*\d+$/, '').trim();
        if (projName === 'Space Pirates' || name === 'A' || name === 'B' || name === 'C') {
          return 'Space Pirates';
        }
        if (name.toLowerCase() === 'winter soildier') return 'Winter Soldier';
        if (name.toLowerCase() === 'wonder women') return 'Wonder Woman';
        if (name.toLowerCase() === 'cygborg') return 'Cyborg';
        if (name.toLowerCase() === 'scalet witch') return 'Scarlet Witch';
        if (name.toLowerCase() === 'strom') return 'Storm';
        return name;
      };

      // Helper: find index of thumbnail under clientX
      function thumbIndexAtX(clientX: number): number {
        if (!thumbs.length) return -1;
        for (let i = 0; i < thumbs.length; i++) {
          const r = thumbs[i].getBoundingClientRect();
          if (clientX >= r.left && clientX <= r.right) return i;
        }
        return clientX < thumbs[0].getBoundingClientRect().left ? 0 : thumbs.length - 1;
      }

      const setDisplayImage = (idx: number) => {
        currentIdx = idx;
        const activeUrl = images[idx] || '';
        activeImg.src = activeUrl;
        
        const cardName = getCardName(activeUrl);
        if (activeLabel) {
          activeLabel.textContent = cardName;
        }
        
        if (pagination) {
          pagination.textContent = `${cardName} — ${idx + 1} / ${images.length}`;
        }

        thumbs.forEach((t, i) => {
          t.classList.toggle('is-active', i === idx);
        });

        // Scroll active thumbnail smoothly into view
        const activeThumb = thumbs[idx];
        if (activeThumb && strip) {
          const stripRect = strip.getBoundingClientRect();
          const thumbRect = activeThumb.getBoundingClientRect();
          if (thumbRect.left < stripRect.left || thumbRect.right > stripRect.right) {
            activeThumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
          }
        }
      };

      const startAutoplay = () => {
        stopAutoplay();
        autoplayInterval = window.setInterval(() => {
          const nextIdx = (currentIdx + 1) % images.length;
          setDisplayImage(nextIdx);
        }, 3000);
      };

      const stopAutoplay = () => {
        if (autoplayInterval) {
          clearInterval(autoplayInterval);
          autoplayInterval = null;
        }
      };

      const handleUserInteraction = () => {
        startAutoplay();
      };

      const isHoverDevice = window.matchMedia('(hover: hover)').matches;
      if (isHoverDevice) {
        thumbs.forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            const idx = parseInt(btn.dataset.index || '0', 10);
            setDisplayImage(idx);
            handleUserInteraction();
          });
        });

        strip.addEventListener('pointerenter', () => {
          slider.classList.add('is-previewing');
          stopAutoplay();
        });
        strip.addEventListener('pointermove', (e) => {
          const idx = thumbIndexAtX(e.clientX);
          if (idx >= 0 && idx !== currentIdx) {
            setDisplayImage(idx);
          }
        });
        strip.addEventListener('pointerleave', () => {
          slider.classList.remove('is-previewing');
          startAutoplay();
        });
      } else {
        thumbs.forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            const idx = parseInt(btn.dataset.index || '0', 10);
            setDisplayImage(idx);
            handleUserInteraction();
          });
        });

        strip.addEventListener('pointermove', (e) => {
          const idx = thumbIndexAtX(e.clientX);
          if (idx >= 0 && idx !== currentIdx) {
            setDisplayImage(idx);
            handleUserInteraction();
          }
        });
      }

      if (activePrev) {
        activePrev.addEventListener('click', (e) => {
          e.stopPropagation();
          const prevIdx = (currentIdx - 1 + images.length) % images.length;
          setDisplayImage(prevIdx);
          handleUserInteraction();
        });
      }

      if (activeNext) {
        activeNext.addEventListener('click', (e) => {
          e.stopPropagation();
          const nextIdx = (currentIdx + 1) % images.length;
          setDisplayImage(nextIdx);
          handleUserInteraction();
        });
      }

      // Keyboard navigation (left/right keys) only if slider is visible in viewport
      document.addEventListener('keydown', (e) => {
        const rect = slider.getBoundingClientRect();
        const isVisible = rect.top < window.innerHeight && rect.bottom > 0;
        if (!isVisible) return;

        if (e.key === 'ArrowLeft') {
          const prevIdx = (currentIdx - 1 + images.length) % images.length;
          setDisplayImage(prevIdx);
          handleUserInteraction();
        }
        if (e.key === 'ArrowRight') {
          const nextIdx = (currentIdx + 1) % images.length;
          setDisplayImage(nextIdx);
          handleUserInteraction();
        }
      });

      // Start autoplay
      startAutoplay();

      // Clean up on page changes
      document.addEventListener('astro:before-preparation', stopAutoplay, { once: true });
    });
  }

  function initCollapseToggle() {
    const detailContainer = document.querySelector('.project-detail');
    const toggleBtn = document.getElementById('project-detail-toggle');
    const nameTitle = document.getElementById('project-name-click');
    if (!detailContainer || !toggleBtn) return;

    const iconMinus = toggleBtn.querySelector('.toggle-icon-minus') as HTMLElement | null;
    const iconPlus = toggleBtn.querySelector('.toggle-icon-plus') as HTMLElement | null;

    const toggleCollapse = () => {
      const isCollapsed = detailContainer.classList.toggle('is-collapsed');
      toggleBtn.setAttribute('aria-expanded', String(!isCollapsed));
      if (iconMinus && iconPlus) {
        if (isCollapsed) {
          iconMinus.style.display = 'none';
          iconPlus.style.display = 'block';
        } else {
          iconMinus.style.display = 'block';
          iconPlus.style.display = 'none';
        }
      }
    };

    toggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleCollapse();
    });

    if (nameTitle) {
      nameTitle.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleCollapse();
      });
    }
  }

  function initCollapsibleSections() {
    const sections = Array.from(document.querySelectorAll('.collapsible-project-section'));
    sections.forEach(section => {
      const header = section.querySelector('.project-section-header');
      const toggleBtn = section.querySelector('.project-detail-collapse-btn');
      const content = section.querySelector('.project-section-content');

      if (!header || !toggleBtn || !content) return;

      const iconMinus = toggleBtn.querySelector('.toggle-icon-minus') as HTMLElement | null;
      const iconPlus = toggleBtn.querySelector('.toggle-icon-plus') as HTMLElement | null;

      const toggleSection = () => {
        const isExpanded = section.classList.toggle('is-expanded');
        toggleBtn.setAttribute('aria-expanded', String(isExpanded));
        
        toggleBtn.querySelectorAll('.link-arrow').forEach((a) => {
          (a as HTMLElement).style.transform = `rotate(${Math.floor(Math.random() * 360)}deg)`;
        });

        if (iconMinus && iconPlus) {
          if (isExpanded) {
            iconMinus.style.display = 'block';
            iconPlus.style.display = 'none';
          } else {
            iconMinus.style.display = 'none';
            iconPlus.style.display = 'block';
          }
        }
      };

      header.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleSection();
      });
      toggleBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleSection();
      });
    });
  }

  function initHeadingScrollTop() {
    const h = document.getElementById('project-top-header');
    if (h && !(h as any)._topWired) {
      (h as any)._topWired = true;
      h.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    }
  }

  document.addEventListener('astro:page-load', () => {
    initGalleries();
    initCollapseToggle();
    initCollapsibleSections();
    initHeadingScrollTop();
  });
  if (document.readyState !== 'loading') {
    initGalleries();
    initCollapseToggle();
    initCollapsibleSections();
    initHeadingScrollTop();
  }
</script>
