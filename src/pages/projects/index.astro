---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

const allProjects = await getCollection('projects');
const allTags = await getCollection('tags');
const allCats = await getCollection('categories');

// Sort by number then year
const sorted = [...allProjects].sort((a, b) => {
  if (a.data.numbr && b.data.numbr) return a.data.numbr - b.data.numbr;
  if (a.data.numbr) return -1;
  if (b.data.numbr) return 1;
  return parseInt(b.data.year ?? '0') - parseInt(a.data.year ?? '0');
});

const tagMap = Object.fromEntries(allTags.map(t => [t.id, t.data.name]));
const catMap = Object.fromEntries(allCats.map(c => [c.id, c.data.displayName]));

// Count projects per tag to find top 4
const tagCounts: Record<string, number> = {};
allProjects.forEach(p => {
  (p.data.tags ?? []).forEach(t => {
    tagCounts[t.id] = (tagCounts[t.id] || 0) + 1;
  });
});
const sortedTags = [...allTags].sort((a, b) => (tagCounts[b.id] || 0) - (tagCounts[a.id] || 0));
---

<PageLayout
  title="Projects"
  label="Projects"
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Projects' }
  ]}
>
  <section class="projects-page">
    <div class="projects-sticky-header">
      <header class="projects-header">
        <h1 class="projects-title">Projects</h1>
        <p class="projects-count text-muted">{allProjects.length} of {allProjects.length} works</p>
      </header>

      <!-- Search bar matching home UI -->
      <div class="projects-search-bar">
        <input
          type="search"
          id="projects-search-input"
          class="projects-search-input"
          placeholder="Search projects by name, tag, location, client, status, year..."
          autocomplete="off"
          aria-label="Search projects"
        />
        <button class="projects-search-clear" id="projects-search-clear" type="button">@Clear All</button>
      </div>

      <!-- Filter bar with dropdown and scrollable tag picker -->
      <div class="filter-bar">
        <div class="filter-group">
          <span class="filter-label text-muted">Category</span>
          <div class="filter-select-wrap">
            <select id="cat-select" class="filter-select">
              <option value="">All Categories</option>
              {allCats.map(cat => (
                <option value={cat.id}>{cat.data.displayName}</option>
              ))}
            </select>
            <svg class="filter-select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </div>
        </div>
        
        <div class="filter-group filter-group--tags">
          <div class="tag-picker-wrapper">
            <button class="tag-picker-item is-active" data-filter="" id="all-tag-btn" type="button">All</button>
            <span class="tag-picker-divider">|</span>
            <div class="tag-scroll-nav">
              <button class="tag-scroll-arrow tag-scroll-arrow--left" id="tag-scroll-left" aria-label="Scroll tags left" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                  <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
              </button>
              <div class="tag-picker-container" id="tag-picker-container">
                <div class="tag-picker" id="tag-picker">
                  {sortedTags.map(tag => (
                    <button class="tag-picker-item" data-filter={tag.id} type="button">
                      {tag.data.name}
                    </button>
                  ))}
                </div>
              </div>
              <button class="tag-scroll-arrow tag-scroll-arrow--right" id="tag-scroll-right" aria-label="Scroll tags right" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Project list — 3-row card layout with sticky stacking -->
    <div class="project-cards-container" id="project-cards-container">
      {sorted.map((p, i) => {
        const tagsArr = (p.data.tags ?? []).map(t => tagMap[t.id] || t.id);
        const tagLine = tagsArr.join(', ');
        const firstTag = tagsArr[0] || (p.data.category ? catMap[p.data.category.id] : '');
        const metaParts = [
          { label: 'Location', val: p.data.location },
          { label: 'Client',   val: p.data.client },
          { label: 'Status',   val: p.data.status },
          { label: 'Program',  val: p.data.program },
        ].filter(m => m.val);
        return (
        <div
          class="project-card"
          style={`--card-index: ${i};`}
          data-name={p.data.name}
          data-loc={p.data.location ?? ''}
          data-year={p.data.year ?? ''}
          data-client={p.data.client ?? ''}
          data-status={p.data.status ?? ''}
          data-size={p.data.size ?? ''}
          data-program={p.data.program ?? ''}
          data-cat={p.data.category ? (catMap[p.data.category.id] || p.data.category.id) : ''}
          data-cat-id={p.data.category ? p.data.category.id : ''}
          data-tags={(p.data.tags ?? []).map(t => tagMap[t.id] || t.id).join(',')}
          data-tag-ids={(p.data.tags ?? []).map(t => t.id).join(',')}
        >
          <!-- Stacked strip — visible when the card is stuck/stacked -->
          <a href={`/projects/${p.id}`} class="project-card__stackrow">
            <span class="project-card__stack-name">{p.data.name}</span>
            <span class="project-card__stack-right">
              {tagLine && <span class="project-card__stack-tags">{tagLine}</span>}
              {p.data.year && <span class="project-card__stack-year">{p.data.year}</span>}
              <span class="project-card__pill">
                <span>Go to project</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
              </span>
            </span>
          </a>

          <!-- Expanded 3-row body -->
          <div class="project-card__full">
            <!-- Row 1: name (left) · tag + year (top right) -->
            <div class="project-card__row project-card__row1">
              <a href={`/projects/${p.id}`} class="project-card__title-link">
                <h2 class="project-card__title">{p.data.name}</h2>
              </a>
              <div class="project-card__r1-right">
                {firstTag && <span class="project-card__tag">{firstTag}</span>}
                {p.data.year && <span class="project-card__year">{p.data.year}</span>}
              </div>
            </div>

            <!-- Row 2: short intro + description (left) · image (right, natural proportion) -->
            <div class="project-card__row project-card__row2">
              <div class="project-card__text-block">
                <p class="project-card__intro">{p.data.smallIntro}</p>
                {p.data.description && (
                  <p class="project-card__desc">
                    {p.data.description.replace(/<[^>]*>/g, '').substring(0, 220) + (p.data.description.replace(/<[^>]*>/g, '').length > 220 ? '...' : '')}
                  </p>
                )}
              </div>
              <a href={`/projects/${p.id}`} class="project-card__img-wrap soft-image-container">
                {p.data.coverImage ? (
                  <img src={p.data.coverImage} alt={p.data.name} loading="lazy" />
                ) : (
                  <div class="project-card__placeholder" />
                )}
              </a>
            </div>

            <!-- Row 3: meta line (left) · go-to-project pill (right) -->
            <div class="project-card__row project-card__row3">
              <div class="project-card__metaline">
                {metaParts.map((m, idx) => (
                  <span class="project-card__meta-item">
                    {idx > 0 && <span class="project-card__meta-sep">·</span>}
                    <span class="project-card__meta-label">{m.label}</span>
                    <span class="project-card__meta-val">{m.val}</span>
                  </span>
                ))}
              </div>
              <a href={`/projects/${p.id}`} class="project-card__pill project-card__pill--cta">
                <span>Go to entire project</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
              </a>
            </div>
          </div>
        </div>
        );
      })}
    </div>

    <!-- Pagination Controls -->
    <div class="pagination-container" id="projects-pagination"></div>

    <!-- Bottom quick-search bubbles — all projects, grey by default, highlight on match -->
    <div class="proj-bubbles" id="proj-bubbles" aria-label="Quick project search">
      {sorted.map(p => {
        const tagsArr = (p.data.tags ?? []).map(t => tagMap[t.id] || t.id);
        return (
          <a
            href={`/projects/${p.id}`}
            class="proj-bubble"
            data-name={p.data.name}
            data-loc={p.data.location ?? ''}
            data-year={p.data.year ?? ''}
            data-client={p.data.client ?? ''}
            data-status={p.data.status ?? ''}
            data-program={p.data.program ?? ''}
            data-cat={p.data.category ? (catMap[p.data.category.id] || p.data.category.id) : ''}
            data-tags={tagsArr.join(',')}
          >
            <span class="proj-bubble__name">{p.data.name}</span>
            <span class="proj-bubble__tag">{tagsArr[0] || (p.data.category ? catMap[p.data.category.id] : 'Design')}</span>
          </a>
        );
      })}
    </div>
  </section>
</PageLayout>

<style>
  .projects-page {
    padding-inline: var(--_tokens---space--small);
    padding-top: calc(clamp(3.5rem, 7vh, 6rem) + 48px); /* more top padding + fixed breadcrumb space */
    padding-bottom: var(--_tokens---space--small);
    min-height: 100dvh;
    box-sizing: border-box;
    position: relative;
  }

  @media (min-width: 1200px) {
    .projects-page {
      padding-inline: clamp(6rem, 12vw, 16rem);
      padding-top: calc(clamp(4rem, 6vh, 5rem) + 48px);
    }
  }

  @media (max-width: 767px) and (orientation: portrait) {
    .projects-page {
      padding-bottom: 80px; /* space for mobile bottom docked breadcrumbs */
    }
  }

  /* Sticky search and filter header */
  .projects-sticky-header {
    position: sticky;
    top: 0;
    z-index: 90;
    background-color: var(--_tokens---color--bg);
    padding-top: 8px;
    padding-bottom: 24px;
    margin-bottom: 16px;
    border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    transition: background-color 0.3s ease;
  }

  .projects-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    text-align: left;
    gap: 6px;
    margin-bottom: 20px;
  }

  .projects-title {
    font-size: var(--_tokens---type--big);
    font-weight: 500;
    color: var(--_tokens---color--fg);
    letter-spacing: -0.03em;
    line-height: 0.95;
    margin: 0;
  }

  .projects-count {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    letter-spacing: 0.04em;
    margin: 0;
  }

  /* Search Bar — left-aligned, taller for breathing room */
  .projects-search-bar {
    display: flex;
    gap: 12px;
    margin: 0 0 18px;
    width: 100%;
    max-width: 100%;
  }

  .projects-search-input {
    flex: 1;
    height: 66px;
    padding: 0 26px;
    font-size: var(--_tokens---type--small);
    font-family: inherit;
    background: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    color: var(--_tokens---color--fg);
    border-radius: 12px;
    outline: none;
    opacity: 0.35; /* grayed out by default */
    transition: background-color 0.2s, opacity 0.3s ease;
  }

  .projects-search-input::placeholder { color: var(--_tokens---color--muted); }
  .projects-search-input:focus,
  .projects-search-input:not(:placeholder-shown),
  .projects-search-input.is-active {
    opacity: 1; /* activated */
  }

  .projects-search-clear {
    height: 66px;
    padding: 0 26px;
    font-size: var(--_tokens---type--small);
    font-family: inherit;
    font-weight: 400;
    letter-spacing: 0.04em;
    background: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    color: var(--_tokens---color--fg);
    border-radius: 12px;
    cursor: pointer;
    white-space: nowrap;
    opacity: 0.35; /* grayed out by default */
    transition: background-color 0.2s, color 0.2s, opacity 0.3s ease;
  }

  .projects-search-input:focus ~ .projects-search-clear,
  .projects-search-input:not(:placeholder-shown) ~ .projects-search-clear,
  .projects-search-clear:hover {
    opacity: 1; /* activated */
  }

  .projects-search-clear:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  /* Filters (Dropdown Category + Scrollable Tag Picker) */
  .filter-bar {
    display: flex;
    flex-direction: row;
    gap: 32px;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 100%;
    margin: 0;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .filter-group--tags {
    flex: 1;
    min-width: 0;
    opacity: 0.35; /* grayed out by default */
    transition: opacity 0.3s ease;
  }

  .filter-group--tags:hover,
  .filter-group--tags:focus-within,
  .filter-group--tags.is-active {
    opacity: 1; /* activated */
  }

  .filter-label {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    text-transform: none;
    letter-spacing: 0.08em;
    color: var(--_tokens---color--muted);
    flex-shrink: 0;
  }

  .filter-select-wrap {
    position: relative;
    display: inline-block;
    flex-shrink: 0;
    opacity: 0.35; /* grayed out by default */
    transition: opacity 0.3s ease;
  }

  .filter-select-wrap:hover,
  .filter-select-wrap:focus-within,
  .filter-select-wrap.is-active {
    opacity: 1; /* activated */
  }

  .filter-select {
    appearance: none;
    -webkit-appearance: none;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--fg);
    font-family: inherit;
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    text-transform: none;
    letter-spacing: 0.04em;
    border: none;
    border-radius: 8px;
    padding: 10px 40px 10px 16px;
    cursor: pointer;
    outline: none;
    min-width: 180px;
    transition: background-color 0.2s;
  }

  .filter-select:hover {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
  }

  .filter-select option {
    background-color: var(--_tokens---color--bg);
    color: var(--_tokens---color--fg);
  }

  .filter-select-arrow {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    width: 1em;
    height: 1em;
    font-size: var(--_tokens---type--micro);
    pointer-events: none;
    color: var(--_tokens---color--fg);
    opacity: 0.7;
  }

  /* Tag horizontal scrollable picker */
  .tag-picker-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
    min-width: 0;
  }

  .tag-picker-divider {
    color: color-mix(in srgb, var(--_tokens---color--fg) 15%, transparent);
    font-weight: 300;
    font-size: var(--_tokens---type--micro);
    user-select: none;
    flex-shrink: 0;
  }

  .tag-scroll-nav {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
    min-width: 0;
  }

  .tag-scroll-arrow {
    display: none;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--fg);
    cursor: pointer;
    flex-shrink: 0;
    transition: background-color 0.2s, opacity 0.2s;
    opacity: 0.8;
  }

  .tag-scroll-arrow:hover {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    opacity: 1;
  }

  .tag-scroll-arrow:disabled {
    opacity: 0.15;
    cursor: not-allowed;
  }

  .tag-scroll-arrow svg {
    width: 16px;
    height: 16px;
  }

  .tag-picker-container {
    flex: 1;
    min-width: 0;
    max-width: 420px;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 2px;
    scroll-behavior: smooth;
  }

  .tag-picker-container::-webkit-scrollbar {
    display: none;
  }

  .tag-picker {
    display: flex;
    gap: 8px;
    white-space: nowrap;
    width: max-content;
  }

  .tag-picker-item {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    text-transform: none;
    letter-spacing: 0.04em;
    border: none;
    border-radius: 6px;
    padding: 6px 14px;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s;
  }

  .tag-picker-item:hover {
    color: var(--_tokens---color--fg);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
  }

  .tag-picker-item.is-active {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  /* Detailed Compact Horizontal Cards */
  .project-cards-container {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-top: 28px;
    position: relative;
  }

  .project-card {
    width: 100%;
    box-sizing: border-box;
    position: sticky;
    top: calc(250px + var(--card-index, 0) * 54px);
    background-color: var(--_tokens---color--bg);
    border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
    padding: clamp(1.5rem, 3vw, 3rem);
    transition: box-shadow 0.3s ease;
    box-shadow: 0 -8px 24px -12px rgba(0, 0, 0, 0.3);
  }

  .project-card[hidden] { display: none !important; }

  /* ── Stacked strip — compact clickable row shown when stacked ── */
  .project-card__stackrow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 13px 2px;
    text-decoration: none;
    color: var(--_tokens---color--fg);
    background-color: var(--_tokens---color--bg);
    opacity: 0;
    pointer-events: none;
  }

  .project-card.is-stacked .project-card__stackrow {
    opacity: 1;
    pointer-events: auto;
  }

  .project-card__stack-name {
    font-size: var(--_tokens---type--small);
    font-weight: 700; /* bold on the left */
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .project-card__stack-right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .project-card__stack-tags,
  .project-card__stack-year {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    color: var(--_tokens---color--muted);
    white-space: nowrap;
  }

  /* ── Pill / bubble button ── */
  .project-card__pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: var(--_tokens---type--micro);
    font-weight: 500;
    color: var(--_tokens---color--fg);
    text-decoration: none;
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 22%, transparent);
    border-radius: 999px;
    padding: 7px 14px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .project-card__pill svg { width: 0.85em; height: 0.85em; transition: transform 0.25s ease; }

  .project-card__pill:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
    border-color: var(--_tokens---color--fg);
  }

  .project-card__pill:hover svg { transform: translate(2px, -2px); }

  /* ── Expanded 3-row body ── */
  .project-card__full {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .project-card.is-stacked .project-card__full {
    opacity: 0;
    pointer-events: none;
  }

  .project-card__row {
    display: flex;
    align-items: center; /* centrally align all text in the row vertically */
    justify-content: space-between;
    gap: 32px;
    width: 100%;
  }

  /* Row 1: name + tag/year */
  .project-card__row1 { align-items: center; }

  .project-card__title-link { text-decoration: none; color: var(--_tokens---color--fg); }

  .project-card__title {
    font-size: var(--_tokens---type--medium);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .project-card__title-link:hover .project-card__title { opacity: 0.7; }

  .project-card__r1-right {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-shrink: 0;
  }

  .project-card__tag {
    font-size: var(--_tokens---type--micro);
    color: var(--_tokens---color--muted);
    letter-spacing: 0.04em;
  }

  .project-card__year {
    font-size: var(--_tokens---type--micro); /* micro text size */
    font-weight: 500;
    color: var(--_tokens---color--fg);
  }

  /* Row 2: intro + description + image */
  .project-card__row2 { align-items: center; }

  .project-card__text-block {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }

  .project-card__intro {
    font-size: var(--_tokens---type--small);
    font-weight: 600; /* semibold */
    line-height: 1.5;
    color: var(--_tokens---color--muted);
    margin: 0;
    max-width: 62ch;
  }

  .project-card__desc {
    font-size: var(--_tokens---type--micro); /* micro size */
    line-height: 1.55;
    color: var(--_tokens---color--muted);
    margin: 0;
    max-width: 62ch;
    opacity: 0.85;
  }

  .project-card__img-wrap {
    width: clamp(160px, 20vw, 240px); /* reduced image size */
    flex-shrink: 0;
    overflow: hidden;
    border-radius: 8px;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    display: block;
    line-height: 0;
  }

  .project-card__img-wrap img {
    width: 100%;
    height: auto; /* preserve the image's natural proportion */
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-card__img-wrap:hover img { transform: scale(1.03); }

  .project-card__placeholder {
    width: 100%;
    aspect-ratio: 16 / 10;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
  }

  /* Row 3: meta line + CTA pill */
  .project-card__row3 { align-items: center; }

  .project-card__metaline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px 4px;
    font-size: var(--_tokens---type--micro);
  }

  .project-card__meta-item { display: inline-flex; align-items: center; gap: 5px; }
  .project-card__meta-sep { color: color-mix(in srgb, var(--_tokens---color--fg) 25%, transparent); margin-right: 4px; }
  .project-card__meta-label { color: var(--_tokens---color--muted); font-weight: 300; letter-spacing: 0.04em; }
  .project-card__meta-val { color: var(--_tokens---color--fg); font-weight: 400; }

  .project-card__pill--cta {
    padding: 9px 16px;
    font-size: var(--_tokens---type--small);
  }

  /* Pagination styles - Dot buttons */
  .pagination-container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: 48px;
    margin-bottom: 24px;
  }

  .pagination-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background-color: var(--_tokens---color--muted);
    cursor: pointer;
    padding: 0;
    transition: background-color 0.2s, transform 0.2s, opacity 0.2s;
    opacity: 0.5;
  }

  .pagination-dot:hover {
    background-color: var(--_tokens---color--fg);
    opacity: 1;
  }

  .pagination-dot.is-active {
    background-color: var(--_tokens---color--fg);
    transform: scale(1.3);
    opacity: 1;
  }

  .pagination-dot:disabled {
    opacity: 0.15;
    cursor: not-allowed;
  }

  /* ── Bottom quick-search bubbles ── */
  .proj-bubbles {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 56px;
    padding-top: 28px;
    border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
  }

  .proj-bubble {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 2%, transparent);
    text-decoration: none;
    white-space: nowrap;
    opacity: 0.32; /* greyed out by default */
    transition: opacity 0.25s ease, background-color 0.25s ease, border-color 0.25s ease, transform 0.2s ease;
  }

  .proj-bubble__name {
    font-size: var(--_tokens---type--micro);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--_tokens---color--fg);
  }

  .proj-bubble__tag {
    font-family: var(--_tokens---font--mono);
    font-size: 0.6rem;
    color: var(--_tokens---color--muted);
    letter-spacing: 0.04em;
  }

  /* Highlighted when matching the active search/filters */
  .proj-bubble.is-match {
    opacity: 1;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 7%, transparent);
    border-color: color-mix(in srgb, var(--_tokens---color--fg) 22%, transparent);
  }

  .proj-bubble.is-match:hover { transform: translateY(-2px); }

  @media (max-width: 768px) {
    .projects-sticky-header {
      position: relative;
      top: auto !important;
      padding-top: 0;
      border-bottom: none;
    }
    .filter-bar {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
    .filter-group--tags {
      width: 100%;
    }
    .project-card {
      position: relative;
      top: auto !important;
      box-shadow: none;
      border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    }
    .project-card__stackrow { display: none; }
    .project-card.is-stacked .project-card__full { opacity: 1; pointer-events: auto; }
    .project-card__row2 {
      flex-direction: column;
    }
    .project-card__img-wrap {
      width: 100%;
    }
    .project-card__row,
    .project-card__row3 {
      flex-wrap: wrap;
      gap: 14px;
    }
    .tag-picker-container {
      max-width: 100%;
    }
  }
</style>

<script>
  const container = document.getElementById('project-cards-container');
  const cards = container?.querySelectorAll<HTMLElement>('.project-card') ?? [];
  const searchInput = document.getElementById('projects-search-input') as HTMLInputElement;
  const clearBtn = document.getElementById('projects-search-clear');
  const countLabel = document.querySelector('.projects-count');
  const paginationContainer = document.getElementById('projects-pagination');

  const catSelect = document.getElementById('cat-select') as HTMLSelectElement;
  const tagPicker = document.getElementById('tag-picker');

  let searchQuery = '';
  let activeCat = '';
  let activeTag = '';
  let currentPage = 1;
  const ITEMS_PER_PAGE = 10;

  function renderPagination(totalItems, matchingCards) {
    if (!paginationContainer) return;
    paginationContainer.innerHTML = '';

    const totalPages = Math.ceil(totalItems / ITEMS_PER_PAGE);
    if (totalPages <= 1) return;

    for (let i = 1; i <= totalPages; i++) {
      const dot = document.createElement('button');
      dot.className = `pagination-dot${i === currentPage ? ' is-active' : ''}`;
      dot.setAttribute('aria-label', `Page ${i}`);
      dot.addEventListener('click', () => {
        currentPage = i;
        applyVisibility(matchingCards);
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      paginationContainer.appendChild(dot);
    }
  }

  function applyVisibility(matchingCards) {
    const totalMatching = matchingCards.length;
    const totalPages = Math.ceil(totalMatching / ITEMS_PER_PAGE);

    if (currentPage > totalPages && totalPages > 0) {
      currentPage = totalPages;
    }
    if (currentPage < 1) {
      currentPage = 1;
    }

    const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
    const endIndex = startIndex + ITEMS_PER_PAGE;

    cards.forEach(card => {
      card.hidden = true;
    });

    matchingCards.forEach((card, idx) => {
      if (idx >= startIndex && idx < endIndex) {
        card.hidden = false;
        // Dynamically compute the stacking index for visible cards on this page
        card.style.setProperty('--card-index', String(idx - startIndex));
      } else {
        card.hidden = true;
      }
    });

    if (countLabel) {
      const showStart = totalMatching > 0 ? startIndex + 1 : 0;
      const showEnd = Math.min(endIndex, totalMatching);
      countLabel.textContent = `Showing ${showStart} to ${showEnd} of ${totalMatching} works`;
    }

    renderPagination(totalMatching, matchingCards);
  }

  // Bottom bubbles: always present, grey by default, highlight on search match
  const bubbles = document.querySelectorAll<HTMLElement>('.proj-bubble');
  function updateBubbles(keywords: string[]) {
    bubbles.forEach(b => {
      if (!keywords.length) { b.classList.remove('is-match'); return; }
      const hay = [
        b.dataset.name, b.dataset.loc, b.dataset.year, b.dataset.client,
        b.dataset.status, b.dataset.program, b.dataset.cat, b.dataset.tags
      ].join(' ').toLowerCase();
      b.classList.toggle('is-match', keywords.every(kw => hay.includes(kw)));
    });
  }

  function updateFieldActivation() {
    // 1. Search input
    if (searchInput) {
      if (searchInput.value.trim()) searchInput.classList.add('is-active');
      else searchInput.classList.remove('is-active');
    }
    // 2. Category select dropdown
    const selectWrap = document.querySelector('.filter-select-wrap');
    if (catSelect && selectWrap) {
      if (catSelect.value) selectWrap.classList.add('is-active');
      else selectWrap.classList.remove('is-active');
    }
    // 3. Tag group wrapper
    const tagGroup = document.querySelector('.filter-group--tags');
    if (tagGroup) {
      if (activeTag) tagGroup.classList.add('is-active');
      else tagGroup.classList.remove('is-active');
    }
  }

  function applyFilter() {
    updateFieldActivation();
    const query = searchQuery.trim().toLowerCase();
    const keywords = query.split(/\s+/).filter(Boolean);

    const matchingCards: HTMLElement[] = [];

    cards.forEach(card => {
      const name = (card.dataset.name ?? '').toLowerCase();
      const loc = (card.dataset.loc ?? '').toLowerCase();
      const year = (card.dataset.year ?? '').toLowerCase();
      const client = (card.dataset.client ?? '').toLowerCase();
      const status = (card.dataset.status ?? '').toLowerCase();
      const size = (card.dataset.size ?? '').toLowerCase();
      const program = (card.dataset.program ?? '').toLowerCase();
      const cat = (card.dataset.cat ?? '').toLowerCase();
      const tags = (card.dataset.tags ?? '').toLowerCase();
      const catId = card.dataset.catId ?? '';
      const tagIds = (card.dataset.tagIds ?? '').split(',').filter(Boolean);

      // smart multi-keyword match (AND logic)
      const searchMatch = !keywords.length || keywords.every(kw =>
        name.includes(kw) ||
        loc.includes(kw) ||
        year.includes(kw) ||
        client.includes(kw) ||
        status.includes(kw) ||
        size.includes(kw) ||
        program.includes(kw) ||
        cat.includes(kw) ||
        tags.includes(kw)
      );

      const catMatch = !activeCat || catId === activeCat;
      const tagMatch = !activeTag || tagIds.includes(activeTag);

      if (searchMatch && catMatch && tagMatch) {
        matchingCards.push(card);
      }
    });

    applyVisibility(matchingCards);
    updateBubbles(keywords);
  }

  // Input typing listener
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value;
    currentPage = 1;
    applyFilter();
  });

  // Select dropdown filter listeners
  catSelect?.addEventListener('change', (e) => {
    activeCat = (e.target as HTMLSelectElement).value;
    currentPage = 1;
    applyFilter();
  });

  // --- Tag Picker Scroll Navigation ---
  const tagPickerContainer = document.getElementById('tag-picker-container');
  const scrollLeftBtn = document.getElementById('tag-scroll-left') as HTMLButtonElement;
  const scrollRightBtn = document.getElementById('tag-scroll-right') as HTMLButtonElement;

  function updateScrollArrows() {
    if (!tagPickerContainer || !scrollLeftBtn || !scrollRightBtn) return;
    const { scrollLeft, scrollWidth, clientWidth } = tagPickerContainer;
    
    // Disable arrows based on scroll position limits
    scrollLeftBtn.disabled = scrollLeft <= 1;
    scrollRightBtn.disabled = scrollLeft + clientWidth >= scrollWidth - 2;
    
    // Only display arrows if container actually has overflow
    const hasOverflow = scrollWidth > clientWidth;
    scrollLeftBtn.style.display = hasOverflow ? 'flex' : 'none';
    scrollRightBtn.style.display = hasOverflow ? 'flex' : 'none';
  }

  // Smooth scroll offset on arrow click
  scrollLeftBtn?.addEventListener('click', () => {
    tagPickerContainer?.scrollBy({ left: -140, behavior: 'smooth' });
  });

  scrollRightBtn?.addEventListener('click', () => {
    tagPickerContainer?.scrollBy({ left: 140, behavior: 'smooth' });
  });

  tagPickerContainer?.addEventListener('scroll', updateScrollArrows, { passive: true });
  window.addEventListener('resize', updateScrollArrows, { passive: true });

  const allTagBtn = document.getElementById('all-tag-btn');

  // Static All Tag button click listener
  allTagBtn?.addEventListener('click', () => {
    // Remove active state from all scrolling tag buttons
    tagPicker?.querySelectorAll('.tag-picker-item').forEach(b => b.classList.remove('is-active'));
    allTagBtn.classList.add('is-active');
    activeTag = '';
    currentPage = 1;
    applyFilter();
    setTimeout(updateScrollArrows, 50);
  });

  // Tag scrollable picker click listener using event delegation
  tagPicker?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.tag-picker-item');
    if (!btn) return;

    const filter = (btn as HTMLElement).dataset.filter ?? '';
    activeTag = filter;
    currentPage = 1;

    // Set active state on clicked button and remove from all others (including All tag button)
    allTagBtn?.classList.remove('is-active');
    tagPicker.querySelectorAll('.tag-picker-item').forEach(b => {
      b.classList.toggle('is-active', b === btn);
    });

    applyFilter();
    // Re-check arrows in case item selection changes container layout (unlikely but safe)
    setTimeout(updateScrollArrows, 50);
  });

  // --- Scroll-Driven Card Stacking Title Animation ---
  function handleCardStacking() {
    const isMobile = window.innerWidth <= 768;
    cards.forEach(card => {
      if (card.hidden) return;
      if (isMobile) {
        card.classList.remove('is-stacked');
        return;
      }
      const rect = card.getBoundingClientRect();
      const computedTop = parseFloat(window.getComputedStyle(card).top);
      // Stuck check: card rect.top meets its sticky top constraint
      const isStacked = rect.top <= computedTop + 2;
      card.classList.toggle('is-stacked', isStacked);
    });
  }

  window.addEventListener('scroll', handleCardStacking, { passive: true });
  window.addEventListener('resize', handleCardStacking, { passive: true });

  // Clear search and filters trigger
  clearBtn?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    if (catSelect) catSelect.value = '';
    searchQuery = '';
    activeCat = '';
    activeTag = '';
    currentPage = 1;
    // Reset tag picker active states
    allTagBtn?.classList.add('is-active');
    tagPicker?.querySelectorAll('.tag-picker-item').forEach(btn => {
      btn.classList.remove('is-active');
    });
    applyFilter();
    updateScrollArrows();
  });

  // Pre-load search query from URL params if present (links from skillset click on About page)
  const urlParams = new URLSearchParams(window.location.search);
  const qParam = urlParams.get('search') || urlParams.get('q');
  if (qParam) {
    searchQuery = qParam;
    if (searchInput) searchInput.value = qParam;
  }

  // Initialize visibility, card stacking state, and tag scroll arrows
  applyFilter();
  handleCardStacking();
  // Brief delay to allow browser layout calculation of scrollWidth/clientWidth
  setTimeout(updateScrollArrows, 100);
</script>
