---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

const allProjects = await getCollection('projects');
const allTags = await getCollection('tags');
const allCats = await getCollection('categories');

// Sort by number then year
const sorted = [...allProjects].sort((a, b) => {
  if (a.data.numbr && b.data.numbr) return a.data.numbr - b.data.numbr;
  if (a.data.numbr) return -1;
  if (b.data.numbr) return 1;
  return parseInt(b.data.year ?? '0') - parseInt(a.data.year ?? '0');
});

const tagMap = Object.fromEntries(allTags.map(t => [t.id, t.data.name]));
const catMap = Object.fromEntries(allCats.map(c => [c.id, c.data.displayName]));
---

<PageLayout
  title="Projects"
  label="Projects"
>
  <section class="projects-page">
    <header class="projects-header">
      <h1 class="projects-title">Projects</h1>
      <p class="projects-count text-muted">{allProjects.length} of {allProjects.length} works</p>
    </header>

    <!-- Search bar matching home UI -->
    <div class="projects-search-bar">
      <input
        type="search"
        id="projects-search-input"
        class="projects-search-input"
        placeholder="Search projects by name, tag, location, client, status, year..."
        autocomplete="off"
        aria-label="Search projects"
      />
      <button class="projects-search-clear" id="projects-search-clear" type="button">@Clear All</button>
    </div>

    <!-- Filter bar matching home UI style -->
    <div class="filter-bar">
      <div class="filter-group">
        <span class="filter-label text-muted">Category</span>
        <div class="filter-pills" id="cat-filter">
          <button class="filter-pill is-active" data-filter="">All</button>
          {allCats.map(cat => (
            <button class="filter-pill" data-filter={cat.id}>
              {cat.data.displayName}
            </button>
          ))}
        </div>
      </div>
      <div class="filter-group">
        <span class="filter-label text-muted">Tag</span>
        <div class="filter-pills" id="tag-filter">
          <button class="filter-pill is-active" data-filter="">All</button>
          {allTags.map(tag => (
            <button class="filter-pill" data-filter={tag.id}>
              {tag.data.name}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Project list with detailed card layout (one per row) -->
    <div class="project-cards-container" id="project-cards-container">
      {sorted.map(p => (
        <div
          class="project-card"
          data-name={p.data.name}
          data-loc={p.data.location ?? ''}
          data-year={p.data.year ?? ''}
          data-client={p.data.client ?? ''}
          data-status={p.data.status ?? ''}
          data-size={p.data.size ?? ''}
          data-program={p.data.program ?? ''}
          data-cat={p.data.category ? (catMap[p.data.category.id] || p.data.category.id) : ''}
          data-tags={(p.data.tags ?? []).map(t => tagMap[t.id] || t.id).join(',')}
        >
          <a href={`/projects/${p.id}`} class="project-card__link">
            <div class="project-card__img-wrap">
              {p.data.coverImage ? (
                <img src={p.data.coverImage} alt={p.data.name} loading="lazy" />
              ) : (
                <div class="project-card__placeholder" />
              )}
            </div>
            
            <div class="project-card__details">
              <div class="project-card__header">
                <span class="project-card__cat">
                  {p.data.category ? catMap[p.data.category.id] : ''}
                </span>
                <h2 class="project-card__title">{p.data.name}</h2>
                {p.data.smallIntro && (
                  <p class="project-card__intro text-muted">{p.data.smallIntro}</p>
                )}
              </div>

              <!-- Metadata Grid -->
              <div class="project-card__meta-grid">
                {p.data.location && (
                  <div class="meta-item">
                    <span class="meta-label text-muted">Location</span>
                    <span class="meta-val">{p.data.location}</span>
                  </div>
                )}
                {p.data.year && (
                  <div class="meta-item">
                    <span class="meta-label text-muted">Year</span>
                    <span class="meta-val">{p.data.year}</span>
                  </div>
                )}
                {p.data.client && (
                  <div class="meta-item">
                    <span class="meta-label text-muted">Client</span>
                    <span class="meta-val">{p.data.client}</span>
                  </div>
                )}
                {p.data.size && (
                  <div class="meta-item">
                    <span class="meta-label text-muted">Size</span>
                    <span class="meta-val">{p.data.size}</span>
                  </div>
                )}
                {p.data.status && (
                  <div class="meta-item">
                    <span class="meta-label text-muted">Status</span>
                    <span class="meta-val">{p.data.status}</span>
                  </div>
                )}
                {p.data.program && (
                  <div class="meta-item">
                    <span class="meta-label text-muted">Program</span>
                    <span class="meta-val">{p.data.program}</span>
                  </div>
                )}
              </div>

              <div class="project-card__footer">
                <div class="project-card__tags">
                  {(p.data.tags ?? []).map(t => (
                    <span class="project-card__tag-pill">{tagMap[t.id] || t.id}</span>
                  ))}
                </div>
                <span class="project-card__arrow" aria-hidden="true">
                  <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
                    <line x1="6" y1="18" x2="18" y2="6"></line>
                    <polyline points="10 6 18 6 18 14"></polyline>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>

    <!-- Pagination Controls -->
    <div class="pagination-container" id="projects-pagination"></div>
  </section>
</PageLayout>

<style>
  .projects-page {
    padding-block: var(--_tokens---space--medium);
  }

  .projects-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 32px;
  }

  .projects-title {
    font-size: var(--_tokens---type--medium);
    font-weight: 700;
    color: var(--_tokens---color--fg);
    letter-spacing: -0.01em;
  }

  .projects-count {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    letter-spacing: 0.04em;
  }

  /* Search Bar */
  .projects-search-bar {
    display: flex;
    gap: 12px;
    margin-bottom: 24px;
    width: 100%;
  }

  .projects-search-input {
    flex: 1;
    height: 48px;
    padding: 0 16px;
    font-size: var(--_tokens---type--small);
    font-family: inherit;
    background: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    color: var(--_tokens---color--fg);
    border-radius: 8px;
    outline: none;
    transition: background-color 0.2s;
  }

  .projects-search-input::placeholder { color: var(--_tokens---color--muted); }
  .projects-search-input:focus { background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent); }

  .projects-search-clear {
    height: 48px;
    padding: 0 20px;
    font-size: var(--_tokens---type--micro);
    font-family: inherit;
    font-weight: 600;
    letter-spacing: 0.04em;
    background: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    color: var(--_tokens---color--fg);
    border-radius: 8px;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.2s, color 0.2s;
  }

  .projects-search-clear:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  /* Filters */
  .filter-bar {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 40px;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .filter-label {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    min-width: 80px;
  }

  .filter-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .filter-pill {
    padding: 6px 14px;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    color: var(--_tokens---color--muted);
    font-size: var(--_tokens---type--micro);
    border-radius: 8px;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .filter-pill:hover,
  .filter-pill.is-active {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  /* Detailed Horizontal Cards */
  .project-cards-container {
    display: flex;
    flex-direction: column;
    gap: 48px;
    margin-top: 16px;
  }

  .project-card {
    width: 100%;
    box-sizing: border-box;
  }

  .project-card[hidden] {
    display: none !important;
  }

  .project-card__link {
    display: grid;
    grid-template-columns: clamp(260px, 24vw, 380px) 1fr;
    gap: 48px;
    align-items: stretch;
    text-decoration: none;
    color: var(--_tokens---color--fg);
    transition: opacity 0.2s ease;
  }

  .project-card__link:hover {
    opacity: 0.85;
  }

  .project-card__img-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    width: 100%;
    overflow: hidden;
    border-radius: 8px;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
  }

  .project-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-card__link:hover img {
    transform: scale(1.03);
  }

  .project-card__placeholder {
    width: 100%;
    height: 100%;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
  }

  .project-card__details {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-block: 8px;
  }

  .project-card__header {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .project-card__cat {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--_tokens---color--muted);
  }

  .project-card__title {
    font-size: var(--_tokens---type--medium);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .project-card__intro {
    font-size: var(--_tokens---type--small);
    line-height: 1.6;
    max-width: 68ch;
    margin-top: 4px;
  }

  /* Metadata Grid */
  .project-card__meta-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px 24px;
    margin-block: 24px;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .meta-label {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .meta-val {
    font-size: var(--_tokens---type--micro);
    font-weight: 400;
    color: var(--_tokens---color--fg);
  }

  .project-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .project-card__tag-pill {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    padding: 4px 10px;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    border-radius: 4px;
    text-transform: capitalize;
  }

  .project-card__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    opacity: 0.5;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }

  .project-card__link:hover .project-card__arrow {
    transform: translate(4px, -4px);
    opacity: 1;
  }

  .link-arrow {
    width: 100%;
    height: 100%;
  }

  /* Pagination styles */
  .pagination-container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    margin-top: 64px;
    margin-bottom: 32px;
  }

  .pagination-btn {
    background: none;
    border: none;
    font-size: var(--_tokens---type--micro);
    font-family: inherit;
    font-weight: 500;
    text-transform: uppercase;
    color: var(--_tokens---color--muted);
    cursor: pointer;
    padding: 8px 16px;
    border-radius: 6px;
    transition: background-color 0.2s, color 0.2s;
  }

  .pagination-btn:hover {
    color: var(--_tokens---color--fg);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
  }

  .pagination-btn.is-active {
    color: var(--_tokens---color--bg);
    background-color: var(--_tokens---color--fg);
  }

  .pagination-btn:disabled {
    opacity: 0.25;
    cursor: not-allowed;
  }

  @media (max-width: 900px) {
    .project-card__link {
      grid-template-columns: 240px 1fr;
      gap: 32px;
    }
    .project-card__meta-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .project-card__link {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .project-card__img-wrap {
      aspect-ratio: 16 / 9;
    }
    .project-card__meta-grid {
      grid-template-columns: repeat(2, 1fr);
      margin-block: 16px;
    }
    .project-card__details {
      padding-block: 0;
    }
  }
</style>

<script>
  const container = document.getElementById('project-cards-container');
  const cards = container?.querySelectorAll<HTMLElement>('.project-card') ?? [];
  const searchInput = document.getElementById('projects-search-input') as HTMLInputElement;
  const clearBtn = document.getElementById('projects-search-clear');
  const countLabel = document.querySelector('.projects-count');
  const paginationContainer = document.getElementById('projects-pagination');

  let searchQuery = '';
  let activeCat = '';
  let activeTag = '';
  let currentPage = 1;
  const ITEMS_PER_PAGE = 10;

  function renderPagination(totalItems, matchingCards) {
    if (!paginationContainer) return;
    paginationContainer.innerHTML = '';

    const totalPages = Math.ceil(totalItems / ITEMS_PER_PAGE);
    if (totalPages <= 1) return;

    // Prev Button
    const prevBtn = document.createElement('button');
    prevBtn.className = 'pagination-btn';
    prevBtn.textContent = 'Prev';
    prevBtn.disabled = currentPage === 1;
    prevBtn.addEventListener('click', () => {
      currentPage--;
      applyVisibility(matchingCards);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
    paginationContainer.appendChild(prevBtn);

    // Page Number Buttons
    for (let i = 1; i <= totalPages; i++) {
      const pageBtn = document.createElement('button');
      pageBtn.className = `pagination-btn${i === currentPage ? ' is-active' : ''}`;
      pageBtn.textContent = String(i);
      pageBtn.addEventListener('click', () => {
        currentPage = i;
        applyVisibility(matchingCards);
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      paginationContainer.appendChild(pageBtn);
    }

    // Next Button
    const nextBtn = document.createElement('button');
    nextBtn.className = 'pagination-btn';
    nextBtn.textContent = 'Next';
    nextBtn.disabled = currentPage === totalPages;
    nextBtn.addEventListener('click', () => {
      currentPage++;
      applyVisibility(matchingCards);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
    paginationContainer.appendChild(nextBtn);
  }

  function applyVisibility(matchingCards) {
    const totalMatching = matchingCards.length;
    const totalPages = Math.ceil(totalMatching / ITEMS_PER_PAGE);

    if (currentPage > totalPages && totalPages > 0) {
      currentPage = totalPages;
    }
    if (currentPage < 1) {
      currentPage = 1;
    }

    const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
    const endIndex = startIndex + ITEMS_PER_PAGE;

    cards.forEach(card => {
      card.hidden = true;
    });

    matchingCards.forEach((card, idx) => {
      if (idx >= startIndex && idx < endIndex) {
        card.hidden = false;
      } else {
        card.hidden = true;
      }
    });

    if (countLabel) {
      const showStart = totalMatching > 0 ? startIndex + 1 : 0;
      const showEnd = Math.min(endIndex, totalMatching);
      countLabel.textContent = `Showing ${showStart} to ${showEnd} of ${totalMatching} works`;
    }

    renderPagination(totalMatching, matchingCards);
  }

  function applyFilter() {
    const query = searchQuery.trim().toLowerCase();
    const keywords = query.split(/\s+/).filter(Boolean);

    const matchingCards: HTMLElement[] = [];

    cards.forEach(card => {
      const name = (card.dataset.name ?? '').toLowerCase();
      const loc = (card.dataset.loc ?? '').toLowerCase();
      const year = (card.dataset.year ?? '').toLowerCase();
      const client = (card.dataset.client ?? '').toLowerCase();
      const status = (card.dataset.status ?? '').toLowerCase();
      const size = (card.dataset.size ?? '').toLowerCase();
      const program = (card.dataset.program ?? '').toLowerCase();
      const cat = (card.dataset.cat ?? '').toLowerCase();
      const tags = (card.dataset.tags ?? '').toLowerCase();

      // smart multi-keyword match (AND logic)
      const searchMatch = !keywords.length || keywords.every(kw => 
        name.includes(kw) || 
        loc.includes(kw) || 
        year.includes(kw) || 
        client.includes(kw) || 
        status.includes(kw) || 
        size.includes(kw) || 
        program.includes(kw) || 
        cat.includes(kw) || 
        tags.includes(kw)
      );

      const catMatch = !activeCat || cat === activeCat.toLowerCase();

      const rowTags = tags.split(',').filter(Boolean);
      const tagMatch = !activeTag || rowTags.includes(activeTag.toLowerCase());

      if (searchMatch && catMatch && tagMatch) {
        matchingCards.push(card);
      }
    });

    applyVisibility(matchingCards);
  }

  // Input typing listener
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value;
    currentPage = 1;
    applyFilter();
  });

  // Pills filter listeners
  document.querySelectorAll('#cat-filter .filter-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#cat-filter .filter-pill').forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      activeCat = (btn as HTMLElement).dataset.filter ?? '';
      currentPage = 1;
      applyFilter();
    });
  });

  document.querySelectorAll('#tag-filter .filter-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#tag-filter .filter-pill').forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      activeTag = (btn as HTMLElement).dataset.filter ?? '';
      currentPage = 1;
      applyFilter();
    });
  });

  // Clear search and pills trigger
  clearBtn?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    searchQuery = '';
    activeCat = '';
    activeTag = '';
    currentPage = 1;
    document.querySelectorAll('.filter-pill').forEach(pill => {
      pill.classList.toggle('is-active', (pill as HTMLElement).dataset.filter === '');
    });
    applyFilter();
  });

  // Initialize visibility
  applyFilter();
</script>
