---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

const allProjects = await getCollection('projects');
const allTags = await getCollection('tags');
const allCats = await getCollection('categories');

// Sort by number then year
const sorted = [...allProjects].sort((a, b) => {
  if (a.data.numbr && b.data.numbr) return a.data.numbr - b.data.numbr;
  if (a.data.numbr) return -1;
  if (b.data.numbr) return 1;
  return parseInt(b.data.year ?? '0') - parseInt(a.data.year ?? '0');
});

const tagMap = Object.fromEntries(allTags.map(t => [t.id, t.data.name]));
const catMap = Object.fromEntries(allCats.map(c => [c.id, c.data.displayName]));
---

<PageLayout
  title="Projects"
  label="Projects"
>
  <section class="projects-page">
    <div class="projects-sticky-header">
      <header class="projects-header">
        <h1 class="projects-title">Projects</h1>
        <p class="projects-count text-muted">{allProjects.length} of {allProjects.length} works</p>
      </header>

      <!-- Search bar matching home UI -->
      <div class="projects-search-bar">
        <input
          type="search"
          id="projects-search-input"
          class="projects-search-input"
          placeholder="Search projects by name, tag, location, client, status, year..."
          autocomplete="off"
          aria-label="Search projects"
        />
        <button class="projects-search-clear" id="projects-search-clear" type="button">@Clear All</button>
      </div>

      <!-- Filter bar with dropdown and scrollable tag picker -->
      <div class="filter-bar">
        <div class="filter-group">
          <span class="filter-label text-muted">Category</span>
          <div class="filter-select-wrap">
            <select id="cat-select" class="filter-select">
              <option value="">All Categories</option>
              {allCats.map(cat => (
                <option value={cat.id}>{cat.data.displayName}</option>
              ))}
            </select>
            <svg class="filter-select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </div>
        </div>
        
        <div class="filter-group filter-group--tags">
          <span class="filter-label text-muted">Tag</span>
          <div class="tag-picker-container">
            <div class="tag-picker" id="tag-picker">
              <button class="tag-picker-item is-active" data-filter="">All</button>
              {allTags.map(tag => (
                <button class="tag-picker-item" data-filter={tag.id}>
                  {tag.data.name}
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Project list with detailed compact card layout (one per row) -->
    <div class="project-cards-container" id="project-cards-container">
      {sorted.map((p, i) => (
        <div
          class="project-card"
          style={`--card-index: ${i};`}
          data-name={p.data.name}
          data-loc={p.data.location ?? ''}
          data-year={p.data.year ?? ''}
          data-client={p.data.client ?? ''}
          data-status={p.data.status ?? ''}
          data-size={p.data.size ?? ''}
          data-program={p.data.program ?? ''}
          data-cat={p.data.category ? (catMap[p.data.category.id] || p.data.category.id) : ''}
          data-tags={(p.data.tags ?? []).map(t => tagMap[t.id] || t.id).join(',')}
        >
          <a href={`/projects/${p.id}`} class="project-card__link">
            <!-- Left side: Details -->
            <div class="project-card__details">
              <!-- Top: Category and Tags -->
              <div class="project-card__top">
                <span class="project-card__cat">
                  {p.data.category ? catMap[p.data.category.id] : ''}
                </span>
                {p.data.tags && p.data.tags.length > 0 && (
                  <span class="project-card__tag-list text-muted">
                    · {p.data.tags.map(t => tagMap[t.id] || t.id).join(', ')}
                  </span>
                )}
              </div>

              <!-- Middle: Title & Metadata -->
              <div class="project-card__mid">
                <h2 class="project-card__title">{p.data.name}</h2>
                
                <!-- Metadata Grid -->
                <div class="project-card__meta-grid">
                  {p.data.location && (
                    <div class="meta-item">
                      <span class="meta-label text-muted">Location</span>
                      <span class="meta-val">{p.data.location}</span>
                    </div>
                  )}
                  {p.data.year && (
                    <div class="meta-item">
                      <span class="meta-label text-muted">Year</span>
                      <span class="meta-val">{p.data.year}</span>
                    </div>
                  )}
                  {p.data.client && (
                    <div class="meta-item">
                      <span class="meta-label text-muted">Client</span>
                      <span class="meta-val">{p.data.client}</span>
                    </div>
                  )}
                  {p.data.size && (
                    <div class="meta-item">
                      <span class="meta-label text-muted">Size</span>
                      <span class="meta-val">{p.data.size}</span>
                    </div>
                  )}
                  {p.data.status && (
                    <div class="meta-item">
                      <span class="meta-label text-muted">Status</span>
                      <span class="meta-val">{p.data.status}</span>
                    </div>
                  )}
                  {p.data.program && (
                    <div class="meta-item">
                      <span class="meta-label text-muted">Program</span>
                      <span class="meta-val">{p.data.program}</span>
                    </div>
                  )}
                </div>
              </div>

              <!-- Bottom: Small Intro (Intro is LAST) -->
              <div class="project-card__bottom">
                {p.data.smallIntro && (
                  <p class="project-card__intro text-muted">{p.data.smallIntro}</p>
                )}
              </div>
            </div>

            <!-- Right side: Image -->
            <div class="project-card__img-wrap">
              {p.data.coverImage ? (
                <img src={p.data.coverImage} alt={p.data.name} loading="lazy" />
              ) : (
                <div class="project-card__placeholder" />
              )}
              
              <!-- Arrow absolutely positioned overlaying the cover image -->
              <span class="project-card__arrow" aria-hidden="true">
                <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="square" stroke-linejoin="miter">
                  <line x1="6" y1="18" x2="18" y2="6"></line>
                  <polyline points="10 6 18 6 18 14"></polyline>
                </svg>
              </span>
            </div>
          </a>
        </div>
      ))}
    </div>

    <!-- Pagination Controls -->
    <div class="pagination-container" id="projects-pagination"></div>
  </section>
</PageLayout>

<style>
  .projects-page {
    padding-block: var(--_tokens---space--medium);
    position: relative;
  }

  /* Sticky search and filter header */
  .projects-sticky-header {
    position: sticky;
    top: 0;
    z-index: 90;
    background-color: var(--_tokens---color--bg);
    padding-top: 8px;
    padding-bottom: 24px;
    margin-bottom: 16px;
    border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    transition: background-color 0.3s ease;
  }

  .projects-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .projects-title {
    font-size: var(--_tokens---type--medium);
    font-weight: 700;
    color: var(--_tokens---color--fg);
    letter-spacing: -0.01em;
    margin: 0;
  }

  .projects-count {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    letter-spacing: 0.04em;
    margin: 0;
  }

  /* Search Bar */
  .projects-search-bar {
    display: flex;
    gap: 12px;
    margin-bottom: 20px;
    width: 100%;
  }

  .projects-search-input {
    flex: 1;
    height: 48px;
    padding: 0 16px;
    font-size: var(--_tokens---type--small);
    font-family: inherit;
    background: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    color: var(--_tokens---color--fg);
    border-radius: 8px;
    outline: none;
    transition: background-color 0.2s;
  }

  .projects-search-input::placeholder { color: var(--_tokens---color--muted); }
  .projects-search-input:focus { background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent); }

  .projects-search-clear {
    height: 48px;
    padding: 0 20px;
    font-size: var(--_tokens---type--micro);
    font-family: inherit;
    font-weight: 600;
    letter-spacing: 0.04em;
    background: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    border: none;
    color: var(--_tokens---color--fg);
    border-radius: 8px;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.2s, color 0.2s;
  }

  .projects-search-clear:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  /* Filters (Dropdown Category + Scrollable Tag Picker) */
  .filter-bar {
    display: flex;
    flex-direction: row;
    gap: 32px;
    align-items: center;
    width: 100%;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .filter-group--tags {
    flex: 1;
    min-width: 0;
  }

  .filter-label {
    font-size: var(--_tokens---type--micro);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--_tokens---color--muted);
    flex-shrink: 0;
  }

  .filter-select-wrap {
    position: relative;
    display: inline-block;
    flex-shrink: 0;
  }

  .filter-select {
    appearance: none;
    -webkit-appearance: none;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--fg);
    font-family: inherit;
    font-size: var(--_tokens---type--micro);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border: none;
    border-radius: 8px;
    padding: 10px 40px 10px 16px;
    cursor: pointer;
    outline: none;
    min-width: 180px;
    transition: background-color 0.2s;
  }

  .filter-select:hover {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
  }

  .filter-select option {
    background-color: var(--_tokens---color--bg);
    color: var(--_tokens---color--fg);
  }

  .filter-select-arrow {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    width: 12px;
    height: 12px;
    pointer-events: none;
    color: var(--_tokens---color--fg);
    opacity: 0.7;
  }

  /* Tag horizontal scrollable picker */
  .tag-picker-container {
    flex: 1;
    overflow-x: auto;
    scrollbar-width: thin;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 2px;
  }

  .tag-picker-container::-webkit-scrollbar {
    height: 3px;
  }

  .tag-picker-container::-webkit-scrollbar-track {
    background: color-mix(in srgb, var(--_tokens---color--fg) 4%, transparent);
    border-radius: 2px;
  }

  .tag-picker-container::-webkit-scrollbar-thumb {
    background: color-mix(in srgb, var(--_tokens---color--fg) 20%, transparent);
    border-radius: 2px;
  }

  .tag-picker {
    display: flex;
    gap: 8px;
    white-space: nowrap;
    width: max-content;
  }

  .tag-picker-item {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
    color: var(--_tokens---color--muted);
    font-size: var(--_tokens---type--micro);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border: none;
    border-radius: 6px;
    padding: 6px 14px;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s;
  }

  .tag-picker-item:hover {
    color: var(--_tokens---color--fg);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
  }

  .tag-picker-item.is-active {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  /* Detailed Compact Horizontal Cards */
  .project-cards-container {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-top: 16px;
    position: relative;
  }

  .project-card {
    width: 100%;
    box-sizing: border-box;
    position: sticky;
    top: calc(250px + var(--card-index, 0) * 36px);
    background-color: var(--_tokens---color--bg);
    border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 8%, transparent);
    padding-top: 20px;
    padding-bottom: 16px;
    transition: transform 0.3s ease, box-shadow 0.3s ease, top 0.3s ease;
    box-shadow: 0 -8px 24px -10px rgba(0, 0, 0, 0.3);
  }

  .project-card[hidden] {
    display: none !important;
  }

  .project-card__link {
    display: grid;
    grid-template-columns: 1fr clamp(160px, 16vw, 240px);
    gap: 32px;
    align-items: start;
    text-decoration: none;
    color: var(--_tokens---color--fg);
    transition: opacity 0.2s ease;
  }

  .project-card__link:hover {
    opacity: 0.85;
  }

  .project-card__img-wrap {
    position: relative;
    aspect-ratio: 16 / 10;
    width: 100%;
    overflow: hidden;
    border-radius: 6px;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 6%, transparent);
  }

  .project-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-card__link:hover img {
    transform: scale(1.03);
  }

  .project-card__placeholder {
    width: 100%;
    height: 100%;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
  }

  .project-card__details {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 8px;
    height: 100%;
  }

  .project-card__top {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .project-card__cat {
    font-size: var(--_tokens---type--micro);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--_tokens---color--muted);
  }

  .project-card__tag-list {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    color: var(--_tokens---color--muted);
  }

  .project-card__title {
    font-size: var(--_tokens---type--medium);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0;
  }

  /* Metadata Grid (Compact Single Line Values) */
  .project-card__meta-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 16px;
    margin-block: 4px;
  }

  .meta-item {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .meta-label {
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .meta-val {
    font-size: var(--_tokens---type--micro);
    font-weight: 400;
    color: var(--_tokens---color--fg);
  }

  .project-card__bottom {
    display: flex;
    margin-top: auto;
  }

  .project-card__intro {
    font-size: var(--_tokens---type--micro);
    line-height: 1.5;
    max-width: 80ch;
    margin: 0;
  }

  /* Rotating overlay arrow on image */
  .project-card__arrow {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 5;
    width: 28px;
    height: 28px;
    opacity: 0.75;
    color: #ffffff;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.4));
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
    pointer-events: none;
  }

  .project-card__link:hover .project-card__arrow {
    transform: rotate(45deg);
    opacity: 1;
  }

  .link-arrow {
    width: 100%;
    height: 100%;
  }

  /* Pagination styles - Dot buttons */
  .pagination-container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: 48px;
    margin-bottom: 24px;
  }

  .pagination-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background-color: var(--_tokens---color--muted);
    cursor: pointer;
    padding: 0;
    transition: background-color 0.2s, transform 0.2s, opacity 0.2s;
    opacity: 0.5;
  }

  .pagination-dot:hover {
    background-color: var(--_tokens---color--fg);
    opacity: 1;
  }

  .pagination-dot.is-active {
    background-color: var(--_tokens---color--fg);
    transform: scale(1.3);
    opacity: 1;
  }

  .pagination-dot:disabled {
    opacity: 0.15;
    cursor: not-allowed;
  }

  @media (max-width: 900px) {
    .project-card__link {
      grid-template-columns: 1fr 180px;
      gap: 24px;
    }
  }

  @media (max-width: 768px) {
    .projects-sticky-header {
      position: relative;
      top: auto !important;
      padding-top: 0;
      border-bottom: none;
    }
    .filter-bar {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
    .filter-group--tags {
      width: 100%;
    }
    .project-card {
      position: relative;
      top: auto !important;
      box-shadow: none;
      border-top: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 12%, transparent);
    }
    .project-card__link {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .project-card__img-wrap {
      aspect-ratio: 16 / 9;
    }
    .project-card__details {
      padding-block: 0;
    }
  }
</style>

<script>
  const container = document.getElementById('project-cards-container');
  const cards = container?.querySelectorAll<HTMLElement>('.project-card') ?? [];
  const searchInput = document.getElementById('projects-search-input') as HTMLInputElement;
  const clearBtn = document.getElementById('projects-search-clear');
  const countLabel = document.querySelector('.projects-count');
  const paginationContainer = document.getElementById('projects-pagination');

  const catSelect = document.getElementById('cat-select') as HTMLSelectElement;
  const tagPickerItems = document.querySelectorAll('#tag-picker .tag-picker-item');

  let searchQuery = '';
  let activeCat = '';
  let activeTag = '';
  let currentPage = 1;
  const ITEMS_PER_PAGE = 10;

  function renderPagination(totalItems, matchingCards) {
    if (!paginationContainer) return;
    paginationContainer.innerHTML = '';

    const totalPages = Math.ceil(totalItems / ITEMS_PER_PAGE);
    if (totalPages <= 1) return;

    for (let i = 1; i <= totalPages; i++) {
      const dot = document.createElement('button');
      dot.className = `pagination-dot${i === currentPage ? ' is-active' : ''}`;
      dot.setAttribute('aria-label', `Page ${i}`);
      dot.addEventListener('click', () => {
        currentPage = i;
        applyVisibility(matchingCards);
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      paginationContainer.appendChild(dot);
    }
  }

  function applyVisibility(matchingCards) {
    const totalMatching = matchingCards.length;
    const totalPages = Math.ceil(totalMatching / ITEMS_PER_PAGE);

    if (currentPage > totalPages && totalPages > 0) {
      currentPage = totalPages;
    }
    if (currentPage < 1) {
      currentPage = 1;
    }

    const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
    const endIndex = startIndex + ITEMS_PER_PAGE;

    cards.forEach(card => {
      card.hidden = true;
    });

    matchingCards.forEach((card, idx) => {
      if (idx >= startIndex && idx < endIndex) {
        card.hidden = false;
        // Dynamically compute the stacking index for visible cards on this page
        card.style.setProperty('--card-index', String(idx - startIndex));
      } else {
        card.hidden = true;
      }
    });

    if (countLabel) {
      const showStart = totalMatching > 0 ? startIndex + 1 : 0;
      const showEnd = Math.min(endIndex, totalMatching);
      countLabel.textContent = `Showing ${showStart} to ${showEnd} of ${totalMatching} works`;
    }

    renderPagination(totalMatching, matchingCards);
  }

  function applyFilter() {
    const query = searchQuery.trim().toLowerCase();
    const keywords = query.split(/\s+/).filter(Boolean);

    const matchingCards: HTMLElement[] = [];

    cards.forEach(card => {
      const name = (card.dataset.name ?? '').toLowerCase();
      const loc = (card.dataset.loc ?? '').toLowerCase();
      const year = (card.dataset.year ?? '').toLowerCase();
      const client = (card.dataset.client ?? '').toLowerCase();
      const status = (card.dataset.status ?? '').toLowerCase();
      const size = (card.dataset.size ?? '').toLowerCase();
      const program = (card.dataset.program ?? '').toLowerCase();
      const cat = (card.dataset.cat ?? '').toLowerCase();
      const tags = (card.dataset.tags ?? '').toLowerCase();

      // smart multi-keyword match (AND logic)
      const searchMatch = !keywords.length || keywords.every(kw => 
        name.includes(kw) || 
        loc.includes(kw) || 
        year.includes(kw) || 
        client.includes(kw) || 
        status.includes(kw) || 
        size.includes(kw) || 
        program.includes(kw) || 
        cat.includes(kw) || 
        tags.includes(kw)
      );

      const catMatch = !activeCat || cat === activeCat.toLowerCase();

      const rowTags = tags.split(',').filter(Boolean);
      const tagMatch = !activeTag || rowTags.includes(activeTag.toLowerCase());

      if (searchMatch && catMatch && tagMatch) {
        matchingCards.push(card);
      }
    });

    applyVisibility(matchingCards);
  }

  // Input typing listener
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value;
    currentPage = 1;
    applyFilter();
  });

  // Select dropdown filter listeners
  catSelect?.addEventListener('change', (e) => {
    activeCat = (e.target as HTMLSelectElement).value;
    currentPage = 1;
    applyFilter();
  });

  // Tag scrollable picker click listeners
  tagPickerItems.forEach(btn => {
    btn.addEventListener('click', () => {
      tagPickerItems.forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      activeTag = (btn as HTMLElement).dataset.filter ?? '';
      currentPage = 1;
      applyFilter();
    });
  });

  // Clear search and filters trigger
  clearBtn?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    if (catSelect) catSelect.value = '';
    searchQuery = '';
    activeCat = '';
    activeTag = '';
    currentPage = 1;
    // Reset tag picker active states
    tagPickerItems.forEach(btn => {
      btn.classList.toggle('is-active', (btn as HTMLElement).dataset.filter === '');
    });
    applyFilter();
  });

  // Initialize visibility
  applyFilter();
</script>
