                <!-- Collaborator circles (people) below the description -->
                <div class="project-people" style="margin-top: 24px;">
                  {people.map((person, idx) => {
                    const isCas = person === 'Casimir Esbach';
                    const isFaizan = person === 'Faizan Khatri';
                    const isDhruv = person === 'Dhruv Chavan';
                    const displayName = isCas ? `${person} (Professor)` : isDhruv ? `${person} (Mumbai Workshop)` : person;
                    // Friends (Devarsh, Dhruv) always sit to the right of the divider,
                    // regardless of who they follow.
                    const isFriend = (p: string) => p === 'Devarsh Deth' || p === 'Dhruv Chavan';
                    const showDivider = isCas || isFaizan || (!isFriend(person) && isFriend(people[idx + 1]));
                    return (
                      <>
                        <div class="project-people__person">
                          <div class="project-people__avatar">
                            <img src={PEOPLE[person] ?? PEOPLE['Advaita Kelkar']} alt={person} loading="lazy" />
                          </div>
                          <span class="project-people__name">{displayName}</span>
                        </div>
                        {showDivider && <div class="project-people__divider" aria-hidden="true" />}
                      </>
                    );
                  })}
                </div>

                <!-- Thumbnail scrub below the people -->
                {hasImages && (
                  <div class="project-detail__thumbs" id="standard-thumbs" style="margin-top: 24px; margin-bottom: 24px;">
                    {allImages.map((img, idx) => (
                      <button
                        type="button"
                        class:list={[
                          "project-detail__thumb-item",
                          idx === 0 && "is-active"
                        ]}
                        data-index={idx}
                      >
                        <img src={img} alt={`${data.name} thumbnail ${idx + 1}`} />
