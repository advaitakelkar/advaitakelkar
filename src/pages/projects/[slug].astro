    pointer-events: none;
  }

  .lightbox-name span {
    display: block;
  }

  @media (min-width: 900px) {
    .lightbox-name {
      font-size: clamp(2.4rem, 5vw, 4rem);
      padding-left: 32px;
    }
  }

  /* Deck variant: H1 styling at medium weight, centred directly below the active card */
  .card-lightbox--deck .lightbox-name {
    font-family: var(--_tokens---font--body);
    font-size: var(--_tokens---type--big);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.05;
    padding: 12px 0 24px;
    text-align: center;
  }

  /* ── Standard (non-card) lightbox: single centred image ── */
  .lightbox-perspective-wrap {
    perspective: 1500px;
    z-index: 5;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    pointer-events: none;
  }

  .lightbox-card-container {
    width: 90%;
    height: 100%;
    max-width: 420px;
    max-height: 630px;
    position: relative;
    cursor: pointer;
    transform-style: preserve-3d;
    transition: transform 0.1s cubic-bezier(0.25, 1, 0.5, 1),
                opacity 0.4s ease;
    pointer-events: auto;
    border-radius: 12px;
    background-color: rgba(255, 255, 255, 0.03);
