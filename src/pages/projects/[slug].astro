                )}
              </div>
            </div>

            {hasImages && (
            <div class="project-col-right" id="project-slider-col">
              <div class="project-slider-wrapper project-slider-wrapper--standard" id="standard-slider-wrapper" data-images={JSON.stringify(allImages)}>
                <div class="project-detail__active-wrap" id="standard-active-wrap" style="cursor: pointer;" title="Click to open image">
                  <button class="project-detail__nav-arrow project-detail__nav-arrow--prev" id="standard-prev" type="button" aria-label="Previous image">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
                  </button>
