    .lightbox-deck__item {
      width: 24vw;
      height: 62dvh;
    }
  }

  /* ── Publisher/team logo — top-left corner, like a playing-card suit mark.
     Inherits the neighbours' grayscale/blur (filter is on the item), and pops
     in with a small scale animation when the card becomes the centre one. ── */
  .lightbox-card-logo {
    position: absolute;
    top: 14px;
    left: 14px;
    width: 20%;
    max-width: 72px;
    height: 52px;
    z-index: 3;
    pointer-events: none;
    opacity: 0.55;
    transform: scale(0.85);
    transform-origin: top left;
    background-color: var(--_tokens---color--bg); /* merges with the scheme */
    -webkit-mask: var(--logo) left top / contain no-repeat;
    mask: var(--logo) left top / contain no-repeat;
    transition: opacity 0.35s ease, transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .lightbox-deck__item.is-center .lightbox-card-logo {
    opacity: 1;
    transform: scale(1);
  }

  /* ── Project name: bottom-left, one word per line ── */
  .lightbox-name {
    position: relative;
    z-index: 10;
    flex-shrink: 0;
    margin: 0;
    padding: 12px 0 16px 20px;
    font-family: var(--_tokens---font--display, var(--_tokens---font--body));
    font-size: clamp(1.4rem, 4vw, 2.2rem);
    font-weight: 700;
    line-height: 1;
    color: var(--_tokens---color--bg);
