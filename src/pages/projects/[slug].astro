---
import fs from 'node:fs';
import path from 'node:path';
import { getCollection, getEntry } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import { isPlaceholder, realText } from '../../lib/content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({
    params: { slug: p.id },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { data } = project;

// Resolve tag and category references
const tags = await Promise.all((data.tags ?? []).map(t => getEntry(t)));
const category = data.category ? await getEntry(data.category) : null;

const gallery = (data.multiImage ?? []).filter(Boolean);
const allImages = [data.coverImage, ...gallery].filter(Boolean);
const hasImages = allImages.length > 0;

const firstTag = tags.find(t => t);
const yearLoc = [data.year, data.location].filter(Boolean).join(', ');

// People registry — avatar portrait per collaborator (files in /images/people/)
const PEOPLE: Record<string, string> = {
  'Advaita Kelkar':  '/images/people/advaita-kelkar.jpg',
  'Nayan Mote':      '/images/people/nayan-mote.png',
  'Varun Mehta':     '/images/people/varun-mehta.jpeg',
  'Sneha Desai':     '/images/people/sneha-desai.jpeg',
  'Casimir Esbach':  '/images/people/casimir-esbach.jpeg',
  'Nicole Hammond':  '/images/people/nicole-hammond.png',
  'Ben Cho':         '/images/people/ben-cho.jpeg',
  'Pankti Thakkar':  '/images/people/pankti-thakkar.jpeg',
  'Faizan Khatri':   '/images/people/faizan-khatri.jpeg',
  'Samir Raut':      '/images/people/samir-raut.jpeg',
};
const people: string[] = (data.people?.length ? data.people : ['Advaita Kelkar']);

// Build dynamic breadcrumbs based on category structure
const dynamicCrumbs = [ { label: 'Home', href: '/' } ];

if (category) {
  dynamicCrumbs.push({ label: category.data.displayName, href: `/${category.id}` });
  
  if (category.id === 'work' && data.tags) {
    const subTag = data.tags.find(t => t.id === 'studio-823' || t.id === 'faizan-khatri');
    if (subTag) {
      const subLabel = subTag.id === 'studio-823' ? 'Studio 823' : 'FKD Workshop';
      dynamicCrumbs.push({ label: subLabel, href: `/work/${subTag.id}` });
    }
  }
} else {
  dynamicCrumbs.push({ label: 'Projects', href: '/projects' });
}

dynamicCrumbs.push({ label: data.name });

// Card deck page slugs
const cardPageSlugs = [
  'alt-verse',
  'architect-x-architects',
  'future-of-dance',
  'indian-royals',
  'sups-cards',
  'sups-in-the-hinterland',
  'human-pods'
];
const isCardPage = cardPageSlugs.includes(project.id);
const isScarpinPage = project.id === 'scarpin';

// Load Scarpin image data if this is the Scarpin page
let scarpinSliders: { folder: string; cleanName: string; personName: string; avatar: string | null; urls: string[] }[] = [];
if (isScarpinPage) {
  const scarpinDir = path.join(process.cwd(), 'public', 'images', 'scarpin');
  if (fs.existsSync(scarpinDir)) {
    const entries = fs.readdirSync(scarpinDir);
    for (const folder of entries) {
      if (folder.startsWith('.')) continue; // skip .DS_Store, .gitkeep
      const folderPath = path.join(scarpinDir, folder);
      if (fs.statSync(folderPath).isDirectory()) {
        let files = fs.readdirSync(folderPath).filter(f => /\.(jpe?g|png|webp|gif|mp4)$/i.test(f));
        if (files.length > 0) {
          files.sort();
          // Ensure a file named 'cover' (any extension) is always first
          const coverIdx = files.findIndex(f => f.toLowerCase().startsWith('cover.'));
          if (coverIdx > 0) {
            const coverFile = files.splice(coverIdx, 1)[0];
            files.unshift(coverFile);
          }
          
          const urls = files.map(f => `/images/scarpin/${folder}/${f}`);
          
          let cleanName = folder.replace(/^\d+\s*/, '').trim();
          let personName = '';
          const dashIdx = cleanName.lastIndexOf('-');
          if (dashIdx !== -1) {
            personName = cleanName.substring(dashIdx + 1).trim();
            cleanName = cleanName.substring(0, dashIdx).trim();
          }

          let avatar = null;
          if (personName) {
            const searchName = personName.toLowerCase().replace(/[^a-z]/g, '');
            for (const [key, val] of Object.entries(PEOPLE)) {
              if (key.toLowerCase().replace(/[^a-z]/g, '') === searchName) {
                avatar = val;
                personName = key;
                break;
              }
            }
            if (!avatar) {
              personName = personName.split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
            }
          }

          scarpinSliders.push({ folder, cleanName, personName, avatar, urls });
        }
      }
    }
  }
  // Sort folders alphabetically (e.g., "01 Scarpa...", "02 Roberto...")
  scarpinSliders.sort((a, b) => a.folder.localeCompare(b.folder));
}

// Derive a display name from an image filename (same rules as the client script)
const cardNameFromUrl = (url: string): string => {
  const filename = url.substring(url.lastIndexOf('/') + 1);
  const ext = filename.substring(filename.lastIndexOf('.'));
  let name = filename.slice(0, filename.length - ext.length);
  name = name.replace(/^ADVT_[A-Z_]+_/, '').replace(/^ADVT_SP_\s*/, '').trim();
  name = name.replace(/\s+\d+\s*$/, '').replace(/\s*\d+$/, '').trim();
  return name || data.name;
};
const firstCardName = hasImages ? cardNameFromUrl(allImages[0]) : '';

// ── Superhero logos (sups-cards / sups-in-the-hinterland) ──
// DC + Marvel publisher logos keep their color; character/team logos render
// monochrome via CSS filter. Matched by character name in the filename.
const LOGO_RULES: Array<{ match: RegExp; src: string; mono: boolean }> = [
  // Character logos first — publisher marks (DC/Marvel) only as a last resort
  { match: /spider/i,                                            src: '/images/logos/spiderman.png',       mono: true },
  { match: /deadpool/i,                                          src: '/images/logos/deadpool.png',        mono: true },
  { match: /captain america/i,                                   src: '/images/logos/captain-america.png', mono: true },
  { match: /wonder wom/i,                                        src: '/images/logos/wonder-women.png',    mono: true },
  { match: /batman|joker|penguin|freeze|poison ivy|harley/i,     src: '/images/logos/batman.png',          mono: true },
  { match: /superman/i,                                          src: '/images/logos/superman.png',        mono: true },
  { match: /flash/i,                                             src: '/images/logos/flash.png',           mono: true },
  { match: /green lantern/i,                                     src: '/images/logos/green-lantern.png',   mono: true },
  { match: /winter so|hulk|loki|scarlet|scalet/i,                src: '/images/logos/avengers.png',        mono: true },
  { match: /wolverine|cyclops|strom|storm|jean grey|professor|nightcrawler|gambit|emma frost|magneto|juggernaut/i,
                                                                 src: '/images/logos/xmen.png',            mono: true },
  { match: /martian|cygborg|cyborg/i,                            src: '/images/logos/dc.png',              mono: true },
  { match: /corleone|hagen|clemenza/i,                           src: '/images/logos/godfather.png',       mono: true },
];
const logoProjects = ['sups-cards', 'sups-in-the-hinterland', 'alt-verse'];
const logoFor = (url: string): { src: string; mono: boolean } | null => {
  if (!logoProjects.includes(project.id)) return null;
  const name = cardNameFromUrl(url);
  return LOGO_RULES.find(r => r.match.test(name)) ?? null;
};
---

<PageLayout
  title={data.name}
  description={realText(data.smallIntro) ?? `${data.name}${data.year ? ` (${data.year})` : ''} — a project by Advaita Kelkar.`}
  ogImage={data.coverImage}
  label={data.name}
  crumbs={dynamicCrumbs}
  showFooter={!isCardPage}
>
    <article class="project-detail" data-project-id={project.id} data-project-name={data.name} data-is-card={isCardPage ? "true" : "false"} data-is-scarpin={isScarpinPage ? "true" : "false"}>
      
      {isScarpinPage ? (
        /* SCARPIN PAGE: 12-slider Grid */
        <>
          <header class="project-top-header" id="project-top-header">
            <div class="project-header-title-row">
              <h1 class="project-name-title" id="project-name-click">
                <span class="project-name-main">{data.name}</span>
              </h1>
            </div>
            
            <div class="project-card__metaline">
              {(yearLoc || data.status) && (
                <div class="project-meta-row">
                  <span class="project-meta-left project-card__meta-val">{yearLoc}</span>
                  {data.status && <span class="project-meta-right project-card__meta-val">{data.status}</span>}
                </div>
              )}
              {(firstTag || category) && (
                <div class="project-meta-row">
                  <span class="project-meta-left project-card__meta-val">{firstTag ? firstTag.data.name : ''}</span>
                  {category && <a href={`/${category.id}`} class="category-link project-meta-right project-card__meta-val">{category.data.displayName}</a>}
                </div>
              )}
            </div>
          </header>
          
          <div class="scarpin-grid-container">
            <div class="scarpin-intro">
               {data.smallIntro && <p class="project-card__intro">{data.smallIntro}</p>}
               {data.description && <div class="project-card__desc" set:html={data.description} />}
            </div>
            
            <div class="scarpin-grid">
              {scarpinSliders.map((slider, idx) => {
                return (
                  <div class="scarpin-grid-item" data-images={JSON.stringify(slider.urls)} data-index={idx}>
                    <div class="scarpin-item-header">
                      <h3 class="scarpin-item-title">{slider.cleanName}</h3>
                    </div>
                    <div class="scarpin-item-media-wrap">
                      {slider.urls[0].endsWith('.mp4') ? (
                        <video class="scarpin-media scarpin-media--active" src={slider.urls[0]} autoplay loop muted playsinline></video>
                      ) : (
                        <img class="scarpin-media scarpin-media--active" src={slider.urls[0]} alt={slider.cleanName} loading="lazy" />
                      )}
                    </div>
                    
                    <div class="scarpin-thumbnails">
                      {slider.urls.map((u, i) => (
                        <button type="button" class={`scarpin-thumb ${i === 0 ? 'is-active' : ''}`} data-thumb-index={i} aria-label={`View media ${i + 1}`}>
                          {u.endsWith('.mp4') ? (
                            <video src={u} muted playsinline></video>
                          ) : (
                            <img src={u} alt="" loading="lazy" />
                          )}
                        </button>
                      ))}
                    </div>

                    <div class="scarpin-item-footer">
                      <div class="scarpin-person">
                        {slider.avatar ? (
                          <img class="scarpin-avatar" src={slider.avatar} alt={slider.personName} loading="lazy" />
                        ) : (
                          <div class="scarpin-avatar scarpin-avatar--placeholder"></div>
                        )}
                        <span class="scarpin-person-name">{slider.personName}</span>
                      </div>
                      
                      <div class="scarpin-pagination-wrap">
                        <div class="autoplay-timer-ring autoplay-timer-ring--mini">
                          <svg width="20" height="20" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" class="timer-ring-bg" />
                            <circle cx="12" cy="12" r="10" class="timer-ring-progress scarpin-timer-ring" />
                          </svg>
                        </div>
                        <span class="scarpin-item-counter">1 / {slider.urls.length}</span>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
          
          {/* Lightbox for Scarpin */}
          <div id="scarpin-lightbox" class="card-lightbox" aria-hidden="true" style="display: none;">
            <img class="lightbox-bg-ambient" id="scarpin-lightbox-ambient" src="" alt="" />
            <div class="lightbox-backdrop"></div>
            
            <div class="lightbox-header">
              <span class="lightbox-pagination" id="scarpin-lightbox-counter">1 / 1</span>
              <button class="lightbox-close-btn" id="scarpin-lightbox-close" type="button" aria-label="Close lightbox">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
              </button>
            </div>
            
            <div class="lightbox-perspective-wrap">
              <div class="lightbox-card-container scarpin-lightbox-container" id="scarpin-lightbox-container">
                <button class="lightbox-nav-arrow lightbox-nav-arrow--prev" id="scarpin-lightbox-prev" type="button" aria-label="Previous">
                  <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
                </button>

                <img class="lightbox-card-img" id="scarpin-lightbox-img" src="" alt="Active media" style="display: none;" />
                <video class="lightbox-card-img" id="scarpin-lightbox-vid" src="" autoplay loop muted playsinline style="display: none;"></video>

                <div class="lightbox-card-shadow"></div>
                <div class="lightbox-card-shine"></div>

                <button class="lightbox-nav-arrow lightbox-nav-arrow--next" id="scarpin-lightbox-next" type="button" aria-label="Next">
                  <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                </button>
              </div>
            </div>

            <h2 class="lightbox-name" id="scarpin-lightbox-label"></h2>
          </div>
        </>
      ) : isCardPage ? (
        /* CARD PAGES: Wrapped in Sticky Dashboard wrapper */
        <div class="project-dashboard-wrap" id="project-dashboard">
          <header class="project-top-header" id="project-top-header">
            <div class="project-header-title-row">
              <h1 class="project-name-title" id="project-name-click">
                <span class="project-name-main">{data.name}</span>
              </h1>
            </div>
            
            <div class="project-card__metaline">
              {(yearLoc || data.status) && (
                <div class="project-meta-row">
                  <span class="project-meta-left project-card__meta-val">{yearLoc}</span>
                  {data.status && <span class="project-meta-right project-card__meta-val">{data.status}</span>}
                </div>
              )}
              {(firstTag || category) && (
                <div class="project-meta-row">
                  <span class="project-meta-left project-card__meta-val">{firstTag ? firstTag.data.name : ''}</span>
                  {category && <a href={`/${category.id}`} class="category-link project-meta-right project-card__meta-val">{category.data.displayName}</a>}
                </div>
              )}
            </div>
          </header>

          <div class="project-content-grid project-content-grid--card">
            <!-- Left Column: Description Text & Name/Pagination Alignment Row -->
            <div class="project-col-left">
              <div class="project-card-info">
                <div class="project-card__row project-card__row2">
                  <div class="project-card__text-block">
                    {data.smallIntro && <p class="project-card__intro">{data.smallIntro}</p>}
                    {data.description && (
                      <div class="project-card__desc" set:html={data.description} />
                    )}
                  </div>
                </div>
                
                <!-- Card Name & Pagination in left column (horizontally aligned with image bottom) -->
                <div class="project-card-name-pagination-row">
                  <div class="page-active-logo" id="page-active-logo" aria-hidden="true"></div>
                  <div class="project-detail__pagination-wrap">
                    <div class="project-detail__pagination" id="page-pagination">
                      1 / {allImages.length}
                    </div>
                    <div class="autoplay-timer-ring autoplay-timer-ring--mini" aria-hidden="true">
                      <svg width="20" height="20" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10" class="timer-ring-bg" />
                        <circle cx="12" cy="12" r="10" class="timer-ring-progress" id="page-timer-progress-mini" />
                      </svg>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Right Column: Active Card Slider (Clean, image-only) -->
            {hasImages && (
            <div class="project-col-right" id="project-slider-col">
              <div class="project-slider-wrapper" id="page-slider-wrapper" data-images={JSON.stringify(allImages)}>
                <div class="project-detail__active-wrap" id="page-active-wrap" style="cursor: pointer;" title="Click to open fullscreen modal">
                  <img class="project-detail__active-img" id="page-active-img" src={allImages[0]} alt={data.name} />

                  <!-- Active card name on the image — one word per row, glitches on change -->
                  <h2 class="project-card__overlay-name" id="page-overlay-name">{firstCardName}</h2>

                  <!-- Active card's team/publisher logo — top-right (desktop) -->
                  <span class="page-active-card-logo" id="page-active-card-logo" aria-hidden="true"></span>

                  <!-- Autoplay Timer Ring (top-left on desktop) -->
                  <div class="autoplay-timer-ring">
                    <svg width="24" height="24" viewBox="0 0 24 24">
                      <circle cx="12" cy="12" r="10" class="timer-ring-bg" />
                      <circle cx="12" cy="12" r="10" class="timer-ring-progress" id="page-timer-progress" />
                    </svg>
                  </div>
                </div>
              </div>
            </div>
            )}
          </div>
        </div>
      ) : (
        /* STANDARD PROJECTS: Normal Stacked Flow */
        <>
          <header class="project-top-header" id="project-top-header">
            <div class="project-header-title-row">
              <h1 class="project-name-title" id="project-name-click">
                <span class="project-name-main">{data.name}</span>
              </h1>
            </div>
          </header>

          <div class="project-content-grid">
            <div class="project-col-left">
              <div class="project-card-info">
                <div class="project-card__metaline project-card__metaline--incol">
                  {(yearLoc || data.status) && (
                    <div class="project-meta-row">
                      <span class="project-meta-left project-card__meta-val">{yearLoc}</span>
                      {data.status && <span class="project-meta-right project-card__meta-val">{data.status}</span>}
                    </div>
                  )}
                  {(firstTag || category) && (
                    <div class="project-meta-row">
                      <span class="project-meta-left project-card__meta-val">{firstTag ? firstTag.data.name : ''}</span>
                      {category && <a href={`/${category.id}`} class="category-link project-meta-right project-card__meta-val">{category.data.displayName}</a>}
                    </div>
                  )}
                </div>

                <div class="project-people">
                  {people.map((person) => (
                    <div class="project-people__person">
                      <div class="project-people__avatar">
                        <img src={PEOPLE[person] ?? PEOPLE['Advaita Kelkar']} alt={person} loading="lazy" />
                      </div>
                      <span class="project-people__name">{person}</span>
                    </div>
                  ))}
                </div>

                <div class="project-card__row project-card__row2">
                  <div class="project-card__text-block">
                    {data.smallIntro && <p class="project-card__intro">{data.smallIntro}</p>}
                    {data.description && (
                      <div class="project-card__desc" set:html={data.description} />
                    )}
                  </div>
                </div>
              </div>
            </div>

            {hasImages && (
            <div class="project-col-right" id="project-slider-col">
              <div class="project-slider-wrapper project-slider-wrapper--standard" id="standard-slider-wrapper" data-images={JSON.stringify(allImages)}>
                <div class="project-detail__active-wrap" id="standard-active-wrap" style="cursor: pointer;" title="Click to open image">
                  <button class="project-detail__nav-arrow project-detail__nav-arrow--prev" id="standard-prev" type="button" aria-label="Previous image">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
                  </button>
                  <img class="project-detail__active-img" id="standard-active-img" src={allImages[0]} alt={data.name} />
                  <button class="project-detail__nav-arrow project-detail__nav-arrow--next" id="standard-next" type="button" aria-label="Next image">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                  </button>
                </div>

                <div class="project-detail__pagination" id="standard-pagination">
                  1 / {allImages.length}
                </div>
                
                <div class="project-detail__thumbs" id="standard-thumbs">
                  {allImages.map((img, idx) => (
                    <button
                      type="button"
                      class:list={[
                        "project-detail__thumb-item",
                        idx === 0 && "is-active"
                      ]}
                      data-index={idx}
                    >
                      <img src={img} alt={`${data.name} thumbnail ${idx + 1}`} />
                    </button>
                  ))}
                </div>
              </div>
            </div>
            )}
          </div>
        </>
      )}

      <!-- STANDARD PAGE ONLY: chapter dropdowns (when defined) or Design & Making -->
      {!isCardPage && !isScarpinPage && (data.chapters?.length ?? 0) > 0 && (
        <div class="project-chapters">
          {data.chapters.map((ch: { title: string; subtitle?: string; body: string }) => {
            const words = (ch.subtitle || ch.title).split(' ');
            // Only peel off a small "lead" line (e.g. "Living with") when
            // there's more than two words — otherwise a short subtitle like
            // "Chrysalis Unveil" would have nothing left for the big line.
            const hasLead = words.length > 2;
            const lead = hasLead ? words.slice(0, 2).join(' ') : '';
            const rest = hasLead ? words.slice(2).join(' ') : words.join(' ');
            return (
            <section class="project-chapter">
              <div class="project-header-title-row project-chapter__header">
                <h3 class="project-chapter__title">
                  {lead && <span class="project-chapter__title-lead">{lead}</span>}
                  {rest && <span class="project-chapter__title-rest">{rest}</span>}
                </h3>
                <button class="project-detail-collapse-btn" type="button" aria-expanded="false" aria-label={`Toggle ${ch.title}`}>
                  <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
                </button>
              </div>
              <div class="project-chapter__content">
                <div class="project-chapter__body" set:html={ch.body} />
              </div>
            </section>
            );
          })}
        </div>
      )}

      {!isCardPage && !isScarpinPage && !(data.chapters?.length) && (
        <div class="project-metadata-sections">
          <section class="project-design-section">
            <div class="project-header-title-row project-design-header" id="project-design-click">
              <h3 class="project-section-subtitle">Design</h3>
              <button class="project-detail-collapse-btn" id="project-design-toggle" type="button" aria-expanded="false" aria-label="Toggle design details">
                <svg class="toggle-icon-minus link-arrow" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" style="display: none;"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
                <svg class="toggle-icon-plus link-arrow" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
              </button>
            </div>
            
            <div class="project-design-content" id="project-design-panel">
              <div class="project-design-grid">
                <div class="project-design-item">
                  <span class="design-label">Program</span>
                  <span class="design-val">{data.program ?? 'N/A'}</span>
                </div>
                <div class="project-design-item">
                  <span class="design-label">Collaborator</span>
                  <span class="design-val">{data.collaborator ?? 'Self-initiated'}</span>
                </div>
                {category && (
                  <div class="project-design-item">
                    <span class="design-label">Category</span>
                    <span class="design-val">{category.data.displayName}</span>
                  </div>
                )}
              </div>
            </div>
          </section>

          <section class="project-making-section">
            <div class="project-header-title-row project-making-header" id="project-making-click">
              <h3 class="project-section-subtitle">Making</h3>
              <button class="project-detail-collapse-btn" id="project-making-toggle" type="button" aria-expanded="false" aria-label="Toggle making details">
                <svg class="toggle-icon-minus link-arrow" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" style="display: none;"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
                <svg class="toggle-icon-plus link-arrow" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
              </button>
            </div>
            
            <div class="project-making-content" id="project-making-panel">
              <div class="project-making-grid">
                <div class="project-making-item">
                  <span class="design-label">Client</span>
                  <span class="design-val">{data.client ?? 'N/A'}</span>
                </div>
                <div class="project-making-item">
                  <span class="design-label">Size</span>
                  <span class="design-val">{data.size ?? 'N/A'}</span>
                </div>
                <div class="project-making-item">
                  <span class="design-label">Location</span>
                  <span class="design-val">{data.location ?? 'N/A'}</span>
                </div>
              </div>
            </div>
          </section>
        </div>
      )}

      <!-- CARD DECK SECTION ONLY (visible at the bottom on mobile, inside left column on desktop) -->
      {hasImages && isCardPage && (
        <section class="card-deck-section">
          <div class="deck-grid" id="deck-grid" data-images={JSON.stringify(allImages)}>
            {allImages.map((img, idx) => {
              // Extract name from filename dynamically
              const filename = img.substring(img.lastIndexOf('/') + 1);
              const ext = filename.substring(filename.lastIndexOf('.'));
              let name = filename.slice(0, filename.length - ext.length);
              name = name.replace(/^ADVT_[A-Z_]+_/, '').replace(/^ADVT_SP_\s*/, '').trim();
              name = name.replace(/\s+\d+\s*$/, '').replace(/\s*\d+$/, '').trim();
              
              const logo = logoFor(img);
              return (
                <button
                  type="button"
                  class:list={["deck-card-item", idx === 0 && "is-active"]}
                  data-index={idx}
                  data-logo={logo?.src}
                  aria-label={`Open card ${name}`}
                >
                  <div class="deck-card-inner">
                    <img src={img} alt={name} loading="lazy" />
                    {logo && <span class="deck-card-logo" style={`--logo: url('${logo.src}')`} aria-hidden="true"></span>}
                    <div class="deck-card-glow"></div>
                    <div class="deck-card-label">{name}</div>
                  </div>
                </button>
              );
            })}
          </div>
        </section>
      )}

      <!-- Fullscreen Lightbox: card pages get a horizontally scrolling deck -->
      {isCardPage && (
        <div id="card-lightbox" class="card-lightbox card-lightbox--deck" aria-hidden="true" style="display: none;">
          <img class="lightbox-bg-ambient" id="lightbox-ambient-img" src="" alt="" />
          <div class="lightbox-backdrop"></div>

          <!-- Top row: timer ring left, pagination centered, close right -->
          <div class="lightbox-header lightbox-header--deck">
            <span class="lightbox-pagination lightbox-pagination--deck" id="lightbox-counter">1 / {allImages.length}</span>
            <div class="lightbox-scrubber" id="lightbox-scrubber" role="slider" aria-label="Scrub through cards">
              <div class="lightbox-scrubber__fill" id="lightbox-scrubber-fill"></div>
            </div>
            <div class="autoplay-timer-ring lightbox-header__ring" aria-hidden="true">
              <svg width="100%" height="100%" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" class="timer-ring-bg" />
                <circle cx="12" cy="12" r="10" class="timer-ring-progress" id="lightbox-timer-progress" />
              </svg>
            </div>
            <button class="lightbox-close-btn" id="lightbox-close" type="button" aria-label="Close lightbox">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
          </div>

          <!-- Scroll-snap deck: one card at a time, neighbours peeking -->
          <div class="lightbox-deck" id="lightbox-deck">
            {allImages.map((img, idx) => {
              const logo = logoFor(img);
              return (
              <div class="lightbox-deck__item" data-index={idx}>
                <img src={img} alt={cardNameFromUrl(img)} loading="lazy" />
                {logo && <span class="lightbox-card-logo" style={`--logo: url('${logo.src}')`} aria-hidden="true"></span>}
              </div>
              );
            })}
          </div>

          <!-- Card name: bottom-left at page padding, one word per row -->
          <h2 class="lightbox-name" id="lightbox-card-label">
            {firstCardName.split(' ').map((word) => <span>{word}<br/></span>)}
          </h2>
        </div>
      )}

      {!isCardPage && (
      <div id="card-lightbox" class="card-lightbox" aria-hidden="true" style="display: none;">
        <!-- Dynamic Blurred Background Ambient Image -->
        <img class="lightbox-bg-ambient" id="lightbox-ambient-img" src="" alt="" />
        <div class="lightbox-backdrop"></div>
        
        <!-- Redesigned Top Action Bar: ring timer left, pagination center, close right -->
        <div class="lightbox-header">
          <div class="autoplay-timer-ring lightbox-header__ring" aria-hidden="true" style="visibility: hidden;">
            <svg width="20" height="20" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" class="timer-ring-bg" />
              <circle cx="12" cy="12" r="10" class="timer-ring-progress" id="lightbox-timer-progress" />
            </svg>
          </div>
          <span class="lightbox-pagination" id="lightbox-counter">1 / 35</span>
          <button class="lightbox-close-btn" id="lightbox-close" type="button" aria-label="Close lightbox">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
        
        <!-- Centered Card Container (with 3D perspective wrapper) -->
        <div class="lightbox-perspective-wrap">
          <div class="lightbox-card-container" id="lightbox-card-container">
            <!-- Left/Right navigation inputs overlaid directly on image container -->
            <button class="lightbox-nav-arrow lightbox-nav-arrow--prev" id="lightbox-prev" type="button" aria-label="Previous card">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>

            <img class="lightbox-card-img" id="lightbox-card-img" src="" alt="Active Playing Card" />

            <div class="lightbox-card-shadow"></div>
            <div class="lightbox-card-shine"></div>

            <button class="lightbox-nav-arrow lightbox-nav-arrow--next" id="lightbox-next" type="button" aria-label="Next card">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          </div>
        </div>

        <!-- Name Label below the Lightbox card container (bottom-left, one word per line) -->
        <h2 class="lightbox-name" id="lightbox-card-label">CARD NAME</h2>

        <div class="lightbox-hint">Tap card to flip to next</div>
      </div>
      )}

    </article>
</PageLayout>

<style>
  .project-detail {
