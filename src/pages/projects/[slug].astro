---
import { getCollection, getEntry } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({
    params: { slug: p.id },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { data } = project;

// Resolve tag and category references
const tags = await Promise.all((data.tags ?? []).map(t => getEntry(t)));
const category = data.category ? await getEntry(data.category) : null;

// Encryption helper
function encrypt(text: string, key: string): string {
  if (!text) return '';
  const encoder = new TextEncoder();
  const textBytes = encoder.encode(text);
  const keyBytes = encoder.encode(key);
  const encryptedBytes = new Uint8Array(textBytes.length);
  for (let i = 0; i < textBytes.length; i++) {
    encryptedBytes[i] = textBytes[i] ^ keyBytes[i % keyBytes.length];
  }
  return Buffer.from(encryptedBytes).toString('base64');
}

const isLocked = !!data.passcode;
let encryptedDescription = '';
let encryptedCoverImage = '';
let encryptedMultiImage: string[] = [];

if (isLocked) {
  const code = data.passcode!;
  encryptedDescription = encrypt(data.description || '', code);
  encryptedCoverImage = encrypt(data.coverImage || '', code);
  encryptedMultiImage = (data.multiImage || []).map(img => encrypt(img, code));
}
---

<PageLayout
  title={data.name}
  description={data.smallIntro}
  ogImage={data.coverImage}
  label={data.name}
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Projects', href: '/projects' },
    { label: data.name },
  ]}
>
  <article class="project-detail" data-project-id={project.id} data-project-name={data.name}>
    {isLocked && (
      <>
      <div id="project-gate" class="terminal-gate" data-project-id={project.id} data-project-name={data.name} data-passcode={data.passcode}>
        <div class="terminal-container">
          <div class="terminal-header">
            <span class="terminal-dot red"></span>
            <span class="terminal-dot yellow"></span>
            <span class="terminal-dot green"></span>
            <span class="terminal-title">SECURITY TERMINAL v1.0</span>
          </div>
          <div class="terminal-body">
            <p class="terminal-line"><span class="term-prompt">SYS:</span> RESTRICTED ACCESS AREA</p>
            <p class="terminal-line"><span class="term-prompt">SYS:</span> DECRYPTION KEY REQUIRED FOR: <span class="term-highlight">{data.name}</span></p>
            <p class="terminal-line"><span class="term-prompt">SYS:</span> CLASSIFICATION: CONFIDENTIAL</p>
            <div class="terminal-spacer"></div>
            <p class="terminal-line term-status-line"><span class="term-prompt">STATUS:</span> <span class="term-status locked">LOCKED</span></p>
            <div class="terminal-input-row">
              <span class="term-prompt">ENTER PASSWORD:</span>
              <div class="terminal-input-wrap">
                <span class="terminal-input-echo" id="input-echo"></span>
                <span class="terminal-cursor">█</span>
                <input type="password" id="gate-input" class="gate-hidden-input" autofocus autocomplete="off" />
              </div>
            </div>
            <p class="terminal-error" id="gate-error">&nbsp;</p>
          </div>
        </div>
      </div>
      
      <div id="project-unlocked-content" class="project-unlocked-content" style="display: none;"
           data-enc-cover={encryptedCoverImage}
           data-enc-desc={encryptedDescription}
           data-enc-multi={JSON.stringify(encryptedMultiImage)}
      >
        <div class="project-detail__cover soft-image-container" id="unlocked-cover-wrap" style="display: none;">
          <img id="unlocked-cover" src="" alt={data.name} />
        </div>

        <div class="project-detail__body">
          <header class="project-detail__header">
            <h1 class="project-detail__title">{data.name}</h1>
            {data.smallIntro && <p class="project-detail__intro text-muted">{data.smallIntro}</p>}
          </header>

          <aside class="project-detail__meta">
            {data.year && (
              <div class="meta-row">
                <span class="meta-label text-muted">Year</span>
                <span class="meta-val">{data.year}</span>
              </div>
            )}
            {data.location && (
              <div class="meta-row">
                <span class="meta-label text-muted">Location</span>
                <span class="meta-val">{data.location}</span>
              </div>
            )}
            {data.client && data.client !== 'NA' && (
              <div class="meta-row">
                <span class="meta-label text-muted">Client</span>
                <span class="meta-val">{data.client}</span>
              </div>
            )}
            {data.collaborator && (
              <div class="meta-row">
                <span class="meta-label text-muted">With</span>
                <span class="meta-val">{data.collaborator}</span>
              </div>
            )}
            {data.program && (
              <div class="meta-row">
                <span class="meta-label text-muted">Program</span>
                <span class="meta-val">{data.program}</span>
              </div>
            )}
            {data.status && (
              <div class="meta-row">
                <span class="meta-label text-muted">Status</span>
                <span class="meta-val">{data.status}</span>
              </div>
            )}
            {category && (
              <div class="meta-row">
                <span class="meta-label text-muted">Category</span>
                <a href={`/type/${category.id}`} class="meta-val meta-link">
                  {category.data.displayName}
                </a>
              </div>
            )}
            {tags.length > 0 && (
              <div class="meta-row meta-row--tags">
                <span class="meta-label text-muted">Tags</span>
                <div class="meta-tags">
                  {tags.map(tag => tag && (
                    <a href={`/tags/${tag.id}`} class="meta-tag">{tag.data.name}</a>
                  ))}
                </div>
              </div>
            )}
          </aside>

          <div class="project-detail__desc" id="unlocked-desc"></div>
        </div>

        <section class="project-detail__gallery" id="unlocked-gallery"></section>
      </div>
      </>
    )}

    {!isLocked && (
      <>
        {data.coverImage && (
          <div class="project-detail__cover soft-image-container">
            <img src={data.coverImage} alt={data.name} />
          </div>
        )}

        <div class="project-detail__body">
          <header class="project-detail__header">
            <h1 class="project-detail__title">{data.name}</h1>
            {data.smallIntro && <p class="project-detail__intro text-muted">{data.smallIntro}</p>}
          </header>

          <aside class="project-detail__meta">
            {data.year && (
              <div class="meta-row">
                <span class="meta-label text-muted">Year</span>
                <span class="meta-val">{data.year}</span>
              </div>
            )}
            {data.location && (
              <div class="meta-row">
                <span class="meta-label text-muted">Location</span>
                <span class="meta-val">{data.location}</span>
              </div>
            )}
            {data.client && data.client !== 'NA' && (
              <div class="meta-row">
                <span class="meta-label text-muted">Client</span>
                <span class="meta-val">{data.client}</span>
              </div>
            )}
            {data.collaborator && (
              <div class="meta-row">
                <span class="meta-label text-muted">With</span>
                <span class="meta-val">{data.collaborator}</span>
              </div>
            )}
            {data.program && (
              <div class="meta-row">
                <span class="meta-label text-muted">Program</span>
                <span class="meta-val">{data.program}</span>
              </div>
            )}
            {data.status && (
              <div class="meta-row">
                <span class="meta-label text-muted">Status</span>
                <span class="meta-val">{data.status}</span>
              </div>
            )}
            {category && (
              <div class="meta-row">
                <span class="meta-label text-muted">Category</span>
                <a href={`/type/${category.id}`} class="meta-val meta-link">
                  {category.data.displayName}
                </a>
              </div>
            )}
            {tags.length > 0 && (
              <div class="meta-row meta-row--tags">
                <span class="meta-label text-muted">Tags</span>
                <div class="meta-tags">
                  {tags.map(tag => tag && (
                    <a href={`/tags/${tag.id}`} class="meta-tag">{tag.data.name}</a>
                  ))}
                </div>
              </div>
            )}
          </aside>

          {data.description && (
            <div class="project-detail__desc" set:html={data.description} />
          )}
        </div>

        {data.multiImage && data.multiImage.length > 0 && (
          <section class="project-detail__gallery">
            {data.multiImage.map((url, i) => (
              <div class="gallery-img soft-image-container">
                <img src={url} alt={`${data.name} — image ${i + 1}`} loading="lazy" />
              </div>
            ))}
          </section>
        )}
      </>
    )}
  </article>
</PageLayout>

<style>
  .project-detail {
    padding-inline: var(--_tokens---space--small);
    padding-top: calc(clamp(2rem, 4vh, 3rem) + 48px); /* space for fixed breadcrumbs */
    padding-bottom: var(--_tokens---space--small);
    min-height: 100dvh;
    box-sizing: border-box;
  }

  @media (min-width: 1200px) {
    .project-detail {
      padding-inline: clamp(6rem, 12vw, 16rem);
      padding-top: calc(clamp(4rem, 6vh, 5rem) + 48px);
    }
  }

  @media (max-width: 767px) and (orientation: portrait) {
    .project-detail {
      padding-bottom: 80px; /* space for mobile bottom docked breadcrumbs */
    }
  }

  .project-detail__cover {
    width: 100%;
    max-height: 70vh;
    overflow: hidden;
    border-radius: var(--_tokens---radius--large);
    margin-bottom: var(--_tokens---space--medium);
  }

  .project-detail__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-detail__body {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: var(--_tokens---space--medium);
    max-width: var(--_tokens---layout--container);
    margin-bottom: var(--_tokens---space--medium);
  }

  .project-detail__header {
    grid-column: 1;
  }

  .project-detail__title {
    font-size: var(--_tokens---type--big);
    font-weight: 500;
    color: var(--_tokens---color--fg);
    margin-bottom: 0.5em;
    line-height: 1.1;
  }

  .project-detail__intro {
    font-size: var(--_tokens---type--small);
    line-height: 1.5;
  }

  .project-detail__meta {
    grid-column: 2;
    grid-row: 1 / 3;
    display: flex;
    flex-direction: column;
    gap: 0.75em;
    padding: var(--_tokens---space--small);
    border: 1px solid var(--_tokens---color--line);
    border-radius: var(--_tokens---radius--medium);
    align-self: start;
  }

  .meta-row {
    display: flex;
    flex-direction: column;
    gap: 0.2em;
  }

  .meta-label {
    font-size: var(--_tokens---type--micro);
    letter-spacing: 0.08em;
    text-transform: none;
  }

  .meta-val {
    font-size: var(--_tokens---type--micro);
    color: var(--_tokens---color--fg);
  }

  .meta-link {
    text-decoration: underline;
    text-underline-offset: 2px;
    color: var(--_tokens---color--fg);
    transition: opacity 0.2s ease;
  }

  .meta-link:hover {
    opacity: 0.7;
  }

  .meta-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4em;
  }

  .meta-tag {
    display: inline-block;
    padding: 0.2em 0.6em;
    border: 1px solid var(--_tokens---color--line);
    border-radius: var(--_tokens---radius--small);
    font-size: var(--_tokens---type--micro);
    color: var(--_tokens---color--muted);
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .meta-tag:hover {
    background-color: var(--_tokens---color--fg);
    color: var(--_tokens---color--bg);
  }

  .project-detail__desc {
    grid-column: 1;
    font-size: var(--_tokens---type--small);
    line-height: 1.7;
    color: var(--_tokens---color--fg);
  }

  .project-detail__desc :global(p) {
    margin-bottom: 1em;
  }

  .project-detail__gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--_tokens---space--small);
    margin-top: var(--_tokens---space--medium);
  }

  .gallery-img {
    overflow: hidden;
    border-radius: var(--_tokens---radius--medium);
    aspect-ratio: 4 / 3;
    background-color: var(--_tokens---color--muted);
  }

  .gallery-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .gallery-img:hover img {
    transform: scale(1.03);
  }

  @media (max-width: 900px) {
    .project-detail__body {
      grid-template-columns: 1fr;
    }

    .project-detail__meta {
      grid-column: 1;
      grid-row: auto;
    }
  }

  /* ══ Passcode Terminal Gate ════════════════════════════════ */
  .terminal-gate {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 60dvh;
    padding: var(--_tokens---space--small);
    font-family: var(--_tokens---font--mono);
    color: var(--_tokens---color--fg);
  }

  .terminal-container {
    width: 100%;
    max-width: 540px;
    background-color: color-mix(in srgb, var(--_tokens---color--bg) 95%, #000);
    border: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 15%, transparent);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
    position: relative;
  }

  .terminal-header {
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 4%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .terminal-dot.red { background-color: #ff5f56; }
  .terminal-dot.yellow { background-color: #ffbd2e; }
  .terminal-dot.green { background-color: #27c93f; }

  .terminal-title {
    font-size: 10px;
    color: var(--_tokens---color--muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-left: 8px;
    font-weight: 300;
  }

  .terminal-body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
    cursor: text;
  }

  /* Scanline effect */
  .terminal-body::after {
    content: " ";
    display: block;
    position: absolute;
    top: 0; left: 0; bottom: 0; right: 0;
    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
    z-index: 10;
    background-size: 100% 3px, 3px 100%;
    pointer-events: none;
    opacity: 0.45;
  }

  .terminal-line {
    font-size: 12px;
    line-height: 1.6;
    margin: 0;
    letter-spacing: 0.02em;
  }

  .term-prompt {
    color: var(--_tokens---color--muted);
    margin-right: 6px;
  }

  .term-highlight {
    font-weight: 500;
    text-shadow: 0 0 4px currentColor;
  }

  .term-status {
    font-weight: 500;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 10px;
    letter-spacing: 0.05em;
  }

  .term-status.locked {
    background-color: color-mix(in srgb, #ff5f56 15%, transparent);
    color: #ff5f56;
    border: 1px solid color-mix(in srgb, #ff5f56 30%, transparent);
  }

  .term-status.granted {
    background-color: color-mix(in srgb, #27c93f 15%, transparent);
    color: #27c93f;
    border: 1px solid color-mix(in srgb, #27c93f 30%, transparent);
  }

  .terminal-spacer {
    height: 12px;
    border-bottom: 1px dashed color-mix(in srgb, var(--_tokens---color--fg) 10%, transparent);
    margin-bottom: 8px;
  }

  .terminal-input-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 12px;
    font-size: 12px;
  }

  .terminal-input-wrap {
    display: inline-flex;
    align-items: center;
    position: relative;
    flex: 1;
  }

  .gate-hidden-input {
    position: absolute;
    top: 0; left: 0; opacity: 0;
    width: 100%; height: 100%;
    border: none; outline: none;
    cursor: text;
    z-index: 5;
  }

  .terminal-input-echo {
    color: var(--_tokens---color--fg);
    min-height: 18px;
    font-weight: 500;
    letter-spacing: 0.15em;
  }

  .terminal-cursor {
    display: inline-block;
    width: 8px;
    height: 15px;
    background-color: var(--_tokens---color--fg);
    margin-left: 2px;
    animation: blink 1s infinite steps(1, start);
    vertical-align: middle;
  }

  .terminal-error {
    color: #ff5f56;
    font-size: 10px;
    min-height: 16px;
    margin: 0;
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @keyframes blink {
    0%, 100% { opacity: 0; }
    50% { opacity: 1; }
  }

  /* Shaking animation for incorrect password */
  .shake {
    animation: shake 0.4s ease;
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20%, 60% { transform: translateX(-8px); }
    40%, 80% { transform: translateX(8px); }
  }
</style>

<script>
  function setupPasscodeGate() {
    const gate = document.getElementById('project-gate');
    if (!gate) return;

    const projectId = gate.dataset.projectId;
    const passcode = gate.dataset.passcode;
    const input = document.getElementById('gate-input') as HTMLInputElement | null;
    const echo = document.getElementById('input-echo');
    const errorMsg = document.getElementById('gate-error');
    const container = gate.querySelector('.terminal-container');
    const unlockedContent = document.getElementById('project-unlocked-content') as HTMLElement | null;

    if (!input || !unlockedContent) return;

    // Focus input on click
    gate.addEventListener('click', () => {
      input.focus();
    });

    // Auto-focus on load
    input.focus();

    // Handle session storage check
    if (sessionStorage.getItem('unlocked_' + projectId) === 'true') {
      unlock();
    }

    // Capture input events
    input.addEventListener('input', () => {
      // Echo characters as bullet block characters for password styling
      if (echo) {
        echo.textContent = '█'.repeat(input.value.length);
      }
      if (errorMsg) {
        errorMsg.innerHTML = '&nbsp;';
      }
    });

    // Handle Enter key
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const val = input.value;
        if (val === passcode) {
          sessionStorage.setItem('unlocked_' + projectId, 'true');
          unlock();
        } else {
          // Shake and show error
          if (container) {
            container.classList.add('shake');
            setTimeout(() => {
              container.classList.remove('shake');
            }, 400);
          }
          if (errorMsg) {
            errorMsg.textContent = 'ACCESS DENIED. DECRYPTION FAILED.';
          }
          input.value = '';
          if (echo) {
            echo.textContent = '';
          }
        }
      }
    });

    function unlock() {
      if (!unlockedContent || !gate) return;
      
      const encCover = unlockedContent.dataset.encCover;
      const encDesc = unlockedContent.dataset.encDesc;
      const encMulti = JSON.parse(unlockedContent.dataset.encMulti || '[]');

      // Decrypt function
      function decryptStr(cipher: string | undefined): string {
        if (!cipher) return '';
        try {
          const binaryString = atob(cipher);
          const textBytes = new Uint8Array(binaryString.length);
          for (let i = 0; i < binaryString.length; i++) {
            textBytes[i] = binaryString.charCodeAt(i);
          }
          const encoder = new TextEncoder();
          const keyBytes = encoder.encode(passcode);
          const decryptedBytes = new Uint8Array(textBytes.length);
          for (let i = 0; i < textBytes.length; i++) {
            decryptedBytes[i] = textBytes[i] ^ keyBytes[i % keyBytes.length];
          }
          const decoder = new TextDecoder();
          return decoder.decode(decryptedBytes);
        } catch (e) {
          console.error("Decryption error:", e);
          return '';
        }
      }

      // 1. Cover Image
      const coverUrl = decryptStr(encCover);
      if (coverUrl) {
        const coverWrap = document.getElementById('unlocked-cover-wrap');
        const coverImg = document.getElementById('unlocked-cover') as HTMLImageElement | null;
        if (coverWrap && coverImg) {
          coverImg.src = coverUrl;
          coverWrap.style.display = 'block';
        }
      }

      // 2. Description
      const descHtml = decryptStr(encDesc);
      const descWrap = document.getElementById('unlocked-desc');
      if (descWrap) {
        descWrap.innerHTML = descHtml;
      }

      // 3. Gallery
      const galleryUrls = encMulti.map(decryptStr).filter(Boolean);
      const galleryWrap = document.getElementById('unlocked-gallery');
      if (galleryWrap && galleryUrls.length > 0) {
        galleryWrap.innerHTML = galleryUrls.map((url: string, i: number) => `
          <div class="gallery-img soft-image-container">
            <img src="${url}" alt="${gate.dataset.projectName} — image ${i + 1}" loading="lazy" />
          </div>
        `).join('');
      }

      // Hide gate and show content
      gate.style.display = 'none';
      unlockedContent.style.display = 'block';
    }
  }

  // Setup on initial load
  setupPasscodeGate();

  // Support Astro View Transitions
  document.addEventListener('astro:after-swap', setupPasscodeGate);
</script>
