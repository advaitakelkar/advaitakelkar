                  <div class="autoplay-timer-ring autoplay-timer-ring--mini" aria-hidden="true">
                    <svg width="20" height="20" viewBox="0 0 24 24">
                      <circle cx="12" cy="12" r="10" class="timer-ring-bg" />
                      <circle cx="12" cy="12" r="10" class="timer-ring-progress" id="page-timer-progress-mini" />
                      <circle cx="12" cy="2" r="2" class="timer-ring-dot" />
                    </svg>
                  </div>
                </div>
              </div>
            </div>
            )}
          </div>
        </>
      )}

      <!-- NON-ORIGINAL-CARD PAGES: chapter dropdowns (when defined) or Design & Making -->
      {!isOriginalCardPage && !isScarpinPage && (data.chapters?.length ?? 0) > 0 && (
        <div class="project-chapters">
          {data.chapters.map((ch: { title: string; subtitle?: string; body: string }) => {
            const words = (ch.subtitle || ch.title).split(' ');
            // Only peel off a small "lead" line (e.g. "Living with") when
            // there's more than two words — otherwise a short subtitle like
            // "Chrysalis Unveil" would have nothing left for the big line.
            const hasLead = words.length > 2;
            const lead = hasLead ? words.slice(0, 2).join(' ') : '';
            const rest = hasLead ? words.slice(2).join(' ') : words.join(' ');
            return (
            <section class="project-chapter">
              <div class="project-header-title-row project-chapter__header">
                <h3 class="project-chapter__title">
                  {lead && <span class="project-chapter__title-lead">{lead}</span>}
                  {rest && <span class="project-chapter__title-rest">{rest}</span>}
                </h3>
                <button class="project-detail-collapse-btn" type="button" aria-expanded="false" aria-label={`Toggle ${ch.title}`}>
                  {isTabLayout ? (
                    <>
                      <svg class="toggle-icon-minus link-arrow" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" style="display: none;"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
                      <svg class="toggle-icon-plus link-arrow" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
