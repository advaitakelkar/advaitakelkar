</style>

<script>
  import { shuffle, reorderChildrenByIndex } from '../../lib/random';

  function initProjectPage() {
    const article = document.querySelector('.project-detail');
    if (!article) return;

    const isCardPage = article.getAttribute('data-is-card') === 'true';
    const isScarpinPage = article.getAttribute('data-is-scarpin') === 'true';

    if (isScarpinPage) {
      initScarpinSliders();
    } else if (isCardPage) {
      initCardDeck();
    } else {
      initStandardSlider();
      initDescReadMore();
    }
  }

  /* ── Description Read-More pill (height-clip, no DOM split) ── */
  function initDescReadMore() {
    const clip = document.getElementById('project-desc-clip') as HTMLElement | null;
    const btn  = document.getElementById('project-readmore-btn') as HTMLButtonElement | null;

    if (!clip || !btn) return;

    // Measure height of just the first child block (first <p> or first child)
    const firstChild = clip.firstElementChild as HTMLElement | null;
    if (!firstChild) { btn.style.display = 'none'; return; }

    // If there's only one child block, no need for the button
    if (clip.children.length < 2) { btn.style.display = 'none'; return; }

    // Collapsed height = height of the first block + its margins
    const collapsedHeight = firstChild.offsetHeight +
      parseInt(getComputedStyle(firstChild).marginTop) +
      parseInt(getComputedStyle(firstChild).marginBottom);

    // Full scrollHeight
    const fullHeight = clip.scrollHeight;

    // Set collapsed
    clip.style.maxHeight = collapsedHeight + 'px';

    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      if (expanded) {
        // Collapse
        btn.setAttribute('aria-expanded', 'false');
        btn.querySelector('.project-readmore-label')!.textContent = 'Read more';
        clip.style.maxHeight = collapsedHeight + 'px';
      } else {
        // Expand
        btn.setAttribute('aria-expanded', 'true');
        btn.querySelector('.project-readmore-label')!.textContent = 'Read less';
        clip.style.maxHeight = clip.scrollHeight + 'px';
      }
    });
  }

  function initCardDeck() {
    const deck = document.getElementById('deck-grid');
    // Work-category pages only: the mobile one-row scrub right under the
    // pagination. Its .deck-card-item buttons share the same click/active
    // wiring as the main #deck-grid below the image (see updateScrubActiveState
    // and cardButtons below).
    const mobileScrub = document.getElementById('deck-grid-mobile-scrub') || (deck?.classList.contains('deck-grid--mobile-scrub') ? deck : null);
    const lightbox = document.getElementById('card-lightbox');
    const ambientImg = document.getElementById('lightbox-ambient-img') as HTMLImageElement | null;
    const closeBtn = document.getElementById('lightbox-close');
    const counter = document.getElementById('lightbox-counter');

    const pageActiveImg = document.getElementById('page-active-img') as HTMLImageElement | null;
    const pageOverlayName = document.getElementById('page-overlay-name');
    const pagePagination = document.getElementById('page-pagination');
    const pageActiveWrap = document.getElementById('page-active-wrap');

    // Glitch/scramble a name element into new text.
    const scrambleTo = (el: HTMLElement, text: string) => {
      const prev = (el as any)._scrRaf;
      if (prev) cancelAnimationFrame(prev);
      const glyphs = '!<>-_\\/[]{}—=+*^?#';
      const totalFrames = Math.min(Math.max(text.length * 1.5, 18), 40);
      let frame = 0;
      const step = () => {
        const progress = frame / totalFrames;
        el.textContent = text
          .split('')
          .map((ch, i) => {
            if (ch === ' ') return ' ';
            if (i < progress * text.length) return ch;
            return glyphs[Math.floor(Math.random() * glyphs.length)];
          })
          .join('');
        frame++;
        if (frame <= totalFrames) {
          (el as any)._scrRaf = requestAnimationFrame(step);
        } else {
          el.textContent = text;
          (el as any)._scrRaf = null;
        }
      };
      step();
    };

    const timerRings = ['page-timer-progress', 'page-timer-progress-mini']
      .map(id => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);
    const detailEl = document.querySelector('.project-detail');

    if (!deck || !lightbox) return;

    // Keep the fixed mobile dashboard's height mirrored into --dash-h so the
    // card deck starts below it (the dashboard is out of the page flow).
    const dashboard = document.getElementById('project-dashboard');
    if (dashboard && detailEl) {
      const setDashHeight = () => {
        (detailEl as HTMLElement).style.setProperty('--dash-h', `${dashboard.offsetHeight}px`);
      };
      setDashHeight();
      if ('ResizeObserver' in window) new ResizeObserver(setDashHeight).observe(dashboard);
      window.addEventListener('resize', setDashHeight, { passive: true });
    }

    const images = JSON.parse(deck.getAttribute('data-images') || '[]');
    const projectName = document.querySelector('.project-detail')?.getAttribute('data-project-name') || '';

    // Randomise the navigation sequence once per load; the scrub grid and the
    // fullscreen deck are both reordered to match it, so next/prev always
    // lands on the visually-adjacent card, and it stays fixed until reload.
    const order = shuffle(Array.from({ length: images.length }, (_, i) => i));
    let currentPos = 0;
    let currentIdx = order[0] ?? 0;
    let isOpen = false;
    let autoplayInterval: number | null = null;

    reorderChildrenByIndex(deck, order);

    const goToPos = (pos: number) => {
      const count = images.length;
      currentPos = ((pos % count) + count) % count;
      currentIdx = order[currentPos];
    };

    const getCardName = (url: string): string => {
      const filename = url.substring(url.lastIndexOf('/') + 1);
      const ext = filename.substring(filename.lastIndexOf('.'));
      let name = filename.slice(0, filename.length - ext.length);
      name = name.replace(/^ADVT_[A-Z_]+_/, '').replace(/^ADVT_SP_\s*/, '').trim();
      name = name.replace(/\s+\d+\s*$/, '').replace(/\s*\d+$/, '').trim();
      if (!name || /^\d+$/.test(name) || name.length <= 1) return projectName;
      if (name.toLowerCase() === 'winter soildier') return 'Winter Soldier';
      if (name.toLowerCase() === 'wonder women') return 'Wonder Woman';
      if (name.toLowerCase() === 'cygborg') return 'Cyborg';
      if (name.toLowerCase() === 'scalet witch') return 'Scarlet Witch';
      if (name.toLowerCase() === 'strom') return 'Storm';
      return name;
    };

    // ── Lightbox deck elements (reordered to match the shuffled sequence) ──
    const lightboxDeck = document.getElementById('lightbox-deck') as HTMLElement | null;
    if (lightboxDeck) reorderChildrenByIndex(lightboxDeck, order);
    let deckItems = lightboxDeck
      ? Array.from(lightboxDeck.querySelectorAll('.lightbox-deck__item')) as HTMLElement[]
      : [];

    /** Update scale/opacity of every deck item based on scroll position */
    const updateDeckTransforms = (): number | undefined => {
      if (!lightboxDeck || !deckItems.length) return undefined;
      const deckRect = lightboxDeck.getBoundingClientRect();
      const deckCenterX = deckRect.left + deckRect.width / 2;
      let closestDist = Infinity;
      let closestIdx = 0;
      deckItems.forEach((item, i) => {
        const rect = item.getBoundingClientRect();
        const itemCenterX = rect.left + rect.width / 2;
        const dist = Math.abs(itemCenterX - deckCenterX);
        const maxDist = deckRect.width * 0.6;
        const t = Math.min(dist / maxDist, 1);
        const sc = 1 - 0.18 * t;
        const op = 1 - 0.8 * t;
        item.style.transform = `scale(${sc.toFixed(3)})`;
        item.style.opacity = `${op.toFixed(3)}`;
        if (dist < closestDist) { closestDist = dist; closestIdx = i; }
      });
      deckItems.forEach((item, i) => item.classList.toggle('is-center', i === closestIdx));
      return closestIdx;
    };

    /** Smoothly scroll the deck so item at idx is centred */
    const scrollDeckTo = (idx: number, behavior: ScrollBehavior = 'smooth') => {
      if (!lightboxDeck || !deckItems[idx]) return;
      const item = deckItems[idx];
      const deckRect = lightboxDeck.getBoundingClientRect();
      const itemRect = item.getBoundingClientRect();
      const itemCenterInDeck = (itemRect.left - deckRect.left) + itemRect.width / 2;
      const targetScrollLeft = lightboxDeck.scrollLeft + itemCenterInDeck - deckRect.width / 2;
      lightboxDeck.scrollTo({ left: targetScrollLeft, behavior });
    };

    // ── Timer ring ─────────────────────────────────────────────────────────
    const resetTimerRing = () => {
      timerRings.forEach(ring => {
        const wrap = ring.closest('.autoplay-timer-ring');
        if (wrap) {
          wrap.classList.remove('is-animating');
          void (wrap as HTMLElement).offsetWidth;
          wrap.classList.add('is-animating');
        }
      });
      const lightboxProgress = document.getElementById('lightbox-timer-progress');
      if (lightboxProgress) {
        const wrap = lightboxProgress.closest('.autoplay-timer-ring');
        if (wrap) {
          wrap.classList.remove('is-animating');
          void (wrap as HTMLElement).offsetWidth;
          if (isOpen) wrap.classList.add('is-animating');
        }
      }
    };

    const updateScrubActiveState = () => {
      deck.querySelectorAll('.deck-card-item').forEach(btn => {
        btn.classList.toggle('is-active', parseInt(btn.getAttribute('data-index') || '-1', 10) === currentIdx);
      });
      mobileScrub?.querySelectorAll('.deck-card-item').forEach(btn => {
        btn.classList.toggle('is-active', parseInt(btn.getAttribute('data-index') || '-1', 10) === currentIdx);
      });
    };

    // ── Name label: set word-by-word spans ─────────────────────────────────
    const nameLabel = document.getElementById('lightbox-card-label') as HTMLElement | null;
    const setNameLabel = (name: string) => {
      if (!nameLabel) return;
      nameLabel.innerHTML = name.split(' ').map(w => `<span>${w}</span>`).join('');
    };

    // ── updateDisplay ───────────────────────────────────────────────────────
    const updateDisplay = (scrollDeck = true) => {
      const activeUrl = images[currentIdx];
      const activeName = getCardName(activeUrl);

      if (ambientImg) ambientImg.src = activeUrl;
      if (counter) counter.textContent = `${currentPos + 1} / ${images.length}`;
      setNameLabel(activeName);

      if (pageActiveImg) pageActiveImg.src = activeUrl;
      if (pageOverlayName) scrambleTo(pageOverlayName, activeName);
      if (pagePagination) pagePagination.textContent = `${currentPos + 1} / ${images.length}`;

      // Active card's logo — beside the pagination (fg-tinted) and on the big
      // card's top-right corner (bg-tinted, desktop); both pop on change
      const logoSrc = deck.querySelector(`.deck-card-item[data-index="${currentIdx}"]`)?.getAttribute('data-logo');
      const logoEl = document.getElementById('page-active-logo');
      if (logoEl) {
        if (logoSrc) {
          logoEl.style.setProperty('--logo', `url("${logoSrc}")`);
          logoEl.style.display = 'block';
          logoEl.classList.remove('is-swap');
          void (logoEl as HTMLElement).offsetWidth;
          logoEl.classList.add('is-swap');
        } else {
          logoEl.style.display = 'none';
        }
      }
      const cardLogoEl = document.getElementById('page-active-card-logo');
      if (cardLogoEl) {
        if (logoSrc) {
          cardLogoEl.style.setProperty('--logo', `url("${logoSrc}")`);
          cardLogoEl.classList.add('is-on');
          cardLogoEl.classList.remove('is-swap');
          void (cardLogoEl as HTMLElement).offsetWidth;
          cardLogoEl.classList.add('is-swap');
        } else {
          cardLogoEl.classList.remove('is-on');
        }
      }

      resetTimerRing();
      updateScrubActiveState();

      const scrubFill = document.getElementById('lightbox-scrubber-fill');
      if (scrubFill) scrubFill.style.width = `${(currentPos / Math.max(order.length - 1, 1)) * 100}%`;

      if (scrollDeck && isOpen) scrollDeckTo(currentPos);
    };

    // ── Autoplay ────────────────────────────────────────────────────────────
    const stopAutoplay = () => {
      if (autoplayInterval) { clearInterval(autoplayInterval); autoplayInterval = null; }
      timerRings.forEach(ring => {
        const wrap = ring.closest('.autoplay-timer-ring');
        if (wrap) wrap.classList.remove('is-animating');
      });
      const lp = document.getElementById('lightbox-timer-progress');
      if (lp) {
        const wrap = lp.closest('.autoplay-timer-ring');
        if (wrap) wrap.classList.remove('is-animating');
      }
    };

    const startAutoplay = () => {
      stopAutoplay();
      resetTimerRing();
      autoplayInterval = window.setInterval(() => {
        goToPos(currentPos + 1);
        updateDisplay(true);
      }, 2000);
    };

    // ── Open / close ────────────────────────────────────────────────────────
    const openLightbox = (index: number) => {
      goToPos(order.indexOf(index));
      isOpen = true;
      lightbox.style.display = 'flex';
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      updateDisplay(false);
      requestAnimationFrame(() => {
        scrollDeckTo(currentPos, 'instant' as ScrollBehavior);
        updateDeckTransforms();
        startAutoplay();
      });
    };

    const closeLightbox = () => {
      isOpen = false;
      lightbox.style.display = 'none';
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      startAutoplay();
    };

    // ── Deck scroll listener ─────────────────────────────────────────────────
    if (lightboxDeck) {
      lightboxDeck.addEventListener('scroll', () => {
        const centerPos = updateDeckTransforms();
        if (centerPos !== undefined && centerPos !== currentPos) {
          goToPos(centerPos);
          const activeUrl = images[currentIdx];
          const activeName = getCardName(activeUrl);
          if (ambientImg) ambientImg.src = activeUrl;
          if (counter) counter.textContent = `${currentPos + 1} / ${images.length}`;
          setNameLabel(activeName);
          if (pageActiveImg) pageActiveImg.src = activeUrl;
          if (pageOverlayName) scrambleTo(pageOverlayName, activeName);
          if (pagePagination) pagePagination.textContent = `${currentPos + 1} / ${images.length}`;
          updateScrubActiveState();
          stopAutoplay();
          startAutoplay();
        }
      }, { passive: true });
    }

    // ── Scrub grid listeners ─────────────────────────────────────────────────
    const cardButtons = Array.from(deck.querySelectorAll('.deck-card-item'))
      .concat((mobileScrub && mobileScrub !== deck) ? Array.from(mobileScrub.querySelectorAll('.deck-card-item')) : []);
    cardButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.getAttribute('data-index') || '0', 10);
        goToPos(order.indexOf(idx));
        updateDisplay(true);
        startAutoplay();
      });
    });

    // Mobile scrub: dragging a finger across the strip live-previews each
    // image under it (same "hover scrub" feel as the category-page thumb
    // strips), instead of needing a separate tap per image.
    if (mobileScrub) {
      const thumbIndexAtX = (clientX: number): number | null => {
        const items = Array.from(mobileScrub.querySelectorAll<HTMLElement>('.deck-card-item'));
        if (!items.length) return null;
        for (const item of items) {
          const r = item.getBoundingClientRect();
          if (clientX >= r.left && clientX <= r.right) {
            return parseInt(item.getAttribute('data-index') || '-1', 10);
          }
        }
        const firstRect = items[0].getBoundingClientRect();
        if (clientX < firstRect.left) return parseInt(items[0].getAttribute('data-index') || '-1', 10);
        const lastRect = items[items.length - 1].getBoundingClientRect();
        if (clientX > lastRect.right) return parseInt(items[items.length - 1].getAttribute('data-index') || '-1', 10);
        return null;
      };
      const scrubTo = (clientX: number) => {
        const idx = thumbIndexAtX(clientX);
        if (idx !== null && idx !== currentIdx) {
          goToPos(order.indexOf(idx));
          updateDisplay(true);
        }
      };
      mobileScrub.addEventListener('pointerdown', (e) => {
        mobileScrub.setPointerCapture(e.pointerId);
        stopAutoplay();
        scrubTo(e.clientX);
      });
      mobileScrub.addEventListener('pointermove', (e) => {
        if (mobileScrub.hasPointerCapture && mobileScrub.hasPointerCapture(e.pointerId)) scrubTo(e.clientX);
      });
      mobileScrub.addEventListener('pointerup', () => startAutoplay());
      mobileScrub.addEventListener('pointercancel', () => startAutoplay());
    }

    closeBtn?.addEventListener('click', closeLightbox);
    lightbox.querySelector('.lightbox-backdrop')?.addEventListener('click', closeLightbox);

    pageActiveWrap?.addEventListener('click', () => {
      openLightbox(currentIdx);
    });

    // Hover pauses autoplay on the page-view image and inside the lightbox;
    // it resumes as soon as the pointer leaves.
    pageActiveWrap?.addEventListener('mouseenter', stopAutoplay);
    pageActiveWrap?.addEventListener('mouseleave', startAutoplay);
    if (lightboxDeck) {
      lightboxDeck.addEventListener('mouseenter', stopAutoplay);
      lightboxDeck.addEventListener('mouseleave', () => { if (isOpen) startAutoplay(); });
    }

    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      // While the lightbox is open the arrows drive it exclusively — stop the
      // event before the site-wide prev/next-project handler can also fire.
      if (e.key === 'ArrowRight') { e.preventDefault(); e.stopImmediatePropagation(); goToPos(currentPos + 1); updateDisplay(true); startAutoplay(); }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); e.stopImmediatePropagation(); goToPos(currentPos - 1); updateDisplay(true); startAutoplay(); }
      if (e.key === 'Escape') { e.preventDefault(); e.stopImmediatePropagation(); closeLightbox(); }
    });

    // ── Broken images never render as empty/alt-text cards: drop the card
    // from the scrub, the lightbox, and the rotation entirely. ──
    const dropCard = (idx: number) => {
      deck.querySelector(`.deck-card-item[data-index="${idx}"]`)?.remove();
      mobileScrub?.querySelector(`.deck-card-item[data-index="${idx}"]`)?.remove();
      lightboxDeck?.querySelector(`.lightbox-deck__item[data-index="${idx}"]`)?.remove();
      deckItems = lightboxDeck
        ? Array.from(lightboxDeck.querySelectorAll('.lightbox-deck__item')) as HTMLElement[]
        : [];
      const pos = order.indexOf(idx);
      if (pos >= 0) order.splice(pos, 1);
      if (!order.length) return;
      if (currentIdx === idx || currentPos >= order.length) {
        goToPos(Math.min(currentPos, order.length - 1));
        updateDisplay(false);
      }
      fitDeckGrid();
    };
    deck.querySelectorAll('.deck-card-item img:not(.deck-card-logo)').forEach(im => {
      const img = im as HTMLImageElement;
      const idx = parseInt(img.closest('.deck-card-item')?.getAttribute('data-index') ?? '-1', 10);
      if (idx < 0) return;
      if (img.complete && img.naturalWidth === 0) { requestAnimationFrame(() => dropCard(idx)); return; }
      img.addEventListener('error', () => dropCard(idx));
    });

    // ── Header scrubber: click/drag jumps through the deck instantly ──
    const scrubberEl = document.getElementById('lightbox-scrubber');
    if (scrubberEl) {
      const scrubTo = (clientX: number) => {
        const rect = scrubberEl.getBoundingClientRect();
        const t = Math.min(Math.max((clientX - rect.left) / rect.width, 0), 1);
        const pos = Math.round(t * (order.length - 1));
        if (pos !== currentPos) {
          goToPos(pos);
          updateDisplay(false);
          scrollDeckTo(currentPos, 'instant' as ScrollBehavior);
        }
      };
      scrubberEl.addEventListener('pointerdown', (e) => {
        e.preventDefault();
        scrubberEl.setPointerCapture(e.pointerId);
        stopAutoplay();
        scrubTo(e.clientX);
      });
      scrubberEl.addEventListener('pointermove', (e) => {
        if (scrubberEl.hasPointerCapture && scrubberEl.hasPointerCapture(e.pointerId)) scrubTo(e.clientX);
      });
      scrubberEl.addEventListener('pointerup', () => startAutoplay());
    }

    updateDisplay(false);
    startAutoplay();
    updateScrubActiveState();

    // ── Fit the scrub grid's columns so its total height matches the
    // right-hand image exactly (grid-row: 3 already reserves that height —
    // we just need enough columns that the rows fill it, not scroll it) ──
    const deckSection = deck.closest('.card-deck-section') as HTMLElement | null;
    const fitDeckGrid = () => {
      if (!deckSection || window.innerWidth < 1024) {
        deck.style.removeProperty('grid-template-columns');
        return;
      }
      const targetHeight = deckSection.clientHeight;
      const containerWidth = deck.clientWidth;
      const count = deck.children.length;
      const gap = 6; // matches desktop .deck-grid gap
      if (!targetHeight || !containerWidth || !count) return;

      // Fewest columns (= biggest cards) whose full grid still fits the
      // reserved height — the scrub grows to meet the image's bottom edge.
      let bestCols = 24;
      for (let cols = 2; cols <= 24; cols++) {
        const cardWidth = (containerWidth - gap * (cols - 1)) / cols;
        if (cardWidth <= 0) continue;
        const rows = Math.ceil(count / cols);
        const totalHeight = rows * cardWidth * 1.5 + (rows - 1) * gap;
        if (totalHeight <= targetHeight) { bestCols = cols; break; }
      }
      // 'important' — the stylesheet's fallback rules also use !important
      deck.style.setProperty('grid-template-columns', `repeat(${bestCols}, 1fr)`, 'important');
    };

    fitDeckGrid();
    window.addEventListener('resize', fitDeckGrid, { passive: true });
    if ('ResizeObserver' in window && deckSection) {
      new ResizeObserver(fitDeckGrid).observe(deckSection);
    }

    // Section collapse (card pages render Design/Making or chapters too, but
    // initStandardSlider — where this used to be wired — never runs here).
    // Tab-layout pages (work + the academic chapter pages) get the single-open
    // accordion: name tab + Design/Making OR name tab + each chapter. Other card
    // pages (freelancer, original card sets) keep Design/Making independent, with
    // no name toggle since that button only renders for tab-layout pages.
    const isTabLayoutPage = document.querySelector('.project-detail')?.getAttribute('data-tab-layout') === 'true';
    if (isTabLayoutPage) {
      wireWorkAccordion();
    } else {
      wireCollapse(document.querySelector('.project-design-section'), 'project-design-click', 'project-design-toggle', 'project-design-panel');
      wireCollapse(document.querySelector('.project-making-section'), 'project-making-click', 'project-making-toggle', 'project-making-panel');
    }

    // Work-category mobile: "Credits" pill reveals the people row
    const creditsBtn = document.getElementById('project-credits-btn');
    const peoplePanel = document.getElementById('project-people-panel');
    creditsBtn?.addEventListener('click', () => {
      const isExpanded = peoplePanel?.classList.toggle('is-expanded') ?? false;
      creditsBtn.setAttribute('aria-expanded', String(isExpanded));
    });
  }


  function initStandardSlider() {
    const slider = document.getElementById('standard-slider-wrapper');
    const lightbox = document.getElementById('card-lightbox');
    const lightboxImg = document.getElementById('lightbox-card-img') as HTMLImageElement | null;
    const ambientImg = document.getElementById('lightbox-ambient-img') as HTMLImageElement | null;
    const cardContainer = document.getElementById('lightbox-card-container');
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');

    const headerTitle = document.getElementById('lightbox-card-title');
    const counter = document.getElementById('lightbox-counter');

    const activeImg = document.getElementById('standard-active-img') as HTMLImageElement | null;
    const activeWrap = document.getElementById('standard-active-wrap');
    const pagination = document.getElementById('standard-pagination');
    const prevArrow = document.getElementById('standard-prev');
    const nextArrow = document.getElementById('standard-next');
    const strip = document.getElementById('standard-thumbs');

    const designSection = document.querySelector('.project-design-section');
    const makingSection = document.querySelector('.project-making-section');

    if (!slider || !activeImg) return;

    const images = JSON.parse(slider.getAttribute('data-images') || '[]');
    const projectName = document.querySelector('.project-detail')?.getAttribute('data-project-name') || '';

    // Each load: pick 5 random images (random order) — that set IS the scrub,
    // the slider, and the lightbox until the next reload. Thumbs outside the
    // pick are removed so the strip never scrolls.
    const order = shuffle(Array.from({ length: images.length }, (_, i) => i)).slice(0, 5);
    if (strip) {
      Array.from(strip.querySelectorAll('.project-detail__thumb-item')).forEach(t => {
        const idx = parseInt(t.getAttribute('data-index') || '-1', 10);
        if (!order.includes(idx)) t.remove();
      });
      reorderChildrenByIndex(strip, order);
    }
    const thumbs = strip ? Array.from(strip.querySelectorAll('.project-detail__thumb-item')) : [];

    let currentPos = 0;
    let currentIdx = order[0] ?? 0;
    let isOpen = false;

    const timerRings = ['page-timer-progress', 'page-timer-progress-mini']
      .map(id => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);

    const resetTimerRing = () => {
      timerRings.forEach(ring => {
        const wrap = ring.closest('.autoplay-timer-ring');
        if (wrap) {
          wrap.classList.remove('is-animating');
          void (wrap as HTMLElement).offsetWidth;
          wrap.classList.add('is-animating');
        }
      });
      const lightboxProgress = document.getElementById('lightbox-timer-progress');
      if (lightboxProgress) {
        const wrap = lightboxProgress.closest('.autoplay-timer-ring');
        if (wrap) {
          wrap.classList.remove('is-animating');
          void (wrap as HTMLElement).offsetWidth;
          if (isOpen) wrap.classList.add('is-animating');
        }
      }
    };

    const goToPos = (pos: number) => {
      const count = order.length;
      currentPos = ((pos % count) + count) % count;
      currentIdx = order[currentPos];
    };

    function thumbIndexAtX(clientX: number): number {
      if (!thumbs.length) return -1;
      for (let i = 0; i < thumbs.length; i++) {
        const r = thumbs[i].getBoundingClientRect();
        if (clientX >= r.left && clientX <= r.right) return i;
      }
      return clientX < thumbs[0].getBoundingClientRect().left ? 0 : thumbs.length - 1;
    }

    const openLightbox = (index: number) => {
      goToPos(order.indexOf(index));
      isOpen = true;
      updateDisplay();

      if (lightbox) {
        lightbox.style.display = 'flex';
        lightbox.setAttribute('aria-hidden', 'false');
      }
      document.body.style.overflow = 'hidden';
      resetTimerRing();
    };

    const closeLightbox = () => {
      isOpen = false;
      if (lightbox) {
        lightbox.style.display = 'none';
        lightbox.setAttribute('aria-hidden', 'true');
      }
      document.body.style.overflow = '';
      if (cardContainer) {
        cardContainer.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
      }
      resetTimerRing();
      restartAutoplay();
    };

    const updateDisplay = () => {
      const activeUrl = images[currentIdx];

      // Lightbox elements
      if (lightboxImg) lightboxImg.src = activeUrl;
      if (ambientImg) ambientImg.src = activeUrl;
      if (headerTitle) headerTitle.textContent = `${projectName} — Photo`;
      if (counter) counter.textContent = `${currentPos + 1} / ${order.length}`;

      // Update scrubber fill
      const scrubFill = document.getElementById('lightbox-scrubber-fill');
      if (scrubFill) {
        const percentage = (currentPos / (order.length - 1)) * 100;
        scrubFill.style.width = `${percentage}%`;
      }

      // Lightbox name label: word-by-word spans
      const lbName = document.getElementById('lightbox-card-label');
      if (lbName) {
        lbName.innerHTML = `${projectName}`.split(' ').map(w => `<span>${w}</span>`).join('');
      }

      // Page active elements
      if (activeImg) activeImg.src = activeUrl;
      if (pagination) pagination.textContent = `${currentPos + 1} / ${order.length}`;

      thumbs.forEach((t, i) => t.classList.toggle('is-active', i === currentPos));

      // Scroll thumbnail
      const activeThumb = thumbs[currentPos];
      if (activeThumb && strip) {
        const stripRect = strip.getBoundingClientRect();
        const thumbRect = activeThumb.getBoundingClientRect();
        if (thumbRect.left < stripRect.left || thumbRect.right > stripRect.right) {
          activeThumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
        }
      }

      resetTimerRing();
    };

    const applyPos = (pos: number) => {
      goToPos(pos);

      if (isOpen && cardContainer) {
        cardContainer.classList.add('is-transitioning');
        setTimeout(() => {
          updateDisplay();
          cardContainer.classList.remove('is-transitioning');
        }, 180);
      } else {
        updateDisplay();
      }
      restartAutoplay();
    };

    // ── Autoplay: advance every 2s; any manual interaction resets the clock ──
    let autoplayInterval: number | null = null;
    const stopAutoplay = () => {
      if (autoplayInterval) { clearInterval(autoplayInterval); autoplayInterval = null; }
    };
    const restartAutoplay = () => {
      stopAutoplay();
      autoplayInterval = window.setInterval(() => {
        goToPos(currentPos + 1);
        updateDisplay();
      }, 2000);
    };
    updateDisplay();
    restartAutoplay();

    // Thumb strip listeners
    if (strip) {
      const isHoverDevice = window.matchMedia('(hover: hover)').matches;
      if (isHoverDevice) {
        thumbs.forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            const idx = parseInt(btn.getAttribute('data-index') || '0', 10);
            applyPos(order.indexOf(idx));
          });
        });

        strip.addEventListener('pointerenter', () => {
          slider.classList.add('is-previewing');
        });
        strip.addEventListener('pointermove', (e) => {
          const idx = thumbIndexAtX(e.clientX);
          if (idx >= 0 && idx !== currentPos) {
            applyPos(idx);
          }
        });
        strip.addEventListener('pointerleave', () => {
          slider.classList.remove('is-previewing');
        });
      } else {
        thumbs.forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            const idx = parseInt(btn.getAttribute('data-index') || '0', 10);
            applyPos(order.indexOf(idx));
          });
        });

        strip.addEventListener('pointermove', (e) => {
          const idx = thumbIndexAtX(e.clientX);
          if (idx >= 0 && idx !== currentPos) {
            applyPos(idx);
          }
        });
      }
    }

    activeWrap?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('.project-detail__nav-arrow')) return;
      openLightbox(currentIdx);
    });

    // Hover pauses autoplay on the page-view image and inside the lightbox;
    // it resumes as soon as the pointer leaves.
    activeWrap?.addEventListener('mouseenter', stopAutoplay);
    activeWrap?.addEventListener('mouseleave', restartAutoplay);
    cardContainer?.addEventListener('mouseenter', stopAutoplay);
    cardContainer?.addEventListener('mouseleave', () => { if (isOpen) restartAutoplay(); });

    prevArrow?.addEventListener('click', (e) => {
      e.stopPropagation();
      applyPos(currentPos - 1);
    });

    nextArrow?.addEventListener('click', (e) => {
      e.stopPropagation();
      applyPos(currentPos + 1);
    });

    closeBtn?.addEventListener('click', closeLightbox);
    lightbox?.querySelector('.lightbox-backdrop')?.addEventListener('click', closeLightbox);

    // Header scrubber: click/drag jumps through the deck instantly
    const scrubberEl = document.getElementById('lightbox-scrubber');
    if (scrubberEl) {
      const scrubTo = (clientX: number) => {
        const rect = scrubberEl.getBoundingClientRect();
        const t = Math.min(Math.max((clientX - rect.left) / rect.width, 0), 1);
        const pos = Math.round(t * (order.length - 1));
        if (pos !== currentPos) {
          applyPos(pos);
        }
      };
      scrubberEl.addEventListener('pointerdown', (e) => {
        e.preventDefault();
        scrubberEl.setPointerCapture(e.pointerId);
        scrubTo(e.clientX);
      });
      scrubberEl.addEventListener('pointermove', (e) => {
        if (scrubberEl.hasPointerCapture && scrubberEl.hasPointerCapture(e.pointerId)) scrubTo(e.clientX);
      });
    }

    if (lightboxImg) {
      lightboxImg.addEventListener('click', (e) => {
        e.stopPropagation();
        applyPos(currentPos + 1);
      });
    }

    prevBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      applyPos(currentPos - 1);
    });

    nextBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      applyPos(currentPos + 1);
    });



    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      // While the lightbox is open the arrows drive it exclusively — stop the
      // event before the site-wide prev/next-project handler can also fire.
      if (e.key === 'ArrowRight') { e.preventDefault(); e.stopImmediatePropagation(); applyPos(currentPos + 1); }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); e.stopImmediatePropagation(); applyPos(currentPos - 1); }
      if (e.key === 'Escape') { e.preventDefault(); e.stopImmediatePropagation(); closeLightbox(); }
    });

    wireCollapse(designSection, 'project-design-click', 'project-design-toggle', 'project-design-panel');
    wireCollapse(makingSection, 'project-making-click', 'project-making-toggle', 'project-making-panel');

    // Chapter dropdowns (data.chapters) — accordion: only one open at a time
    const chapterSections = Array.from(document.querySelectorAll('.project-chapter'));
    const collapseChapter = (sect: Element) => {
      const toggleBtn = sect.querySelector('.project-detail-collapse-btn');
      if (!toggleBtn) return;
      sect.classList.remove('is-expanded');
      toggleBtn.setAttribute('aria-expanded', 'false');
    };

    chapterSections.forEach(sect => {
      const header = sect.querySelector('.project-chapter__header');
      const toggleBtn = sect.querySelector('.project-detail-collapse-btn');
      if (!header || !toggleBtn) return;
      header.addEventListener('click', () => {
        const willExpand = !sect.classList.contains('is-expanded');

        // Collapse every other chapter before opening this one
        chapterSections.forEach(other => {
          if (other !== sect) collapseChapter(other);
        });

        sect.classList.toggle('is-expanded', willExpand);
        toggleBtn.setAttribute('aria-expanded', String(willExpand));
        toggleBtn.querySelectorAll('.link-arrow').forEach((a) => {
          (a as HTMLElement).style.transform = `rotate(${Math.floor(Math.random() * 360)}deg)`;
        });
        // Opening/closing a chapter changes whether the mobile head is fixed
        // and whether the intro is collapsed.
        refreshFixedHead();
      });
    });
  }

  function initScarpinSliders() {
    const isScarpin = document.querySelector('.project-detail')?.getAttribute('data-is-scarpin') === 'true';
    if (!isScarpin) return;

    const items = document.querySelectorAll('.scarpin-grid-item');
    const scarpinLb = document.getElementById('scarpin-lightbox');
    if (!scarpinLb) return;

    const lbImg = document.getElementById('scarpin-lightbox-img');
    const lbVid = document.getElementById('scarpin-lightbox-vid');
    const lbAmbient = document.getElementById('scarpin-lightbox-ambient');
    const lbCounter = document.getElementById('scarpin-lightbox-counter');
    const lbLabel = document.getElementById('scarpin-lightbox-label');
    const lbPrev = document.getElementById('scarpin-lightbox-prev');
    const lbNext = document.getElementById('scarpin-lightbox-next');
    const lbClose = document.getElementById('scarpin-lightbox-close');

    let lbImages = [];
    let lbPos = 0;
    let lbTitle = '';
    let isLbOpen = false;

    const updateLightbox = () => {
      if (lbImages.length === 0) return;
      const url = lbImages[lbPos];
      if (url.endsWith('.mp4')) {
        lbImg.style.display = 'none';
        lbVid.style.display = 'block';
        lbVid.src = url;
        lbAmbient.src = '';
      } else {
        lbVid.style.display = 'none';
        lbVid.src = '';
        lbImg.style.display = 'block';
        lbImg.src = url;
        lbAmbient.src = url;
      }
      lbCounter.textContent = `${lbPos + 1} / ${lbImages.length}`;
    };

    const openScarpinLightbox = (images, pos, title) => {
      lbImages = images;
      lbPos = pos;
      lbTitle = title;
      lbLabel.textContent = title;
      updateLightbox();
      scarpinLb.style.display = 'block';
      setTimeout(() => {
        scarpinLb.classList.add('is-open');
        scarpinLb.setAttribute('aria-hidden', 'false');
        isLbOpen = true;
      }, 10);
    };

    const closeScarpinLightbox = () => {
      if (!isLbOpen) return;
      scarpinLb.classList.remove('is-open');
      scarpinLb.setAttribute('aria-hidden', 'true');
      isLbOpen = false;
      setTimeout(() => {
        scarpinLb.style.display = 'none';
        lbVid.src = ''; // stop video playback
      }, 400);
    };

    lbClose?.addEventListener('click', closeScarpinLightbox);
    scarpinLb?.querySelector('.lightbox-backdrop')?.addEventListener('click', closeScarpinLightbox);

    lbPrev?.addEventListener('click', (e) => {
      e.stopPropagation();
      lbPos = (lbPos - 1 + lbImages.length) % lbImages.length;
      updateLightbox();
    });

    lbNext?.addEventListener('click', (e) => {
      e.stopPropagation();
      lbPos = (lbPos + 1) % lbImages.length;
      updateLightbox();
    });

    document.addEventListener('keydown', (e) => {
      if (isLbOpen) {
        if (e.key === 'ArrowRight') { e.preventDefault(); e.stopImmediatePropagation(); lbNext.click(); }
        if (e.key === 'ArrowLeft') { e.preventDefault(); e.stopImmediatePropagation(); lbPrev.click(); }
        if (e.key === 'Escape') { e.preventDefault(); e.stopImmediatePropagation(); closeScarpinLightbox(); }
      }
    });

    items.forEach(item => {
      const urls = JSON.parse(item.getAttribute('data-images') || '[]');
      if (urls.length === 0) return;

      let pos = 0;
      let timer = null;
      let isHovered = false;
      const AUTOPLAY_DELAY = 4000;

      const counter = item.querySelector('.scarpin-item-counter');
      const mediaWrap = item.querySelector('.scarpin-item-media-wrap');
      const thumbs = item.querySelectorAll('.scarpin-thumb');
      const title = item.querySelector('.scarpin-item-title').textContent;
      const progressRing = item.querySelector('.scarpin-timer-ring');

      const updateMedia = () => {
        const url = urls[pos];
        const existingMedia = mediaWrap.querySelector('.scarpin-media');

        let newMedia;
        if (url.endsWith('.mp4')) {
          newMedia = document.createElement('video');
          newMedia.className = 'scarpin-media scarpin-media--active';
          newMedia.src = url;
          newMedia.autoplay = true;
          newMedia.loop = true;
          newMedia.muted = true;
          newMedia.playsInline = true;
        } else {
          newMedia = document.createElement('img');
          newMedia.className = 'scarpin-media scarpin-media--active';
          newMedia.src = url;
          newMedia.loading = 'lazy';
          newMedia.alt = title;
        }

        existingMedia.replaceWith(newMedia);
        counter.textContent = `${pos + 1} / ${urls.length}`;

        thumbs.forEach((thumb, idx) => {
          thumb.classList.toggle('is-active', idx === pos);
          if (idx === pos) {
            thumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
          }
        });

        resetTimer();
      };

      const resetTimer = () => {
        clearInterval(timer);
        const wrap = progressRing ? progressRing.closest('.autoplay-timer-ring') as HTMLElement | null : null;
        if (wrap) {
          // Restart the keyframe sweep: drop the class, set this slider's
          // duration, force a reflow, then (below) re-add to run it fresh.
          wrap.classList.remove('is-animating');
          wrap.style.setProperty('--timer-dur', `${AUTOPLAY_DELAY}ms`);
          void wrap.offsetWidth; // reflow so the re-added class restarts the animation
        }

        const hasHoverCapability = window.matchMedia('(hover: hover)').matches;
        // Mobile (no hover): always auto-play
        // Desktop (has hover): auto-play ONLY when hovering
        const shouldPlay = !isLbOpen && urls.length > 1 && (!hasHoverCapability || isHovered);

        if (shouldPlay) {
          if (wrap) wrap.classList.add('is-animating');
          timer = setInterval(() => {
            pos = (pos + 1) % urls.length;
            updateMedia();
          }, AUTOPLAY_DELAY);
        }
      };

      item.addEventListener('mouseenter', () => {
        isHovered = true;
        resetTimer();
      });

      item.addEventListener('mouseleave', () => {
        isHovered = false;
        resetTimer();
      });

      thumbs.forEach((thumb, idx) => {
        thumb.addEventListener('click', (e) => {
          e.stopPropagation();
          pos = idx;
          updateMedia();
        });
      });

      mediaWrap?.addEventListener('click', () => {
        openScarpinLightbox(urls, pos, title);
      });

      resetTimer();
    });
  }

  function initHeadingScrollTop() {
    // Card pages: header is always on screen, so tap-to-scroll-top is pointless
    const article = document.querySelector('.project-detail');
    if (article?.getAttribute('data-is-card') === 'true') return;
    const h = document.getElementById('project-top-header');
    if (h && !(h as any)._topWired) {
      (h as any)._topWired = true;
      h.addEventListener('click', (e) => {
        // Don't hijack taps on links inside the header (e.g. the category link)
        if ((e.target as HTMLElement).closest('a')) return;
        // Tapping the head closes any open chapter → the fixed intro returns
        collapseAllChapters();
        refreshFixedHead();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  }

  // Generic header+arrow collapse toggle (module-level so both initStandardSlider
  // and initCardDeck can wire Design/Making — and, on card pages, the project
  // name's own toggle — to the same is-expanded/aria-expanded/icon-swap behavior).
  function wireCollapse(sect: Element | null, headerId: string, toggleId: string, panelId: string) {
    if (!sect) return;
    const header = sect.querySelector(`#${headerId}`);
    const toggleBtn = sect.querySelector(`#${toggleId}`);

    if (!header || !toggleBtn) return;
    const iconMinus = toggleBtn.querySelector('.toggle-icon-minus') as HTMLElement | null;
    const iconPlus = toggleBtn.querySelector('.toggle-icon-plus') as HTMLElement | null;

    const toggleSection = () => {
      const isExpanded = sect.classList.toggle('is-expanded');
      toggleBtn.setAttribute('aria-expanded', String(isExpanded));

      toggleBtn.querySelectorAll('.link-arrow').forEach((a) => {
        (a as HTMLElement).style.transform = `rotate(${Math.floor(Math.random() * 360)}deg)`;
      });

      if (iconMinus && iconPlus) {
        if (isExpanded) {
          iconMinus.style.display = 'block';
          iconPlus.style.display = 'none';
        } else {
          iconMinus.style.display = 'none';
          iconPlus.style.display = 'block';
        }
      }
    };

    header.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleSection();
    });
    toggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleSection();
    });
  }

  // Tab-layout pages: the project name tab plus its section tabs act as one
  // accordion — only one open at a time (opening one closes the others), a
  // single click toggles just that tab, and a double click opens or closes
  // all of them together. Each tab's own header sticks to the top of the
  // viewport (CSS: position:sticky) while its content is being scrolled. The
  // section tabs are EITHER the generic Design / Making pair (work pages
  // without chapters) OR one tab per chapter (the academic chapter pages) —
  // whichever the page actually rendered.
  function wireWorkAccordion() {
    type Entry = { sect: Element; header: Element; toggle: Element };
    const entries: Entry[] = [];
    const add = (sect: Element | null, headerSel: string, toggleSel: string) => {
      if (!sect) return;
      const header = sect.querySelector(headerSel);
      const toggle = sect.querySelector(toggleSel);
      if (header && toggle) entries.push({ sect, header, toggle });
    };
    add(document.getElementById('project-dashboard'), '#project-name-header', '#project-name-toggle');
    add(document.querySelector('.project-design-section'), '#project-design-click', '#project-design-toggle');
    add(document.querySelector('.project-making-section'), '#project-making-click', '#project-making-toggle');
    document.querySelectorAll('.project-chapter').forEach(ch =>
      add(ch, '.project-chapter__header', '.project-detail-collapse-btn'));

    const setExpanded = (entry: Entry, expanded: boolean) => {
      entry.sect.classList.toggle('is-expanded', expanded);
      entry.toggle.setAttribute('aria-expanded', String(expanded));
      const iconMinus = entry.toggle.querySelector('.toggle-icon-minus') as HTMLElement | null;
      const iconPlus = entry.toggle.querySelector('.toggle-icon-plus') as HTMLElement | null;
      if (iconMinus && iconPlus) {
        iconMinus.style.display = expanded ? 'block' : 'none';
        iconPlus.style.display = expanded ? 'none' : 'block';
      }
    };

    const toggleAll = () => {
      const allOpen = entries.every(entry => entry.sect.classList.contains('is-expanded'));
      entries.forEach(entry => setExpanded(entry, !allOpen));
    };

    entries.forEach(entry => {
      // A double click fires click, click, dblclick — delay the single-click
      // action just long enough to cancel it if a second click follows.
      let clickTimer: number | null = null;

      const onClick = (e: Event) => {
        e.stopPropagation();
        if (clickTimer) { clearTimeout(clickTimer); clickTimer = null; return; }
        clickTimer = window.setTimeout(() => {
          clickTimer = null;
          const wasExpanded = entry.sect.classList.contains('is-expanded');
          setExpanded(entry, !wasExpanded);
        }, 250);
      };

      const onDblClick = (e: Event) => {
        e.stopPropagation();
        if (clickTimer) { clearTimeout(clickTimer); clickTimer = null; }
        toggleAll();
      };

      entry.header.addEventListener('click', onClick);
      entry.toggle.addEventListener('click', onClick);
      entry.header.addEventListener('dblclick', onDblClick);
      entry.toggle.addEventListener('dblclick', onDblClick);
    });
  }

  // Collapse every chapter accordion (module-level so the header tap can call it)
  function collapseAllChapters() {
    document.querySelectorAll('.project-chapter.is-expanded').forEach(sect => {
      sect.classList.remove('is-expanded');
      const btn = sect.querySelector('.project-detail-collapse-btn');
      btn?.setAttribute('aria-expanded', 'false');
    });
  }

  // Recompute the mobile head: it is FIXED only while no chapter is open; when a
  // chapter opens, the head un-fixes and the intro (grid) collapses.
  function refreshFixedHead() {
    const article = document.querySelector('.project-detail') as HTMLElement | null;
    if (!article || article.getAttribute('data-is-card') === 'true') return;
    const header = document.getElementById('project-top-header');
    if (!header) return;
    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    const anyChapterOpen = !!document.querySelector('.project-chapter.is-expanded');
    const fixed = isMobile && !anyChapterOpen;
    header.classList.toggle('is-fixed-head', fixed);
    article.classList.toggle('has-fixed-head', fixed);
    article.classList.toggle('intro-collapsed', isMobile && anyChapterOpen);
    if (fixed) {
      article.style.setProperty('--head-h', `${header.offsetHeight}px`);
    } else {
      article.style.removeProperty('--head-h');
    }
  }

  // ── Mobile (standard pages): the project name + metaline + people become a
  // fixed opaque head; everything else scrolls beneath it. The metaline and
  // people nodes are relocated into the header on mobile and restored to the
  // left column on desktop. ──
  function initMobileFixedHead() {
    const article = document.querySelector('.project-detail') as HTMLElement | null;
    if (!article || article.getAttribute('data-is-card') === 'true') return;
    const header = document.getElementById('project-top-header');
    const metaline = document.querySelector('.project-card__metaline--incol') as HTMLElement | null;
    const people = document.querySelector('.project-people') as HTMLElement | null;
    const info = document.querySelector('.project-card-info') as HTMLElement | null;
    if (!header) return;

    const mq = window.matchMedia('(max-width: 768px)');
    const apply = () => {
      if (mq.matches) {
        // Mobile: metaline + people live inside the (fixed) head
        if (metaline) header.appendChild(metaline);
        if (people) header.appendChild(people);
      } else {
        // Desktop: restore them to the left column, drop all mobile-head state
        if (info) {
          const textRow = info.querySelector('.project-card__row2');
          if (metaline) info.insertBefore(metaline, textRow);
          if (people) info.insertBefore(people, textRow);
        }
        article.classList.remove('intro-collapsed');
      }
      refreshFixedHead();
    };
    apply();
    if (!(header as any)._mqWired) {
      (header as any)._mqWired = true;
      mq.addEventListener('change', apply);
    }
    if (!(header as any)._headRO && 'ResizeObserver' in window) {
      (header as any)._headRO = new ResizeObserver(() => refreshFixedHead());
      (header as any)._headRO.observe(header);
    }
  }

  function initProjectPeople() {
    const peopleEls = document.querySelectorAll('.project-people__person');
    peopleEls.forEach(el => {
      el.addEventListener('click', (e) => {
        e.stopPropagation();
        const wasActive = el.classList.contains('is-active');
        peopleEls.forEach(p => p.classList.remove('is-active'));
        if (!wasActive) el.classList.add('is-active');
      });
    });

    document.addEventListener('click', () => {
      peopleEls.forEach(p => p.classList.remove('is-active'));
    });
  }

  function initCopyPrompt() {
    document.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.copy-prompt-btn') as HTMLElement | null;
      if (!btn) return;
      const box = btn.closest('.prompt-box');
      const textEl = box?.querySelector('.prompt-text');
      if (textEl) {
        navigator.clipboard.writeText(textEl.textContent || '');
        const btnText = btn.querySelector('.copy-btn-text');
        const oldHtml = btn.innerHTML;
        if (btnText) {
          btnText.textContent = 'Copied!';
          btn.style.color = 'var(--_tokens---color--fg)';
        } else {
          btn.innerHTML = '<span class="copied-indicator">Copied!</span>';
        }
        setTimeout(() => {
          btn.innerHTML = oldHtml;
          btn.style.color = '';
        }, 1500);
      }
    });
  }

  document.addEventListener('astro:page-load', () => {
    initProjectPage();
    initHeadingScrollTop();
    initMobileFixedHead();
    initProjectPeople();
    initCopyPrompt();
  });
  if (document.readyState !== 'loading') {
    initProjectPage();
    initHeadingScrollTop();
    initMobileFixedHead();
    initProjectPeople();
    initCopyPrompt();
  }
</script>
