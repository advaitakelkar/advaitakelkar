---
import { getCollection, getEntry } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({
    params: { slug: p.id },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { data } = project;

// Resolve tag and category references
const tags = await Promise.all((data.tags ?? []).map(t => getEntry(t)));
const category = data.category ? await getEntry(data.category) : null;

const PLACEHOLDER = '/images/admin/placeholder.png';
const cover = data.coverImage || PLACEHOLDER;
const gallery = (data.multiImage ?? []).filter(Boolean);
const allImages = [cover, ...gallery];

const metaParts = [
  { label: 'Year', val: data.year },
  { label: 'Location', val: data.location },
  { label: 'Client', val: data.client && data.client !== 'NA' ? data.client : null },
  { label: 'With', val: data.collaborator },
  { label: 'Program', val: data.program },
  { label: 'Status', val: data.status },
  { label: 'Category', val: category ? category.data.displayName : null }
].filter(m => m.val);
---

<PageLayout
  title={data.name}
  description={data.smallIntro}
  ogImage={data.coverImage}
  label={data.name}
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Projects', href: '/projects' },
    { label: data.name },
  ]}
>
    <article class="project-detail" data-project-id={project.id} data-project-name={data.name}>
      
      <!-- Top Image Slider -->
      <div class="project-slider">
        <button class="slider-btn slider-btn--prev" aria-label="Previous image">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <div class="project-slider__track" id="slider-track">
          {allImages.map((img, idx) => (
            <div class="project-slider__slide soft-image-container">
              <img src={img} alt={`${data.name} - Image ${idx + 1}`} loading={idx === 0 ? "eager" : "lazy"} />
            </div>
          ))}
        </div>
        <button class="slider-btn slider-btn--next" aria-label="Next image">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>

      <!-- Enlarged Project Card Info -->
      <div class="project-card-info">
        <!-- Row 1: name (left) -->
        <div class="project-card__row project-card__row1">
          <h1 class="project-card__title">{data.name}</h1>
        </div>

        <!-- Row 2: intro + description (left) -->
        <div class="project-card__row project-card__row2">
          <div class="project-card__text-block">
            {data.smallIntro && <p class="project-card__intro">{data.smallIntro}</p>}
            {data.description && (
              <div class="project-card__desc" set:html={data.description} />
            )}
          </div>
        </div>

        <!-- Row 3: meta (left) -->
        <div class="project-card__row project-card__row3">
          <div class="project-card__metaline">
            {metaParts.map((m, idx) => (
              <span class="project-card__meta-item">
                {idx > 0 && <span class="project-card__meta-sep">·</span>}
                <span class="meta-label-inline">{m.label}:</span> <span class="project-card__meta-val">{m.val}</span>
              </span>
            ))}
            {tags.length > 0 && (
              <span class="project-card__meta-item">
                {metaParts.length > 0 && <span class="project-card__meta-sep">·</span>}
                <span class="meta-label-inline">Tags:</span>
                <span class="project-card__meta-val tag-val">
                  {tags.map((tag, tIdx) => tag && (
                    <a href={`/tags/${tag.id}`} class="tag-link">{tag.data.name}</a>
                  ))}
                </span>
              </span>
            )}
          </div>
        </div>
      </div>
    </article>
</PageLayout>

<style>
  .project-detail {
    padding-inline: var(--_tokens---space--small);
    padding-top: calc(clamp(2rem, 4vh, 3rem) + 48px);
    padding-bottom: clamp(4rem, 8vh, 8rem);
    min-height: 100dvh;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: var(--_tokens---space--medium);
  }

  @media (min-width: 1200px) {
    .project-detail {
      padding-inline: clamp(6rem, 12vw, 16rem);
      padding-top: calc(clamp(4rem, 6vh, 5rem) + 48px);
    }
  }

  @media (max-width: 767px) and (orientation: portrait) {
    .project-detail {
      padding-bottom: 80px;
    }
  }

  /* ── Slider ── */
  .project-slider {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: var(--_tokens---radius--large);
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 3%, var(--_tokens---color--bg));
  }

  .project-slider__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .project-slider__track::-webkit-scrollbar {
    display: none;
  }

  .project-slider__slide {
    flex: 0 0 100%;
    min-width: 100%;
    scroll-snap-align: center;
    max-height: 45vh; /* Reduced to ensure text fits in viewport */
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-slider__slide img {
    width: 100%;
    height: 100%;
    object-fit: contain; /* Contain ensures we see the whole image uncropped */
    background-color: var(--_tokens---color--bg); /* fill empty space */
  }

  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    background: var(--_tokens---color--bg);
    color: var(--_tokens---color--fg);
    border: 1px solid var(--_tokens---color--line);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    opacity: 0.8;
    transition: opacity 0.2s, transform 0.2s;
  }
  
  .slider-btn:hover {
    opacity: 1;
    transform: translateY(-50%) scale(1.1);
  }

  .slider-btn svg {
    width: 24px;
    height: 24px;
  }

  .slider-btn--prev { left: 16px; }
  .slider-btn--next { right: 16px; }

  @media (max-width: 767px) {
    .slider-btn { display: none; } /* Hide buttons on mobile, rely on swipe */
    .project-slider__slide { max-height: 35vh; }
  }

  /* ── Enlarged Card Info ── */
  .project-card-info {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    padding: 16px 0;
  }

  .project-card__row {
    display: flex;
    width: 100%;
  }

  .project-card__title {
    font-size: clamp(4rem, 4rem + 5vw, 8rem); /* Much larger project name font size */
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0;
    color: var(--_tokens---color--fg);
  }

  .project-card__text-block {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 80ch;
  }

  .project-card__intro {
    font-size: var(--_tokens---type--medium, 1.25rem);
    font-weight: 600;
    line-height: 1.4;
    color: var(--_tokens---color--fg);
    margin: 0;
  }

  .project-card__desc {
    font-size: var(--_tokens---type--small);
    line-height: 1.6;
    color: var(--_tokens---color--muted);
    margin: 0;
  }

  .project-card__desc :global(p) {
    margin-bottom: 1em;
  }

  /* Metadata row */
  .project-card__metaline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-top: 16px;
    padding-top: 24px;
    border-top: 1px solid var(--_tokens---color--line);
    width: 100%;
  }

  .project-card__meta-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: var(--_tokens---type--micro);
    color: var(--_tokens---color--fg);
  }

  .project-card__meta-sep {
    color: var(--_tokens---color--muted);
    opacity: 0.5;
  }

  .meta-label-inline {
    font-weight: 300;
    color: var(--_tokens---color--muted);
    letter-spacing: 0.04em;
  }

  .project-card__meta-val {
    font-weight: 500;
  }
  
  .tag-val {
    display: inline-flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tag-link {
    color: var(--_tokens---color--fg);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity 0.2s ease;
  }

  .tag-link:hover {
    opacity: 0.7;
  }
</style>

<script>
  let autoSlideInterval;

  // Slider Controls
  function initSlider() {
    const track = document.getElementById('slider-track');
    const btnPrev = document.querySelector('.slider-btn--prev');
    const btnNext = document.querySelector('.slider-btn--next');

    if (autoSlideInterval) clearInterval(autoSlideInterval);
    if (!track) return;

    const startAutoSlide = () => {
      if (autoSlideInterval) clearInterval(autoSlideInterval);
      autoSlideInterval = setInterval(() => {
        // If at the end of the scroll track, loop back to the start
        if (track.scrollLeft + track.clientWidth >= track.scrollWidth - 10) {
          track.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          track.scrollBy({ left: track.clientWidth, behavior: 'smooth' });
        }
      }, 3500); // Auto-slide every 3.5 seconds
    };

    const stopAutoSlide = () => {
      if (autoSlideInterval) clearInterval(autoSlideInterval);
    };

    if (btnPrev && btnNext) {
      btnNext.addEventListener('click', () => {
        track.scrollBy({ left: track.clientWidth, behavior: 'smooth' });
        startAutoSlide(); // Reset auto-slide timer when manually interacted
      });
      btnPrev.addEventListener('click', () => {
        track.scrollBy({ left: -track.clientWidth, behavior: 'smooth' });
        startAutoSlide(); // Reset auto-slide timer when manually interacted
      });
    }

    // Pause sliding when user is hovering or touching the slider
    track.addEventListener('mouseenter', stopAutoSlide);
    track.addEventListener('mouseleave', startAutoSlide);
    track.addEventListener('touchstart', stopAutoSlide, { passive: true });
    track.addEventListener('touchend', startAutoSlide, { passive: true });

    startAutoSlide();
  }

  document.addEventListener('astro:page-load', initSlider);
  if (document.readyState !== 'loading') initSlider();

  // Clean up interval before navigating away (Astro view transitions)
  document.addEventListener('astro:before-swap', () => {
    if (autoSlideInterval) clearInterval(autoSlideInterval);
  });

  // ← Left arrow navigates back to the projects list
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'ArrowLeft') return;
    const activeEl = document.activeElement as HTMLElement;
    const tag = activeEl?.tagName;
    // Don't intercept if user is in a text field
    if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
    window.location.href = '/projects';
  });
</script>
