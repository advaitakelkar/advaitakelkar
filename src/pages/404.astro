---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="404 — Not Found" label="404">
  <section class="not-found">
    <h1 class="not-found__code">404</h1>
    <p class="not-found__msg text-muted">This page doesn't exist.</p>
    <a href="/" class="not-found__link">← Go Home</a>
  </section>
</PageLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    min-height: 100dvh;
    gap: var(--_tokens---space--micro);
    padding-inline: var(--_tokens---space--small);
    padding-top: calc(clamp(2rem, 4vh, 3rem) + 48px); /* space for fixed breadcrumbs */
    padding-bottom: var(--_tokens---space--small);
    box-sizing: border-box;
  }

  @media (min-width: 1200px) {
    .not-found {
      padding-inline: clamp(6rem, 12vw, 16rem);
      padding-top: calc(clamp(4rem, 6vh, 5rem) + 48px);
    }
  }

  @media (max-width: 767px) and (orientation: portrait) {
    .not-found {
      padding-bottom: 80px; /* space for mobile bottom docked breadcrumbs */
    }
  }

  .not-found__code {
    font-size: var(--_tokens---type--big);
    font-weight: 500;
    color: var(--_tokens---color--fg);
    line-height: 1;
  }

  .not-found__msg {
    font-size: var(--_tokens---type--small);
  }

  .not-found__link {
    margin-top: var(--_tokens---space--small);
    font-size: var(--_tokens---type--micro);
    font-weight: 300;
    color: var(--_tokens---color--muted);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .not-found__link:hover {
    color: var(--_tokens---color--fg);
  }
</style>
