---
import { getEntry } from 'astro:content';
import ExhibitionLayout from '../../layouts/ExhibitionLayout.astro';
import VGWheel from '../../components/VGWheel.astro';

const ex = await getEntry('exhibitions', 'virtual-gods');
const data = ex!.data;
---

<ExhibitionLayout
  title="Virtual Gods"
  description="India's first online group art exhibition. Sixteen participants, sixteen architects, four surreal worlds — ARCHV, 2020."
>
  <section class="vg-home">
    <header class="vg-home__head">
      <h1 class="vg-home__title" data-scramble>{data.title}</h1>
      <p class="vg-home__meta">{data.year} · ARCHV Collective · {data.tagline}</p>
      <div class="vg-home__intro">
        {data.intro?.map(p => <p>{p}</p>)}
      </div>
    </header>

    <VGWheel quadrants={data.quadrants} />

    <p class="vg-home__hint">
      Hover a form to trace it back to its maker. Click any node to step inside:
      the outer ring holds the sixteen modules, the middle ring their fusions,
      the center each group's finished world.
    </p>
  </section>
</ExhibitionLayout>

<style>
  .vg-home {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 4vh, 3rem);
    padding: clamp(1.5rem, 4vh, 3rem) clamp(16px, 3vw, 32px) clamp(3rem, 8vh, 6rem);
    box-sizing: border-box;
  }

  .vg-home__head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    gap: clamp(1rem, 3vw, 3rem);
    align-items: end;
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
  }

  .vg-home__title {
    grid-column: 1;
    font-size: var(--_tokens---type--big);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 0.95;
    margin: 0;
    color: var(--_tokens---color--fg);
  }

  .vg-home__meta {
    grid-column: 1;
    grid-row: 2;
    font-size: var(--_tokens---type--micro);
    color: var(--_tokens---color--muted);
    margin: 8px 0 0;
  }

  .vg-home__intro {
    grid-column: 2;
    grid-row: 1 / span 2;
    display: flex;
    flex-direction: column;
    gap: 0.75em;
  }

  .vg-home__intro :global(p) {
    font-size: var(--_tokens---type--micro);
    line-height: 1.55;
    color: var(--_tokens---color--muted);
    margin: 0;
    max-width: 62ch;
  }

  .vg-home__hint {
    max-width: 62ch;
    margin: 0 auto;
    text-align: center;
    font-size: var(--_tokens---type--ultrathin);
    line-height: 1.6;
    color: var(--_tokens---color--muted);
  }

  @media (max-width: 860px) {
    .vg-home__head { grid-template-columns: 1fr; }
    .vg-home__title, .vg-home__meta, .vg-home__intro { grid-column: 1; }
    .vg-home__intro { grid-row: auto; margin-top: 12px; }
  }
</style>
