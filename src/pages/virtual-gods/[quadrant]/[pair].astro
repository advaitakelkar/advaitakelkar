---
// A pair room. Left: the process, and the way back up. Middle: the active work.
// Right: the index of everything in this room.
import { getEntry } from 'astro:content';
import ExhibitionLayout from '../../../layouts/ExhibitionLayout.astro';
import VGStage from '../../../components/VGStage.astro';
import { publicFileExists, publicFilesLike } from '../../../lib/content';

export async function getStaticPaths() {
  const ex = await getEntry('exhibitions', 'virtual-gods');
  return ex!.data.quadrants.flatMap(q =>
    q.pairs.map(p => ({
      params: { quadrant: q.slug, pair: p.slug },
      props: { q, p },
    }))
  );
}

const { q, p } = Astro.props;
const asset = (rel: string) => `/images/virtual-gods/vg/${rel}`;

const VIEWS = ['iso', 'front', 'back', 'left', 'right', 'top', 'bottom'];
const views = VIEWS.filter(v => publicFileExists(asset(`mergers/${p.slug}/${v}.webp`)));
// Some pairs archived their intermediate fusion steps. The source folders
// number them inconsistently (A–F for one pair, 01–12 for another), so read
// whatever the pipeline produced instead of assuming a naming scheme.
const steps = publicFilesLike(`/images/virtual-gods/vg/mergers/${p.slug}`, 'module-', '.mp4');

// Order matters: the room reads as the fusion first, then how it was arrived
// at, then what it was made from, then the film.
const groups: any[] = [];

if (publicFileExists(asset(`mergers/${p.slug}.mp4`))) {
  groups.push({
    label: 'Fusion',
    note: 'the merged form',
    items: [{ type: 'video', src: asset(`mergers/${p.slug}`), label: `${p.label} — the fused form` }],
  });
}

if (views.length) {
  groups.push({
    label: 'Views',
    note: 'orthographic',
    items: views.map(v => ({ type: 'image', src: asset(`mergers/${p.slug}/${v}.webp`), label: `${p.label} — ${v} view` })),
  });
}

if (steps.length) {
  groups.push({
    label: 'Steps',
    note: 'the form resolving',
    items: steps.map((s, i) => ({ type: 'video', src: asset(`mergers/${p.slug}/${s}`), label: `Fusion step ${i + 1}` })),
  });
}

groups.push({
  label: 'Modules',
  note: 'the two sources',
  items: p.members
    .filter((m: any) => m.module)
    .map((m: any) => ({ type: 'video', src: asset(`modules/${m.module}`), label: `${m.name} — ${m.architect}` })),
});

if (p.film && publicFileExists(asset(`films/${p.film}.mp4`))) {
  groups.push({
    label: 'Film',
    note: 'the world',
    items: [{ type: 'video', src: asset(`films/${p.film}`), label: `${p.label} — film`, film: true }],
  });
}

// A pair with no surviving modules would render an empty stage.
const live = groups.filter(g => g.items.length > 0);
const lost = p.members.filter((m: any) => !m.module).map((m: any) => m.name);
---

<ExhibitionLayout
  title={`${p.label} — Virtual Gods`}
  description={`${p.label}: two modules fused into one form. ARCHV's Virtual Gods, 2020.`}
  trail={[
    { label: q.architects.slice(0, 2).join(' & '), href: `/virtual-gods/${q.slug}` },
    { label: p.label },
  ]}
  accent={q.color}
>
  <VGStage
    title={p.label}
    subtitle={p.members.map((m: any) => m.architect).join(' × ')}
    backHref={`/virtual-gods/${q.slug}`}
    backLabel={q.architects.slice(0, 2).join(' & ')}
    groups={live}
  />

  {lost.length > 0 && (
    <p class="vgp__lost-note">
      {lost.join(' and ')}{lost.length > 1 ? "'s modules were" : "'s module was"} never archived.
    </p>
  )}
</ExhibitionLayout>

<style>
  .vgp__lost-note {
    margin: 0 auto clamp(24px, 5vh, 48px);
    padding-inline: clamp(16px, 2.5vw, 32px);
    max-width: 62ch;
    font-size: var(--_tokens---type--ultrathin);
    color: var(--_tokens---color--muted);
    text-align: center;
  }
</style>
