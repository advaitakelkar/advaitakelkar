---
// A pair room: two makers, two architects, one fused form.
// The merger leads; its orthographic views scrub beneath it; the two source
// modules sit below as the ingredients; the film closes the room.
import { getEntry } from 'astro:content';
import ExhibitionLayout from '../../../layouts/ExhibitionLayout.astro';
import VGLoop from '../../../components/VGLoop.astro';
import { publicFileExists, publicFilesLike } from '../../../lib/content';

export async function getStaticPaths() {
  const ex = await getEntry('exhibitions', 'virtual-gods');
  return ex!.data.quadrants.flatMap(q =>
    q.pairs.map(p => ({
      params: { quadrant: q.slug, pair: p.slug },
      props: { q, p, pairs: q.pairs },
    }))
  );
}

const { q, p, pairs } = Astro.props;
const other = pairs.find((x: any) => x.slug !== p.slug);

const VIEWS = ['iso', 'front', 'back', 'left', 'right', 'top', 'bottom'];
const asset = (path: string) => `/images/virtual-gods/vg/${path}`;

const views = VIEWS.filter(v => publicFileExists(asset(`mergers/${p.slug}/${v}.webp`)));
const hasMerger = publicFileExists(asset(`mergers/${p.slug}.mp4`));
const hasFilm = p.film && publicFileExists(asset(`films/${p.film}.mp4`));

// Some pairs archived their intermediate fusion steps. The source folders
// number them inconsistently (A–F for one pair, 01–12 for another), so read
// whatever the pipeline produced instead of assuming a naming scheme.
const steps = publicFilesLike(`/images/virtual-gods/vg/mergers/${p.slug}`, 'module-', '.mp4');
---

<ExhibitionLayout
  title={`${p.label} — Virtual Gods`}
  description={`${p.label}: two modules fused into one form. ARCHV's Virtual Gods, 2020.`}
  trail={[
    { label: q.architects.slice(0, 2).join(' & '), href: `/virtual-gods/${q.slug}` },
    { label: p.label },
  ]}
  accent={q.color}
>
  <article class="vgp" style={`--q: ${q.color}`}>
    <header class="vgp__head">
      <h1 class="vgp__title">{p.label}</h1>
      <p class="vgp__arch">
        {p.members.map((m: any, i: number) => (
          <>
            {i > 0 && <span class="vgp__x" aria-hidden="true">×</span>}
            <span class="vgp__arch-item">{m.architect}</span>
          </>
        ))}
      </p>
    </header>

    <!-- The fused form -->
    {hasMerger && (
      <section class="vgp__merger">
        <VGLoop src={`mergers/${p.slug}`} label={`${p.label} — the fused form`} />
      </section>
    )}

    <!-- Orthographic scrub of the fusion -->
    {views.length > 0 && (
      <section class="vgp__ortho" data-ortho>
        <h2 class="vgp__h2">Orthographic views</h2>
        <div class="vgp__ortho-main">
          <img
            id="ortho-img"
            src={asset(`mergers/${p.slug}/${views[0]}.webp`)}
            alt={`${p.label}, ${views[0]} view`}
            loading="lazy" decoding="async"
          />
        </div>
        <div class="vgp__ortho-strip" role="tablist" aria-label="Orthographic views">
          {views.map((v, i) => (
            <button
              class:list={["vgp__ortho-tab", i === 0 && "is-active"]}
              type="button"
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              data-view={v}
              data-src={asset(`mergers/${p.slug}/${v}.webp`)}
            >{v}</button>
          ))}
        </div>
      </section>
    )}

    <!-- Intermediate fusion steps, where they survived -->
    {steps.length > 0 && (
      <section class="vgp__steps">
        <h2 class="vgp__h2">Fusion steps</h2>
        <p class="vgp__note">The form resolving, one pass at a time.</p>
        <div class="vgp__grid vgp__grid--4">
          {steps.map((s, i) => (
            <VGLoop src={`mergers/${p.slug}/${s}`} label={`Step ${i + 1}`} />
          ))}
        </div>
      </section>
    )}

    <!-- The two source modules -->
    <section class="vgp__sources">
      <h2 class="vgp__h2">The two modules</h2>
      <div class="vgp__grid vgp__grid--2">
        {p.members.map((m: any) => (
          <figure class="vgp__source">
            {m.module
              ? <VGLoop src={`modules/${m.module}`} label={`${m.name} — ${m.architect}`} />
              : (
                <div class="vgp__lost">
                  <span aria-hidden="true">—</span>
                  <p>module not archived</p>
                </div>
              )}
            <figcaption class="vgp__source-cap">
              <span class="vgp__source-name">{m.name}</span>
              <span class="vgp__source-arch">{m.architect}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>

    <!-- The film -->
    {hasFilm && (
      <section class="vgp__film">
        <h2 class="vgp__h2">The film</h2>
        <VGLoop src={`films/${p.film}`} label={`${p.label} — film`} ratio="16 / 9" film={true} />
      </section>
    )}

    <nav class="vgp__nav" aria-label="Elsewhere in this group">
      {other && (
        <a class="vgp__nav-link" href={`/virtual-gods/${q.slug}/${other.slug}`}>
          <span class="vgp__nav-dir">The other pair</span>
          <span class="vgp__nav-name">{other.label}</span>
        </a>
      )}
      <a class="vgp__nav-link vgp__nav-link--up" href={`/virtual-gods/${q.slug}`}>
        <span class="vgp__nav-dir">Back up</span>
        <span class="vgp__nav-name">{q.architects.slice(0, 2).join(' & ')}</span>
      </a>
    </nav>
  </article>
</ExhibitionLayout>

<style>
  .vgp {
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    padding: clamp(1.5rem, 4vh, 3rem) clamp(16px, 3vw, 32px) clamp(3rem, 8vh, 6rem);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 7vh, 4.5rem);
  }

  .vgp__head { display: flex; flex-direction: column; gap: 8px; }

  .vgp__title {
    margin: 0;
    font-size: var(--_tokens---type--medium);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--_tokens---color--fg);
  }

  .vgp__arch {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: var(--_tokens---type--micro);
    color: var(--q);
  }
  .vgp__x { opacity: 0.6; }

  .vgp__h2 {
    margin: 0 0 4px;
    font-size: var(--_tokens---type--small);
    font-weight: 600;
    color: var(--_tokens---color--fg);
  }

  .vgp__note { margin: 0 0 20px; font-size: var(--_tokens---type--micro); color: var(--_tokens---color--muted); }

  .vgp__merger { max-width: 620px; width: 100%; margin: 0 auto; }

  /* ── orthographic scrub ── */
  .vgp__ortho { display: flex; flex-direction: column; gap: 12px; }

  .vgp__ortho-main {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: color-mix(in srgb, var(--_tokens---color--fg) 3%, transparent);
    border: 1px solid var(--_tokens---color--line-soft);
    border-radius: var(--_tokens---radius--small);
    box-sizing: border-box;
    padding: 16px;
  }

  .vgp__ortho-main img {
    max-width: 100%;
    max-height: 60vh;
    height: auto;
    display: block;
  }

  .vgp__ortho-strip { display: flex; flex-wrap: wrap; gap: 6px; }

  .vgp__ortho-tab {
    padding: 6px 14px;
    font-size: var(--_tokens---type--ultrathin);
    font-family: inherit;
    text-transform: capitalize;
    letter-spacing: 0.04em;
    color: var(--_tokens---color--muted);
    background: transparent;
    border: 1px solid var(--_tokens---color--line-soft);
    border-radius: var(--_tokens---radius--pill);
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .vgp__ortho-tab:hover,
  .vgp__ortho-tab.is-active {
    background-color: var(--q);
    border-color: var(--q);
    color: var(--_tokens---color--bg);
  }

  .vgp__grid { display: grid; gap: 16px; }
  .vgp__grid--2 { grid-template-columns: repeat(2, 1fr); }
  .vgp__grid--4 { grid-template-columns: repeat(4, 1fr); }

  .vgp__source { margin: 0; display: flex; flex-direction: column; }

  .vgp__source-cap { display: flex; flex-direction: column; gap: 1px; margin-top: 8px; }
  .vgp__source-name { font-size: var(--_tokens---type--micro); color: var(--_tokens---color--fg); }
  .vgp__source-arch { font-size: var(--_tokens---type--ultrathin); color: var(--q); }

  .vgp__lost {
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: 1px dashed var(--_tokens---color--line-soft);
    border-radius: var(--_tokens---radius--small);
    color: var(--_tokens---color--muted);
  }
  .vgp__lost span { font-size: var(--_tokens---type--medium); opacity: 0.35; line-height: 1; }
  .vgp__lost p { margin: 0; font-size: var(--_tokens---type--ultrathin); }

  .vgp__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 24px;
    border-top: 1px solid var(--_tokens---color--line-soft);
  }

  .vgp__nav-link { display: flex; flex-direction: column; gap: 2px; text-decoration: none; }
  .vgp__nav-link--up { text-align: right; }
  .vgp__nav-dir { font-size: var(--_tokens---type--ultrathin); color: var(--_tokens---color--muted); }
  .vgp__nav-name { font-size: var(--_tokens---type--micro); color: var(--_tokens---color--fg); transition: color 0.2s ease; }
  .vgp__nav-link:hover .vgp__nav-name { color: var(--q); }

  @media (max-width: 860px) {
    .vgp__grid--4 { grid-template-columns: repeat(2, 1fr); }
    .vgp__grid--2 { grid-template-columns: 1fr; }
    .vgp__nav { flex-direction: column; align-items: flex-start; gap: 20px; }
    .vgp__nav-link--up { text-align: left; }
  }
</style>

<script>
  // Orthographic scrub: tabs swap the big image. Arrow keys walk the views,
  // matching the roving-tabindex pattern the rest of the site uses for pills.
  function initOrtho() {
    const root = document.querySelector('[data-ortho]');
    if (!root || (root as any)._wired) return;
    (root as any)._wired = true;

    const img = root.querySelector('#ortho-img') as HTMLImageElement | null;
    const tabs = Array.from(root.querySelectorAll('.vgp__ortho-tab')) as HTMLButtonElement[];
    if (!img || !tabs.length) return;

    const select = (i: number) => {
      const tab = tabs[i];
      if (!tab) return;
      tabs.forEach(t => { t.classList.remove('is-active'); t.setAttribute('aria-selected', 'false'); });
      tab.classList.add('is-active');
      tab.setAttribute('aria-selected', 'true');
      img.src = tab.dataset.src!;
      img.alt = `${img.alt.split(',')[0]}, ${tab.dataset.view} view`;
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => select(i));
      tab.addEventListener('pointerenter', () => select(i));
      tab.addEventListener('keydown', (e) => {
        if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
        e.preventDefault();
        const next = (i + (e.key === 'ArrowRight' ? 1 : -1) + tabs.length) % tabs.length;
        tabs[next].focus();
        select(next);
      });
    });
  }

  initOrtho();
  document.addEventListener('astro:after-swap', initOrtho);
</script>
