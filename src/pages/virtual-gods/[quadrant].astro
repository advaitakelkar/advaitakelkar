---
// A quadrant room: one group of four, read as a process.
// Left: the stages. Middle: the active work. Right: the index.
import { getEntry } from 'astro:content';
import ExhibitionLayout from '../../layouts/ExhibitionLayout.astro';
import VGStage from '../../components/VGStage.astro';
import { publicFileExists } from '../../lib/content';

export async function getStaticPaths() {
  const ex = await getEntry('exhibitions', 'virtual-gods');
  return ex!.data.quadrants.map(q => ({ params: { quadrant: q.slug }, props: { q, all: ex!.data.quadrants } }));
}

const { q, all } = Astro.props;
const idx = all.findIndex((x: any) => x.slug === q.slug);
const next = all[(idx + 1) % all.length];

const asset = (rel: string) => `/images/virtual-gods/vg/${rel}`;
const members = q.pairs.flatMap((p: any) => p.members);

const groups: any[] = [];

groups.push({
  label: 'Modules',
  note: 'one architect each',
  items: members
    .filter((m: any) => m.module)
    .map((m: any) => ({ type: 'video', src: asset(`modules/${m.module}`), label: `${m.name} — ${m.architect}` })),
});

groups.push({
  label: 'Fusion',
  note: 'two forms, one',
  items: q.pairs
    .filter((p: any) => publicFileExists(asset(`mergers/${p.slug}.mp4`)))
    .map((p: any) => ({ type: 'video', src: asset(`mergers/${p.slug}`), label: p.label })),
});

if (q.film && publicFileExists(asset(`films/${q.film}.mp4`))) {
  groups.push({
    label: 'World',
    note: 'the assembled whole',
    items: [{ type: 'video', src: asset(`films/${q.film}`), label: `${q.label} — the world`, film: true }],
  });
}

// Only the Marx × Zaha group kept its methodology sheets and final renders.
const methodology = (q.methodology ?? []).filter((m: string) => publicFileExists(asset(`posters/${m}.webp`)));
if (methodology.length) {
  groups.push({
    label: 'Methodology',
    note: 'the process sheets',
    items: methodology.map((m: string) => ({ type: 'image', src: asset(`posters/${m}.webp`), label: 'Methodology sheet' })),
  });
}

const renders = (q.renders ?? []).filter((r: string) => publicFileExists(asset(`posters/${r}.webp`)));
if (renders.length) {
  groups.push({
    label: 'Renders',
    note: 'the finished world',
    items: renders.map((r: string, i: number) => ({ type: 'image', src: asset(`posters/${r}.webp`), label: `Render ${i + 1}` })),
  });
}

const live = groups.filter(g => g.items.length > 0);
---

<ExhibitionLayout
  title={`${q.label} — Virtual Gods`}
  description={`${q.label}. Four modules fused into one world, ARCHV's Virtual Gods, 2020.`}
  trail={[{ label: q.architects.slice(0, 2).join(' & ') }]}
  accent={q.color}
>
  <VGStage
    title={q.label}
    subtitle={members.map((m: any) => m.name).join(' · ')}
    backHref="/virtual-gods"
    backLabel="The wheel"
    groups={live}
  />

  <nav class="vgq__pairs" style={`--q: ${q.color}`} aria-label="Pairs in this group">
    {q.pairs.map((p: any) => (
      <a class="vgq__pair" href={`/virtual-gods/${q.slug}/${p.slug}`}>
        <span class="vgq__pair-label">{p.label}</span>
        <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" aria-hidden="true"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
      </a>
    ))}
    <a class="vgq__pair vgq__pair--next" href={`/virtual-gods/${next.slug}`} style={`--q: ${next.color}`}>
      <span class="vgq__pair-label">Next group: {next.architects.slice(0, 2).join(' & ')}</span>
      <svg class="link-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" aria-hidden="true"><line x1="6" y1="18" x2="18" y2="6"></line><polyline points="10 6 18 6 18 14"></polyline></svg>
    </a>
  </nav>
</ExhibitionLayout>

<style>
  .vgq__pairs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0 clamp(16px, 2.5vw, 32px) clamp(24px, 5vh, 48px);
  }

  .vgq__pair {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    font-size: var(--_tokens---type--ultrathin);
    color: var(--_tokens---color--muted);
    text-decoration: none;
    border: 1px solid var(--_tokens---color--line-soft);
    border-radius: var(--_tokens---radius--pill);
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .vgq__pair svg { width: 0.85em; height: 0.85em; }

  .vgq__pair:hover {
    background-color: var(--q);
    border-color: var(--q);
    color: var(--_tokens---color--bg);
  }

  .vgq__pair--next { margin-left: auto; }

  @media (max-width: 900px) {
    .vgq__pair--next { margin-left: 0; }
  }
</style>
